  .prog-midcta__inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; border: 1px solid var(--prog-border); border-left: 4px solid var(--subject-accent); border-radius: var(--border-radius-lg); background: var(--prog-bg-card); padding: 1.5rem 1.75rem; }
  .prog-midcta__heading { font-size: 1.25rem; font-weight: 700; margin: 0 0 0.3rem; font-family: var(--font-body); letter-spacing: -0.01em; }
  .prog-midcta__sub { font-size: 0.92rem; line-height: 1.55; color: var(--prog-text-secondary); margin: 0; max-width: 560px; }
