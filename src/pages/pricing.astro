---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Tuition Fees Singapore | English, Maths, GP & Econs | A-Worthy" description="O-Level English & Maths from S$280/mo, H1 GP & H2 Econs from S$360/mo. No hidden fees, all materials included. Compare tuition plans and book a free assessment.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="pricing-hero">
    <div class="container">
      <p class="eyebrow">Pricing</p>
      <h1 class="pricing-hero__heading">Tuition pricing in Singapore &mdash; transparent and all-inclusive</h1>
      <p class="pricing-hero__sub">No hidden fees, no lock-in contracts. Every A-Worthy programme &mdash; O-Level English, O-Level Mathematics, H1 General Paper, and H2 Economics &mdash; includes materials, assessments, and WhatsApp support, so you know exactly what you&rsquo;re paying for.</p>
    </div>
  </section>

  <!-- ===== PRICING TABLE ===== -->
  <section class="section pricing-table-section">
    <div class="container">
      <div class="pricing-table-wrap" data-animate="reveal-up">
        <table class="pricing-table">
          <thead>
            <tr>
              <th scope="col" class="pricing-table__label-col"></th>
              <th scope="col" class="pricing-table__th--popular">
                <span class="pricing-table__popular-badge">Most popular</span>
                <span class="pricing-table__programme-name">O-Level English</span>
                <span class="pricing-table__programme-level">Sec 1 &ndash; 4</span>
              </th>
              <th scope="col">
                <span class="pricing-table__programme-name">O-Level Maths</span>
                <span class="pricing-table__programme-level">Sec 1 &ndash; 4</span>
              </th>
              <th scope="col">
                <span class="pricing-table__programme-name">Pre-IB Maths</span>
                <span class="pricing-table__programme-level">Year 3 &ndash; 4</span>
              </th>
              <th scope="col">
                <span class="pricing-table__programme-name">H1 General Paper</span>
                <span class="pricing-table__programme-level">JC 1 &ndash; 2</span>
              </th>
              <th scope="col">
                <span class="pricing-table__programme-name">H2 Economics</span>
                <span class="pricing-table__programme-level">JC 1 &ndash; 2</span>
              </th>
              <th scope="col">
                <span class="pricing-table__programme-name">1-to-1 Coaching</span>
                <span class="pricing-table__programme-level">All Subjects</span>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td scope="row" class="pricing-table__row-label">Monthly Fee</td>
              <td><strong>SGD 280&ndash;320</strong></td>
              <td><strong>SGD 280&ndash;320</strong></td>
              <td><strong>SGD 280&ndash;320</strong></td>
              <td><strong>SGD 360&ndash;400</strong></td>
              <td><strong>SGD 360&ndash;400</strong></td>
              <td><strong>SGD 120&ndash;140</strong><span class="pricing-table__note">/session</span></td>
            </tr>
            <tr>
              <td scope="row" class="pricing-table__row-label">Session Duration</td>
              <td>90 min</td>
              <td>90 min</td>
              <td>90 min</td>
              <td>90 min</td>
              <td>90 min</td>
              <td>60&ndash;90 min</td>
            </tr>
            <tr>
              <td scope="row" class="pricing-table__row-label">Sessions / Month</td>
              <td>4&times;</td>
              <td>4&times;</td>
              <td>4&times;</td>
              <td>4&times;</td>
              <td>4&times;</td>
              <td>Flexible</td>
            </tr>
            <tr>
              <td scope="row" class="pricing-table__row-label">Class Size</td>
              <td>Max 6</td>
              <td>Max 6</td>
              <td>Max 6</td>
              <td>Max 6</td>
              <td>Max 6</td>
              <td>1</td>
            </tr>
            <tr>
              <td scope="row" class="pricing-table__row-label">Materials</td>
              <td>Included</td>
              <td>Included</td>
              <td>Included</td>
              <td>Included</td>
              <td>Included</td>
              <td>Included</td>
            </tr>
            <tr>
              <td scope="row" class="pricing-table__row-label">Assessment</td>
              <td>Free</td>
              <td>Free</td>
              <td>Free</td>
              <td>Free</td>
              <td>Free</td>
              <td>Free</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile pricing cards (visible on small screens) -->
      <h2 class="sr-only">Programme pricing</h2>
      <div class="pricing-cards" data-animate="reveal-up">
        <div class="pricing-card card--elevated pricing-card--popular">
          <span class="pricing-card__popular-badge">Most popular</span>
          <h3 class="pricing-card__name">O-Level English</h3>
          <p class="pricing-card__level">Sec 1 &ndash; 4</p>
          <p class="pricing-card__price">SGD 280&ndash;320<span>/month</span></p>
          <ul class="pricing-card__details">
            <li>90 min sessions</li>
            <li>4&times; per month</li>
            <li>Max 6 students</li>
            <li>Materials included</li>
            <li>Free assessment</li>
          </ul>
          <a href="/contact/" class="btn btn-accent pricing-card__cta">Book Free Assessment</a>
        </div>
        <div class="pricing-card card--elevated">
          <h3 class="pricing-card__name">O-Level Mathematics</h3>
          <p class="pricing-card__level">Sec 1 &ndash; 4</p>
          <p class="pricing-card__price">SGD 280&ndash;320<span>/month</span></p>
          <ul class="pricing-card__details">
            <li>90 min sessions</li>
            <li>4&times; per month</li>
            <li>Max 6 students</li>
            <li>Materials included</li>
            <li>Free assessment</li>
          </ul>
          <a href="/contact/" class="btn btn-accent pricing-card__cta">Book Free Assessment</a>
        </div>
        <div class="pricing-card card--elevated">
          <h3 class="pricing-card__name">Pre-IB Mathematics</h3>
          <p class="pricing-card__level">Year 3 &ndash; 4</p>
          <p class="pricing-card__price">SGD 280&ndash;320<span>/month</span></p>
          <ul class="pricing-card__details">
            <li>90 min sessions</li>
            <li>4&times; per month</li>
            <li>Max 6 students</li>
            <li>Materials included</li>
            <li>Free assessment</li>
          </ul>
          <a href="/contact/" class="btn btn-accent pricing-card__cta">Book Free Assessment</a>
        </div>
        <div class="pricing-card card--elevated">
          <h3 class="pricing-card__name">H1 General Paper</h3>
          <p class="pricing-card__level">JC 1 &ndash; 2</p>
          <p class="pricing-card__price">SGD 360&ndash;400<span>/month</span></p>
          <ul class="pricing-card__details">
            <li>90 min sessions</li>
            <li>4&times; per month</li>
            <li>Max 6 students</li>
            <li>Materials included</li>
            <li>Free assessment</li>
          </ul>
          <a href="/contact/" class="btn btn-accent pricing-card__cta">Book Free Assessment</a>
        </div>
        <div class="pricing-card card--elevated">
          <h3 class="pricing-card__name">H2 Economics</h3>
          <p class="pricing-card__level">JC 1 &ndash; 2</p>
          <p class="pricing-card__price">SGD 360&ndash;400<span>/month</span></p>
          <ul class="pricing-card__details">
            <li>90 min sessions</li>
            <li>4&times; per month</li>
            <li>Max 6 students</li>
            <li>Materials included</li>
            <li>Free assessment</li>
          </ul>
          <a href="/contact/" class="btn btn-accent pricing-card__cta">Book Free Assessment</a>
        </div>
        <div class="pricing-card card--elevated">
          <h3 class="pricing-card__name">1-to-1 Coaching</h3>
          <p class="pricing-card__level">All Subjects</p>
          <p class="pricing-card__price">SGD 120&ndash;140<span>/session</span></p>
          <ul class="pricing-card__details">
            <li>60&ndash;90 min sessions</li>
            <li>Flexible schedule</li>
            <li>1 student</li>
            <li>Materials included</li>
            <li>Free assessment</li>
          </ul>
          <a href="/contact/" class="btn btn-accent pricing-card__cta">Book Free Assessment</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ALL PROGRAMMES INCLUDE ===== -->
  <section class="section pricing-includes">
    <div class="container">
      <h2 class="section-title" data-animate="reveal-up">All programmes include</h2>
      <p class="section-subtitle" data-animate="reveal-up">Everything your child needs to succeed &mdash; no extras to pay for.</p>
      <div class="includes-grid" data-animate="reveal-up" data-animate-delay="1">
        <div class="includes-item">
          <svg class="includes-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          <h3>Free Diagnostic Assessment</h3>
          <p>20-minute assessment to identify gaps and recommend the right programme.</p>
        </div>
        <div class="includes-item">
          <svg class="includes-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <h3>Monthly Progress Reports</h3>
          <p>Detailed feedback on your child&rsquo;s strengths, areas for improvement, and next steps.</p>
        </div>
        <div class="includes-item">
          <svg class="includes-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          <h3>WhatsApp Support</h3>
          <p>Ask questions between sessions &mdash; your child gets help when they need it most.</p>
        </div>
        <div class="includes-item">
          <svg class="includes-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          <h3>SHARP Method Resources</h3>
          <p>Proprietary notes, practice papers, and model answers &mdash; all included in the fee. See how SHARP works for <a href="/o-level-english/#playbook">English</a>, <a href="/o-level-mathematics/#playbook">Maths</a>, <a href="/h1-general-paper/#playbook">GP</a>, and <a href="/h2-economics/#playbook">Economics</a>.</p>
        </div>
        <div class="includes-item">
          <svg class="includes-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <h3>Money-Back Guarantee</h3>
          <p>Not satisfied after the first month? We&rsquo;ll refund your fees &mdash; no questions asked.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPARISON ===== -->
  <section class="section pricing-compare">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Why A-Worthy</span>
      <h2 class="section-title" data-animate="reveal-up">How A-Worthy compares to typical tuition</h2>
      <p class="section-subtitle" data-animate="reveal-up">We&rsquo;re priced like premium tuition but built like a small private cohort. Here&rsquo;s what you actually get for the fee &mdash; and what most centres quietly leave out.</p>

      <div class="compare-table-wrap" data-animate="reveal-up" data-animate-delay="1">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="compare-table__label-col">What matters</th>
              <th class="compare-col-typical">Typical Singapore tuition</th>
              <th class="compare-col-us">A-Worthy</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="compare-row-label">Class size</td>
              <td>12&ndash;20 students per class</td>
              <td><strong>Capped at 6</strong> &mdash; every student gets feedback every session</td>
            </tr>
            <tr>
              <td class="compare-row-label">Tutor qualifications</td>
              <td>Undergraduate or recent A-Level grad</td>
              <td><strong>NUS Law graduate</strong> &mdash; analytical training applied to exam technique</td>
            </tr>
            <tr>
              <td class="compare-row-label">Teaching method</td>
              <td>Drill past papers, hope something sticks</td>
              <td><strong>SHARP Method</strong> &mdash; See, Hit, Apply, Refine, Practise</td>
            </tr>
            <tr>
              <td class="compare-row-label">Feedback turnaround</td>
              <td>Marked work returned 1&ndash;2 weeks later</td>
              <td><strong>Live feedback in-session</strong> &mdash; corrections happen while you&rsquo;re still in the room</td>
            </tr>
            <tr>
              <td class="compare-row-label">Between-session support</td>
              <td>None &mdash; ask the tutor next week</td>
              <td><strong>WhatsApp Q&amp;A</strong> &mdash; included in every programme</td>
            </tr>
            <tr>
              <td class="compare-row-label">Materials</td>
              <td>Photocopied past papers, charged extra</td>
              <td><strong>Included</strong> &mdash; proprietary notes, model answers, practice papers</td>
            </tr>
            <tr>
              <td class="compare-row-label">Progress tracking</td>
              <td>Term-end report card</td>
              <td><strong>Monthly progress reports</strong> &mdash; against official marking criteria</td>
            </tr>
            <tr>
              <td class="compare-row-label">Lock-in</td>
              <td>Term-by-term or year contracts</td>
              <td><strong>Month-to-month</strong> &mdash; first-month money-back guarantee</td>
            </tr>
            <tr>
              <td class="compare-row-label">Format</td>
              <td>Travel to a centre, fixed slot</td>
              <td><strong>Online on the A-Worthy Whiteboard</strong> &mdash; from anywhere in Singapore</td>
            </tr>
            <tr>
              <td class="compare-row-label">Monthly fee (English)</td>
              <td>SGD 350&ndash;500/month</td>
              <td><strong>SGD 280&ndash;320/month</strong></td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="compare-footnote" data-animate="reveal-up">Based on publicly listed rates from major Singapore tuition centres as of 2026. We don&rsquo;t name competitors out of professional courtesy &mdash; but we&rsquo;re happy to walk through the comparison with any parent who asks.</p>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section pricing-cta">
    <div class="container">
      <div class="pricing-cta__inner" data-animate="reveal-up">
        <h2>Ready to get started?</h2>
        <p>Book a free 20-minute diagnostic assessment &mdash; we&rsquo;ll identify your child&rsquo;s gaps and recommend the right programme.</p>
        <a href="/contact/" class="btn btn-accent pricing-cta__btn">Book Free Assessment</a>
        <p class="pricing-cta__reassure">Month-to-month &middot; no lock-in &middot; 7-day money-back guarantee</p>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section pricing-faq">
    <div class="container">
      <h2 class="section-title" data-animate="reveal-up">Frequently Asked Questions</h2>
      <div class="faq-list" data-animate="reveal-up" data-animate-delay="1">
        <details class="faq-item">
          <summary class="faq-question">How much does tuition cost at A-Worthy?</summary>
          <p class="faq-answer">O-Level English and Mathematics are SGD 280&ndash;320/month, and H1 General Paper and H2 Economics are SGD 360&ndash;400/month, for small classes of up to 6 students. One-to-one coaching is SGD 120&ndash;140/session. Every fee includes materials, assessments, and WhatsApp support, with no registration fee.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Are there any registration or material fees?</summary>
          <p class="faq-answer">No. The monthly fee covers everything &mdash; lesson materials, practice papers, model answers, and access to the resource vault. There are no hidden fees.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Is there a lock-in contract?</summary>
          <p class="faq-answer">No. All programmes are month-to-month. You can stop at any time with no penalty &mdash; we believe in earning your trust every month.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Why is the fee range (e.g. SGD 280&ndash;320) instead of a fixed price?</summary>
          <p class="faq-answer">The lower end is for Sec 1&ndash;2 or JC 1 foundation programmes, and the higher end is for Sec 3&ndash;4 or JC 2 intensive programmes, which include more exam-focused content and additional practice materials.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">How does the money-back guarantee work?</summary>
          <p class="faq-answer">If you&rsquo;re not satisfied after the first month of lessons, contact us within 7 days of the last session and we&rsquo;ll issue a full refund &mdash; no questions asked.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Can I switch between group and 1-to-1 coaching?</summary>
          <p class="faq-answer">Yes. Many students start with group sessions and add occasional 1-to-1 coaching closer to exams. You can mix and match as needed.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-question">Are there sibling or multi-subject discounts?</summary>
          <p class="faq-answer">Yes, we offer a 10% sibling discount and a 5% discount for students enrolled in two or more subjects. Contact us for details.</p>
        </details>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does tuition cost at A-Worthy?",
        "acceptedAnswer": { "@type": "Answer", "text": "O-Level English and Mathematics are SGD 280–320/month, and H1 General Paper and H2 Economics are SGD 360–400/month, for small classes of up to 6 students. One-to-one coaching is SGD 120–140/session. Every fee includes materials, assessments, and WhatsApp support, with no registration fee." }
      },
      {
        "@type": "Question",
        "name": "Are there any registration or material fees?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. The monthly fee covers everything — lesson materials, practice papers, model answers, and access to the resource vault. There are no hidden fees." }
      },
      {
        "@type": "Question",
        "name": "Is there a lock-in contract?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. All programmes are month-to-month. You can stop at any time with no penalty — we believe in earning your trust every month." }
      },
      {
        "@type": "Question",
        "name": "Why is the fee a range (e.g. SGD 280–320) instead of a fixed price?",
        "acceptedAnswer": { "@type": "Answer", "text": "The lower end is for Sec 1–2 or JC 1 foundation programmes, and the higher end is for Sec 3–4 or JC 2 intensive programmes, which include more exam-focused content and additional practice materials." }
      },
      {
        "@type": "Question",
        "name": "How does the money-back guarantee work?",
        "acceptedAnswer": { "@type": "Answer", "text": "If you're not satisfied after the first month of lessons, contact us within 7 days of the last session and we'll issue a full refund — no questions asked." }
      },
      {
        "@type": "Question",
        "name": "Can I switch between group and 1-to-1 coaching?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Many students start with group sessions and add occasional 1-to-1 coaching closer to exams. You can mix and match as needed." }
      },
      {
        "@type": "Question",
        "name": "Are there sibling or multi-subject discounts?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes, we offer a 10% sibling discount and a 5% discount for students enrolled in two or more subjects. Contact us for details." }
      }
    ]
  })} />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .pricing-hero {
    padding: 1.75rem 0;
    text-align: center;
    background: var(--bg-primary);
  }

  .pricing-hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 200;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }

  .pricing-hero__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ===== PRICING TABLE ===== */
  .pricing-table-section {
    background: var(--bg-secondary);
  }

  .pricing-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
  }

  .pricing-table thead th {
    padding: 1.5rem 1.25rem;
    text-align: center;
    border-bottom: 2px solid var(--border-color);
    vertical-align: bottom;
  }

  .pricing-table__label-col {
    width: 160px;
  }

  .pricing-table__programme-name {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .pricing-table__programme-level {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-text);
  }

  .pricing-table tbody td {
    padding: 1rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .pricing-table tbody tr:last-child td {
    border-bottom: none;
  }

  .pricing-table tbody td.pricing-table__row-label {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .pricing-table__note {
    display: block;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .pricing-table tbody td strong {
    color: var(--color-accent-text);
    font-weight: 600;
  }

  /* Mobile pricing cards — hidden on desktop, shown on mobile */
  .pricing-cards {
    display: none;
  }

  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: 2rem;
    text-align: center;
  }

  .pricing-card--popular {
    border-color: var(--color-accent);
    box-shadow: 0 12px 36px rgba(212, 133, 58, 0.18), 0 0 0 1px var(--color-accent);
    position: relative;
    transform: translateY(-4px);
  }
  .pricing-card--popular::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: var(--border-radius-lg);
    background: linear-gradient(180deg, rgba(212, 133, 58, 0.08), transparent 40%);
    pointer-events: none;
    z-index: 0;
