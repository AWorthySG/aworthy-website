  <section class="section related-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Explore More</span>
      <div class="related-links" data-animate="reveal-up">
        <a href="/resources/" class="related-link">
          <strong>Free Resources</strong>
          <span>Download sample worksheets and study guides</span>
