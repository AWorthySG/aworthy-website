---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Best H2 Economics Tuition Singapore | JC A-Level Econs Tutor | A-Worthy" description="Top-rated H2 Economics tuition in Singapore for JC 1-2 students. Master the full 9570 syllabus with small group online classes (max 6). Diagram precision, essay technique & case study mastery. Book a free assessment." ogImage="/images/og-econs.png">
  <Header slot="header" />

  <nav class="sticky-toc" id="sticky-toc" aria-label="Table of contents">
    <ul class="sticky-toc-list" id="sticky-toc-list"></ul>
  </nav>

  <!-- ===== PAGE HERO ===== -->
  <section class="prog-hero">
    <div class="container">
      <p class="eyebrow">H2 Economics</p>
      <h1 class="prog-hero__heading">Best H2 Economics Tuition<br />in Singapore for JC Students</h1>
      <p class="prog-hero__sub">Master the full A-Level H2 Economics 9570 syllabus with rigorous analytical frameworks &mdash; from diagram precision and essay technique to case study mastery and higher-order evaluation.</p>
    </div>
  </section>

  <!-- ===== NAV PILLS ===== -->
  <nav class="prog-nav" aria-label="Programme quick links">
    <div class="container prog-nav__inner" data-animate="reveal-up">
      <a href="#jc1" class="prog-nav__link">JC 1</a>
      <a href="#jc2" class="prog-nav__link">JC 2</a>
      <a href="#one-to-one" class="prog-nav__link">One-to-One</a>
      <a href="#syllabus" class="prog-nav__link">Syllabus Coverage</a>
      <a href="#approach" class="prog-nav__link">Our Approach</a>
      <a href="#faq" class="prog-nav__link">FAQ</a>
      <a href="#schedule" class="prog-nav__link">Schedule</a>
    </div>
  </nav>

  <!-- ===== JC 1 PROGRAMME ===== -->
  <section class="prog-section" id="jc1">
    <div class="container">
      <p class="eyebrow">JC 1</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">JC 1 H2 Economics Foundation Programme</h2>
      <p class="prog-section__sub">Build a strong foundation in microeconomics and macroeconomics from JC 1 &mdash; with emphasis on diagram accuracy and essay structure from day one.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Foundation Programme</h3>
          <p class="prog-card__desc">Small group online sessions designed to build core economic reasoning skills &mdash; demand-supply analysis, market failure, and introductory macro concepts &mdash; with emphasis on diagram accuracy and essay structure from day one.</p>
          <ul class="prog-card__topics">
            <li>Scarcity, choice, and opportunity cost</li>
            <li>Demand and supply analysis with diagrams</li>
            <li>Elasticity (PED, YED, XED, PES)</li>
            <li>Market failure: externalities, public goods, merit goods</li>
            <li>Government intervention and its limitations</li>
            <li>Introduction to macroeconomic indicators</li>
            <li>Essay planning and paragraph structure (PEEL)</li>
          </ul>
          <div class="prog-card__meta">
            <span>120 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 360 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== JC 2 A-LEVEL INTENSIVE ===== -->
  <section class="prog-section" id="jc2">
    <div class="container">
      <p class="eyebrow">JC 2</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">JC 2 A-Level H2 Economics Intensive Programme</h2>
      <p class="prog-section__sub">Exam-focused H2 Economics preparation with timed essay practice, case study drills, and detailed marker-style feedback to push your child&rsquo;s grade from B to A.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">A-Level Intensive Programme</h3>
          <p class="prog-card__desc">Rigorous, exam-aligned preparation covering every component of the GCE A-Level H2 Economics papers &mdash; with regular timed practice and individualised feedback on essay and case study technique.</p>
          <ul class="prog-card__topics">
            <li>Paper 1 Case Study: data interpretation, application, evaluation</li>
            <li>Paper 2 Essays: thesis-driven structure with balanced evaluation</li>
            <li>Microeconomics: firm theory, market structures, factor markets</li>
            <li>Macroeconomics: AD-AS, fiscal/monetary/supply-side policies</li>
            <li>International trade: comparative advantage, protectionism, globalisation</li>
            <li>Diagram precision and annotation technique</li>
            <li>Anti-thesis, synthesis, and higher-order evaluation</li>
          </ul>
          <div class="prog-card__meta">
            <span>120 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 400 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ONE-TO-ONE COACHING ===== -->
  <section class="prog-section" id="one-to-one">
    <div class="container">
      <p class="eyebrow">One-to-One</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">One-to-One H2 Economics Tuition &amp; Coaching</h2>
      <p class="prog-section__sub">For students requiring targeted support on specific topics or intensive exam preparation.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Individual Coaching</h3>
          <p class="prog-card__desc">Fully customised to the student&rsquo;s specific gaps &mdash; whether it&rsquo;s essay technique, diagram accuracy, case study interpretation, or conceptual understanding. Individual online sessions via Zoom, scheduled at your convenience.</p>
          <div class="prog-card__meta">
            <span>Per session</span>
            <span>1 student</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 140 / session</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SYLLABUS COVERAGE ===== -->
  <section class="prog-section" id="syllabus">
    <div class="container">
      <p class="eyebrow">9570 Syllabus</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Full H2 Economics syllabus coverage</h2>
      <p class="prog-section__sub">Every topic in the Singapore-Cambridge GCE A-Level H2 Economics syllabus (9570), taught with depth and precision.</p>

      <div class="card-grid card-grid--2">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Microeconomics</h3>
          <ul class="prog-card__topics">
            <li>Scarcity, choice, and opportunity cost</li>
            <li>Demand and supply</li>
            <li>Elasticity of demand and supply</li>
            <li>Market failure</li>
            <li>Government microeconomic intervention</li>
            <li>Theory of the firm and costs</li>
            <li>Market structures (perfect competition, monopoly, monopolistic competition, oligopoly)</li>
            <li>Factor markets and income distribution</li>
          </ul>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="2">
          <h3 class="prog-card__title">Macroeconomics</h3>
          <ul class="prog-card__topics">
            <li>Key macroeconomic indicators</li>
            <li>National income determination (Keynesian model)</li>
            <li>Aggregate demand and aggregate supply</li>
            <li>Inflation, unemployment, and economic growth</li>
            <li>Fiscal, monetary, and supply-side policies</li>
            <li>International trade and comparative advantage</li>
            <li>Balance of payments and exchange rates</li>
            <li>Globalisation and economic development</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR APPROACH ===== -->
  <section class="prog-section" id="approach">
    <div class="container">
      <p class="eyebrow">Our Approach</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Why paper-matched frameworks produce stronger H2 Economics results</h2>

      <div class="card-grid card-grid--2">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Conceptual Clarity That Sticks</h3>
          <p class="prog-card__desc">Most students can regurgitate definitions. Few can apply them under pressure. Your child learns economics as a way of thinking &mdash; every concept connected to real-world context and exam scenarios, so when an unfamiliar question appears, they reason their way to the answer instead of freezing.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="2">
          <h3 class="prog-card__title">Diagram Precision That Earns Full Marks</h3>
          <p class="prog-card__desc">Cambridge examiners award separate marks for diagram accuracy &mdash; and most students throw them away with sloppy labelling, missing shifts, or incorrect intersections. Your child practises diagram technique every single lesson until precision becomes automatic. No more losing easy marks on mechanics.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="3">
          <h3 class="prog-card__title">Essay Technique That Separates A from B</h3>
          <p class="prog-card__desc">The number one reason students score B instead of A? Weak evaluation. Your child masters thesis-driven essay structure with built-in counter-arguments and synthesis &mdash; the higher-order skills that Cambridge explicitly rewards in the top mark band. Every essay practice includes marker-style feedback so your child knows exactly where their evaluation falls short.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="4">
          <h3 class="prog-card__title">Case Study Confidence Under Pressure</h3>
          <p class="prog-card__desc">Paper 1 case studies are designed to be unfamiliar &mdash; that&rsquo;s the point. Your child develops a systematic approach to data interpretation, extract analysis, and application questions through regular timed practice. When exam day arrives, they&rsquo;ve already seen every type of question the paper can throw at them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SUBJECT TESTIMONIALS ===== -->
  <section class="subject-testimonials" data-animate="reveal-up">
    <div class="container">
      <div class="subject-testimonial-grid">
        <blockquote class="subject-quote">
          <p>&ldquo;The case study approach was a game changer. I finally understood how to apply theory to real data instead of just memorising definitions.&rdquo;</p>
          <cite>&mdash; JC2 student, 2025</cite>
        </blockquote>
        <blockquote class="subject-quote">
          <p>&ldquo;From U grade to B in H2 Economics. The small class size meant every question I had was answered properly.&rdquo;</p>
          <cite>&mdash; JC2 student, 2025</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="faq-section" id="faq">
    <div class="container">
      <span class="eyebrow">FAQ</span>
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-list">
        <details class="faq-item" data-animate="reveal-up">
          <summary class="faq-question">How much does H2 Economics tuition cost in Singapore?</summary>
          <div class="faq-answer"><p>From SGD 360/month for small group classes of up to 6 students. Includes all materials, worksheets, and exam practice papers. No registration or hidden fees.</p></div>
        </details>
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="1">
          <summary class="faq-question">Is H2 Economics tuition worth it?</summary>
          <div class="faq-answer"><p>Students who join A-Worthy&rsquo;s programme see an average improvement of 2 grades within one term. Our paper-matched frameworks ensure consistent, measurable progress rather than ad-hoc revision.</p></div>
        </details>
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="2">
          <summary class="faq-question">What is the difference between H1 and H2 Economics?</summary>
          <div class="faq-answer"><p>H2 Economics covers microeconomics and macroeconomics in greater depth, with a compulsory case study paper. H1 covers similar topics but at a broader level with no case study component.</p></div>
        </details>
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="3">
          <summary class="faq-question">How can I improve my H2 Economics essays?</summary>
          <div class="faq-answer"><p>Focus on application over theory. Use real-world examples, draw accurate diagrams, and structure essays with clear thesis statements. Our paper-matched frameworks teach a repeatable structure for essay excellence.</p></div>
        </details>
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="4">
          <summary class="faq-question">When should I start H2 Economics tuition?</summary>
          <div class="faq-answer"><p>Ideally at the start of JC1 to build strong foundations. However, students joining in JC2 can still see significant improvement with our intensive programme that targets exam-specific skills.</p></div>
        </details>
      </div>
    </div>
  </section>

  <!-- ===== RECOMMENDED READING ===== -->
  <section class="recommended-reading">
    <div class="container">
      <span class="eyebrow">Recommended Reading</span>
      <h2 class="section-title">From the blog</h2>
      <div class="reading-grid">
        <a href="/blog/h2-econs-case-study-tips/" class="reading-card" data-animate="reveal-up">
          <h3>H2 Economics Case Study: How to Score L3 Every Time</h3>
          <span class="reading-card-arrow">&rarr;</span>
        </a>
        <a href="/blog/economics-essay-diagrams/" class="reading-card" data-animate="reveal-up">
          <h3>Economics Essay Diagrams: When and How to Use Them</h3>
          <span class="reading-card-arrow">&rarr;</span>
        </a>
        <a href="/blog/exam-prep-timeline/" class="reading-card" data-animate="reveal-up">
          <h3>The 12-Week Exam Prep Timeline</h3>
          <span class="reading-card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== FREE DIAGNOSTIC ASSESSMENT CTA ===== -->
  <section class="prog-cta">
    <div class="container prog-cta__inner">
      <p class="eyebrow">Get Started</p>
      <h2 class="prog-cta__heading" data-animate="reveal-up">Not sure which programme?</h2>
      <p class="prog-cta__sub">Book a free 20-minute diagnostic assessment. We&rsquo;ll review your child&rsquo;s recent Economics paper and identify specific areas for improvement &mdash; no obligation, no sales pitch.</p>
      <div class="prog-cta__actions">
        <a href="/contact/" class="prog-cta__btn prog-cta__btn--primary">Book Assessment</a>
        <a href="https://wa.me/6583384033?text=Hi%2C%20I%27m%20interested%20in%20H2%20Economics%20tuition%20for%20my%20child.%20Could%20you%20share%20more%20details%20on%20the%20programme%20and%20available%20slots%3F" target="_blank" rel="noopener" class="prog-cta__btn prog-cta__btn--whatsapp">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CLASS SCHEDULE ===== -->
  <section class="prog-section" id="schedule">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Schedule</span>
      <h2 class="prog-section__heading" data-animate="reveal-up">Class Schedule &amp; Availability</h2>
      <p class="prog-section__sub">All classes are online via Zoom. Limited to 6 students per class for personalised attention.</p>

      <div class="slots-banner" data-animate="reveal-up">
        <div class="slots-indicator">
          <span class="slots-dot pulse"></span>
          <span class="slots-text"><strong>JC1 H2 Economics:</strong> 2 of 6 slots remaining</span>
        </div>
        <div class="slots-indicator">
          <span class="slots-dot pulse"></span>
          <span class="slots-text"><strong>JC2 H2 Economics:</strong> 1 of 6 slots remaining</span>
        </div>
      </div>

      <div class="schedule-table-wrap" data-animate="reveal-up">
        <table class="schedule-table">
          <thead>
            <tr>
              <th>Programme</th>
              <th>Day &amp; Time</th>
              <th>Duration</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>JC 1 Foundation</td>
              <td>Saturday, 10:00 AM &ndash; 12:00 PM</td>
              <td>2 hours</td>
              <td><span class="slot-badge slot-badge--limited">3 slots left</span></td>
            </tr>
            <tr>
              <td>JC 2 Intensive</td>
              <td>Sunday, 2:00 PM &ndash; 4:00 PM</td>
              <td>2 hours</td>
              <td><span class="slot-badge slot-badge--limited">2 slots left</span></td>
            </tr>
            <tr>
              <td>One-to-One</td>
              <td>Flexible &ndash; by arrangement</td>
              <td>1.5 hours</td>
              <td><span class="slot-badge slot-badge--open">Available</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="schedule-note">Next intake: <strong>Term 3, July 2026</strong>. <a href="/contact/">Book a free assessment</a> to secure your slot.</p>
    </div>
  </section>

