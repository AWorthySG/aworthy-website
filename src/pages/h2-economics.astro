</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --prog-bg: var(--bg-primary);
    --prog-bg-card: var(--bg-card);
    --prog-border: var(--border-color);
    --prog-text: var(--text-primary);
    --prog-text-secondary: var(--text-secondary);
    --prog-accent: var(--color-accent);
    --prog-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --prog-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prog-accent);
    margin-bottom: 1rem;
  }

  /* ===== HERO ===== */
  .prog-hero {
    background: var(--prog-bg);
    padding: calc(var(--header-height) + 3rem) 0 3rem;
    text-align: center;
  }

  .prog-hero__heading {
    font-family: var(--prog-font);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 200;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .prog-hero__sub {
    font-family: var(--prog-font);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ===== NAV ===== */
  .prog-nav {
    background: var(--prog-bg);
    border-bottom: 1px solid var(--prog-border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 90;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .prog-nav::-webkit-scrollbar {
    display: none;
  }

  .prog-nav__inner {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: nowrap;
    min-width: max-content;
  }

  .prog-nav__link {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .prog-nav__link:hover {
    color: var(--prog-text);
