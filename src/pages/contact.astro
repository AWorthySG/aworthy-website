---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Contact A-Worthy | Book a Free Assessment | O-Level English & Economics Tuition Singapore" description="Book a free diagnostic assessment for O-Level English, H1 General Paper, or H2 Economics tuition. Contact A-Worthy via WhatsApp, phone, or email. Small group online classes via Zoom across Singapore.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="contact-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Book a free diagnostic assessment</h1>
      <p class="contact-hero__subtitle">Start with a free 20-minute assessment for O-Level English, H1 GP, or H2 Economics &mdash; we&rsquo;ll identify your child&rsquo;s specific gaps and recommend the right programme</p>
    </div>
  </section>

  <!-- ===== TWO-COLUMN: FORM + INFO ===== -->
  <section class="section contact-section">
    <div class="container contact-grid">

      <!-- Enquiry Form -->
      <div class="contact-form-col" data-animate="reveal-left">
        <p class="eyebrow">Enquiry Form</p>
        <h2 class="contact-form-col__heading">Send us a message</h2>

        <form id="contact-form" class="contact-form" action="https://formspree.io/f/xcontact" method="POST" novalidate>
          <!-- Honeypot — hidden from real users, catches bots -->
          <div class="form-hp" aria-hidden="true" tabindex="-1">
            <label for="website">Website</label>
            <input type="text" name="_gotcha" id="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="parent-name">Parent / Guardian Name <span class="required">*</span></label>
              <input type="text" id="parent-name" name="parentName" required placeholder="Jane Doe" />
            </div>
            <div class="form-group">
              <label for="student-name">Student Name <span class="required">*</span></label>
              <input type="text" id="student-name" name="studentName" required placeholder="John Doe" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email <span class="required">*</span></label>
              <input type="email" id="email" name="email" required placeholder="jane@email.com" />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number <span class="required">*</span></label>
              <input type="tel" id="phone" name="phone" required placeholder="+65 8338 4033" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="student-level">Student Level <span class="required">*</span></label>
              <select id="student-level" name="studentLevel" required>
                <option value="">-- Select Level --</option>
                <option value="Sec 1">Sec 1</option>
                <option value="Sec 2">Sec 2</option>
                <option value="Sec 3">Sec 3</option>
                <option value="Sec 4">Sec 4</option>
                <option value="JC 1">JC 1</option>
                <option value="JC 2">JC 2</option>
              </select>
            </div>
            <div class="form-group">
              <label for="referral">How did you hear about us?</label>
              <select id="referral" name="referral">
                <option value="">-- Select --</option>
                <option value="Google">Google</option>
                <option value="Facebook">Facebook</option>
                <option value="Friend/Family">Friend / Family</option>
                <option value="School">School</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <fieldset class="form-group form-fieldset">
            <legend>Programme of Interest</legend>
            <div class="checkbox-group">
              <label class="check-label"><input type="checkbox" name="subjects" value="English Foundation (Sec 1-2)" /><span>English Foundation (Sec 1-2)</span></label>
              <label class="check-label"><input type="checkbox" name="subjects" value="O-Level Intensive (Sec 3-4)" /><span>O-Level Intensive (Sec 3-4)</span></label>
              <label class="check-label"><input type="checkbox" name="subjects" value="H1 General Paper (JC)" /><span>H1 General Paper (JC)</span></label>
              <label class="check-label"><input type="checkbox" name="subjects" value="One-to-One Coaching" /><span>One-to-One Coaching</span></label>
            </div>
          </fieldset>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us more about your child's learning needs..."></textarea>
          </div>

          <button type="submit" id="form-submit-btn" class="btn btn-accent btn-submit"><span>Send Enquiry</span></button>

          <div id="form-success" class="form-success" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            Thank you for your enquiry! We will get back to you within 24 hours.
          </div>
          <div id="form-errors" class="form-errors" hidden></div>
        </form>
      </div>

      <!-- Contact Information -->
      <div class="contact-info-col" data-animate="reveal-right">
        <p class="eyebrow">Contact Details</p>
        <h2 class="contact-info-col__heading">How we teach</h2>

        <div class="info-card">
          <div class="info-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div>
            <h3>Online via Zoom</h3>
            <p>All lessons conducted via Zoom Pro from anywhere in Singapore</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <h3>Reach Us</h3>
            <ul class="contact-details">
              <li><strong>Phone:</strong> <a href="tel:+6561234567">+65 6123 4567</a></li>
              <li><strong>WhatsApp:</strong> <a href="https://wa.me/6583384033">8338 4033</a></li>
              <li><strong>Email:</strong> <a href="mailto:hello@aworthy.sg">hello@aworthy.sg</a></li>
            </ul>
          </div>
        </div>

        <div class="info-card">
          <div class="info-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3>Operating Hours</h3>
            <ul class="contact-details">
              <li><strong>Mon &ndash; Fri:</strong> 2:00 PM &ndash; 9:30 PM</li>
              <li><strong>Sat &ndash; Sun:</strong> 9:00 AM &ndash; 6:00 PM</li>
            </ul>
          </div>
        </div>

        <div class="online-badge">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <div>
            <strong>100% Online via Zoom</strong>
            <span>No commuting. Students join from anywhere in Singapore.</span>
          </div>
        </div>
      </div>

      <!-- ===== TRIAL BOOKING ===== -->
      <div class="trial-booking" data-animate="reveal-up">
        <span class="eyebrow">Free Trial</span>
        <h3>Book a free trial lesson</h3>
        <p class="trial-desc">Experience the CASE Method first-hand. Select your subject and preferred timeslot &mdash; we&rsquo;ll confirm within 24 hours.</p>
        <form class="trial-form" action="https://formspree.io/f/xcontact" method="POST">
          <input type="hidden" name="_subject" value="Trial Lesson Booking" />
          <div class="form-group">
            <label for="trial-parent">Parent Name <span class="required">*</span></label>
            <input type="text" id="trial-parent" name="parentName" required placeholder="Jane Doe" />
          </div>
          <div class="form-group">
            <label for="trial-student">Student Name <span class="required">*</span></label>
            <input type="text" id="trial-student" name="studentName" required placeholder="John Doe" />
          </div>
          <div class="form-group">
            <label for="trial-email">Email <span class="required">*</span></label>
            <input type="email" id="trial-email" name="email" required placeholder="jane@email.com" />
          </div>
          <div class="form-group">
            <label for="trial-phone">WhatsApp Number <span class="required">*</span></label>
            <input type="tel" id="trial-phone" name="phone" required placeholder="+65 8338 4033" />
          </div>
          <div class="form-group">
            <label for="trial-level">Student Level <span class="required">*</span></label>
            <select id="trial-level" name="studentLevel" required>
              <option value="">-- Select --</option>
              <option value="Sec 1">Sec 1</option>
              <option value="Sec 2">Sec 2</option>
              <option value="Sec 3">Sec 3</option>
              <option value="Sec 4">Sec 4</option>
              <option value="JC 1">JC 1</option>
              <option value="JC 2">JC 2</option>
            </select>
          </div>
          <div class="form-group">
            <label for="trial-subject">Subject <span class="required">*</span></label>
            <select id="trial-subject" name="subject" required>
              <option value="">-- Select Subject --</option>
              <option value="O-Level English">O-Level English</option>
              <option value="H1 General Paper">H1 General Paper</option>
              <option value="H2 Economics">H2 Economics</option>
            </select>
          </div>
          <div class="form-group">
            <label for="trial-timeslot">Preferred Timeslot</label>
            <select id="trial-timeslot" name="timeslot">
              <option value="">-- Select Timeslot --</option>
              <option value="Sat 10AM-12PM">Saturday 10:00 AM – 12:00 PM</option>
              <option value="Sat 2PM-4PM">Saturday 2:00 PM – 4:00 PM</option>
              <option value="Sun 10AM-12PM">Sunday 10:00 AM – 12:00 PM</option>
              <option value="Sun 2PM-4PM">Sunday 2:00 PM – 4:00 PM</option>
              <option value="Flexible">Flexible / Discuss with me</option>
            </select>
          </div>
          <button type="submit" class="btn btn-accent" style="width:100%;">Book Free Trial Lesson</button>
        </form>
      </div>

    </div>
  </section>

  <!-- ===== HOW TO ENROL ===== -->
  <section class="section enrol-section">
    <div class="container">
      <p class="eyebrow">How to Enrol</p>
      <h2 class="enrol-heading" data-animate="reveal-up">Three simple steps to get started</h2>

      <div class="enrol-timeline" data-animate="reveal-up">
        <div class="enrol-step">
          <div class="enrol-step-num">1</div>
          <div class="enrol-step-content">
            <h3>Book a Free Assessment</h3>
            <p>A 20-minute diagnostic session where we analyse your child's recent paper &mdash; English, GP, or Economics &mdash; and identify specific areas for improvement.</p>
          </div>
        </div>
        <div class="enrol-step">
          <div class="enrol-step-num">2</div>
          <div class="enrol-step-content">
            <h3>Get a Personalised Plan</h3>
            <p>We recommend the right programme based on your child's level, goals, and areas that need the most attention.</p>
          </div>
        </div>
        <div class="enrol-step">
          <div class="enrol-step-num">3</div>
          <div class="enrol-step-content">
            <h3>Start Learning</h3>
            <p>Join a small group class or start one-to-one coaching. See measurable improvement within the first month.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ACCORDION ===== -->
  <section class="section faq-section">
    <div class="container">
      <div class="faq-header">
        <p class="eyebrow">FAQ</p>
        <h2>Frequently asked questions</h2>
        <p class="faq-header__subtitle">Got questions? We've got answers.</p>
      </div>

      <div class="faq-list">
        <div class="faq-item" data-animate="reveal-up" data-animate-delay="1">
          <button class="faq-question" aria-expanded="false">
            <span>What is the maximum class size?</span>
            <span class="faq-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </button>
          <div class="faq-answer" hidden>
            <p>Maximum 6 students per group class.</p>
          </div>
        </div>

        <div class="faq-item" data-animate="reveal-up" data-animate-delay="2">
          <button class="faq-question" aria-expanded="false">
            <span>Is there a free trial?</span>
            <span class="faq-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </button>
          <div class="faq-answer" hidden>
            <p>Yes &mdash; we offer a free 20-minute diagnostic assessment where we analyse your child's recent paper (English, GP, or Economics).</p>
          </div>
        </div>

        <div class="faq-item" data-animate="reveal-up" data-animate-delay="3">
          <button class="faq-question" aria-expanded="false">
            <span>What if my child misses a lesson?</span>
            <span class="faq-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </button>
          <div class="faq-answer" hidden>
            <p>All lessons are recorded. Students receive the cloud recording within 24 hours.</p>
          </div>
        </div>

        <div class="faq-item" data-animate="reveal-up" data-animate-delay="4">
          <button class="faq-question" aria-expanded="false">
            <span>What curriculum do you follow?</span>
            <span class="faq-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </button>
          <div class="faq-answer" hidden>
            <p>Our lessons are aligned to the MOE/Cambridge syllabuses &mdash; O-Level English (1128), H1 General Paper (8807), and H2 Economics (9570) &mdash; and use our proprietary CASE Method framework.</p>
          </div>
        </div>

        <div class="faq-item" data-animate="reveal-up" data-animate-delay="5">
          <button class="faq-question" aria-expanded="false">
            <span>How do I pay?</span>
            <span class="faq-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </button>
          <div class="faq-answer" hidden>
            <p>PayNow (preferred), bank transfer, or credit card via HitPay.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <p class="eyebrow">Enrol Now</p>
      <h2 data-animate="reveal-up">Ready to start?</h2>
      <p class="cta-subtitle">Reach out on WhatsApp for the fastest response.</p>
      <a href="https://wa.me/6583384033" class="btn btn-accent" target="_blank" rel="noopener noreferrer">
        <span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: middle; margin-right: 0.5rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<!-- ===== CLIENT-SIDE SCRIPTS ===== -->
<script>
  // --- Form Validation & Submission ---
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success') as HTMLDivElement;
  const errorsMsg = document.getElementById('form-errors') as HTMLDivElement;

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    const errors: string[] = [];

    const parentName = (form.querySelector('#parent-name') as HTMLInputElement).value.trim();
    const studentName = (form.querySelector('#student-name') as HTMLInputElement).value.trim();
    const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
    const phone = (form.querySelector('#phone') as HTMLInputElement).value.trim();
    const studentLevel = (form.querySelector('#student-level') as HTMLSelectElement).value;
    if (!parentName) errors.push('Parent/Guardian Name is required.');
    if (!studentName) errors.push('Student Name is required.');
    if (!email) {
      errors.push('Email is required.');
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) {
      errors.push('Please enter a valid email address.');
    }
    if (!phone) {
      errors.push('Phone Number is required.');
    } else if (!/^\+?[\d][\d\s\-()]{6,14}$/.test(phone)) {
      errors.push('Please enter a valid phone number.');
    }
    if (!studentLevel) errors.push('Please select a Student Level.');

    if (errors.length > 0) {
      errorsMsg.hidden = false;
      errorsMsg.textContent = '';
      errors.forEach(err => {
        const p = document.createElement('p');
        p.textContent = err;
        errorsMsg.appendChild(p);
      });
      successMsg.hidden = true;
      errorsMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // Submit form data
    var submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner"></span> Sending...';

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' },
      });

      if (response.ok) {
        errorsMsg.hidden = true;
        successMsg.hidden = false;
        form.reset();
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      errorsMsg.hidden = false;
      errorsMsg.textContent = '';
      const p = document.createElement('p');
      p.textContent = 'Something went wrong. Please try again or contact us via WhatsApp.';
      errorsMsg.appendChild(p);
      successMsg.hidden = true;
      errorsMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span>Send Enquiry</span>';
    }
  });

  // --- FAQ Accordion (single-open) ---
  document.querySelectorAll('.faq-question').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement as HTMLDivElement;
      const answer = item.querySelector('.faq-answer') as HTMLDivElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.faq-item').forEach((otherItem) => {
        if (otherItem !== item) {
          const otherBtn = otherItem.querySelector('.faq-question') as HTMLButtonElement;
          const otherAnswer = otherItem.querySelector('.faq-answer') as HTMLDivElement;
          otherBtn.setAttribute('aria-expanded', 'false');
          otherAnswer.hidden = true;
          otherItem.classList.remove('is-open');
        }
      });

      // Toggle current
      btn.setAttribute('aria-expanded', String(!isOpen));
      answer.hidden = isOpen;
      item.classList.toggle('is-open', !isOpen);
    });
  });
</script>

<style>
  .calendar-placeholder {
    background: var(--bg-card);
    border: 2px dashed var(--border-color);
    border-radius: 8px;
    padding: 3rem;
    text-align: center;
    margin-top: 1rem;
  }
  .calendar-embed-section {
    grid-column: 1 / -1;
  }
  .contact-col-heading {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  /* ===== CONTACT HERO ===== */
  .contact-hero {
    padding: calc(var(--header-height) + 3rem) 0 var(--space-2xl);
    background: var(--bg-primary);
    text-align: center;
    border-bottom: 1px solid var(--border-color);
  }

  .contact-hero .eyebrow {
    margin-bottom: var(--space-md);
  }

  .contact-hero h1 {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .contact-hero__subtitle {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto;
  }

  /* ===== CONTACT GRID ===== */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  /* ===== FORM COLUMN ===== */
  .contact-form-col .eyebrow {
    margin-bottom: var(--space-sm);
  }

  .contact-form-col__heading {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: var(--space-2xl);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
