---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PdfPreviewModal from '../components/PdfPreviewModal.astro';
import '../styles/global.css';

const resources = [
  {
    title: "O-Level English Scoring Guide",
    description: "A free PDF covering exactly how each component is marked, what examiners reward, and a step-by-step plan to move from C to A. Includes grade benchmarks and sample answers.",
    category: "Exam Prep",
    type: "PDF Guide",
    samplePdf: "/docs/samples/scoring-guide-sample.pdf",
  },
  {
    title: "Comprehension Techniques Checklist",
    description: "A downloadable one-page checklist for literal, inferential, evaluative, and vocabulary-in-context questions. Tick off each technique as you practise.",
    category: "English",
    type: "Checklist",
    samplePdf: "/docs/samples/comprehension-checklist-sample.pdf",
  },
  {
    title: "Essay Writing Framework",
    description: "Quick-reference sheet for the SHARP Method applied to continuous writing. Covers essay planning, paragraph structure, introductions, and conclusions in one printable page.",
    category: "English",
    type: "Quick Reference",
    samplePdf: "/docs/samples/essay-framework-sample.pdf",
  },
  {
    title: "Common Grammar Mistakes to Avoid",
    description: "Practice sheet listing the 20 most frequent grammar errors in O-Level scripts — with corrections, explanations, and exercises to reinforce each rule.",
    category: "English",
    type: "Practice Sheet",
    samplePdf: "/docs/samples/grammar-mistakes-sample.pdf",
  },
  {
    title: "Situational Writing Format Guide",
    description: "Text-type conventions for formal letter, email, report, and speech with register indicators. Includes annotated model answers for each format.",
    category: "Exam Prep",
    type: "PDF Guide",
    samplePdf: "/docs/samples/situational-writing-sample.pdf",
  },
  {
    title: "Oral Preparation Checklist",
    description: "Structure, timing, vocabulary lists by topic, and self-assessment rubric for the video stimulus response. Use it to practise independently before each session.",
    category: "Exam Prep",
    type: "Checklist",
  },
  {
    title: "50 High-Impact O-Level Vocabulary Words",
    description: "Organised by theme with definitions, model sentences, and synonyms. Print it out and work through five words a day for ten days of focused revision.",
    category: "English",
    type: "PDF Guide",
    samplePdf: "/docs/samples/vocabulary-50-sample.pdf",
  },
  {
    title: "Summary Writing: The 80-Word Challenge",
    description: "Step-by-step technique for identifying main ideas, paraphrasing, and staying within the word limit. Includes three timed practice passages with answer keys.",
    category: "English",
    type: "Practice Sheet",
  },
  {
    title: "Common Inference Question Patterns",
    description: "The five most common inference question types and how to answer each using the SHARP Method. Worked examples from past papers included.",
    category: "English",
    type: "Quick Reference",
  },
  {
    title: "Editing Paper Strategies",
    description: "How to spot and correct grammatical errors systematically in Paper 1 editing. Covers the top error categories with practice exercises and an answer key.",
    category: "Exam Prep",
    type: "Practice Sheet",
  },
  {
    title: "Essay Hooks That Work",
    description: "Opening techniques for narrative, expository, and argumentative essays that grab examiner attention. Ten proven openers with before-and-after examples.",
    category: "Study Tips",
    type: "Quick Reference",
  },
  {
    title: "Mock Paper Self-Assessment Guide",
    description: "How to review your own mock papers using the SHARP checklist for maximum improvement. Includes a printable marking rubric and reflection template.",
    category: "Exam Prep",
    type: "PDF Guide",
  },
  {
    title: "GP Model Essays Collection",
    description: "Five model GP essays spanning Science & Technology, Media, Environment, Globalisation, and Arts & Culture. Each essay demonstrates the SHARP Method structure with examiner annotations and band descriptors.",
    category: "General Paper",
    type: "Model Essays",
  },
  {
    title: "H2 Economics Case Study Toolkit",
    description: "Step-by-step approach to A-Level Economics case study questions. Includes extract analysis techniques, data interpretation frameworks, and 3 fully worked case study examples with model answers.",
    category: "Economics",
    type: "Toolkit",
  },
  {
    title: "2026 A-Level Exam Predictions",
    description: "Our annual analysis of likely exam topics for H1 GP and H2 Economics based on syllabus trends, past-year patterns, and current affairs. Updated for the November 2026 sitting.",
    category: "Exam Prep",
    type: "Predictions",
  },
  {
    title: "O-Level English Model Compositions",
    description: "Four model compositions covering narrative, expository, argumentative, and descriptive writing. Each includes planning notes, draft-to-final comparison, and examiner feedback.",
    category: "English",
    type: "Model Essays",
  },
  {
    title: "Economics Diagram Master Sheet",
    description: "Every H2 Economics diagram you need for the A-Level exam on one printable reference sheet. Demand-supply, market failure, AD-AS, exchange rates, and Phillips curve — all correctly labelled.",
    category: "Economics",
    type: "Quick Reference",
  },
];

const categories = ["All", "English", "General Paper", "Economics", "Exam Prep", "Study Tips"];
---

<BaseLayout title="Free Study Resources | English, Maths, GP & Econs | A-Worthy" description="Free tuition resources: O-Level English & Maths guides, GP essay frameworks and H2 Economics diagram sheets. Aligned to GCE O-Level & A-Level syllabuses.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="r-hero">
    <div class="r-container">
      <span class="eyebrow">Resources</span>
      <h1 class="r-hero-heading">Free O-Level English tuition resources &amp; study guides</h1>
      <p class="r-hero-sub">Download free O-Level English study guides, checklists, and exam frameworks curated by A-Worthy&rsquo;s Singapore tutors. Sample resources available instantly &mdash; full versions by request.</p>
    </div>
  </section>

  <!-- ===== SEARCH + FILTERS ===== -->
  <section class="r-filters" data-animate="reveal-up">
    <div class="r-container">
      <div class="r-search-wrap">
        <label for="resource-search" class="sr-only">Search resources</label>
        <input
          type="text"
          id="resource-search"
          class="r-search"
          placeholder="Search resources..."
          autocomplete="off"
        />
      </div>

      <div class="r-filter-row" role="group" aria-label="Filter by category">
        {categories.map((cat) => (
          <button
            class:list={["r-filter-btn", { active: cat === "All" }]}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESOURCE CARDS ===== -->
  <section class="r-cards-section">
    <div class="r-container">

      <!-- Reading Room catalogue header (claudedesign F.3) -->
      <header class="r-catalogue-head" data-animate="reveal-up">
        <span class="eyebrow">Reading Room &middot; Catalogue</span>
        <p class="r-catalogue-copy">
          <span class="r-count">{resources.length}</span>
          guides currently in circulation. Sample any title in&nbsp;full; request the unwatermarked edition on&nbsp;enrolment.
        </p>
      </header>

      <div class="r-grid" id="resources-grid">
        {resources.map((resource, i) => (
          <article
            class:list={["r-card", { "r-card--has-sample": !!resource.samplePdf }]}
            data-category={resource.category}
            data-title={resource.title.toLowerCase()}
            data-description={resource.description.toLowerCase()}
            data-animate="reveal-up"
            data-animate-delay={String((i % 3) + 1)}
          >
            <div class="r-card-top">
              <span class="eyebrow">{resource.category}</span>
              <span class:list={["r-type-badge", { "r-type-badge--sample": !!resource.samplePdf }]}>
                {resource.samplePdf ? "Sample Available" : resource.type}
              </span>
            </div>
            <h3 class="r-card-title">{resource.title}</h3>
            <p class="r-card-desc">{resource.description}</p>

            {resource.samplePdf ? (
              <Fragment>
                <div class="r-card-inline-preview">
                  <div class="r-card-preview-thumb" aria-hidden="true">
                    <div class="r-prev-page">
                      <div class="r-prev-eyebrow">A-Worthy &middot; {resource.category}</div>
                      <div class="r-prev-title">{resource.title}</div>
                      <div class="r-prev-rule"></div>
                      <div class="r-prev-line" style="width: 88%"></div>
                      <div class="r-prev-line" style="width: 74%"></div>
                      <div class="r-prev-line" style="width: 92%"></div>
                      <div class="r-prev-line" style="width: 68%"></div>
                      <div class="r-prev-line" style="width: 84%"></div>
                      <span class="r-prev-page-num">2 / 8</span>
                    </div>
                    <div class="r-card-preview-blur-overlay">
                      <span class="r-card-preview-unlock">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        Preview
                      </span>
                    </div>
                  </div>
                </div>
                <div class="r-card-actions">
                  <button
                    class="r-card-preview-btn"
                    data-preview-pdf={resource.samplePdf}
                    data-preview-title={resource.title}
                    type="button"
                  >
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    Preview Sample
                  </button>
                  <a
                    class="r-card-download-btn plausible-event-name=Resource+Download"
                    href={resource.samplePdf}
                    data-resource-title={resource.title}
                    data-resource-mode="download"
                    download
                  >
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Download
                  </a>
                </div>
              </Fragment>
            ) : (
              <a
                href="#"
                class="r-card-link"
                data-resource-title={resource.title}
                data-resource-mode="request"
              >
                Request Free Copy <span class="r-arrow">&rarr;</span>
              </a>
            )}
          </article>
        ))}
      </div>

      <!-- No Results -->
      <div class="r-no-results" id="no-results" style="display: none;">
        <p class="r-no-results-heading">No resources found</p>
        <p class="r-no-results-sub">Try adjusting your search term or selecting a different category.</p>
      </div>
    </div>
  </section>

  <!-- ===== NEWSLETTER ===== -->
  <section class="r-newsletter-section">
    <div class="r-container">
      <div class="r-newsletter-card" data-animate="reveal-up">
        <span class="eyebrow">Stay Updated</span>
        <h2 class="r-newsletter-heading">Get new resources in your inbox</h2>
        <p class="r-newsletter-sub">Free worksheets, study tips, and exam prep materials delivered weekly.</p>
        <form class="r-newsletter-form" id="newsletter-form" action="https://formspree.io/f/xreoozkk" method="POST">
          <div class="r-newsletter-row">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="newsletter-email"
              name="email"
              class="r-newsletter-input"
              placeholder="you@email.com"
              required
            />
            <button type="submit" class="r-btn-subscribe" id="newsletter-submit">Subscribe</button>
          </div>
          <p class="r-newsletter-note">Join 3,000+ parents and students. Unsubscribe anytime.</p>
          <p class="r-newsletter-success" id="newsletter-success" hidden>Thanks for subscribing! You'll receive our next newsletter shortly.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="r-cta">
    <div class="r-container">
      <span class="eyebrow">Next Step</span>
      <h2 class="r-cta-heading" data-animate="reveal-up">Want personalised guidance?</h2>
      <p class="r-cta-sub">Our resources are a great start — personalised tuition takes it further.</p>
      <a href="/contact/" class="r-btn-cta">Book Free Assessment</a>
    </div>
  </section>

  <PdfPreviewModal />
  <Footer slot="footer" />
</BaseLayout>

<script>
  const searchInput = document.getElementById('resource-search') as HTMLInputElement;
  const filterButtons = document.querySelectorAll('.r-filter-btn');
  const resourceCards = document.querySelectorAll('.r-card') as NodeListOf<HTMLElement>;
  const noResults = document.getElementById('no-results') as HTMLElement;

  let activeCategory = 'All';

  function filterResources() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    resourceCards.forEach((card) => {
      const title = card.getAttribute('data-title') || '';
      const description = card.getAttribute('data-description') || '';
      const category = card.getAttribute('data-category') || '';

      const matchesCategory = activeCategory === 'All' || category === activeCategory;
      const matchesSearch = !searchTerm || title.includes(searchTerm) || description.includes(searchTerm);

      if (matchesCategory && matchesSearch) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
  }

  searchInput.addEventListener('input', filterResources);

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.getAttribute('data-category') || 'All';
      filterResources();
    });
  });

  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement;
  const newsletterSuccess = document.getElementById('newsletter-success') as HTMLElement;
  const newsletterSubmit = document.getElementById('newsletter-submit') as HTMLButtonElement;

  newsletterForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    if (!emailInput.value) return;

    newsletterSubmit.disabled = true;
    newsletterSubmit.textContent = 'Subscribing...';

    try {
      const formData = new FormData(newsletterForm);
      const response = await fetch(newsletterForm.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' },
      });

      if (response.ok) {
        emailInput.value = '';
        newsletterSuccess.hidden = false;
      } else {
        throw new Error('Failed');
      }
    } catch {
      newsletterSuccess.hidden = false;
      newsletterSuccess.textContent = 'Something went wrong. Please try again.';
    } finally {
      newsletterSubmit.disabled = false;
      newsletterSubmit.textContent = 'Subscribe';
    }
  });
</script>

<script is:inline>
(function(){
  var FORMSPREE_ID = 'xreoozkk';
  var FORMSPREE_URL = 'https://formspree.io/f/' + FORMSPREE_ID;

  function getStoredLead() {
    try {
      var raw = localStorage.getItem('resource-lead');
      return raw ? JSON.parse(raw) : null;
    } catch (e) { return null; }
  }

  function storeLead(email, phone, name) {
    try {
      localStorage.setItem('resource-lead', JSON.stringify({ email: email, phone: phone, name: name || '' }));
    } catch (e) {}
  }

  function submitLead(payload) {
    return fetch(FORMSPREE_URL, {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
  }

  function showToast(message) {
    var toast = document.createElement('div');
    toast.className = 'resource-toast';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(function() { toast.classList.add('resource-toast--show'); }, 10);
    setTimeout(function() {
      toast.classList.remove('resource-toast--show');
      setTimeout(function() { toast.remove(); }, 300);
    }, 4500);
  }

  function deliverResource(mode, url, title) {
    if (mode === 'download' && url) {
      window.open(url, '_blank');
      showToast('Sample opened in a new tab. The full version of "' + title + '" will be emailed shortly.');
    } else {
      showToast('Thanks! We’ll email the full version of "' + title + '" within 24 hours.');
    }
  }

  function openGate(mode, url, title) {
    var overlay = document.createElement('div');
    overlay.className = 'resource-gate-overlay';
    var ctaLabel = mode === 'download' ? 'Send me the resource' : 'Email me the full version';
    var heading = mode === 'download'
      ? 'Get instant access to your A-Worthy resource'
      : 'Request the full version of this resource';
    var subline = mode === 'download'
      ? 'Enter your details to preview the sample now. We’ll also email the full version of "' + title + '" to you.'
      : 'Enter your details and we’ll email "' + title + '" to you within 24 hours.';

    var waMessage = encodeURIComponent('Hi A-Worthy, I would like the full version of "' + title + '". Could you send it to me?');
    var waUrl = 'https://wa.me/6583384033?text=' + waMessage;

    overlay.innerHTML =
      '<div class="resource-gate" role="dialog" aria-modal="true" aria-labelledby="resource-gate-title">' +
        '<button class="resource-gate-close" aria-label="Close">&times;</button>' +
        '<span class="resource-gate-eyebrow">Free Resource</span>' +
        '<h4 id="resource-gate-title">' + heading + '</h4>' +
        '<p>' + subline + '</p>' +
        '<form class="resource-gate-form" novalidate>' +
          '<label class="resource-gate-label">' +
            '<span>Email <em>*</em></span>' +
            '<input type="email" name="email" required autocomplete="email" placeholder="you@email.com" />' +
          '</label>' +
          '<label class="resource-gate-label">' +
            '<span>Phone (Singapore) <em>*</em></span>' +
            '<input type="tel" name="phone" required autocomplete="tel" inputmode="tel" placeholder="+65 9123 4567" />' +
          '</label>' +
          '<label class="resource-gate-label">' +
            '<span>Name <em class="resource-gate-optional">(optional)</em></span>' +
            '<input type="text" name="name" autocomplete="name" placeholder="Parent or student name" />' +
          '</label>' +
          '<button type="submit" class="resource-gate-submit">' + ctaLabel + '</button>' +
          '<p class="resource-gate-error" role="alert" hidden></p>' +
          '<p class="resource-gate-note">We respect your privacy. No spam &mdash; unsubscribe anytime.</p>' +
        '</form>' +
        '<div class="resource-gate-divider"><span>or</span></div>' +
        '<a class="resource-gate-whatsapp" href="' + waUrl + '" target="_blank" rel="noopener noreferrer">' +
          '<svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.711.307 1.265.489 1.697.626.713.226 1.362.194 1.875.118.572-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>' +
          'Get it instantly on WhatsApp' +
        '</a>' +
      '</div>';

    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';

    function close() {
      overlay.remove();
      document.body.style.overflow = '';
    }

    overlay.querySelector('.resource-gate-close').addEventListener('click', close);
    overlay.addEventListener('click', function(ev) {
      if (ev.target === overlay) close();
    });
    document.addEventListener('keydown', function escHandler(ev) {
      if (ev.key === 'Escape') { close(); document.removeEventListener('keydown', escHandler); }
    });

    setTimeout(function() {
      var firstInput = overlay.querySelector('input[name="email"]');
      if (firstInput) firstInput.focus();
    }, 50);

    var form = overlay.querySelector('form');
    var submitBtn = overlay.querySelector('.resource-gate-submit');
    var errorEl = overlay.querySelector('.resource-gate-error');

    form.addEventListener('submit', function(ev) {
      ev.preventDefault();
      var email = form.email.value.trim();
      var phone = form.phone.value.trim();
      var name = form.name.value.trim();

      var phoneDigits = phone.replace(/\D/g, '');
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.textContent = 'Please enter a valid email address.';
        errorEl.hidden = false;
        return;
      }
      if (phoneDigits.length < 8) {
        errorEl.textContent = 'Please enter a valid phone number.';
        errorEl.hidden = false;
        return;
      }
      errorEl.hidden = true;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      var payload = {
        email: email,
        phone: phone,
        name: name,
        resource: title,
        mode: mode,
        _subject: 'Resource Download Request: ' + title
      };

      submitLead(payload).then(function(res) {
        if (!res.ok) throw new Error('submit-failed');
        storeLead(email, phone, name);
        close();
        deliverResource(mode, url, title);
      }).catch(function() {
        // Still store locally and deliver so the user isn't blocked by a Formspree outage.
        storeLead(email, phone, name);
        close();
        deliverResource(mode, url, title);
      });
    });
  }

  function handleClick(e) {
    var el = e.currentTarget;
    var mode = el.getAttribute('data-resource-mode');
    var title = el.getAttribute('data-resource-title') || 'A-Worthy resource';
    var url = el.getAttribute('href');
    var stored = getStoredLead();

    if (stored && stored.email && stored.phone) {
      // Returning visitor: silently log the request and deliver.
      submitLead({
        email: stored.email,
        phone: stored.phone,
        name: stored.name || '',
        resource: title,
        mode: mode,
        repeat: true,
        _subject: 'Resource Re-download: ' + title
      }).catch(function() {});

      if (mode === 'request') {
        e.preventDefault();
        deliverResource(mode, url, title);
      }
      // For mode === 'download', let the native <a download> open the file.
      return;
    }

    e.preventDefault();
    openGate(mode, url, title);
  }

  document.querySelectorAll('[data-resource-mode]').forEach(function(el) {
    el.addEventListener('click', handleClick);
  });
})();
</script>

<style>
  .resource-gate-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }
  .resource-gate {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem 1.75rem 1.5rem;
    max-width: 420px;
    width: 100%;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  }
  .resource-gate-close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--text-muted);
    cursor: pointer;
