---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PdfPreviewModal from '../components/PdfPreviewModal.astro';
import '../styles/global.css';

const resources = [
  {
    title: "O-Level English Scoring Guide",
    description: "A free PDF covering exactly how each component is marked, what examiners reward, and a step-by-step plan to move from C to A. Includes grade benchmarks and sample answers.",
    category: "Exam Prep",
    type: "PDF Guide",
    samplePdf: "/docs/samples/scoring-guide-sample.pdf",
  },
  {
    title: "Comprehension Techniques Checklist",
    description: "A downloadable one-page checklist for literal, inferential, evaluative, and vocabulary-in-context questions. Tick off each technique as you practise.",
    category: "English",
    type: "Checklist",
    samplePdf: "/docs/samples/comprehension-checklist-sample.pdf",
  },
  {
    title: "Essay Writing Framework",
    description: "Quick-reference sheet for the CASE Method applied to continuous writing. Covers essay planning, paragraph structure, introductions, and conclusions in one printable page.",
    category: "English",
    type: "Quick Reference",
    samplePdf: "/docs/samples/essay-framework-sample.pdf",
  },
  {
    title: "Common Grammar Mistakes to Avoid",
    description: "Practice sheet listing the 20 most frequent grammar errors in O-Level scripts — with corrections, explanations, and exercises to reinforce each rule.",
    category: "English",
    type: "Practice Sheet",
    samplePdf: "/docs/samples/grammar-mistakes-sample.pdf",
  },
  {
    title: "Situational Writing Format Guide",
    description: "Text-type conventions for formal letter, email, report, and speech with register indicators. Includes annotated model answers for each format.",
    category: "Exam Prep",
    type: "PDF Guide",
    samplePdf: "/docs/samples/situational-writing-sample.pdf",
  },
  {
    title: "Oral Preparation Checklist",
    description: "Structure, timing, vocabulary lists by topic, and self-assessment rubric for the video stimulus response. Use it to practise independently before each session.",
    category: "Exam Prep",
    type: "Checklist",
  },
  {
    title: "50 High-Impact O-Level Vocabulary Words",
    description: "Organised by theme with definitions, model sentences, and synonyms. Print it out and work through five words a day for ten days of focused revision.",
    category: "English",
    type: "PDF Guide",
    samplePdf: "/docs/samples/vocabulary-50-sample.pdf",
  },
  {
    title: "Summary Writing: The 80-Word Challenge",
    description: "Step-by-step technique for identifying main ideas, paraphrasing, and staying within the word limit. Includes three timed practice passages with answer keys.",
    category: "English",
    type: "Practice Sheet",
  },
  {
    title: "Common Inference Question Patterns",
    description: "The five most common inference question types and how to answer each using the CASE Method. Worked examples from past papers included.",
    category: "English",
    type: "Quick Reference",
  },
  {
    title: "Editing Paper Strategies",
    description: "How to spot and correct grammatical errors systematically in Paper 1 editing. Covers the top error categories with practice exercises and an answer key.",
    category: "Exam Prep",
    type: "Practice Sheet",
  },
  {
    title: "Essay Hooks That Work",
    description: "Opening techniques for narrative, expository, and argumentative essays that grab examiner attention. Ten proven openers with before-and-after examples.",
    category: "Study Tips",
    type: "Quick Reference",
  },
  {
    title: "Mock Paper Self-Assessment Guide",
    description: "How to review your own mock papers using the CASE checklist for maximum improvement. Includes a printable marking rubric and reflection template.",
    category: "Exam Prep",
    type: "PDF Guide",
  },
  {
    title: "GP Model Essays Collection",
    description: "Five model GP essays spanning Science & Technology, Media, Environment, Globalisation, and Arts & Culture. Each essay demonstrates the CASE Method structure with examiner annotations and band descriptors.",
    category: "General Paper",
    type: "Model Essays",
  },
  {
    title: "H2 Economics Case Study Toolkit",
    description: "Step-by-step approach to A-Level Economics case study questions. Includes extract analysis techniques, data interpretation frameworks, and 3 fully worked case study examples with model answers.",
    category: "Economics",
    type: "Toolkit",
  },
  {
    title: "2026 A-Level Exam Predictions",
    description: "Our annual analysis of likely exam topics for H1 GP and H2 Economics based on syllabus trends, past-year patterns, and current affairs. Updated for the November 2026 sitting.",
    category: "Exam Prep",
    type: "Predictions",
  },
  {
    title: "O-Level English Model Compositions",
    description: "Four model compositions covering narrative, expository, argumentative, and descriptive writing. Each includes planning notes, draft-to-final comparison, and examiner feedback.",
    category: "English",
    type: "Model Essays",
  },
  {
    title: "Economics Diagram Master Sheet",
    description: "Every H2 Economics diagram you need for the A-Level exam on one printable reference sheet. Demand-supply, market failure, AD-AS, exchange rates, and Phillips curve — all correctly labelled.",
    category: "Economics",
    type: "Quick Reference",
  },
];

const categories = ["All", "English", "General Paper", "Economics", "Exam Prep", "Study Tips"];
---

<BaseLayout title="Free O-Level English Resources & Study Guides | A-Worthy Singapore" description="Download free O-Level English resources: scoring guides, comprehension checklists, essay frameworks, grammar guides & vocabulary lists. Aligned to the GCE O-Level English syllabus. Start improving your child's grades tonight.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="r-hero">
    <div class="r-container">
      <span class="eyebrow">Resources</span>
      <h1 class="r-hero-heading">Free O-Level English tuition resources &amp; study guides</h1>
      <p class="r-hero-sub">Download free O-Level English study guides, checklists, and exam frameworks curated by A-Worthy&rsquo;s Singapore tutors. No sign-up required.</p>
    </div>
  </section>

  <!-- ===== SEARCH + FILTERS ===== -->
  <section class="r-filters" data-animate="reveal-up">
    <div class="r-container">
      <div class="r-search-wrap">
        <label for="resource-search" class="sr-only">Search resources</label>
        <input
          type="text"
          id="resource-search"
          class="r-search"
          placeholder="Search resources..."
          autocomplete="off"
        />
      </div>

      <div class="r-filter-row" role="group" aria-label="Filter by category">
        {categories.map((cat) => (
          <button
            class:list={["r-filter-btn", { active: cat === "All" }]}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESOURCE CARDS ===== -->
  <section class="r-cards-section">
    <div class="r-container">
      <div class="r-grid" id="resources-grid">
        {resources.map((resource, i) => (
          <article
            class:list={["r-card", { "r-card--has-sample": !!resource.samplePdf }]}
            data-category={resource.category}
            data-title={resource.title.toLowerCase()}
            data-description={resource.description.toLowerCase()}
            data-animate="reveal-up"
            data-animate-delay={String((i % 3) + 1)}
          >
            <div class="r-card-top">
              <span class="eyebrow">{resource.category}</span>
              <span class:list={["r-type-badge", { "r-type-badge--sample": !!resource.samplePdf }]}>
                {resource.samplePdf ? "Sample Available" : resource.type}
              </span>
            </div>
            <h3 class="r-card-title">{resource.title}</h3>
            <p class="r-card-desc">{resource.description}</p>

            {resource.samplePdf ? (
              <Fragment>
                <div class="r-card-inline-preview">
                  <div class="r-card-preview-thumb">
                    <div class="r-card-preview-lines">
                      <div class="r-preview-line" style="width: 85%"></div>
                      <div class="r-preview-line" style="width: 92%"></div>
                      <div class="r-preview-line" style="width: 78%"></div>
                      <div class="r-preview-line" style="width: 88%"></div>
                      <div class="r-preview-line" style="width: 65%"></div>
                      <div class="r-preview-line" style="width: 90%"></div>
                    </div>
                    <div class="r-card-preview-blur-overlay">
                      <span class="r-card-preview-unlock">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        Preview
                      </span>
                    </div>
                  </div>
                </div>
                <div class="r-card-actions">
                  <button
                    class="r-card-preview-btn"
                    data-preview-pdf={resource.samplePdf}
                    data-preview-title={resource.title}
                    type="button"
                  >
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    Preview Sample
                  </button>
                  <a class="r-card-download-btn" href={resource.samplePdf} download>
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Download
                  </a>
                </div>
              </Fragment>
            ) : (
              <a href="/contact/" class="r-card-link">
                Request Free Copy <span class="r-arrow">&rarr;</span>
              </a>
            )}
          </article>
        ))}
      </div>

      <!-- No Results -->
      <div class="r-no-results" id="no-results" style="display: none;">
        <p class="r-no-results-heading">No resources found</p>
        <p class="r-no-results-sub">Try adjusting your search term or selecting a different category.</p>
      </div>
    </div>
  </section>

  <!-- ===== NEWSLETTER ===== -->
  <section class="r-newsletter-section">
    <div class="r-container">
      <div class="r-newsletter-card" data-animate="reveal-up">
        <span class="eyebrow">Stay Updated</span>
        <h2 class="r-newsletter-heading">Get new resources in your inbox</h2>
        <p class="r-newsletter-sub">Free worksheets, study tips, and exam prep materials delivered weekly.</p>
        <form class="r-newsletter-form" id="newsletter-form" action="https://formspree.io/f/xnewsletter" method="POST">
          <div class="r-newsletter-row">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="newsletter-email"
              name="email"
              class="r-newsletter-input"
              placeholder="you@email.com"
              required
            />
            <button type="submit" class="r-btn-subscribe" id="newsletter-submit">Subscribe</button>
          </div>
          <p class="r-newsletter-note">Join 3,000+ parents and students. Unsubscribe anytime.</p>
          <p class="r-newsletter-success" id="newsletter-success" hidden>Thanks for subscribing! You'll receive our next newsletter shortly.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="r-cta">
    <div class="r-container">
      <span class="eyebrow">Next Step</span>
      <h2 class="r-cta-heading" data-animate="reveal-up">Want personalised guidance?</h2>
      <p class="r-cta-sub">Our resources are a great start — personalised tuition takes it further.</p>
      <a href="/contact/" class="r-btn-cta">Get in Touch</a>
    </div>
  </section>

  <PdfPreviewModal />
  <Footer />
</BaseLayout>

<script>
  const searchInput = document.getElementById('resource-search') as HTMLInputElement;
  const filterButtons = document.querySelectorAll('.r-filter-btn');
  const resourceCards = document.querySelectorAll('.r-card') as NodeListOf<HTMLElement>;
  const noResults = document.getElementById('no-results') as HTMLElement;

  let activeCategory = 'All';

  function filterResources() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    resourceCards.forEach((card) => {
      const title = card.getAttribute('data-title') || '';
      const description = card.getAttribute('data-description') || '';
      const category = card.getAttribute('data-category') || '';

      const matchesCategory = activeCategory === 'All' || category === activeCategory;
      const matchesSearch = !searchTerm || title.includes(searchTerm) || description.includes(searchTerm);

      if (matchesCategory && matchesSearch) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
  }

  searchInput.addEventListener('input', filterResources);

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.getAttribute('data-category') || 'All';
      filterResources();
    });
  });

  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement;
  const newsletterSuccess = document.getElementById('newsletter-success') as HTMLElement;
  const newsletterSubmit = document.getElementById('newsletter-submit') as HTMLButtonElement;

  newsletterForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    if (!emailInput.value) return;

    newsletterSubmit.disabled = true;
    newsletterSubmit.textContent = 'Subscribing...';

    try {
      const formData = new FormData(newsletterForm);
      const response = await fetch(newsletterForm.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' },
      });

      if (response.ok) {
        emailInput.value = '';
        newsletterSuccess.hidden = false;
      } else {
        throw new Error('Failed');
      }
    } catch {
      newsletterSuccess.hidden = false;
      newsletterSuccess.textContent = 'Something went wrong. Please try again.';
    } finally {
      newsletterSubmit.disabled = false;
      newsletterSubmit.textContent = 'Subscribe';
    }
  });
</script>

<script is:inline>
(function(){
  // Gate resource downloads behind email
  var cards = document.querySelectorAll('.vault-card');
  cards.forEach(function(card) {
    card.addEventListener('click', function(e) {
      if (localStorage.getItem('resource-email')) return; // Already captured
      e.preventDefault();
      var url = card.getAttribute('href');
      var overlay = document.createElement('div');
      overlay.className = 'resource-gate-overlay';
      overlay.innerHTML = '<div class="resource-gate">' +
        '<button class="resource-gate-close" aria-label="Close">&times;</button>' +
        '<h4>Enter your email to access free resources</h4>' +
        '<p>Get instant access to all sample PDFs and future resource updates.</p>' +
        '<form class="resource-gate-form">' +
        '<input type="email" placeholder="Your email address" required />' +
        '<button type="submit" class="btn btn-accent" style="width:100%">Access Resource</button>' +
        '</form></div>';
      document.body.appendChild(overlay);
      document.body.style.overflow = 'hidden';

      overlay.querySelector('.resource-gate-close').addEventListener('click', function() {
        overlay.remove();
        document.body.style.overflow = '';
      });
      overlay.addEventListener('click', function(ev) {
        if (ev.target === overlay) { overlay.remove(); document.body.style.overflow = ''; }
      });
      overlay.querySelector('form').addEventListener('submit', function(ev) {
        ev.preventDefault();
        var email = overlay.querySelector('input').value;
        if (email) {
          localStorage.setItem('resource-email', email);
          overlay.remove();
          document.body.style.overflow = '';
          window.open(url, '_blank');
        }
      });
    });
  });
})();
</script>

<style>
  .resource-gate-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    backdrop-filter: blur(4px);
  }
  .resource-gate {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    max-width: 380px;
    width: 100%;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .resource-gate-close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--text-muted);
    cursor: pointer;
  }
  .resource-gate h4 {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .resource-gate p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .resource-gate-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .resource-gate-form input {
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 0.9rem;
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }
</style>

<style>
  /* Uses global design tokens from global.css */

  /* ===== SHARED ===== */
  .r-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ===== HERO ===== */
  .r-hero {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    padding: calc(var(--header-height) + 3rem) 0 2rem;
    text-align: center;
  }

  .r-hero-heading {
    font-family: var(--font-body);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 200;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 1.25rem;
  }

  .r-hero-sub {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ===== SEARCH + FILTERS ===== */
  .r-filters {
    background: var(--bg-primary);
    padding: 0 0 3rem;
  }

  .r-search-wrap {
    max-width: 480px;
    margin: 0 auto 2rem;
  }

  .r-search {
    width: 100%;
    padding: 0.85rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .r-search::placeholder {
    color: var(--text-muted);
  }

  .r-search:focus {
    border-color: rgba(232, 113, 58, 0.6);
    box-shadow: 0 0 0 3px rgba(232, 113, 58, 0.15);
  }

  .r-filter-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.25rem;
  }

  .r-filter-btn {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: none;
    border: none;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: color 0.2s ease;
    border-radius: 4px;
  }

  .r-filter-btn:hover {
    color: var(--text-secondary);
  }

  .r-filter-btn.active {
    color: var(--color-accent);
  }

  /* ===== RESOURCE CARDS ===== */
  .r-cards-section {
    background: var(--bg-primary);
    padding: 0 0 5rem;
  }

  .r-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .r-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2rem 1.75rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .r-card:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  .r-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .r-card-top .eyebrow {
    margin-bottom: 0;
  }

  .r-type-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .r-card-title {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1.4;
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
  }

  .r-card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex-grow: 1;
    margin: 0 0 1.25rem;
  }

  .r-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .r-card-link:hover {
    gap: 0.7rem;
  }

  /* ===== SAMPLE BADGE ===== */
  .r-type-badge--sample {
    color: var(--color-accent);
    border-color: rgba(212, 133, 58, 0.25);
    background: rgba(212, 133, 58, 0.08);
  }

  /* ===== CARD WITH SAMPLE ===== */
  .r-card--has-sample {
    border-color: rgba(212, 133, 58, 0.12);
  }

  /* ===== CARD ACTIONS (preview + download) ===== */
  .r-card-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: auto;
  }

  .r-card-preview-btn,
  .r-card-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.55rem 1rem;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .r-card-preview-btn {
    color: var(--text-primary);
    background: var(--color-accent);
    border: 1px solid var(--color-accent);
    flex: 1;
    justify-content: center;
  }

  .r-card-preview-btn:hover {
    background: #e8a060;
    border-color: #e8a060;
  }

  .r-card-download-btn {
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border-color);
    justify-content: center;
  }

  .r-card-download-btn:hover {
    border-color: rgba(26, 42, 58, 0.15);
    color: var(--text-primary);
    background: rgba(26, 42, 58, 0.04);
  }

  .r-arrow {
    font-size: 1rem;
    transition: transform 0.2s ease;
