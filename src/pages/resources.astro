---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const resources = [
  {
    title: "O-Level English Scoring Guide",
    description: "A free PDF covering exactly how each component is marked, what examiners reward, and a step-by-step plan to move from C to A. Includes grade benchmarks and sample answers.",
    category: "Exam Prep",
    type: "PDF Guide",
    cta: "Request Free Copy",
  },
  {
    title: "Comprehension Techniques Checklist",
    description: "A downloadable one-page checklist for literal, inferential, evaluative, and vocabulary-in-context questions. Tick off each technique as you practise.",
    category: "English",
    type: "Checklist",
    cta: "Request Free Copy",
  },
  {
    title: "Essay Writing Framework",
    description: "Quick-reference sheet for the CASE Method applied to continuous writing. Covers essay planning, paragraph structure, introductions, and conclusions in one printable page.",
    category: "English",
    type: "Quick Reference",
    cta: "Request Free Copy",
  },
  {
    title: "Common Grammar Mistakes to Avoid",
    description: "Practice sheet listing the 20 most frequent grammar errors in O-Level scripts — with corrections, explanations, and exercises to reinforce each rule.",
    category: "English",
    type: "Practice Sheet",
    cta: "Request Free Copy",
  },
  {
    title: "Situational Writing Format Guide",
    description: "Text-type conventions for formal letter, email, report, and speech with register indicators. Includes annotated model answers for each format.",
    category: "Exam Prep",
    type: "PDF Guide",
    cta: "Request Free Copy",
  },
  {
    title: "Oral Preparation Checklist",
    description: "Structure, timing, vocabulary lists by topic, and self-assessment rubric for the video stimulus response. Use it to practise independently before each session.",
    category: "Exam Prep",
    type: "Checklist",
    cta: "Request Free Copy",
  },
  {
    title: "50 High-Impact O-Level Vocabulary Words",
    description: "Organised by theme with definitions, model sentences, and synonyms. Print it out and work through five words a day for ten days of focused revision.",
    category: "English",
    type: "PDF Guide",
    cta: "Request Free Copy",
  },
  {
    title: "Summary Writing: The 80-Word Challenge",
    description: "Step-by-step technique for identifying main ideas, paraphrasing, and staying within the word limit. Includes three timed practice passages with answer keys.",
    category: "English",
    type: "Practice Sheet",
    cta: "Request Free Copy",
  },
  {
    title: "Common Inference Question Patterns",
    description: "The five most common inference question types and how to answer each using the CASE Method. Worked examples from past papers included.",
    category: "English",
    type: "Quick Reference",
    cta: "Request Free Copy",
  },
  {
    title: "Editing Paper Strategies",
    description: "How to spot and correct grammatical errors systematically in Paper 1 editing. Covers the top error categories with practice exercises and an answer key.",
    category: "Exam Prep",
    type: "Practice Sheet",
    cta: "Request Free Copy",
  },
  {
    title: "Essay Hooks That Work",
    description: "Opening techniques for narrative, expository, and argumentative essays that grab examiner attention. Ten proven openers with before-and-after examples.",
    category: "Study Tips",
    type: "Quick Reference",
    cta: "Request Free Copy",
  },
  {
    title: "Mock Paper Self-Assessment Guide",
    description: "How to review your own mock papers using the CASE checklist for maximum improvement. Includes a printable marking rubric and reflection template.",
    category: "Exam Prep",
    type: "PDF Guide",
    cta: "Request Free Copy",
  },
];

const categories = ["All", "English", "Exam Prep", "Study Tips"];
---

<BaseLayout title="Free Resources — A Worthy" description="Free O-Level English worksheets, study guides, and exam prep tips curated by A-Worthy tutors. No sign-up required.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="r-hero">
    <div class="r-container">
      <span class="eyebrow">Resources</span>
      <h1 class="r-hero-heading">Free academic resources</h1>
      <p class="r-hero-sub">No sign-up required. Worksheets, guides, and study tips curated by our experienced tutors.</p>
    </div>
  </section>

  <!-- ===== SEARCH + FILTERS ===== -->
  <section class="r-filters" data-animate="reveal-up">
    <div class="r-container">
      <div class="r-search-wrap">
        <label for="resource-search" class="sr-only">Search resources</label>
        <input
          type="text"
          id="resource-search"
          class="r-search"
          placeholder="Search resources..."
          autocomplete="off"
        />
      </div>

      <div class="r-filter-row" role="group" aria-label="Filter by category">
        {categories.map((cat) => (
          <button
            class:list={["r-filter-btn", { active: cat === "All" }]}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESOURCE CARDS ===== -->
  <section class="r-cards-section">
    <div class="r-container">
      <div class="r-grid" id="resources-grid">
        {resources.map((resource, i) => (
          <article
            class="r-card"
            data-category={resource.category}
            data-title={resource.title.toLowerCase()}
            data-description={resource.description.toLowerCase()}
            data-animate="reveal-up"
            data-animate-delay={String((i % 3) + 1)}
          >
            <div class="r-card-top">
              <span class="eyebrow">{resource.category}</span>
              <span class="r-type-badge">{resource.type}</span>
            </div>
            <h3 class="r-card-title">{resource.title}</h3>
            <p class="r-card-desc">{resource.description}</p>
            <a href="/contact/" class="r-card-link">
              {resource.cta} <span class="r-arrow">&rarr;</span>
            </a>
          </article>
        ))}
      </div>

      <!-- No Results -->
      <div class="r-no-results" id="no-results" style="display: none;">
        <p class="r-no-results-heading">No resources found</p>
        <p class="r-no-results-sub">Try adjusting your search term or selecting a different category.</p>
      </div>
    </div>
  </section>

  <!-- ===== NEWSLETTER ===== -->
  <section class="r-newsletter-section">
    <div class="r-container">
      <div class="r-newsletter-card" data-animate="reveal-up">
        <span class="eyebrow">Stay Updated</span>
        <h2 class="r-newsletter-heading">Get new resources in your inbox</h2>
        <p class="r-newsletter-sub">Free worksheets, study tips, and exam prep materials delivered weekly.</p>
        <form class="r-newsletter-form" id="newsletter-form" action="https://formspree.io/f/xnewsletter" method="POST">
          <div class="r-newsletter-row">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="newsletter-email"
              name="email"
              class="r-newsletter-input"
              placeholder="you@email.com"
              required
            />
            <button type="submit" class="r-btn-subscribe" id="newsletter-submit">Subscribe</button>
          </div>
          <p class="r-newsletter-note">Join 3,000+ parents and students. Unsubscribe anytime.</p>
          <p class="r-newsletter-success" id="newsletter-success" hidden>Thanks for subscribing! You'll receive our next newsletter shortly.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="r-cta">
    <div class="r-container">
      <span class="eyebrow">Next Step</span>
      <h2 class="r-cta-heading" data-animate="reveal-up">Want personalised guidance?</h2>
      <p class="r-cta-sub">Our resources are a great start — personalised tuition takes it further.</p>
      <a href="/contact/" class="r-btn-cta">Get in Touch</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  const searchInput = document.getElementById('resource-search') as HTMLInputElement;
  const filterButtons = document.querySelectorAll('.r-filter-btn');
  const resourceCards = document.querySelectorAll('.r-card') as NodeListOf<HTMLElement>;
  const noResults = document.getElementById('no-results') as HTMLElement;

  let activeCategory = 'All';

  function filterResources() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    resourceCards.forEach((card) => {
      const title = card.getAttribute('data-title') || '';
      const description = card.getAttribute('data-description') || '';
      const category = card.getAttribute('data-category') || '';

      const matchesCategory = activeCategory === 'All' || category === activeCategory;
      const matchesSearch = !searchTerm || title.includes(searchTerm) || description.includes(searchTerm);

      if (matchesCategory && matchesSearch) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
  }

  searchInput.addEventListener('input', filterResources);

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.getAttribute('data-category') || 'All';
      filterResources();
    });
  });

  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement;
  const newsletterSuccess = document.getElementById('newsletter-success') as HTMLElement;
  const newsletterSubmit = document.getElementById('newsletter-submit') as HTMLButtonElement;

  newsletterForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    if (!emailInput.value) return;

    newsletterSubmit.disabled = true;
    newsletterSubmit.textContent = 'Subscribing...';

    try {
      const formData = new FormData(newsletterForm);
      const response = await fetch(newsletterForm.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' },
      });

      if (response.ok) {
        emailInput.value = '';
        newsletterSuccess.hidden = false;
      } else {
        throw new Error('Failed');
      }
    } catch {
      newsletterSuccess.hidden = false;
      newsletterSuccess.textContent = 'Something went wrong. Please try again.';
    } finally {
      newsletterSubmit.disabled = false;
      newsletterSubmit.textContent = 'Subscribe';
    }
  });
</script>

<style>
  /* Uses global design tokens from global.css */

  /* ===== SHARED ===== */
  .r-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ===== HERO ===== */
  .r-hero {
    background: var(--bg-primary);
    padding: calc(var(--header-height) + 3rem) 0 2rem;
    text-align: center;
  }

  .r-hero-heading {
    font-family: var(--font-body);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 1.25rem;
  }

  .r-hero-sub {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ===== SEARCH + FILTERS ===== */
  .r-filters {
    background: var(--bg-primary);
    padding: 0 0 3rem;
  }

  .r-search-wrap {
    max-width: 480px;
    margin: 0 auto 2rem;
  }

  .r-search {
    width: 100%;
    padding: 0.85rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-primary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .r-search::placeholder {
    color: var(--text-muted);
  }

  .r-search:focus {
    border-color: rgba(232, 113, 58, 0.6);
    box-shadow: 0 0 0 3px rgba(232, 113, 58, 0.15);
  }

  .r-filter-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.25rem;
  }

  .r-filter-btn {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: none;
    border: none;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: color 0.2s ease;
    border-radius: 4px;
  }

  .r-filter-btn:hover {
    color: var(--text-secondary);
  }

  .r-filter-btn.active {
    color: var(--color-accent);
  }

  /* ===== RESOURCE CARDS ===== */
  .r-cards-section {
    background: var(--bg-primary);
    padding: 0 0 5rem;
  }

  .r-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .r-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 2rem 1.75rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .r-card:hover {
    transform: scale(0.98);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .r-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .r-card-top .eyebrow {
    margin-bottom: 0;
  }

  .r-type-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.06);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .r-card-title {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    margin: 0 0 0.75rem;
  }

  .r-card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex-grow: 1;
    margin: 0 0 1.25rem;
  }

  .r-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .r-card-link:hover {
    gap: 0.7rem;
  }

  /* --soon styles removed — all resources now link to /contact/ */

  .r-arrow {
    font-size: 1rem;
    transition: transform 0.2s ease;
  }

  /* ===== NO RESULTS ===== */
  .r-no-results {
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 0;
  }

  .r-no-results-heading {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin: 0 0 0.5rem;
  }

  .r-no-results-sub {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* ===== NEWSLETTER ===== */
  .r-newsletter-section {
    background: var(--bg-primary);
    padding: 0 0 5rem;
  }

  .r-newsletter-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 3rem;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .r-newsletter-heading {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .r-newsletter-sub {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 1.75rem;
  }

  .r-newsletter-form {
    width: 100%;
  }

  .r-newsletter-row {
    display: flex;
    gap: 0.5rem;
  }

  .r-newsletter-input {
    flex: 1;
    padding: 0.8rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-primary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .r-newsletter-input::placeholder {
    color: var(--text-muted);
  }

  .r-newsletter-input:focus {
    border-color: rgba(232, 113, 58, 0.6);
    box-shadow: 0 0 0 3px rgba(232, 113, 58, 0.15);
  }

  .r-btn-subscribe {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    background: var(--color-accent);
    border: none;
    border-radius: 6px;
    padding: 0.8rem 1.5rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }

  .r-btn-subscribe:hover {
    background: #d4632f;
  }

  .r-newsletter-note {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0.75rem 0 0;
  }

  .r-newsletter-success {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-accent);
    margin: 0.75rem 0 0;
    font-weight: 500;
  }

  /* ===== CTA ===== */
  .r-cta {
    background: var(--bg-primary);
    padding: 3rem 0 7rem;
    text-align: center;
  }

  .r-cta-heading {
    font-family: var(--font-body);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .r-cta-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0 0 2rem;
  }

  .r-btn-cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    background: var(--color-accent);
    border: none;
    border-radius: 6px;
    padding: 0.85rem 2rem;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .r-btn-cta:hover {
    background: #d4632f;
  }

  /* ===== VISUAL PLACEHOLDER ===== */
  .r-visual-placeholder {
    background: var(--bg-secondary);
    border: 1px dashed var(--border-color);
    border-radius: var(--border-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .r-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .r-hero {
      padding: 5rem 0 3rem;
    }

    .r-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .r-card {
      padding: 1.5rem 1.25rem;
    }

    .r-filter-row {
      gap: 0;
    }

    .r-filter-btn {
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }

    .r-newsletter-card {
      padding: 2rem 1.5rem;
    }

    .r-newsletter-row {
      flex-direction: column;
    }

    .r-cta {
      padding: 2rem 0 5rem;
    }
  }

  @media (min-width: 1921px) {
    .r-container {
      max-width: 1400px;
    }
  }
</style>
