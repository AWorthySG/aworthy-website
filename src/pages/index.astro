---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="A Worthy — Singapore's Premier Tuition Centre">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content animate-fade-in-up">
        <span class="hero-badge">Trusted by 2,000+ Singapore families since 2015</span>
        <h1>Unlock Your Child's <span class="highlight">Full Academic Potential</span></h1>
        <p class="hero-subtitle">
          Expert tuition in Mathematics, Science, and English for Primary, Secondary, and JC students.
          Small class sizes. Proven MOE-aligned methods. Results that speak for themselves.
        </p>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn-primary btn-lg">Book a Free Trial</a>
          <a href="/programmes/" class="btn btn-secondary btn-lg">View Programmes</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-number">95%</span>
            <span class="stat-label">Score A or A* at PSLE</span>
          </div>
          <div class="stat">
            <span class="stat-number">8:1</span>
            <span class="stat-label">Student-to-Teacher Ratio</span>
          </div>
          <div class="stat">
            <span class="stat-number">10+</span>
            <span class="stat-label">Years of Excellence</span>
          </div>
        </div>
      </div>
      <div class="hero-visual animate-fade-in">
        <div class="hero-image-wrapper">
          <img src="/images/heroes/hero-students.jpg" alt="Students learning together at A Worthy tuition centre in Singapore" class="hero-img" loading="eager" />
          <div class="floating-card card-1">A* in Maths</div>
          <div class="floating-card card-2">Distinction in Science</div>
          <div class="floating-card card-3">AL1 for English</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE US ===== -->
  <section class="section why-us" id="why-us">
    <div class="container">
      <h2 class="section-title">Why Families Choose A Worthy</h2>
      <p class="section-subtitle">We go beyond rote learning — we build deep understanding, exam confidence, and a lifelong love for learning.</p>

      <div class="features-grid">
        <div class="card feature-card">
          <div class="feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></div>
          <h3>NIE-Trained & MOE-Experienced Tutors</h3>
          <p>Every tutor is either NIE-trained or has 5+ years of experience in Singapore's MOE curriculum. They don't just teach — they mentor.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
          <h3>Small Class Sizes (Max 8)</h3>
          <p>With a maximum of 8 students per class, every child receives individual attention, targeted feedback, and personalised learning plans.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></div>
          <h3>MOE-Aligned Curriculum</h3>
          <p>Our materials are meticulously aligned to the latest MOE syllabus, incorporating exam-focused strategies for PSLE, O-Level, and A-Level success.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
          <h3>Proven Track Record</h3>
          <p>95% of our PSLE students score A/A*, and 90% of our O-Level students achieve A1–A2. Results verified and published annually.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
          <h3>Real-Time Parent Updates</h3>
          <p>Stay informed with termly progress reports, WhatsApp updates after every lesson, and regular parent-teacher consultations.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
          <h3>Comfortable Learning Space</h3>
          <p>Our air-conditioned centres are designed for focus — with dedicated quiet zones, a resource library, and a welcoming waiting area for parents.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMMES OVERVIEW ===== -->
  <section class="section programmes-overview">
    <div class="container">
      <h2 class="section-title">Our Programmes</h2>
      <p class="section-subtitle">Structured learning pathways for every stage of your child's academic journey.</p>

      <div class="programmes-grid">
        <div class="card programme-card">
          <img src="/images/programmes/primary-students.jpg" alt="Primary school students learning" class="programme-img" loading="lazy" />
          <div class="programme-level">Primary</div>
          <h3>P3 – P6</h3>
          <p>Build strong foundations in Mathematics, Science, and English with hands-on learning and PSLE-focused preparation.</p>
          <ul class="programme-subjects">
            <li>Mathematics</li>
            <li>Science</li>
            <li>English</li>
            <li>Higher Chinese</li>
          </ul>
          <div class="programme-price">
            <span class="price">From $240</span>
            <span class="price-period">/month</span>
          </div>
          <a href="/programmes/#primary" class="btn btn-secondary">Learn More</a>
        </div>

        <div class="card programme-card featured">
          <div class="programme-badge">Most Popular</div>
          <img src="/images/programmes/secondary-students.jpg" alt="Secondary school students in class" class="programme-img" loading="lazy" />
          <div class="programme-level">Secondary</div>
          <h3>Sec 1 – 4/5</h3>
          <p>Master complex topics with structured revision, exam techniques, and consistent practice for O-Level and N-Level success.</p>
          <ul class="programme-subjects">
            <li>E & A Mathematics</li>
            <li>Physics / Chemistry / Biology</li>
            <li>English</li>
            <li>Combined Humanities</li>
          </ul>
          <div class="programme-price">
            <span class="price">From $280</span>
            <span class="price-period">/month</span>
          </div>
          <a href="/programmes/#secondary" class="btn btn-primary">Learn More</a>
        </div>

        <div class="card programme-card">
          <img src="/images/programmes/jc-students.jpg" alt="Junior college students studying" class="programme-img" loading="lazy" />
          <div class="programme-level">Junior College</div>
          <h3>JC 1 – 2</h3>
          <p>Tackle H1 and H2 subjects with rigorous content mastery, past-year paper drills, and expert guidance from experienced JC tutors.</p>
          <ul class="programme-subjects">
            <li>H2 Mathematics</li>
            <li>H2 Physics / Chemistry</li>
            <li>H1 General Paper</li>
            <li>H2 Economics</li>
          </ul>
          <div class="programme-price">
            <span class="price">From $360</span>
            <span class="price-period">/month</span>
          </div>
          <a href="/programmes/#jc" class="btn btn-secondary">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== APPROACH ===== -->
  <section class="section approach">
    <div class="container">
      <h2 class="section-title">The A Worthy Teaching Method</h2>
      <p class="section-subtitle">A structured, four-step pedagogical approach that turns struggle into mastery.</p>

      <div class="approach-steps">
        <div class="approach-step">
          <div class="step-number">01</div>
          <h3>Diagnose</h3>
          <p>We start with a comprehensive diagnostic assessment to identify each student's knowledge gaps, learning style, and areas of strength.</p>
        </div>
        <div class="approach-step">
          <div class="step-number">02</div>
          <h3>Build</h3>
          <p>Concepts are taught from the ground up using clear explanations, real-world examples, and visual aids — ensuring genuine understanding, not memorisation.</p>
        </div>
        <div class="approach-step">
          <div class="step-number">03</div>
          <h3>Practise</h3>
          <p>Students tackle curated worksheets and past-year exam papers with increasing difficulty, building speed, accuracy, and exam confidence.</p>
        </div>
        <div class="approach-step">
          <div class="step-number">04</div>
          <h3>Excel</h3>
          <p>We push students beyond the syllabus with challenging problems, timed mock exams, and one-to-one coaching to ensure peak performance on exam day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS PREVIEW ===== -->
  <section class="section testimonials-preview">
    <div class="container">
      <h2 class="section-title">What Parents & Students Say</h2>
      <p class="section-subtitle">Don't just take our word for it — hear from the families we've helped.</p>

      <div class="testimonials-grid">
        <div class="card testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <blockquote>
            "My son went from a C5 in Maths to an A2 in just 8 months. The tutors at A Worthy are incredibly patient and really know the O-Level syllabus inside out."
          </blockquote>
          <div class="testimonial-author">
            <img src="/images/avatars/avatar-linda.jpg" alt="" class="testimonial-avatar" loading="lazy" />
            <div class="testimonial-author-info">
              <strong>Mrs. Linda Tan</strong>
              <span>Mother of Sec 4 student, Chung Cheng High</span>
            </div>
          </div>
        </div>

        <div class="card testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <blockquote>
            "I scored AL1 for both Maths and Science at PSLE! Thank you, Teacher Jason, for always believing in me and making lessons so fun."
          </blockquote>
          <div class="testimonial-author">
            <img src="/images/avatars/avatar-ethan.jpg" alt="" class="testimonial-avatar" loading="lazy" />
            <div class="testimonial-author-info">
              <strong>Ethan Lim</strong>
              <span>P6 student, Ai Tong School — PSLE 2025</span>
            </div>
          </div>
        </div>

        <div class="card testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <blockquote>
            "The small class sizes made all the difference. My daughter is no longer afraid of Chemistry, and she even enjoys going to tuition now!"
          </blockquote>
          <div class="testimonial-author">
            <img src="/images/avatars/avatar-rajesh.jpg" alt="" class="testimonial-avatar" loading="lazy" />
            <div class="testimonial-author-info">
              <strong>Mr. Rajesh Kumar</strong>
              <span>Father of Sec 3 student, Bukit Panjang Govt High</span>
            </div>
          </div>
        </div>
      </div>

      <div class="testimonials-cta">
        <a href="/testimonials/" class="btn btn-secondary">Read More Testimonials</a>
      </div>
    </div>
  </section>

  <!-- ===== CTA BANNER ===== -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <h2>Ready to See Your Child Thrive?</h2>
      <p>Book a <strong>free diagnostic assessment</strong> and trial lesson — no obligations, no pressure. Let us show you the A Worthy difference.</p>
      <div class="cta-actions">
        <a href="/contact/" class="btn btn-accent btn-lg">Book Free Trial</a>
        <a href="https://wa.me/6591234567" class="btn btn-secondary btn-lg" style="border-color: #FFF; color: #FFF;">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    padding: var(--space-3xl) 0 var(--space-4xl);
    background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--bg-secondary);
    border: 1px solid var(--color-accent);
    color: var(--color-primary);
    padding: var(--space-xs) var(--space-md);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .hero h1 {
    margin-bottom: var(--space-lg);
  }

  .highlight {
    color: var(--color-primary);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
  }

  .btn-lg {
    padding: 0.9rem 2rem;
    font-size: 1.05rem;
  }

  .hero-stats {
    display: flex;
    gap: var(--space-2xl);
  }

  .stat { text-align: center; }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image-wrapper {
    position: relative;
    width: 100%;
    max-width: 500px;
  }

  .hero-img {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius-lg);
    box-shadow: 0 8px 30px var(--shadow-hover);
  }

  .floating-card {
    position: absolute;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--border-radius);
    font-size: 0.9rem;
    font-weight: 600;
    box-shadow: 0 4px 15px var(--shadow-color);
    white-space: nowrap;
    z-index: 2;
  }

  .card-1 { top: 10%; left: 0; animation: float 3s ease-in-out infinite; }
  .card-2 { bottom: 25%; right: 0; animation: float 3s ease-in-out infinite 1s; }
  .card-3 { bottom: 10%; left: 10%; animation: float 3s ease-in-out infinite 2s; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* ===== FEATURES ===== */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .feature-card {
    text-align: center;
    padding: var(--space-2xl);
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
  }

  .feature-card h3 {
    font-size: 1.15rem;
    margin-bottom: var(--space-sm);
  }

  .feature-card p { font-size: 0.95rem; }

  /* ===== PROGRAMMES ===== */
  .programmes-overview { background: var(--bg-secondary); }

  .programmes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    align-items: start;
  }

  .programme-card {
    text-align: center;
    padding: var(--space-2xl);
    position: relative;
  }

  .programme-card.featured {
    border-color: var(--color-primary);
    border-width: 2px;
    transform: scale(1.03);
  }

  .programme-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: #FFF;
    padding: 4px 16px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .programme-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
    margin: calc(-1 * var(--space-2xl)) calc(-1 * var(--space-2xl)) var(--space-lg);
    width: calc(100% + 2 * var(--space-2xl));
  }

  .programme-level {
    color: var(--color-accent);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-xs);
  }

  .programme-card h3 {
    margin-bottom: var(--space-md);
    font-size: 1.5rem;
  }

  .programme-subjects {
    list-style: none;
    padding: 0;
    margin: var(--space-lg) 0;
    text-align: left;
  }

  .programme-subjects li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.95rem;
  }

  .programme-subjects li::before {
    content: '✓ ';
    color: var(--color-primary);
    font-weight: 700;
  }

  .programme-price { margin: var(--space-lg) 0; }

  .price {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .price-period {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* ===== APPROACH ===== */
  .approach-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
  }

  .approach-step { text-align: center; }

  .step-number {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.2;
    margin-bottom: var(--space-sm);
  }

  .approach-step h3 {
    font-size: 1.2rem;
    margin-bottom: var(--space-sm);
    color: var(--color-primary);
  }

  .approach-step p { font-size: 0.95rem; }

  /* ===== TESTIMONIALS ===== */
  .testimonials-preview { background: var(--bg-secondary); }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .testimonial-card { padding: var(--space-xl); }

  .testimonial-stars {
    color: var(--color-accent);
    font-size: 1.2rem;
    letter-spacing: 3px;
    margin-bottom: var(--space-md);
  }

  .testimonial-card blockquote {
    font-style: italic;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }

  .testimonial-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .testimonial-author strong {
    display: block;
    color: var(--text-primary);
  }

  .testimonial-author span {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .testimonials-cta {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  /* ===== CTA BANNER ===== */
  .cta-banner {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: #FFFFFF;
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .cta-banner h2 { color: #FFFFFF; margin-bottom: var(--space-md); }

  .cta-banner p {
    color: rgba(255,255,255,0.9);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto var(--space-xl);
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-visual { display: none; }
    .hero-stats { justify-content: center; }
    .hero-actions { justify-content: center; }
    .features-grid, .programmes-grid, .testimonials-grid { grid-template-columns: 1fr 1fr; }
    .approach-steps { grid-template-columns: 1fr 1fr; }
    .programme-card.featured { transform: none; }
  }

  @media (max-width: 640px) {
    .features-grid, .programmes-grid, .testimonials-grid, .approach-steps { grid-template-columns: 1fr; }
    .hero-stats { flex-direction: column; gap: var(--space-md); }
  }

  @media (max-width: 480px) {
    .hero-badge { font-size: 0.75rem; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
    .cta-actions { flex-direction: column; }
    .cta-actions .btn { width: 100%; justify-content: center; }
  }

  @media (min-width: 1921px) {
    .hero-inner { gap: var(--space-4xl); }
    .hero-image-wrapper { max-width: 650px; }
    .features-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-2xl); }
    .programmes-grid { gap: var(--space-2xl); }
    .testimonials-grid { gap: var(--space-2xl); }
    .approach-steps { gap: var(--space-2xl); }
    .feature-icon { width: 80px; height: 80px; }
    .feature-icon svg { width: 40px; height: 40px; }
  }
</style>
