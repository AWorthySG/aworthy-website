---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PenAnimation from '../components/PenAnimation.astro';
import '../styles/global.css';
---

<BaseLayout title="A-Worthy — Singapore's First Analytical English Tuition" description="A-Worthy uses the CASE Method — a proprietary legal-analytical framework — to help secondary students master O-Level English. Small classes, proven results. Book a free trial.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <!-- Animated floating orbs -->
    <div class="hero-orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
      <div class="orb orb-5"></div>
    </div>
    <!-- Grid lines decoration -->
    <div class="hero-grid-lines" aria-hidden="true">
      <div class="grid-line grid-line-v1"></div>
      <div class="grid-line grid-line-v2"></div>
      <div class="grid-line grid-line-v3"></div>
      <div class="grid-line grid-line-h1"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="eyebrow hero-stagger" style="--stagger:0">Singapore's First Analytical English Tuition</span>
        <h1 class="hero-heading shimmer-text hero-stagger" style="--stagger:1">Think sharper.<br/>Write stronger.<br/>Score higher.</h1>
        <p class="hero-subtitle hero-stagger" style="--stagger:2">
          Founded by a law graduate, A-Worthy uses the CASE Method — a proprietary framework that brings legal-analytical precision to help secondary students master O-Level English.
        </p>
        <div class="hero-proof hero-stagger" style="--stagger:3">
          <div class="proof-item">
            <span class="proof-number">95%</span>
            <span class="proof-label">pass rate</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">50+</span>
            <span class="proof-label">5-star reviews</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">6</span>
            <span class="proof-label">max class size</span>
          </div>
        </div>
        <p class="hero-intake hero-stagger" style="--stagger:4">Next intake: <strong>Term 3, July 2026</strong> — Limited slots available</p>
        <div class="hero-actions hero-stagger" style="--stagger:5">
          <a href="/#contact" class="btn btn-accent hero-cta-primary">Get Your A</a>
          <a href="https://wa.me/6591234567" class="btn btn-outline hero-cta-secondary" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 6px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <PenAnimation />
      </div>
      <div class="hero-badges">
        <span class="hero-badge">MOE-Aligned</span>
        <span class="hero-badge">100% Online via Zoom</span>
        <span class="hero-badge">NUS Law Graduate Founder</span>
      </div>
    </div>
  </section>

  <!-- ===== STATS BAR with Story Context (#14) ===== -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="1">
        <span class="stat-number" data-count="95" data-count-suffix="%">0%</span>
        <span class="stat-label">O-Level English pass rate</span>
        <span class="stat-story">Including Sarah, who went from D7 to A2</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="2">
        <span class="stat-number">6:1</span>
        <span class="stat-label">Maximum class size</span>
        <span class="stat-story">Every student gets personal attention</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="3">
        <span class="stat-number" data-count="500" data-count-suffix="+">0+</span>
        <span class="stat-label">Students taught</span>
        <span class="stat-story">Across all secondary levels since 2022</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="4">
        <span class="stat-number">Law</span>
        <span class="stat-label">Graduate founder</span>
        <span class="stat-story">NUS Law — analytical precision in teaching</span>
      </div>
    </div>
  </section>

  <!-- ===== SOCIAL PROOF TICKER (#10) ===== -->
  <div class="social-proof-ticker" aria-live="polite">
    <div class="container">
      <div class="proof-ticker-inner" id="proof-ticker">
        <div class="proof-ticker-item">
          <span class="proof-ticker-dot"></span>
          <span class="proof-ticker-text">A parent in Bukit Timah just enrolled their Sec 3 child</span>
          <span class="proof-ticker-time">2 hours ago</span>
        </div>
      </div>
    </div>
  </div>


  <!-- ===== TRUST STRIP ===== -->
  <section class="trust-strip">
    <div class="container trust-inner">
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span>4.9/5 from 50+ parent reviews</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>MOE-aligned curriculum</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>NUS Law graduate founder</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span>100% online via Zoom</span>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section id="about" class="section problem-section">
    <div class="container">
      <div class="problem-grid">
        <div class="problem-col" data-animate="reveal-up">
          <span class="eyebrow">The Problem</span>
          <h2 class="problem-heading">Most English tuition teaches content.<br/>Not thinking.</h2>
          <ul class="problem-list">
            <li>Students memorise model answers instead of learning how to reason</li>
            <li>Large class sizes mean generic, one-size-fits-all instruction</li>
            <li>No systematic framework — just "practise more papers"</li>
          </ul>
        </div>
        <div class="solution-col" data-animate="reveal-up" data-animate-delay="1">
          <span class="eyebrow">Our Approach</span>
          <h2 class="problem-heading">A-Worthy teaches students<br/>how to think.</h2>
          <ul class="solution-list">
            <li><strong>The CASE Method</strong> — a proprietary framework from legal reasoning</li>
            <li><strong>Max 6 students</strong> — every student gets individual attention</li>
            <li><strong>Structured mastery</strong> — not rote learning, but analytical precision</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMMES OVERVIEW ===== -->
  <section id="programmes" class="section programmes-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Programmes</span>
      <h2 class="section-heading" data-animate="reveal-up">Structured learning pathways for every stage</h2>

      <div class="programmes-grid">
        <a href="/programmes/#sec1-2" class="programme-card" data-animate="reveal-up" data-animate-delay="1">
          <div class="programme-body">
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 1&ndash;2 English Foundation</h3>
            <p>90-minute weekly sessions covering Paper 1 and Paper 2 skills. Build a strong analytical foundation in comprehension, composition, and language use.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 280/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#sec3-4" class="programme-card programme-card--popular" data-animate="reveal-up" data-animate-delay="2">
          <div class="programme-body">
            <span class="programme-popular-badge">Most Popular</span>
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 3&ndash;4 O-Level Intensive</h3>
            <p>90-minute exam-focused sessions with monthly mock grading. Master every O-Level English component with the CASE Method and targeted practice.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 320/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#h1-gp" class="programme-card programme-card--new" data-animate="reveal-up" data-animate-delay="3">
          <div class="programme-body">
            <span class="programme-new-badge">New</span>
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>H1 General Paper</h3>
            <p>A-Level GP preparation using the CASE Method's legal-analytical framework. Build argumentation, critical reading, and essay writing skills across all content themes.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 360/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#one-to-one" class="programme-card" data-animate="reveal-up" data-animate-delay="4">
          <div class="programme-body">
            <span class="programme-level">Individual Online</span>
            <h3>One-to-One Coaching</h3>
            <p>Intensive exam prep or tailored support designed around your child's specific needs. Flexible scheduling with personalised feedback every session.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 120/session</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>
      </div>

      <!-- Programme Selector Quiz (#8) -->
      <div class="quiz-section" data-animate="reveal-up">
        <div class="quiz-card">
          <span class="eyebrow">Not Sure Which Programme?</span>
          <h3 class="quiz-heading">Find the right programme in 30 seconds</h3>
          <div class="quiz-body" id="programme-quiz">
            <div class="quiz-step" data-step="1">
              <p class="quiz-question">What level is your child in?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="sec1-2" data-next="2">Sec 1 or 2</button>
                <button class="quiz-option" data-value="sec3-4" data-next="2">Sec 3 or 4</button>
                <button class="quiz-option" data-value="jc" data-next="2">JC 1 or 2</button>
              </div>
            </div>
            <div class="quiz-step" data-step="2" hidden>
              <p class="quiz-question">What's the biggest challenge?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="comprehension" data-next="3">Comprehension & inference</button>
                <button class="quiz-option" data-value="writing" data-next="3">Essay writing & structure</button>
                <button class="quiz-option" data-value="overall" data-next="3">Overall grade improvement</button>
              </div>
            </div>
            <div class="quiz-step" data-step="3" hidden>
              <p class="quiz-question">What kind of support does your child need?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="group" data-next="result">Small group learning</button>
                <button class="quiz-option" data-value="individual" data-next="result">Individual attention</button>
              </div>
            </div>
            <div class="quiz-result" id="quiz-result" hidden>
              <div class="quiz-result-icon">&#10003;</div>
              <h4 class="quiz-result-heading" id="quiz-result-title"></h4>
              <p class="quiz-result-desc" id="quiz-result-desc"></p>
              <a href="/programmes/" class="btn btn-accent quiz-result-cta">View Programme Details</a>
              <button class="quiz-restart" id="quiz-restart">Start again</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CASE FLOW DIAGRAM ===== -->
  <section class="section case-flow-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">How It Works</span>
      <h2 class="section-heading" data-animate="reveal-up">Every lesson follows the CASE Method</h2>
      <div class="case-flow" data-animate="reveal-up">
        <div class="case-flow-step">
          <div class="case-flow-icon"><span>C</span><div class="icon-ring"></div></div>
          <h3>Contextualise</h3>
          <p>Identify the task and purpose</p>
        </div>
        <div class="case-flow-connector" aria-hidden="true">
          <svg width="60" height="24" viewBox="0 0 60 24">
            <defs><linearGradient id="arrow-grad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.3"/><stop offset="100%" stop-color="var(--color-accent)" stop-opacity="1"/></linearGradient></defs>
            <path class="connector-line" d="M0 12h48" stroke="url(#arrow-grad)" stroke-width="2" fill="none" stroke-dasharray="48" stroke-dashoffset="48"/>
            <path class="connector-arrow" d="M44 6l8 6-8 6" stroke="var(--color-accent)" stroke-width="2" fill="none" opacity="0"/>
          </svg>
        </div>
        <div class="case-flow-step">
          <div class="case-flow-icon"><span>A</span><div class="icon-ring"></div></div>
          <h3>Analyse</h3>
          <p>Read closely for meaning</p>
        </div>
        <div class="case-flow-connector" aria-hidden="true">
          <svg width="60" height="24" viewBox="0 0 60 24">
            <path class="connector-line" d="M0 12h48" stroke="url(#arrow-grad)" stroke-width="2" fill="none" stroke-dasharray="48" stroke-dashoffset="48"/>
            <path class="connector-arrow" d="M44 6l8 6-8 6" stroke="var(--color-accent)" stroke-width="2" fill="none" opacity="0"/>
          </svg>
        </div>
        <div class="case-flow-step">
          <div class="case-flow-icon"><span>S</span><div class="icon-ring"></div></div>
          <h3>Structure</h3>
          <p>Organise and write</p>
        </div>
        <div class="case-flow-connector" aria-hidden="true">
          <svg width="60" height="24" viewBox="0 0 60 24">
            <path class="connector-line" d="M0 12h48" stroke="url(#arrow-grad)" stroke-width="2" fill="none" stroke-dasharray="48" stroke-dashoffset="48"/>
            <path class="connector-arrow" d="M44 6l8 6-8 6" stroke="var(--color-accent)" stroke-width="2" fill="none" opacity="0"/>
          </svg>
        </div>
        <div class="case-flow-step">
          <div class="case-flow-icon"><span>E</span><div class="icon-ring"></div></div>
          <h3>Evaluate</h3>
          <p>Review and reflect</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== APPROACH ===== -->
  <section id="method" class="section approach-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">The CASE Method</span>
      <h2 class="section-heading" data-animate="reveal-up">Legal precision meets English mastery</h2>
      <p class="approach-subtitle">Our proprietary framework applies legal reasoning structures to every O-Level English component</p>

      <div class="approach-grid">
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="1">
          <div class="approach-card-header">
            <span class="approach-letter">C</span>
            <span class="approach-time">10 min</span>
          </div>
          <h3>Contextualise</h3>
          <p>Identify the task, purpose, audience, and text type. What is being asked? What kind of response is required? Just as lawyers issue-spot before applying any rule.</p>
        </div>
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="2">
          <div class="approach-card-header">
            <span class="approach-letter">A</span>
            <span class="approach-time">20 min</span>
          </div>
          <h3>Analyse</h3>
          <p>Read closely for explicit and implicit meaning, language technique, and writer's purpose. The analytical step is where marks are won or lost.</p>
        </div>
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="3">
          <div class="approach-card-header">
            <span class="approach-letter">S</span>
            <span class="approach-time">20 min</span>
          </div>
          <h3>Structure</h3>
          <p>Organise ideas into a coherent response. Build paragraphs with claim, evidence, and reasoned explanation. Structure is not decoration — it is the argument itself.</p>
        </div>
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="4">
          <div class="approach-card-header">
            <span class="approach-letter">E</span>
            <span class="approach-time">10 min</span>
          </div>
          <h3>Evaluate</h3>
          <p>Review, revise, and reflect. Does the response address the question? Is the evidence well-chosen? Is the language precise? The deliberate checking of reasoning.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPARISON TABLE (#15) ===== -->
  <section class="section comparison-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Why A-Worthy</span>
      <h2 class="section-heading" data-animate="reveal-up">How we compare</h2>
      <div class="comparison-table-wrap" data-animate="reveal-up">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th class="comparison-highlight">A-Worthy</th>
              <th>Large Tuition Chains</th>
              <th>Self-Study</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="comparison-feature">Class Size</td>
              <td class="comparison-highlight"><strong>Max 6 students</strong></td>
              <td>15-30 students</td>
              <td>N/A</td>
            </tr>
            <tr>
              <td class="comparison-feature">Teaching Method</td>
              <td class="comparison-highlight"><strong>CASE Method (proprietary)</strong></td>
              <td>Generic worksheets</td>
              <td>Model answer memorisation</td>
            </tr>
            <tr>
              <td class="comparison-feature">Individual Feedback</td>
              <td class="comparison-highlight"><strong>Every session</strong></td>
              <td>Periodic, if any</td>
              <td>None</td>
            </tr>
            <tr>
              <td class="comparison-feature">Founder Qualification</td>
              <td class="comparison-highlight"><strong>NUS Law graduate</strong></td>
              <td>Varies</td>
              <td>N/A</td>
            </tr>
            <tr>
              <td class="comparison-feature">A1-B3 Rate</td>
              <td class="comparison-highlight"><strong>90%</strong></td>
              <td>Undisclosed</td>
              <td>Varies</td>
            </tr>
            <tr>
              <td class="comparison-feature">Monthly Fee</td>
              <td class="comparison-highlight"><strong>From SGD 280</strong></td>
              <td>SGD 200-500</td>
              <td>Free</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== THE VAULT — Free O-Level English Resources ===== -->
  <section id="vault" class="section vault-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">The Vault</span>
      <h2 class="section-heading" data-animate="reveal-up">Free resources your child can use <em>tonight</em></h2>
      <p class="vault-subtitle" data-animate="reveal-up">Samples from our proprietary CASE Method resource library — aligned to the GCE O-Level English 1184 syllabus. Download, print, and start improving.</p>

      <div class="vault-grid">
        <a href="/docs/samples/scoring-guide-sample.pdf" target="_blank" rel="noopener" class="vault-card" data-animate="reveal-up" data-animate-delay="1">
          <div class="vault-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <span class="vault-tag">Exam Prep</span>
          <h3>O-Level Scoring Guide</h3>
          <p>How each component is marked, what examiners reward, and a step-by-step plan to move from C to A.</p>
          <span class="vault-dl">View Sample PDF &rarr;</span>
        </a>

        <a href="/docs/samples/essay-framework-sample.pdf" target="_blank" rel="noopener" class="vault-card" data-animate="reveal-up" data-animate-delay="2">
          <div class="vault-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <span class="vault-tag">Writing</span>
          <h3>Essay Writing Framework</h3>
          <p>CASE Method applied to continuous writing — essay planning, paragraph structure, and 6 proven opening hooks.</p>
          <span class="vault-dl">View Sample PDF &rarr;</span>
        </a>

