---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="A-Worthy — Singapore's First Analytical English Tuition" description="A-Worthy uses the CASE Method — a proprietary legal-analytical framework — to help secondary students master O-Level English. Small classes, proven results. Book a free trial.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="eyebrow">Singapore's First Analytical English Tuition</span>
        <h1 class="hero-heading">Think sharper.<br/>Write stronger.<br/>Score higher.</h1>
        <p class="hero-subtitle">
          Founded by a law graduate, A-Worthy uses the CASE Method — a proprietary framework that brings legal-analytical precision to help secondary students master O-Level English.
        </p>
        <div class="hero-proof">
          <div class="proof-item">
            <span class="proof-number">95%</span>
            <span class="proof-label">pass rate</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">50+</span>
            <span class="proof-label">5-star reviews</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">6</span>
            <span class="proof-label">max class size</span>
          </div>
        </div>
        <p class="hero-intake">Next intake: <strong>Term 3, July 2026</strong> — Limited slots available</p>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn-accent hero-cta-primary">Book a Free Trial Class</a>
          <a href="https://wa.me/6591234567" class="btn btn-outline hero-cta-secondary" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 6px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-type-element" aria-hidden="true">
          <span class="type-letter type-c">C</span>
          <span class="type-dot">·</span>
          <span class="type-letter type-a">A</span>
          <span class="type-dot">·</span>
          <span class="type-letter type-s">S</span>
          <span class="type-dot">·</span>
          <span class="type-letter type-e">E</span>
        </div>
        <p class="hero-type-label">The Method</p>
      </div>
      <div class="hero-badges">
        <span class="hero-badge">MOE-Aligned</span>
        <span class="hero-badge">100% Online via Zoom</span>
        <span class="hero-badge">NUS Law Graduate Founder</span>
      </div>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="1">
        <span class="stat-number" data-count="95" data-count-suffix="%">0%</span>
        <span class="stat-label">O-Level English pass rate</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="2">
        <span class="stat-number">6:1</span>
        <span class="stat-label">Maximum class size</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="3">
        <span class="stat-number" data-count="500" data-count-suffix="+">0+</span>
        <span class="stat-label">Students taught</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="4">
        <span class="stat-number">Law</span>
        <span class="stat-label">Graduate founder</span>
      </div>
    </div>
  </section>


  <!-- ===== TRUST STRIP ===== -->
  <section class="trust-strip">
    <div class="container trust-inner">
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span>4.9/5 from 50+ parent reviews</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>MOE-aligned curriculum</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>NUS Law graduate founder</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span>100% online via Zoom</span>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section id="about" class="section problem-section">
    <div class="container">
      <div class="problem-grid">
        <div class="problem-col" data-animate="reveal-up">
          <span class="eyebrow">The Problem</span>
          <h2 class="problem-heading">Most English tuition teaches content.<br/>Not thinking.</h2>
          <ul class="problem-list">
            <li>Students memorise model answers instead of learning how to reason</li>
            <li>Large class sizes mean generic, one-size-fits-all instruction</li>
            <li>No systematic framework — just "practise more papers"</li>
          </ul>
        </div>
        <div class="solution-col" data-animate="reveal-up" data-animate-delay="1">
          <span class="eyebrow">Our Approach</span>
          <h2 class="problem-heading">A-Worthy teaches students<br/>how to think.</h2>
          <ul class="solution-list">
            <li><strong>The CASE Method</strong> — a proprietary framework from legal reasoning</li>
            <li><strong>Max 6 students</strong> — every student gets individual attention</li>
            <li><strong>Structured mastery</strong> — not rote learning, but analytical precision</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMMES OVERVIEW ===== -->
  <section id="programmes" class="section programmes-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Programmes</span>
      <h2 class="section-heading" data-animate="reveal-up">Structured learning pathways for every stage</h2>

      <div class="programmes-grid">
        <a href="/programmes/#sec1-2" class="programme-card" data-animate="reveal-up" data-animate-delay="1">
          <div class="programme-body">
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 1&ndash;2 English Foundation</h3>
            <p>90-minute weekly sessions covering Paper 1 and Paper 2 skills. Build a strong analytical foundation in comprehension, composition, and language use.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 280/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#sec3-4" class="programme-card programme-card--popular" data-animate="reveal-up" data-animate-delay="2">
          <div class="programme-body">
            <span class="programme-popular-badge">Most Popular</span>
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 3&ndash;4 O-Level Intensive</h3>
            <p>90-minute exam-focused sessions with monthly mock grading. Master every O-Level English component with the CASE Method and targeted practice.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 320/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#one-to-one" class="programme-card" data-animate="reveal-up" data-animate-delay="3">
          <div class="programme-body">
            <span class="programme-level">Individual Online</span>
            <h3>One-to-One Coaching</h3>
            <p>Intensive exam prep or tailored support designed around your child's specific needs. Flexible scheduling with personalised feedback every session.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 120/session</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CASE FLOW DIAGRAM ===== -->
  <section class="section case-flow-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">How It Works</span>
      <h2 class="section-heading" data-animate="reveal-up">Every lesson follows the CASE Method</h2>
      <div class="case-flow" data-animate="reveal-up">
        <div class="case-flow-step">
          <div class="case-flow-icon">C</div>
          <h3>Contextualise</h3>
          <p>Identify the task and purpose</p>
        </div>
        <div class="case-flow-connector" aria-hidden="true">
          <svg width="40" height="24" viewBox="0 0 40 24"><path d="M0 12h32m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" fill="none"/></svg>
        </div>
        <div class="case-flow-step">
          <div class="case-flow-icon">A</div>
          <h3>Analyse</h3>
          <p>Read closely for meaning</p>
        </div>
        <div class="case-flow-connector" aria-hidden="true">
          <svg width="40" height="24" viewBox="0 0 40 24"><path d="M0 12h32m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" fill="none"/></svg>
        </div>
        <div class="case-flow-step">
          <div class="case-flow-icon">S</div>
          <h3>Structure</h3>
          <p>Organise and write</p>
        </div>
        <div class="case-flow-connector" aria-hidden="true">
          <svg width="40" height="24" viewBox="0 0 40 24"><path d="M0 12h32m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" fill="none"/></svg>
        </div>
        <div class="case-flow-step">
          <div class="case-flow-icon">E</div>
          <h3>Evaluate</h3>
          <p>Review and reflect</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== APPROACH ===== -->
  <section id="method" class="section approach-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">The CASE Method</span>
      <h2 class="section-heading" data-animate="reveal-up">Legal precision meets English mastery</h2>
      <p class="approach-subtitle">Our proprietary framework applies legal reasoning structures to every O-Level English component</p>

      <div class="approach-grid">
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="1">
          <div class="approach-card-header">
            <span class="approach-letter">C</span>
            <span class="approach-time">10 min</span>
          </div>
          <h3>Contextualise</h3>
          <p>Identify the task, purpose, audience, and text type. What is being asked? What kind of response is required? Just as lawyers issue-spot before applying any rule.</p>
        </div>
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="2">
          <div class="approach-card-header">
            <span class="approach-letter">A</span>
            <span class="approach-time">20 min</span>
          </div>
          <h3>Analyse</h3>
          <p>Read closely for explicit and implicit meaning, language technique, and writer's purpose. The analytical step is where marks are won or lost.</p>
        </div>
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="3">
          <div class="approach-card-header">
            <span class="approach-letter">S</span>
            <span class="approach-time">20 min</span>
          </div>
          <h3>Structure</h3>
          <p>Organise ideas into a coherent response. Build paragraphs with claim, evidence, and reasoned explanation. Structure is not decoration — it is the argument itself.</p>
        </div>
        <div class="approach-card" data-animate="reveal-up" data-animate-delay="4">
          <div class="approach-card-header">
            <span class="approach-letter">E</span>
            <span class="approach-time">10 min</span>
          </div>
          <h3>Evaluate</h3>
          <p>Review, revise, and reflect. Does the response address the question? Is the evidence well-chosen? Is the language precise? The deliberate checking of reasoning.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section id="reviews" class="section testimonials-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">What Families Say</span>
      <h2 class="section-heading" data-animate="reveal-up">Don't just take our word for it</h2>

      <div class="testimonials-grid">
        <div class="testimonial-card" data-animate="reveal-up" data-animate-delay="1">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "My son's English improved from C5 to A2 in just three months. The CASE Method gave him a systematic way to approach every comprehension question."
          </blockquote>
          <div class="testimonial-author">
            <div class="testimonial-initials">LT</div>
            <div>
              <strong>Mrs. Linda Tan</strong>
              <span>Mother of Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card testimonial-featured" data-animate="reveal-up" data-animate-delay="2">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "I used to hate essay writing. Now I actually enjoy it because I know how to structure my arguments properly."
          </blockquote>
          <div class="testimonial-author">
            <div class="testimonial-initials">EL</div>
            <div>
              <strong>Ethan Lim</strong>
              <span>Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card" data-animate="reveal-up" data-animate-delay="3">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "What impressed me most was how the legal reasoning approach made inference questions click for my daughter."
          </blockquote>
          <div class="testimonial-author">
            <div class="testimonial-initials">RK</div>
            <div>
              <strong>Mr. Rajesh Kumar</strong>
              <span>Father of Sec 3 student</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section faq-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Common Questions</span>
      <h2 class="section-heading" data-animate="reveal-up">What parents ask us</h2>
      <div class="faq-list">
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="1">
          <summary>How is A-Worthy different from other English tuition centres?</summary>
          <p>We use the CASE Method — a proprietary framework adapted from legal reasoning. Instead of memorising model answers, students learn structured analytical thinking that applies to every question type.</p>
        </details>
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="2">
          <summary>Why are classes online only?</summary>
          <p>Online delivery via Zoom lets us keep class sizes small (max 6) while keeping fees accessible. Every student gets screen-shared feedback on their work in real time — something difficult in a physical classroom of 15-20.</p>
        </details>
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="3">
          <summary>What if my child doesn't improve?</summary>
          <p>We offer a free diagnostic assessment before any commitment. If after 3 months your child hasn't shown measurable improvement, we'll work with you on a revised plan at no extra cost.</p>
        </details>
        <details class="faq-item" data-animate="reveal-up" data-animate-delay="4">
          <summary>How much does it cost?</summary>
          <p>Sec 1-2 Foundation: SGD 280/month. Sec 3-4 O-Level Intensive: SGD 320/month. One-to-One Coaching: SGD 120/session. All classes are 90 minutes weekly.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section id="contact" class="cta-section">
    <div class="container cta-inner">
      <span class="eyebrow" data-animate="reveal-up">Get Started</span>
      <h2 data-animate="reveal-up">Your child is A-Worthy</h2>
      <p>Book a free diagnostic assessment — a 20-minute session analysing your child's recent English paper</p>
      <a href="/contact/" class="btn btn-primary btn-lg">Book Free Assessment</a>
    </div>
  </section>

  <!-- Sticky Mobile CTA -->
  <div class="sticky-cta" id="sticky-cta">
    <a href="/contact/" class="btn btn-accent sticky-cta-btn">Book Free Trial Class</a>
    <button class="sticky-cta-dismiss" id="sticky-cta-dismiss" aria-label="Dismiss booking prompt">&times;</button>
  </div>

  <Footer />
</BaseLayout>

<script is:inline>
  // Show sticky CTA after scrolling past hero, with dismiss support
  (function() {
    const sticky = document.getElementById('sticky-cta');
    const dismissBtn = document.getElementById('sticky-cta-dismiss');
    if (!sticky) return;
    let dismissed = false;
    let ticking = false;
    window.addEventListener('scroll', function() {
      if (dismissed) return;
      if (!ticking) {
        requestAnimationFrame(function() {
          sticky.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.8);
          ticking = false;
        });
        ticking = true;
      }
    });
    dismissBtn?.addEventListener('click', function() {
      dismissed = true;
      sticky.classList.remove('is-visible');
    });
  })();
</script>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --section-bg: var(--bg-primary);
    --section-bg-alt: var(--bg-secondary);
    --card-bg: var(--bg-card);
    --accent: var(--color-accent);
    --on-dark: #ffffff;
    --on-dark-muted: rgba(255,255,255,0.7);
    --divider: var(--border-color);
    --on-dark-subtle: rgba(255,255,255,0.05);
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  /* ===== SECTION HEADING ===== */
  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 200;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: 2.5rem;
    max-width: 700px;
    letter-spacing: -0.03em;
  }

  /* ===== SECTION SPACING ===== */
  .section {
    padding: 6rem 0;
    background: var(--bg-primary);
    scroll-margin-top: var(--header-height);
  }

  .cta-section {
    scroll-margin-top: var(--header-height);
  }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    /* Use dvh for mobile browser chrome awareness */
    min-height: 100dvh;
    display: flex;
    align-items: center;
    background: var(--bg-primary);
    padding-top: var(--header-height);
    padding-bottom: 0;
    overflow: hidden;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(43, 90, 140, 0.15) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 20%, rgba(212, 133, 58, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-content {
    max-width: 560px;
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 200;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .proof-item {
    display: flex;
    flex-direction: column;
  }

  .proof-number {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 200;
    color: var(--text-primary);
  }

  .proof-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .proof-divider {
    width: 1px;
    height: 40px;
    background: var(--border-color);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .hero-intake {
    font-size: 0.8rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .hero-intake strong {
    color: var(--text-primary);
  }

  .hero-cta-primary {
    padding: 1rem 2.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 0;
    box-shadow: none;
    transition: all 0.3s ease;
  }

  .hero-cta-primary:hover {
    transform: none;
    box-shadow: none;
    background: #e8a060;
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
  }

  .btn-outline {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--text-primary);
    padding: 0.875rem 2rem;
    border-radius: 0;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-outline:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
  }

  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero-type-element {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .type-letter {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 8vw, 7rem);
    font-weight: 100;
    letter-spacing: -0.04em;
    line-height: 1;
    color: rgba(255, 255, 255, 0.08);
    text-shadow: 0 0 80px rgba(43, 90, 140, 0.3);
    transition: color 0.5s ease;
  }

  .type-dot {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    color: var(--text-muted);
    opacity: 0.3;
  }

  .hero-type-label {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-top: 0.75rem;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .hero-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 0;
    color: var(--text-muted);
    background: transparent;
  }

  /* ===== PROBLEM → SOLUTION ===== */
  .problem-section {
    background: var(--section-bg);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .problem-heading {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .problem-list, .solution-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .problem-list li {
    padding-left: 1.5rem;
    position: relative;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .problem-list li::before {
    content: '✕';
    position: absolute;
    left: 0;
    color: #c44;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .solution-list li {
    padding-left: 1.5rem;
    position: relative;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .solution-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.9rem;
  }

  /* ===== FAQ ===== */
  .faq-section {
    background: var(--section-bg);
  }

  .faq-list {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.5rem 0;
  }

  .faq-item summary {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-muted);
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    color: var(--text-secondary);
    margin-top: 1rem;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  /* ===== STICKY MOBILE CTA ===== */
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(11, 11, 15, 0.9);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    padding: 0.75rem var(--space-lg);
    /* Safe area for notched phones */
    padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    z-index: 100;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border-top: 1px solid var(--border-color);
  }

  .sticky-cta.is-visible {
    transform: translateY(0);
  }

  .sticky-cta-btn {
    flex: 1;
    text-align: center;
    display: block;
  }

  .sticky-cta-dismiss {
    position: absolute;
    top: 0.25rem;
    right: 0.5rem;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.25rem;
    line-height: 1;
  }

  .sticky-cta-dismiss:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .sticky-cta {
      display: block;
    }
    .problem-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .hero-badges {
      justify-content: center;
    }
  }

  .testimonial-initials {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(212, 133, 58, 0.1);
    border: 1px solid rgba(212, 133, 58, 0.2);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .programme-illustration {
    max-width: 100%;
    height: auto;
    margin-bottom: 1rem;
  }

  /* ===== STATS BAR ===== */
  .stats-bar {
    background: rgba(255, 255, 255, 0.02);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    padding: 4rem 0;
    backdrop-filter: blur(8px);
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .stat-item {
    flex: 1;
    text-align: center;
    padding: 0.5rem 1.5rem;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 200;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--divider);
    flex-shrink: 0;
  }

  /* ===== TRUST STRIP ===== */
  .trust-strip {
    background: rgba(255, 255, 255, 0.01);
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .trust-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .trust-divider {
    width: 1px;
    height: 16px;
    background: var(--border-color);
  }

  @media (max-width: 640px) {
    .trust-inner {
      gap: 1rem 1.5rem;
    }
    .trust-divider {
      display: none;
    }
  }

  /* ===== PROGRAMMES ===== */
  .programmes-section {
    background: var(--section-bg);
  }

  .programmes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .programme-card {
    display: block;
    text-decoration: none;
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  @media (hover: hover) {
    .programme-card:hover {
      background: var(--bg-card-hover);
      border-color: rgba(255, 255, 255, 0.12);
      transform: translateY(-4px);
    }
  }

  .programme-img-wrap {
    height: 200px;
    overflow: hidden;
  }

  .programme-img,
  .programme-img-wrap .placeholder-img {
    width: 100%;
    height: 100%;
    transition: transform 0.4s ease;
  }

  .programme-card:hover .programme-img,
  .programme-card:hover .programme-img-wrap .placeholder-img {
    transform: scale(1.04);
  }

  .programme-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .programme-level {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .programme-body h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .programme-body p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .programme-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--divider);
  }

  .programme-price {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .programme-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ===== POPULAR BADGE ===== */
  .programme-card--popular {
    border-color: rgba(212, 133, 58, 0.2);
    position: relative;
  }

  .programme-popular-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 0.3rem 0.75rem;
    border-radius: 0;
    margin-bottom: 0.75rem;
  }

  /* ===== APPROACH ===== */
  .approach-section {
    background: var(--section-bg-alt);
  }

  .approach-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 640px;
    margin-bottom: 2rem;
    margin-top: -1rem;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .approach-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: var(--space-xl);
    transition: all 0.4s ease;
  }

  @media (hover: hover) {
    .approach-card:hover {
      background: var(--bg-card-hover);
      border-color: rgba(255, 255, 255, 0.12);
    }
  }

  .approach-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .approach-letter {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 200;
    color: var(--color-accent);
  }

  .approach-time {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: var(--section-bg-alt);
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--divider);
  }

  .approach-card h3 {
    font-family: 'DM Sans', 'Inter', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .approach-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .approach-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ===== CASE FLOW DIAGRAM ===== */
  .case-flow-section {
    background: var(--bg-secondary);
  }

  .case-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin-top: 2rem;
  }

  .case-flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 0 auto;
    max-width: 160px;
  }

  .case-flow-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(43, 90, 140, 0.1);
    border: 1px solid rgba(43, 90, 140, 0.2);
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    box-shadow: none;
  }

  .case-flow-step h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .case-flow-step p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
  }

  .case-flow-connector {
    display: flex;
    align-items: center;
    padding-top: 1.25rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .case-flow {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .case-flow-connector {
      transform: rotate(90deg);
      padding-top: 0;
    }
    .case-flow-step {
      max-width: 200px;
    }
  }

  /* ===== TESTIMONIALS ===== */
  .testimonials-section {
    background: var(--section-bg);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2rem;
    transition: all 0.4s ease;
  }

  @media (hover: hover) {
    .testimonial-card:hover {
      background: var(--bg-card-hover);
      border-color: rgba(255, 255, 255, 0.12);
    }
  }

  .testimonial-stars {
    color: var(--color-accent);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .testimonial-card blockquote {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-style: normal;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--divider);
  }

  .testimonial-avatar,
  .testimonial-author .placeholder-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .testimonial-author strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .testimonial-author span {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  /* ===== CTA ===== */
  .cta-section {
    padding: 8rem 0;
    background: var(--bg-secondary);
    text-align: center;
    position: relative;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(212, 133, 58, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }

  .cta-section .eyebrow {
    display: inline-block;
  }

  .cta-section h2 {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  /* ===== BUTTON OVERRIDES ===== */
  .btn-primary {
    background: var(--accent);
    color: var(--on-dark);
    border: 1px solid var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .btn-primary:hover {
    background: #d4622e;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .btn-secondary:hover {
    border-color: var(--text-primary);
    transform: translateY(-1px);
  }

  .btn-lg {
    padding: 1rem 2.5rem;
    font-size: 0.9rem;
  }

  /* ===== MARQUEE ===== */
  .marquee {
    overflow: hidden;
    white-space: nowrap;
    background: var(--section-bg-alt);
    border-bottom: 1px solid var(--divider);
    padding: 1rem 0;
  }
  .marquee-inner {
    display: inline-flex;
    animation: marquee-scroll 30s linear infinite;
  }
  .marquee-item {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    padding: 0 2rem;
  }
  .marquee-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-right: 0.75rem;
    flex-shrink: 0;
  }
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ===== TESTIMONIAL FEATURED ===== */
  .testimonial-featured {
    border-color: rgba(212, 133, 58, 0.2);
    background: rgba(212, 133, 58, 0.03);
  }
  @media (max-width: 768px) {
    .testimonial-featured { transform: none; background: rgba(212, 133, 58, 0.03); }
  }

  /* ===== RESPONSIVE ===== */
  @media (min-width: 1024px) {
    .approach-scroll-track {
      overflow: visible;
      margin: 0;
      padding: 0;
    }
    .approach-scroll-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .approach-scroll-inner .approach-card {
      min-width: unset;
    }
  }

  @media (max-width: 1024px) {
    .programmes-grid,
    .testimonials-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }
    .hero-content {
      max-width: 100%;
    }
    .hero-proof {
      justify-content: center;
    }
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .hero-visual {
      order: -1;
    }
    .section {
      padding: 3rem 0;
    }

    .cta-section {
      padding: 3rem 0;
    }

    .stats-inner {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .stat-divider {
      display: none;
    }

    .stat-item {
      flex: 0 0 45%;
    }
  }

  @media (max-width: 640px) {
    .programmes-grid,
    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .stat-item {
