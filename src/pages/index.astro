    max-width: 700px;
    margin-bottom: 2rem;
  }
  .result-bar-item { display: flex; flex-direction: column; gap: 0.4rem; }
  .result-bar-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  .result-bar-pct {
