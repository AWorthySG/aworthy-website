    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    background: rgba(212,133,58,0.1);
    border: 1px solid rgba(212,133,58,0.2);
    border-radius: 4px;
    color: var(--color-accent);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }
  .form-errors {
    padding: 1rem;
    background: rgba(248,113,113,0.1);
    border: 1px solid rgba(248,113,113,0.2);
    border-radius: 4px;
    color: #f87171;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  .info-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-color);
  }
  .info-card:last-of-type { border-bottom: none; }
