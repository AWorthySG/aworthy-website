    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 2rem 0;
    margin-bottom: 3rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    background: var(--bg-card);
    backdrop-filter: blur(12px);
