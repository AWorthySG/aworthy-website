---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PenAnimation from '../components/PenAnimation.astro';
import '../styles/global.css';
---

<BaseLayout title="English, Maths, GP & Econs Tuition Singapore | A-Worthy" description="Singapore's top-rated tuition for O-Level English & Maths, H1 GP & H2 Economics. 90% A1–B3 rate, max 6 per class, NUS Law graduate tutor. Book a free assessment.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-depth-layer" aria-hidden="true"></div>

    <div class="hero-centre">
      <div class="hero-reveal-line hero-anim" style="--d:0">
        <span class="hero-kicker">Top-Rated O-Level English &amp; Maths, GP &amp; H2 Economics Tuition in Singapore</span>
      </div>
      <h1 class="hero-display">
        <span class="hero-prelude">
          <span class="hero-prelude-word" style="--i:0">You</span>
          <span class="hero-prelude-word" style="--i:1">are</span>
        </span>
        <span class="hero-tagline">
          <span class="hero-letter" style="--i:0">A</span>
          <span class="hero-letter hero-letter--space" style="--i:1">&nbsp;</span>
          <span class="hero-letter hero-letter--italic" style="--i:2">W</span>
          <span class="hero-letter hero-letter--italic" style="--i:3">o</span>
          <span class="hero-letter hero-letter--italic" style="--i:4">r</span>
          <span class="hero-letter hero-letter--italic" style="--i:5">t</span>
          <span class="hero-letter hero-letter--italic" style="--i:6">h</span>
          <span class="hero-letter hero-letter--italic" style="--i:7">y</span>
        </span>
        <span class="hero-underline" aria-hidden="true"></span>
      </h1>
      <p class="hero-sub hero-anim" style="--d:10">Your child studies hard but their grades don&rsquo;t move. They know the content &mdash; they just can&rsquo;t show it under exam pressure. SHARP gives them a five-step system to see what the question wants, pick the right framework, and write answers that score &mdash; across O-Level English &amp; Maths, H1 General Paper, and H2 Economics.</p>

      <div class="hero-proof-row hero-anim" style="--d:12">
        <div class="hero-proof-item">
          <span class="hero-proof-num">90%</span>
          <span class="hero-proof-lbl">A1–B3 rate</span>
        </div>
        <div class="hero-proof-item">
          <span class="hero-proof-num">127</span>
          <span class="hero-proof-lbl">5-star reviews</span>
        </div>
        <div class="hero-proof-item">
          <span class="hero-proof-num">6</span>
          <span class="hero-proof-lbl">max class size</span>
        </div>
      </div>

      <div class="hero-google-wrap hero-anim" style="--d:13">
        <a class="google-badge" href="https://g.page/r/aworthy-sg/review" target="_blank" rel="noopener noreferrer" aria-label="Google rating 4.9 stars across 127 reviews">
          <span class="gb-rating">4.9</span>
          <span class="gb-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="gb-meta">Google &middot; 127 reviews</span>
        </a>
      </div>

      <p class="hero-intake hero-anim" style="--d:14">Next intake: <strong>Term 3, July 2026</strong> &mdash; secure a seat before the O/A-Level run-in. Limited slots.</p>
      <p class="hero-pricing-note hero-anim" style="--d:14">Transparent fees from <strong>S$280/mo</strong> &mdash; no registration fee, all materials included. <a href="/pricing/">See full pricing &rarr;</a></p>

      <div class="hero-btns hero-anim" style="--d:15">
        <a href="/#contact" class="btn btn-accent hero-cta-primary">Book Free Assessment</a>
        <a href="https://wa.me/6583384033" class="btn btn-outline hero-cta-secondary" target="_blank" rel="noopener noreferrer">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 6px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>

      <div class="hero-badges-row hero-anim" style="--d:17">
        <span class="hero-badge">MOE-Aligned</span>
        <span class="hero-badge">100% Online via Zoom</span>
        <span class="hero-badge">NUS Law Graduate Founder</span>
      </div>

      <div class="audience-toggle hero-anim" style="--d:7" role="tablist" aria-label="View content for">
        <button class="audience-btn active" data-audience="parent" role="tab" aria-selected="true" aria-controls="msg-parent" id="tab-parent">I'm a Parent</button>
        <button class="audience-btn" data-audience="student" role="tab" aria-selected="false" aria-controls="msg-student" id="tab-student">I'm a Student</button>
      </div>
      <div class="audience-msg audience-msg--parent" id="msg-parent" role="tabpanel" aria-labelledby="tab-parent">
        <p><strong>For parents:</strong> See your child's grades improve with SHARP &mdash; our five-step method that deploys paper-matched frameworks. Monthly progress reports, small classes of 6, and a free diagnostic assessment to start.</p>
      </div>
      <div class="audience-msg audience-msg--student" id="msg-student" role="tabpanel" aria-labelledby="tab-student" hidden>
        <p><strong>For students:</strong> Stop memorising, start recognising. SHARP gives you a five-step process &mdash; See, Hit, Apply, Refine, Practise. At step H you pick the right framework (Core Move, CAPS, P-E-E-L) for that specific question type.</p>
      </div>
    </div>

    <div class="hero-scroll-cue" aria-hidden="true">
      <span>Scroll</span>
      <div class="hero-scroll-line"></div>
    </div>
  </section>

  <!-- ===== STATS BAR with Story Context (#14) ===== -->
  <section class="stats-bar section--sand">
    <div class="container stats-inner">
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="1">
        <span class="stat-number" data-count="90" data-count-suffix="%">90%</span>
        <span class="stat-label">A1–B3 Rate</span>
        <span class="stat-story">Our O-Level English students consistently outperform national averages</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="2">
        <span class="stat-number">6</span>
        <span class="stat-label">Maximum class size</span>
        <span class="stat-story">Small group tuition with personalised feedback every session</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="3">
        <span class="stat-number" data-count="500" data-count-suffix="+">500+</span>
        <span class="stat-label">Students taught</span>
        <span class="stat-story">From Secondary 1 through JC 2 across Singapore</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="reveal-up" data-animate-delay="4">
        <span class="stat-number">Law</span>
        <span class="stat-label">Graduate founder</span>
        <span class="stat-story">NUS Law &mdash; the foundation of our SHARP Method</span>
      </div>
    </div>
  </section>

  <section id="programmes" class="section section--sand programmes-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Programmes</span>
      <h2 class="section-heading" data-animate="reveal-up">Tuition programmes for every level &mdash; Sec 1 to JC 2</h2>

      <div class="programmes-grid">
        <a href="/o-level-english/" class="programme-card programme-card--popular" data-animate="reveal-up" data-animate-delay="1">
          <div class="programme-card-illustration">
            <img src="/images/illustration-english.svg" alt="O-Level English tuition in Singapore — Secondary 1 to 4" width="400" height="240" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-popular-badge">Most Popular</span>
            <span class="programme-level">Sec 1 &ndash; 4</span>
            <h3>O-Level English</h3>
            <p>Comprehensive O-Level English tuition for Secondary 1&ndash;4. Master comprehension, composition, oral, and editing with our proprietary SHARP Method.</p>
            <div class="programme-meta">
              <span class="programme-price">From SGD 280/month</span>
              <span class="programme-link">View O-Level English &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/h1-general-paper/" class="programme-card" data-animate="reveal-up" data-animate-delay="2">
          <div class="programme-card-illustration">
            <img src="/images/illustration-gp.svg" alt="H1 General Paper tuition in Singapore — JC 1 and JC 2" width="400" height="240" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-level">JC 1 &ndash; 2</span>
            <h3>H1 General Paper</h3>
            <p>A-Level General Paper tuition using the SHARP Method&rsquo;s legal-analytical framework. Build argumentation, critical reading, and essay writing skills that examiners reward.</p>
            <div class="programme-meta">
              <span class="programme-price">From SGD 360/month</span>
              <span class="programme-link">View H1 General Paper &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/o-level-mathematics/" class="programme-card programme-card--new" data-animate="reveal-up" data-animate-delay="3">
          <div class="programme-card-illustration">
            <img src="/images/illustration-maths.svg" alt="O-Level Mathematics tuition in Singapore — Secondary 1 to 4" width="400" height="240" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-new-badge">New</span>
            <span class="programme-level">Sec 1 &ndash; 4</span>
            <h3>O-Level Mathematics</h3>
            <p>O-Level Mathematics tuition using the SHARP Method. Master algebra, geometry, trigonometry, functions, and statistics with named frameworks for every question type.</p>
            <div class="programme-meta">
              <span class="programme-price">From SGD 280/month</span>
              <span class="programme-link">View O-Level Maths &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/pre-ib-mathematics/" class="programme-card programme-card--new" data-animate="reveal-up" data-animate-delay="4">
          <div class="programme-card-illustration">
            <img src="/images/illustration-maths.svg" alt="Pre-IB Mathematics tuition in Singapore — Year 3 and Year 4" width="400" height="240" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-new-badge">New</span>
            <span class="programme-level">Year 3 &ndash; 4</span>
            <h3>Pre-IB Mathematics</h3>
            <p>Pre-IB Mathematics tuition for Year 3 &amp; Year 4. From indices and surds to logarithms and an introduction to calculus &mdash; taught with the SHARP Method and annotated, line-by-line working that IB examiners reward.</p>
            <div class="programme-meta">
              <span class="programme-price">From SGD 280/month</span>
              <span class="programme-link">View Pre-IB Maths &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/h2-economics/" class="programme-card" data-animate="reveal-up" data-animate-delay="5">
          <div class="programme-card-illustration">
            <img src="/images/illustration-econs.svg" alt="H2 Economics tuition in Singapore — A-Level JC 1 and JC 2" width="400" height="240" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-level">JC 1 &ndash; 2</span>
            <h3>H2 Economics</h3>
            <p>Rigorous H2 Economics tuition covering micro and macroeconomics. Diagram precision, essay technique, and case study mastery for the full A-Level 9570 syllabus.</p>
            <div class="programme-meta">
              <span class="programme-price">From SGD 360/month</span>
              <span class="programme-link">View H2 Economics &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/" class="programme-card" data-animate="reveal-up" data-animate-delay="6">
          <div class="programme-card-illustration">
            <img src="/images/illustration-coaching.svg" alt="One-to-one coaching for O-Level English, Maths, GP and H2 Economics" width="400" height="240" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-level">All Subjects</span>
            <h3>One-to-One Coaching</h3>
            <p>Intensive one-to-one tuition tailored to your child&rsquo;s specific gaps. Flexible scheduling with personalised feedback every session &mdash; ideal for targeted exam preparation.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 120&ndash;140/session</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>
      </div>

      <p class="programmes-pricing-link" data-animate="reveal-up"><a href="/pricing/">Compare all plans &amp; fees &mdash; transparent, all-inclusive &rarr;</a></p>

      <!-- Programme Selector Quiz (#8) -->
      <div class="quiz-section" data-animate="reveal-up">
        <div class="quiz-card">
          <span class="eyebrow">Not Sure Which Programme?</span>
          <h3 class="quiz-heading">Find the right programme in 30 seconds</h3>
          <div class="quiz-body" id="programme-quiz">
            <div class="quiz-step" data-step="1">
              <p class="quiz-question">What level is your child in?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="sec1-2" data-next="1a">Sec 1 or 2</button>
                <button class="quiz-option" data-value="sec3-4" data-next="1a">Sec 3 or 4</button>
                <button class="quiz-option" data-value="jc" data-next="1b">JC 1 or 2</button>
              </div>
            </div>
            <div class="quiz-step" data-step="1a" hidden>
              <p class="quiz-question">Which subject?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="english" data-next="2">O-Level English</button>
                <button class="quiz-option" data-value="maths" data-next="2">O-Level Mathematics</button>
              </div>
            </div>
            <div class="quiz-step" data-step="1b" hidden>
              <p class="quiz-question">Which subject?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="gp" data-next="2">H1 General Paper</button>
                <button class="quiz-option" data-value="econs" data-next="2">H2 Economics</button>
              </div>
            </div>
            <div class="quiz-step" data-step="2" hidden>
              <p class="quiz-question">What's the biggest challenge?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="comprehension" data-next="3">Comprehension & inference</button>
                <button class="quiz-option" data-value="writing" data-next="3">Essay writing & structure</button>
                <button class="quiz-option" data-value="overall" data-next="3">Overall grade improvement</button>
              </div>
            </div>
            <div class="quiz-step" data-step="3" hidden>
              <p class="quiz-question">What kind of support does your child need?</p>
              <div class="quiz-options">
                <button class="quiz-option" data-value="group" data-next="result">Small group learning</button>
                <button class="quiz-option" data-value="individual" data-next="result">Individual attention</button>
              </div>
            </div>
            <div class="quiz-result" id="quiz-result" hidden>
              <div class="quiz-result-icon">&#10003;</div>
              <h4 class="quiz-result-heading" id="quiz-result-title"></h4>
              <p class="quiz-result-desc" id="quiz-result-desc"></p>
              <a href="/programmes/" class="btn btn-accent quiz-result-cta" id="quiz-result-link">View Programme Details</a>
              <button class="quiz-restart" id="quiz-restart">Start again</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MEET YOUR TUTOR ===== -->
  <section class="section founder-band">
    <div class="container">
      <div class="founder-band__inner" data-animate="reveal-up">
        <div class="founder-band__avatar" aria-hidden="true"><span>JL</span></div>
        <div class="founder-band__body">
          <span class="eyebrow">Meet Your Tutor</span>
          <h2 class="founder-band__title">A lawyer&rsquo;s rigour, turned into a method your child can follow</h2>
          <p class="founder-band__lead">A-Worthy was founded by <strong>Jeremy Lim</strong> after a career in corporate law. He built the SHARP Method (See, Hit, Apply, Refine, Practise) to distil the analytical discipline of legal training into a five-step system &mdash; so students stop guessing and start answering exactly what each question is asking for.</p>
          <ul class="founder-band__creds">
            <li>LLB (Hons), NUS Faculty of Law</li>
            <li>500+ students taught</li>
            <li>Creator of the SHARP Method</li>
          </ul>
          <a href="/about/" class="founder-band__link">Read Jeremy&rsquo;s story &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <section id="reviews" class="section section--sand testimonials-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">What Families Say</span>
      <h2 class="section-heading" data-animate="reveal-up">What Singapore parents and students say about our tuition</h2>

      <div class="testimonials-grid">
        <div class="testimonial-card card--elevated" data-animate="reveal-up" data-animate-delay="1">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "My son's English improved from C5 to A2 in just three months. At the See step, he learned to spot inference traps he'd been falling for. The SHARP Method gave him a systematic way to approach every comprehension question."
          </blockquote>
          <div class="testimonial-author">
            <div class="testimonial-avatar-circle" style="--avatar-hue: 30">
              <span>LT</span>
            </div>
            <div>
              <strong>Mrs. Linda Tan</strong>
              <span>Mother of Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card testimonial-featured card--elevated" data-animate="reveal-up" data-animate-delay="2">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "I used to hate essay writing. The Hit step taught me to pick the right essay framework before I start writing. Now I actually enjoy it because I know how to structure my arguments properly."
          </blockquote>
          <div class="testimonial-author">
            <div class="testimonial-avatar-circle" style="--avatar-hue: 210">
              <span>EL</span>
            </div>
            <div>
              <strong>Ethan Lim</strong>
              <span>Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card card--elevated" data-animate="reveal-up" data-animate-delay="3">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "What impressed me most was how SHARP's See-then-Hit approach made inference questions click for my daughter. She now reads the question, identifies the type, and picks a framework before she even looks at the passage."
          </blockquote>
          <div class="testimonial-author">
            <div class="testimonial-avatar-circle" style="--avatar-hue: 150">
              <span>RK</span>
            </div>
            <div>
              <strong>Mr. Rajesh Kumar</strong>
              <span>Father of Sec 3 student</span>
            </div>
          </div>
        </div>
      </div>

      <div class="reviews-cta" data-animate="reveal-up">
        <a href="https://g.page/r/aworthy-sg/review" target="_blank" rel="noopener noreferrer" class="reviews-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Read all 127 reviews on Google
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>

      <div class="transformations" data-animate="reveal-up">
        <h3 class="transformations__title">Recent grade transformations</h3>
        <div class="transformations__grid">
          <a class="transformation-card" href="/success-stories/">
            <span class="transformation-card__jump"><span class="transformation-card__before">D7</span><span class="transformation-card__arrow">&rarr;</span><span class="transformation-card__after">B3</span></span>
            <span class="transformation-card__meta">O-Level English &middot; 4 months</span>
            <span class="transformation-card__quote">&ldquo;I went from failing English to actually looking forward to the exam.&rdquo;</span>
          </a>
          <a class="transformation-card" href="/success-stories/">
            <span class="transformation-card__jump"><span class="transformation-card__before">U</span><span class="transformation-card__arrow">&rarr;</span><span class="transformation-card__after">B</span></span>
            <span class="transformation-card__meta">H1 General Paper &middot; 6 months</span>
            <span class="transformation-card__quote">&ldquo;GP felt like a guessing game until the frameworks made every question answerable.&rdquo;</span>
          </a>
          <a class="transformation-card" href="/success-stories/">
            <span class="transformation-card__jump"><span class="transformation-card__before">U</span><span class="transformation-card__arrow">&rarr;</span><span class="transformation-card__after">A</span></span>
            <span class="transformation-card__meta">H2 Economics &middot; 8 months</span>
            <span class="transformation-card__quote">&ldquo;I went from blank-staring at case studies to actually enjoying them.&rdquo;</span>
          </a>
        </div>
        <a href="/success-stories/" class="transformations__link">See all student transformations &rarr;</a>
      </div>
    </div>
  </section>

  <section id="results" class="section results-section">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Results</span>
      <h2 class="section-heading" data-animate="reveal-up">Proven tuition results across O-Level English, GP &amp; Economics</h2>

      <div class="results-stats" data-animate="reveal-up">
        <div class="result-stat">
          <span class="result-stat-number" data-count="90" data-count-suffix="%">90%</span>
          <span class="result-stat-label">A1–B3 Rate</span>
        </div>
        <div class="result-stat-divider"></div>
        <div class="result-stat">
          <span class="result-stat-number">6</span>
          <span class="result-stat-label">Max Class Size</span>
