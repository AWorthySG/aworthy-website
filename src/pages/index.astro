---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="A-Worthy — Singapore's First Analytical English Tuition">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg">
      <div class="placeholder-img hero-placeholder"></div>
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-inner">
      <span class="eyebrow">Singapore's First Analytical English Tuition</span>
      <h1 class="hero-heading">Think sharper. Write stronger. Score higher.</h1>
      <p class="hero-subtitle">
        A-Worthy is Singapore's first analytical English tuition programme, founded by a law graduate who brings the precision of legal reasoning to help secondary students master O-Level English.
      </p>
      <div class="hero-actions">
        <a href="/contact/" class="btn btn-primary">Book a Free Trial</a>
        <a href="#approach" class="btn btn-secondary">The CASE Method</a>
      </div>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat-item">
        <span class="stat-number">95%</span>
        <span class="stat-label">O-Level English pass rate</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">6:1</span>
        <span class="stat-label">Maximum class size</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">500+</span>
        <span class="stat-label">Students taught</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">Law</span>
        <span class="stat-label">Graduate founder</span>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMMES OVERVIEW ===== -->
  <section class="section programmes-section">
    <div class="container">
      <span class="eyebrow">Our Programmes</span>
      <h2 class="section-heading">Structured learning pathways for every stage</h2>

      <div class="programmes-grid">
        <a href="/programmes/#foundation" class="programme-card">
          <div class="programme-body">
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 1&ndash;2 English Foundation</h3>
            <p>90-minute weekly sessions covering Paper 1 and Paper 2 skills. Build a strong analytical foundation in comprehension, composition, and language use.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 280/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#intensive" class="programme-card">
          <div class="programme-body">
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 3&ndash;4 O-Level Intensive</h3>
            <p>90-minute exam-focused sessions with monthly mock grading. Master every O-Level English component with the CASE Method and targeted practice.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 320/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#coaching" class="programme-card">
          <div class="programme-body">
            <span class="programme-level">Individual Online</span>
            <h3>One-to-One Coaching</h3>
            <p>Intensive exam prep or tailored support designed around your child's specific needs. Flexible scheduling with personalised feedback every session.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 120/session</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== APPROACH ===== -->
  <section id="approach" class="section approach-section">
    <div class="container">
      <span class="eyebrow">The CASE Method</span>
      <h2 class="section-heading">Legal precision meets English mastery</h2>
      <p class="approach-subtitle">Our proprietary framework applies legal reasoning structures to every O-Level English component</p>

      <div class="approach-grid">
        <div class="approach-card">
          <span class="approach-number">C</span>
          <h3>Contextualise</h3>
          <p>Identify the task, purpose, audience, and text type. What is being asked? What kind of response is required? Just as lawyers issue-spot before applying any rule.</p>
        </div>
        <div class="approach-card">
          <span class="approach-number">A</span>
          <h3>Analyse</h3>
          <p>Read closely for explicit and implicit meaning, language technique, and writer's purpose. The analytical step is where marks are won or lost.</p>
        </div>
        <div class="approach-card">
          <span class="approach-number">S</span>
          <h3>Structure</h3>
          <p>Organise ideas into a coherent response. Build paragraphs with claim, evidence, and reasoned explanation. Structure is not decoration — it is the argument itself.</p>
        </div>
        <div class="approach-card">
          <span class="approach-number">E</span>
          <h3>Evaluate</h3>
          <p>Review, revise, and reflect. Does the response address the question? Is the evidence well-chosen? Is the language precise? The deliberate checking of reasoning.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section testimonials-section">
    <div class="container">
      <span class="eyebrow">What Families Say</span>
      <h2 class="section-heading">Don't just take our word for it</h2>

      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "My son's English improved from C5 to A2 in just three months. The CASE Method gave him a systematic way to approach every comprehension question."
          </blockquote>
          <div class="testimonial-author">
            <div class="placeholder-avatar">LT</div>
            <div>
              <strong>Mrs. Linda Tan</strong>
              <span>Mother of Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "I used to hate essay writing. Now I actually enjoy it because I know how to structure my arguments properly."
          </blockquote>
          <div class="testimonial-author">
            <div class="placeholder-avatar">EL</div>
            <div>
              <strong>Ethan Lim</strong>
              <span>Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "What impressed me most was how the legal reasoning approach made inference questions click for my daughter."
          </blockquote>
          <div class="testimonial-author">
            <div class="placeholder-avatar">RK</div>
            <div>
              <strong>Mr. Rajesh Kumar</strong>
              <span>Father of Sec 3 student</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container cta-inner">
      <span class="eyebrow">Get Started</span>
      <h2>Your child is A-Worthy</h2>
      <p>Book a free diagnostic assessment — a 20-minute session analysing your child's recent English paper</p>
      <a href="/contact/" class="btn btn-primary btn-lg">Book Free Assessment</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --dark-bg: var(--bg-primary);
    --dark-bg-lighter: #323538;
    --dark-bg-card: #2f3134;
    --accent-orange: var(--color-accent);
    --white: #ffffff;
    --white-60: var(--text-secondary);
    --white-10: var(--border-color);
    --white-05: var(--bg-secondary);
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: block;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-orange);
    margin-bottom: 1rem;
  }

  /* ===== SECTION HEADING ===== */
  .section-heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 3.5rem;
    max-width: 640px;
    letter-spacing: -0.02em;
  }

  /* ===== SECTION SPACING ===== */
  .section {
    padding: 7rem 0;
    background: var(--dark-bg);
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== PLACEHOLDER IMAGES ===== */
  .placeholder-img {
    background: var(--bg-secondary);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--border-color);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px dashed var(--border-color);
  }

  .hero-placeholder {
    position: absolute;
    inset: 0;
    aspect-ratio: auto;
    font-size: 0;
    color: transparent;
  }

  .placeholder-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-primary-light);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(42, 44, 47, 0.75) 0%,
      rgba(42, 44, 47, 0.90) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
    padding-bottom: 5rem;
    max-width: 800px;
  }

  .hero .eyebrow {
    margin-bottom: 1.5rem;
  }

  .hero-heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.75rem;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--white-60);
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ===== STATS BAR ===== */
  .stats-bar {
    background: var(--dark-bg-lighter);
    border-top: 1px solid var(--white-10);
    border-bottom: 1px solid var(--white-10);
    padding: 2.5rem 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .stat-item {
    flex: 1;
    text-align: center;
    padding: 0.5rem 1.5rem;
  }

  .stat-number {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--white-60);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--white-10);
    flex-shrink: 0;
  }

  /* ===== PROGRAMMES ===== */
  .programmes-section {
    background: var(--dark-bg);
  }

  .programmes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .programme-card {
    display: flex;
    flex-direction: column;
    background: var(--dark-bg-card);
    border: 1px solid var(--white-10);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: var(--white);
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .programme-card:hover {
    transform: scale(0.98);
    border-color: var(--accent-orange);
  }

  .programme-img-wrap {
    height: 200px;
    overflow: hidden;
  }

  .programme-img,
  .programme-img-wrap .placeholder-img {
    width: 100%;
    height: 100%;
    transition: transform 0.4s ease;
  }

  .programme-card:hover .programme-img,
  .programme-card:hover .programme-img-wrap .placeholder-img {
    transform: scale(1.04);
  }

  .programme-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .programme-level {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-orange);
    margin-bottom: 0.5rem;
  }

  .programme-body h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .programme-body p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--white-60);
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .programme-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--white-10);
  }

  .programme-price {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
  }

  .programme-link {
    font-size: 0.85rem;
    color: var(--accent-orange);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ===== APPROACH ===== */
  .approach-section {
    background: var(--dark-bg-lighter);
  }

  .approach-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--white-60);
    max-width: 640px;
    margin-bottom: 3.5rem;
    margin-top: -2rem;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .approach-card {
    background: var(--dark-bg);
    border: 1px solid var(--white-10);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .approach-card:hover {
    transform: scale(0.98);
    border-color: var(--accent-orange);
  }

  .approach-number {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--white);
    opacity: 0.12;
    line-height: 1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .approach-card h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .approach-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--white-60);
  }

  /* ===== TESTIMONIALS ===== */
  .testimonials-section {
    background: var(--dark-bg);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--dark-bg-card);
    border: 1px solid var(--white-10);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .testimonial-card:hover {
    transform: scale(0.98);
    border-color: var(--accent-orange);
  }

  .testimonial-stars {
    color: var(--accent-orange);
    font-size: 1rem;
    letter-spacing: 2px;
    margin-bottom: 1.25rem;
  }

  .testimonial-card blockquote {
    font-size: 0.95rem;
    font-style: normal;
    line-height: 1.7;
    color: var(--white-60);
    margin: 0 0 1.5rem 0;
    padding: 0;
    border: none;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--white-10);
  }

  .testimonial-avatar,
  .testimonial-author .placeholder-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .testimonial-author strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
  }

  .testimonial-author span {
    font-size: 0.8rem;
    color: var(--white-60);
  }

  /* ===== CTA ===== */
  .cta-section {
    background: var(--dark-bg-lighter);
    border-top: 1px solid var(--white-10);
    padding: 7rem 0;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-section .eyebrow {
    display: inline-block;
  }

  .cta-section h2 {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--white);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    color: var(--white-60);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  /* ===== BUTTON OVERRIDES ===== */
  .btn-primary {
    background: var(--accent-orange);
    color: var(--white);
    border: 1px solid var(--accent-orange);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .btn-primary:hover {
    background: #d4622e;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 1px solid var(--white-10);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .btn-secondary:hover {
    border-color: var(--white);
    transform: translateY(-1px);
  }

  .btn-lg {
    padding: 1rem 2.5rem;
    font-size: 0.9rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .programmes-grid,
    .testimonials-grid {
      grid-template-columns: 1fr 1fr;
    }

    .approach-grid {
      grid-template-columns: 1fr 1fr;
    }

    .hero-heading {
      font-size: clamp(2.25rem, 5vw, 3.5rem);
    }
  }

  @media (max-width: 768px) {
    .section {
      padding: 5rem 0;
    }

    .cta-section {
      padding: 5rem 0;
    }

    .stats-inner {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .stat-divider {
      display: none;
    }

    .stat-item {
      flex: 0 0 45%;
    }
  }

  @media (max-width: 640px) {
    .programmes-grid,
    .testimonials-grid,
    .approach-grid {
      grid-template-columns: 1fr;
    }

    .hero-inner {
      padding-top: 6rem;
      padding-bottom: 3rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      text-align: center;
    }

    .stat-item {
      flex: 0 0 100%;
    }

    .section-heading {
      font-size: 1.75rem;
      margin-bottom: 2.5rem;
    }
  }
</style>
