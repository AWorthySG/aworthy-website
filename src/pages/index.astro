---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="A Worthy — Singapore's Premier Tuition Centre">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/heroes/hero-students.jpg" alt="" class="hero-bg-img" loading="eager" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-inner">
      <span class="eyebrow">Singapore's Premier Tuition Centre</span>
      <h1 class="hero-heading">Building the next generation of achievers</h1>
      <p class="hero-subtitle">
        Expert tuition in Mathematics, Science, and English for Primary, Secondary, and JC students.
        Small class sizes. Proven MOE-aligned methods. Results that speak for themselves.
      </p>
      <div class="hero-actions">
        <a href="/programmes/" class="btn btn-primary">View Our Programmes</a>
        <a href="/testimonials/" class="btn btn-secondary">Our Results</a>
      </div>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat-item">
        <span class="stat-number">95%</span>
        <span class="stat-label">PSLE A/A*</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">8:1</span>
        <span class="stat-label">Student Ratio</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">500+</span>
        <span class="stat-label">Students Taught</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">10+</span>
        <span class="stat-label">Years Experience</span>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMMES OVERVIEW ===== -->
  <section class="section programmes-section">
    <div class="container">
      <span class="eyebrow">Our Programmes</span>
      <h2 class="section-heading">Structured learning pathways for every stage</h2>

      <div class="programmes-grid">
        <a href="/programmes/#primary" class="programme-card">
          <div class="programme-img-wrap">
            <img src="/images/programmes/primary-students.jpg" alt="Primary school students learning" class="programme-img" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-level">Primary</span>
            <h3>P3 &ndash; P6</h3>
            <p>Build strong foundations in Mathematics, Science, and English with hands-on learning and PSLE-focused preparation.</p>
            <div class="programme-meta">
              <span class="programme-price">From $240/mo</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#secondary" class="programme-card">
          <div class="programme-img-wrap">
            <img src="/images/programmes/secondary-students.jpg" alt="Secondary school students in class" class="programme-img" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-level">Secondary</span>
            <h3>Sec 1 &ndash; 4/5</h3>
            <p>Master complex topics with structured revision, exam techniques, and consistent practice for O-Level and N-Level success.</p>
            <div class="programme-meta">
              <span class="programme-price">From $280/mo</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#jc" class="programme-card">
          <div class="programme-img-wrap">
            <img src="/images/programmes/jc-students.jpg" alt="Junior college students studying" class="programme-img" loading="lazy" />
          </div>
          <div class="programme-body">
            <span class="programme-level">Junior College</span>
            <h3>JC 1 &ndash; 2</h3>
            <p>Tackle H1 and H2 subjects with rigorous content mastery, past-year paper drills, and expert guidance from experienced JC tutors.</p>
            <div class="programme-meta">
              <span class="programme-price">From $360/mo</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== APPROACH ===== -->
  <section class="section approach-section">
    <div class="container">
      <span class="eyebrow">Our Approach</span>
      <h2 class="section-heading">A four-step method that turns struggle into mastery</h2>

      <div class="approach-grid">
        <div class="approach-card">
          <span class="approach-number">01</span>
          <h3>Diagnose</h3>
          <p>We start with a comprehensive diagnostic assessment to identify each student's knowledge gaps, learning style, and areas of strength.</p>
        </div>
        <div class="approach-card">
          <span class="approach-number">02</span>
          <h3>Build</h3>
          <p>Concepts are taught from the ground up using clear explanations, real-world examples, and visual aids — ensuring genuine understanding, not memorisation.</p>
        </div>
        <div class="approach-card">
          <span class="approach-number">03</span>
          <h3>Practise</h3>
          <p>Students tackle curated worksheets and past-year exam papers with increasing difficulty, building speed, accuracy, and exam confidence.</p>
        </div>
        <div class="approach-card">
          <span class="approach-number">04</span>
          <h3>Excel</h3>
          <p>We push students beyond the syllabus with challenging problems, timed mock exams, and one-to-one coaching to ensure peak performance on exam day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section testimonials-section">
    <div class="container">
      <span class="eyebrow">What Families Say</span>
      <h2 class="section-heading">Don't just take our word for it</h2>

      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "My son went from a C5 in Maths to an A2 in just 8 months. The tutors at A Worthy are incredibly patient and really know the O-Level syllabus inside out."
          </blockquote>
          <div class="testimonial-author">
            <img src="/images/avatars/avatar-linda.jpg" alt="" class="testimonial-avatar" loading="lazy" />
            <div>
              <strong>Mrs. Linda Tan</strong>
              <span>Mother of Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "I scored AL1 for both Maths and Science at PSLE! Thank you, Teacher Jason, for always believing in me and making lessons so fun."
          </blockquote>
          <div class="testimonial-author">
            <img src="/images/avatars/avatar-ethan.jpg" alt="" class="testimonial-avatar" loading="lazy" />
            <div>
              <strong>Ethan Lim</strong>
              <span>P6 student, PSLE 2025</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "The small class sizes made all the difference. My daughter is no longer afraid of Chemistry, and she even enjoys going to tuition now!"
          </blockquote>
          <div class="testimonial-author">
            <img src="/images/avatars/avatar-rajesh.jpg" alt="" class="testimonial-avatar" loading="lazy" />
            <div>
              <strong>Mr. Rajesh Kumar</strong>
              <span>Father of Sec 3 student</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container cta-inner">
      <span class="eyebrow">Get Started</span>
      <h2>Your child's potential is limitless</h2>
      <p>Book a free diagnostic assessment and trial lesson. No obligations, no pressure.</p>
      <a href="/contact/" class="btn btn-primary btn-lg">Get a Free Assessment</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --dark-bg: #2a2c2f;
    --dark-bg-lighter: #323538;
    --dark-bg-card: #2f3134;
    --accent-orange: #e8713a;
    --white: #ffffff;
    --white-60: rgba(255, 255, 255, 0.6);
    --white-10: rgba(255, 255, 255, 0.1);
    --white-05: rgba(255, 255, 255, 0.05);
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: block;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-orange);
    margin-bottom: 1rem;
  }

  /* ===== SECTION HEADING ===== */
  .section-heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 3.5rem;
    max-width: 640px;
    letter-spacing: -0.02em;
  }

  /* ===== SECTION SPACING ===== */
  .section {
    padding: 7rem 0;
    background: var(--dark-bg);
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(42, 44, 47, 0.75) 0%,
      rgba(42, 44, 47, 0.90) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
    padding-bottom: 5rem;
    max-width: 800px;
  }

  .hero .eyebrow {
    margin-bottom: 1.5rem;
  }

  .hero-heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.75rem;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--white-60);
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ===== STATS BAR ===== */
  .stats-bar {
    background: var(--dark-bg-lighter);
    border-top: 1px solid var(--white-10);
    border-bottom: 1px solid var(--white-10);
    padding: 2.5rem 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .stat-item {
    flex: 1;
    text-align: center;
    padding: 0.5rem 1.5rem;
  }

  .stat-number {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--white-60);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--white-10);
    flex-shrink: 0;
  }

  /* ===== PROGRAMMES ===== */
  .programmes-section {
    background: var(--dark-bg);
  }

  .programmes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .programme-card {
    display: flex;
    flex-direction: column;
    background: var(--dark-bg-card);
    border: 1px solid var(--white-10);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: var(--white);
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .programme-card:hover {
    transform: scale(0.98);
    border-color: var(--accent-orange);
  }

  .programme-img-wrap {
    height: 200px;
    overflow: hidden;
  }

  .programme-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .programme-card:hover .programme-img {
    transform: scale(1.04);
  }

  .programme-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .programme-level {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-orange);
    margin-bottom: 0.5rem;
  }

  .programme-body h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .programme-body p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--white-60);
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .programme-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--white-10);
  }

  .programme-price {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
  }

  .programme-link {
    font-size: 0.85rem;
    color: var(--accent-orange);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ===== APPROACH ===== */
  .approach-section {
    background: var(--dark-bg-lighter);
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .approach-card {
    background: var(--dark-bg);
    border: 1px solid var(--white-10);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .approach-card:hover {
    transform: scale(0.98);
    border-color: var(--accent-orange);
  }

  .approach-number {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--white);
    opacity: 0.12;
    line-height: 1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .approach-card h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .approach-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--white-60);
  }

  /* ===== TESTIMONIALS ===== */
  .testimonials-section {
    background: var(--dark-bg);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--dark-bg-card);
    border: 1px solid var(--white-10);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .testimonial-card:hover {
    transform: scale(0.98);
    border-color: var(--accent-orange);
  }

  .testimonial-stars {
    color: var(--accent-orange);
    font-size: 1rem;
    letter-spacing: 2px;
    margin-bottom: 1.25rem;
  }

  .testimonial-card blockquote {
    font-size: 0.95rem;
    font-style: normal;
    line-height: 1.7;
    color: var(--white-60);
    margin: 0 0 1.5rem 0;
    padding: 0;
    border: none;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--white-10);
  }

  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonial-author strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
  }

  .testimonial-author span {
    font-size: 0.8rem;
    color: var(--white-60);
  }

  /* ===== CTA ===== */
  .cta-section {
    background: var(--dark-bg-lighter);
    border-top: 1px solid var(--white-10);
    padding: 7rem 0;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-section .eyebrow {
    display: inline-block;
  }

  .cta-section h2 {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--white);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    color: var(--white-60);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  /* ===== BUTTON OVERRIDES ===== */
  .btn-primary {
    background: var(--accent-orange);
    color: var(--white);
    border: 1px solid var(--accent-orange);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .btn-primary:hover {
    background: #d4622e;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 1px solid var(--white-10);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .btn-secondary:hover {
    border-color: var(--white);
    transform: translateY(-1px);
  }

  .btn-lg {
    padding: 1rem 2.5rem;
    font-size: 0.9rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .programmes-grid,
    .testimonials-grid {
      grid-template-columns: 1fr 1fr;
    }

    .approach-grid {
      grid-template-columns: 1fr 1fr;
    }

    .hero-heading {
      font-size: clamp(2.25rem, 5vw, 3.5rem);
    }
  }

  @media (max-width: 768px) {
    .section {
      padding: 5rem 0;
    }

    .cta-section {
      padding: 5rem 0;
    }

    .stats-inner {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .stat-divider {
      display: none;
    }

    .stat-item {
      flex: 0 0 45%;
    }
  }

  @media (max-width: 640px) {
    .programmes-grid,
    .testimonials-grid,
    .approach-grid {
      grid-template-columns: 1fr;
    }

    .hero-inner {
      padding-top: 6rem;
      padding-bottom: 3rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      text-align: center;
    }

    .stat-item {
      flex: 0 0 100%;
    }

    .section-heading {
      font-size: 1.75rem;
      margin-bottom: 2.5rem;
    }
  }
</style>
