  .cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }

  .cta-section .eyebrow {
    display: inline-block;
  }

  .cta-section h2 {
    font-family: var(--font-body);
    font-size: clamp(2rem, 4vw, 3rem);
