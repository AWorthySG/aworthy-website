---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="A-Worthy — Singapore's First Analytical English Tuition">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="eyebrow">Singapore's First Analytical English Tuition</span>
        <h1 class="hero-heading">Think sharper.<br/>Write stronger.<br/>Score higher.</h1>
        <p class="hero-subtitle">
          Founded by a law graduate, A-Worthy uses the CASE Method — a proprietary framework that brings legal-analytical precision to help secondary students master O-Level English.
        </p>
        <div class="hero-proof">
          <div class="proof-item">
            <span class="proof-number">95%</span>
            <span class="proof-label">pass rate</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">50+</span>
            <span class="proof-label">5-star reviews</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">6</span>
            <span class="proof-label">max class size</span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn-accent hero-cta-primary">Book a Free Trial Class</a>
          <a href="https://wa.me/6591234567" class="btn btn-outline hero-cta-secondary" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 6px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <img src="/images/illustrations/hero-books.svg" alt="" class="hero-illustration" />
      </div>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat-item" data-animate="fade-up" data-animate-delay="1">
        <span class="stat-number">95%</span>
        <span class="stat-label">O-Level English pass rate</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="fade-up" data-animate-delay="2">
        <span class="stat-number">6:1</span>
        <span class="stat-label">Maximum class size</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="fade-up" data-animate-delay="3">
        <span class="stat-number">500+</span>
        <span class="stat-label">Students taught</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item" data-animate="fade-up" data-animate-delay="4">
        <span class="stat-number">Law</span>
        <span class="stat-label">Graduate founder</span>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMMES OVERVIEW ===== -->
  <section class="section programmes-section">
    <div class="container">
      <span class="eyebrow" data-animate="fade-up">Our Programmes</span>
      <h2 class="section-heading" data-animate="fade-up">Structured learning pathways for every stage</h2>

      <div class="programmes-grid">
        <a href="/programmes/#foundation" class="programme-card" data-animate="fade-up" data-animate-delay="1">
          <div class="programme-body">
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 1&ndash;2 English Foundation</h3>
            <p>90-minute weekly sessions covering Paper 1 and Paper 2 skills. Build a strong analytical foundation in comprehension, composition, and language use.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 280/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#intensive" class="programme-card" data-animate="fade-up" data-animate-delay="2">
          <div class="programme-body">
            <span class="programme-level">Small Group Online (Max 6)</span>
            <h3>Sec 3&ndash;4 O-Level Intensive</h3>
            <p>90-minute exam-focused sessions with monthly mock grading. Master every O-Level English component with the CASE Method and targeted practice.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 320/month</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>

        <a href="/programmes/#coaching" class="programme-card" data-animate="fade-up" data-animate-delay="3">
          <div class="programme-body">
            <span class="programme-level">Individual Online</span>
            <h3>One-to-One Coaching</h3>
            <p>Intensive exam prep or tailored support designed around your child's specific needs. Flexible scheduling with personalised feedback every session.</p>
            <div class="programme-meta">
              <span class="programme-price">SGD 120/session</span>
              <span class="programme-link">Learn more &rarr;</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== APPROACH ===== -->
  <section id="approach" class="section approach-section">
    <div class="container">
      <span class="eyebrow" data-animate="fade-up">The CASE Method</span>
      <h2 class="section-heading" data-animate="fade-up">Legal precision meets English mastery</h2>
      <p class="approach-subtitle">Our proprietary framework applies legal reasoning structures to every O-Level English component</p>

      <div class="approach-grid">
        <div class="approach-card" data-animate="fade-up" data-animate-delay="1">
          <span class="approach-number">C</span>
          <h3>Contextualise</h3>
          <p>Identify the task, purpose, audience, and text type. What is being asked? What kind of response is required? Just as lawyers issue-spot before applying any rule.</p>
        </div>
        <div class="approach-card" data-animate="fade-up" data-animate-delay="2">
          <span class="approach-number">A</span>
          <h3>Analyse</h3>
          <p>Read closely for explicit and implicit meaning, language technique, and writer's purpose. The analytical step is where marks are won or lost.</p>
        </div>
        <div class="approach-card" data-animate="fade-up" data-animate-delay="3">
          <span class="approach-number">S</span>
          <h3>Structure</h3>
          <p>Organise ideas into a coherent response. Build paragraphs with claim, evidence, and reasoned explanation. Structure is not decoration — it is the argument itself.</p>
        </div>
        <div class="approach-card" data-animate="fade-up" data-animate-delay="4">
          <span class="approach-number">E</span>
          <h3>Evaluate</h3>
          <p>Review, revise, and reflect. Does the response address the question? Is the evidence well-chosen? Is the language precise? The deliberate checking of reasoning.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section testimonials-section">
    <div class="container">
      <span class="eyebrow" data-animate="fade-up">What Families Say</span>
      <h2 class="section-heading" data-animate="fade-up">Don't just take our word for it</h2>

      <div class="testimonials-grid">
        <div class="testimonial-card" data-animate="fade-up" data-animate-delay="1">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "My son's English improved from C5 to A2 in just three months. The CASE Method gave him a systematic way to approach every comprehension question."
          </blockquote>
          <div class="testimonial-author">
            <div class="placeholder-avatar">LT</div>
            <div>
              <strong>Mrs. Linda Tan</strong>
              <span>Mother of Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card" data-animate="fade-up" data-animate-delay="2">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "I used to hate essay writing. Now I actually enjoy it because I know how to structure my arguments properly."
          </blockquote>
          <div class="testimonial-author">
            <div class="placeholder-avatar">EL</div>
            <div>
              <strong>Ethan Lim</strong>
              <span>Sec 4 student</span>
            </div>
          </div>
        </div>

        <div class="testimonial-card" data-animate="fade-up" data-animate-delay="3">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote>
            "What impressed me most was how the legal reasoning approach made inference questions click for my daughter."
          </blockquote>
          <div class="testimonial-author">
            <div class="placeholder-avatar">RK</div>
            <div>
              <strong>Mr. Rajesh Kumar</strong>
              <span>Father of Sec 3 student</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container cta-inner">
      <span class="eyebrow" data-animate="fade-up">Get Started</span>
      <h2 data-animate="fade-up">Your child is A-Worthy</h2>
      <p>Book a free diagnostic assessment — a 20-minute session analysing your child's recent English paper</p>
      <a href="/contact/" class="btn btn-primary btn-lg">Book Free Assessment</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --section-bg: var(--bg-primary);
    --section-bg-alt: var(--bg-secondary);
    --card-bg: var(--bg-card);
    --accent: var(--color-accent);
    --on-dark: #ffffff;
    --on-dark-muted: rgba(255,255,255,0.7);
    --divider: var(--border-color);
    --on-dark-subtle: rgba(255,255,255,0.05);
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: block;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  /* ===== SECTION HEADING ===== */
  .section-heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--on-dark);
    line-height: 1.15;
    margin-bottom: 3.5rem;
    max-width: 640px;
    letter-spacing: -0.02em;
  }

  /* ===== SECTION SPACING ===== */
  .section {
    padding: 7rem 0;
    background: var(--section-bg);
  }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--bg-primary);
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content {
    max-width: 560px;
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .proof-item {
    display: flex;
    flex-direction: column;
  }

  .proof-number {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .proof-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .proof-divider {
    width: 1px;
    height: 32px;
    background: var(--border-color);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .hero-cta-primary {
    padding: 0.875rem 2rem;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
  }

  .btn-outline {
    background: transparent;
    border: 1.5px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.75rem 1.5rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-illustration {
    width: 100%;
    max-width: 450px;
    height: auto;
  }

  /* ===== PLACEHOLDER IMAGES ===== */
  .placeholder-img {
    background: var(--bg-secondary);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--border-color);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px dashed var(--border-color);
  }

  .placeholder-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-primary-light);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .programme-illustration {
    max-width: 100%;
    height: auto;
    margin-bottom: 1rem;
  }

  /* ===== STATS BAR ===== */
  .stats-bar {
    background: var(--section-bg-alt);
    border-top: 1px solid var(--divider);
    border-bottom: 1px solid var(--divider);
    padding: 2.5rem 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .stat-item {
    flex: 1;
    text-align: center;
    padding: 0.5rem 1.5rem;
  }

  .stat-number {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--divider);
    flex-shrink: 0;
  }

  /* ===== PROGRAMMES ===== */
  .programmes-section {
    background: var(--section-bg);
  }

  .programmes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .programme-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--divider);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: var(--text-primary);
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .programme-card:hover {
    transform: scale(0.98);
    border-color: var(--accent);
  }

  .programme-img-wrap {
    height: 200px;
    overflow: hidden;
  }

  .programme-img,
  .programme-img-wrap .placeholder-img {
    width: 100%;
    height: 100%;
    transition: transform 0.4s ease;
  }

  .programme-card:hover .programme-img,
  .programme-card:hover .programme-img-wrap .placeholder-img {
    transform: scale(1.04);
  }

  .programme-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .programme-level {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .programme-body h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .programme-body p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .programme-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--divider);
  }

  .programme-price {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .programme-link {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ===== APPROACH ===== */
  .approach-section {
    background: var(--section-bg-alt);
  }

  .approach-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 640px;
    margin-bottom: 3.5rem;
    margin-top: -2rem;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .approach-card {
    background: var(--section-bg);
    border: 1px solid var(--divider);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .approach-card:hover {
    transform: scale(0.98);
    border-color: var(--accent);
  }

  .approach-number {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    opacity: 0.12;
    line-height: 1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .approach-card h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .approach-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  /* ===== TESTIMONIALS ===== */
  .testimonials-section {
    background: var(--section-bg);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--card-bg);
    border: 1px solid var(--divider);
    border-radius: 8px;
    padding: 2rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .testimonial-card:hover {
    transform: scale(0.98);
    border-color: var(--accent);
  }

  .testimonial-stars {
    color: var(--accent);
    font-size: 1rem;
    letter-spacing: 2px;
    margin-bottom: 1.25rem;
  }

  .testimonial-card blockquote {
    font-size: 0.95rem;
    font-style: normal;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 1.5rem 0;
    padding: 0;
    border: none;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--divider);
  }

  .testimonial-avatar,
  .testimonial-author .placeholder-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .testimonial-author strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .testimonial-author span {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  /* ===== CTA ===== */
  .cta-section {
    background: var(--section-bg-alt);
    border-top: 1px solid var(--divider);
    padding: 7rem 0;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-section .eyebrow {
    display: inline-block;
  }

  .cta-section h2 {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--on-dark);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    color: var(--on-dark-muted);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  /* ===== BUTTON OVERRIDES ===== */
  .btn-primary {
    background: var(--accent);
    color: var(--on-dark);
    border: 1px solid var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.85rem 2rem;
