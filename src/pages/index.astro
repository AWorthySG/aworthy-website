  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .approach-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: var(--space-xl);
    transition: all 0.4s ease;
  }

  @media (hover: hover) {
    .approach-card:hover {
      background: var(--bg-card-hover);
      border-color: rgba(26, 42, 58, 0.15);
    }
  }

  .approach-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .approach-letter {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 200;
    color: var(--color-accent);
    animation: shimmer-glow 4s ease-in-out infinite;
    animation-delay: calc(var(--letter-index, 0) * 0.5s);
  }

  .approach-card:nth-child(1) .approach-letter { --letter-index: 0; }
  .approach-card:nth-child(2) .approach-letter { --letter-index: 1; }
  .approach-card:nth-child(3) .approach-letter { --letter-index: 2; }
  .approach-card:nth-child(4) .approach-letter { --letter-index: 3; }

  .approach-time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: var(--section-bg-alt);
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    border: 1px solid var(--divider);
  }

  .approach-card h3 {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .approach-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .approach-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ===== CASE FLOW DIAGRAM ===== */
  .case-flow-section {
    background: var(--bg-secondary);
  }

  .case-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin-top: 2rem;
  }

  .case-flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 0 auto;
    max-width: 160px;
  }

  .case-flow-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(43, 90, 140, 0.1);
    border: 1px solid rgba(43, 90, 140, 0.2);
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    box-shadow: none;
    animation: case-icon-shimmer 5s ease-in-out infinite;
    animation-delay: calc(var(--step-index, 0) * 0.6s);
  }

  .case-flow-step:nth-child(1) .case-flow-icon { --step-index: 0; }
  .case-flow-step:nth-child(3) .case-flow-icon { --step-index: 1; }
  .case-flow-step:nth-child(5) .case-flow-icon { --step-index: 2; }
  .case-flow-step:nth-child(7) .case-flow-icon { --step-index: 3; }

  @keyframes case-icon-shimmer {
    0%, 100% {
      box-shadow: 0 0 0 transparent;
      border-color: rgba(43, 90, 140, 0.2);
    }
    50% {
      box-shadow: 0 0 18px rgba(212, 133, 58, 0.2), 0 0 40px rgba(201, 169, 110, 0.08);
      border-color: rgba(212, 133, 58, 0.35);
    }
  }

  .case-flow-icon {
    position: relative;
  }
  .icon-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(212,133,58,0.15);
    animation: ring-pulse 4s ease-in-out infinite;
    animation-delay: calc(var(--step-index, 0) * 0.6s);
  }
  @keyframes ring-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.15); opacity: 0; }
  }

  /* Animated connector lines */
  .case-flow.is-visible .connector-line {
    animation: draw-line 0.6s ease-out forwards;
  }
  .case-flow.is-visible .case-flow-connector:nth-child(2) .connector-line { animation-delay: 0.3s; }
  .case-flow.is-visible .case-flow-connector:nth-child(4) .connector-line { animation-delay: 0.6s; }
  .case-flow.is-visible .case-flow-connector:nth-child(6) .connector-line { animation-delay: 0.9s; }
  .case-flow.is-visible .connector-arrow {
    animation: show-arrow 0.3s ease-out forwards;
  }
  .case-flow.is-visible .case-flow-connector:nth-child(2) .connector-arrow { animation-delay: 0.8s; }
  .case-flow.is-visible .case-flow-connector:nth-child(4) .connector-arrow { animation-delay: 1.1s; }
  .case-flow.is-visible .case-flow-connector:nth-child(6) .connector-arrow { animation-delay: 1.4s; }
  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }
  @keyframes show-arrow {
    to { opacity: 1; }
  }

  .case-flow-step h3 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .case-flow-step p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
  }

  .case-flow-connector {
    display: flex;
    align-items: center;
    padding-top: 1.25rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .case-flow {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .case-flow-connector {
      transform: rotate(90deg);
      padding-top: 0;
    }
    .case-flow-step {
      max-width: 200px;
    }
  }

  /* ===== TESTIMONIALS ===== */
  /* ═══ THE VAULT ═══ */
  .vault-section {
    background:
      radial-gradient(circle at 2px 2px, rgba(212,133,58,0.025) 1px, transparent 1px) 0 0 / 32px 32px,
      linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    position: relative;
  }
  .vault-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin-bottom: 2.5rem;
    margin-top: -1rem;
    line-height: 1.7;
  }
  .vault-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .vault-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 1.75rem;
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
  }
  .vault-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-primary));
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .vault-card:hover {
    transform: translateY(-4px);
    border-color: rgba(212,133,58,0.2);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    background: var(--bg-card-hover);
  }
  .vault-card:hover::before { opacity: 1; }
  .vault-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    background: rgba(212,133,58,0.08);
    display: flex; align-items: center; justify-content: center;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .vault-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .vault-card h3 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .vault-card p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-secondary);
    flex: 1;
    margin-bottom: 1rem;
  }
  .vault-dl {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    transition: letter-spacing 0.2s ease;
  }
  .vault-card:hover .vault-dl {
    letter-spacing: 0.12em;
  }
  .vault-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 2rem;
    font-style: italic;
  }
  .vault-cta {
    text-align: center;
    margin-top: var(--space-xl);
  }
  @media (max-width: 1024px) {
    .vault-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .vault-grid { grid-template-columns: 1fr; }
  }

  /* ═══ TESTIMONIALS ═══ */
  .testimonials-section {
    background:
      radial-gradient(ellipse at 20% 80%, rgba(212,133,58,0.03) 0%, transparent 45%),
      var(--section-bg);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--bg-card);
