---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="O-Level English Tuition Singapore | Best Sec 1-4 English Tutor | A-Worthy" description="Looking for the best O-Level English tuition in Singapore? A-Worthy's CASE Method delivers a 90% A1-B3 rate. Small groups of 6, online via Zoom. Sec 1-4 foundation & intensive programmes. Book a free assessment." ogImage="/images/og-english.svg">
  <Header slot="header" />

  <!-- ===== PAGE HERO ===== -->
  <section class="prog-hero">
    <div class="container">
      <p class="eyebrow">O-Level English</p>
      <h1 class="prog-hero__heading">Best O-Level English Tuition<br />in Singapore</h1>
      <p class="prog-hero__sub">Our students achieve a 90% A1&ndash;B3 rate using the CASE Method &mdash; a proven four-stage framework that builds the analytical skills examiners reward across every English component.</p>
    </div>
  </section>

  <!-- ===== NAV PILLS ===== -->
  <nav class="prog-nav" aria-label="Programme quick links">
    <div class="container prog-nav__inner" data-animate="reveal-up">
      <a href="#sec1-2" class="prog-nav__link">Sec 1-2</a>
      <a href="#sec3-4" class="prog-nav__link">Sec 3-4</a>
      <a href="#one-to-one" class="prog-nav__link">One-to-One</a>
      <a href="#syllabus" class="prog-nav__link">Syllabus Coverage</a>
      <a href="#approach" class="prog-nav__link">Our Approach</a>
    </div>
  </nav>

  <!-- ===== SEC 1-2 ENGLISH FOUNDATION ===== -->
  <section class="prog-section" id="sec1-2">
    <div class="container">
      <p class="eyebrow">Sec 1 &ndash; 2</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Sec 1&ndash;2 O-Level English Foundation Programme</h2>
      <p class="prog-section__sub">Start building strong English comprehension and writing skills early &mdash; the earlier your child begins, the stronger their O-Level foundation.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Foundation Programme</h3>
          <p class="prog-card__desc">Small group online sessions designed to develop the core English skills that underpin O-Level success &mdash; starting from Secondary 1.</p>
          <ul class="prog-card__topics">
            <li>Close reading and inference techniques</li>
            <li>Essay structure fundamentals (narrative, expository)</li>
            <li>Vocabulary building and contextual usage</li>
            <li>Comprehension answering frameworks</li>
            <li>Grammar and editing accuracy</li>
          </ul>
          <div class="prog-card__meta">
            <span>90 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 280 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SEC 3-4 O-LEVEL INTENSIVE ===== -->
  <section class="prog-section" id="sec3-4">
    <div class="container">
      <p class="eyebrow">Sec 3 &ndash; 4</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Sec 3&ndash;4 O-Level English Intensive Programme</h2>
      <p class="prog-section__sub">Targeted exam preparation with monthly mock papers, detailed marker-style feedback, and proven techniques to push grades from C to A.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">O-Level Intensive Programme</h3>
          <p class="prog-card__desc">Rigorous, exam-aligned preparation covering every component of the GCE O-Level English paper &mdash; with regular mock practice and individualised feedback.</p>
          <ul class="prog-card__topics">
            <li>Paper 1 Situational Writing (format, purpose, audience, register)</li>
            <li>Paper 1 Continuous Writing (narrative, expository, argumentative)</li>
            <li>Paper 2 Comprehension (literal, inferential, evaluative questions)</li>
            <li>Paper 2 Summary (80-word paraphrase technique)</li>
            <li>Oral Communication (video stimulus response)</li>
            <li>Editing (grammar and vocabulary correction)</li>
          </ul>
          <div class="prog-card__meta">
            <span>90 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 320 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ONE-TO-ONE COACHING ===== -->
  <section class="prog-section" id="one-to-one">
    <div class="container">
      <p class="eyebrow">One-to-One</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">One-to-One English Coaching</h2>
      <p class="prog-section__sub">For students requiring tailored support or intensive exam preparation.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Individual Coaching</h3>
          <p class="prog-card__desc">Fully customised to the student&rsquo;s specific gaps &mdash; whether it&rsquo;s comprehension, composition, oral, or editing. Individual online sessions via Zoom, scheduled at your convenience.</p>
          <div class="prog-card__meta">
            <span>Per session</span>
            <span>1 student</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 120 / session</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SYLLABUS COVERAGE ===== -->
  <section class="prog-section" id="syllabus">
    <div class="container">
      <p class="eyebrow">1128 Syllabus</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Complete GCE O-Level English Language (1128) Syllabus Coverage</h2>
      <p class="prog-section__sub">Every component of the GCE O-Level English Language syllabus (1128), taught with precision and exam alignment.</p>

      <div class="card-grid card-grid--2">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Paper 1 &mdash; Writing</h3>
          <ul class="prog-card__topics">
            <li>Situational Writing (formal/informal letters, reports, proposals, emails)</li>
            <li>Continuous Writing &mdash; Narrative</li>
            <li>Continuous Writing &mdash; Expository</li>
            <li>Continuous Writing &mdash; Argumentative</li>
            <li>Format, purpose, audience, and register awareness</li>
            <li>Planning and paragraph structure</li>
          </ul>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="2">
          <h3 class="prog-card__title">Paper 2 &mdash; Comprehension</h3>
          <ul class="prog-card__topics">
            <li>Visual text comprehension</li>
            <li>Narrative and non-fiction comprehension</li>
            <li>Literal, inferential, and evaluative questions</li>
            <li>Summary writing (80-word paraphrase)</li>
            <li>Editing (grammar and vocabulary correction)</li>
            <li>Oral Communication (video stimulus response)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR APPROACH ===== -->
  <section class="prog-section" id="approach">
    <div class="container">
      <p class="eyebrow">The CASE Method</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Why the CASE Method produces O-Level English results other approaches can&rsquo;t</h2>

      <div class="card-grid card-grid--2">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Contextualise (10 min)</h3>
          <p class="prog-card__desc">Most students lose marks because they misread what the question is really asking. Your child learns to decode every question type &mdash; comprehension, situational writing, essay prompt &mdash; before putting pen to paper. No more careless misinterpretations.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="2">
          <h3 class="prog-card__title">Analyse (20 min)</h3>
          <p class="prog-card__desc">Inference questions are where O-Level English is won or lost. Your child develops the close-reading skills to extract implicit meaning, identify language techniques, and construct the kind of interpretations that earn full marks &mdash; not the surface-level answers that cap out at B4.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="3">
          <h3 class="prog-card__title">Structure (20 min)</h3>
          <p class="prog-card__desc">Whether it&rsquo;s a narrative essay, a formal letter, or a comprehension response, your child learns the exact paragraph structures examiners reward. Live writing practice with immediate tutor feedback &mdash; not corrections returned a week later when the moment has passed.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="4">
          <h3 class="prog-card__title">Evaluate (10 min)</h3>
          <p class="prog-card__desc">The step that turns B-grade students into A-grade students. Your child learns to self-check every response against a systematic checklist &mdash; catching the grammar slips, missing content points, and weak conclusions that silently drag marks down.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FREE DIAGNOSTIC ASSESSMENT CTA ===== -->
  <section class="prog-cta">
    <div class="container prog-cta__inner">
      <p class="eyebrow">Get Started</p>
      <h2 class="prog-cta__heading" data-animate="reveal-up">Ready to improve your child&rsquo;s O-Level English grade?</h2>
      <p class="prog-cta__sub">Book a free 20-minute diagnostic assessment. We&rsquo;ll analyse your child&rsquo;s recent English paper, identify their specific gaps, and recommend the right programme &mdash; no obligation, no sales pitch.</p>
      <div class="prog-cta__actions">
        <a href="/contact/" class="prog-cta__btn prog-cta__btn--primary">Book Assessment</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  :root {
    --prog-bg: var(--bg-primary);
    --prog-bg-card: var(--bg-card);
    --prog-border: var(--border-color);
    --prog-text: var(--text-primary);
    --prog-text-secondary: var(--text-secondary);
    --prog-accent: var(--color-accent);
    --prog-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --prog-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }
  .eyebrow { font-family: var(--prog-mono); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--prog-accent); margin-bottom: 1rem; }
  .prog-hero { background: var(--prog-bg); padding: calc(var(--header-height) + 3rem) 0 3rem; text-align: center; }
  .prog-hero__heading { font-family: var(--prog-font); font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 200; line-height: 1.15; color: var(--text-primary); margin-bottom: 1.5rem; letter-spacing: -0.03em; }
  .prog-hero__sub { font-family: var(--prog-font); font-size: 1.1rem; line-height: 1.7; color: var(--prog-text-secondary); max-width: 640px; margin: 0 auto; }
  .prog-nav { background: var(--prog-bg); border-bottom: 1px solid var(--prog-border); padding: 1.25rem 0; position: sticky; top: 0; z-index: 90; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; -ms-overflow-style: none; }
  .prog-nav::-webkit-scrollbar { display: none; }
  .prog-nav__inner { display: flex; justify-content: center; gap: 2rem; flex-wrap: nowrap; min-width: max-content; }
  .prog-nav__link { font-family: var(--prog-mono); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--prog-text-secondary); text-decoration: none; padding: 0.4rem 0; border-bottom: 1px solid transparent; transition: color 0.2s ease, border-color 0.2s ease; }
  .prog-nav__link:hover { color: var(--prog-text); border-bottom-color: var(--prog-accent); }
  .prog-section { background: var(--prog-bg); padding: 4rem 0; scroll-margin-top: 60px; }
  .prog-section + .prog-section { border-top: 1px solid var(--prog-border); }
  .prog-section__heading { font-family: var(--prog-font); font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 200; color: var(--text-primary); margin-bottom: 0.75rem; letter-spacing: -0.03em; }
  .prog-section__sub { font-family: var(--prog-font); font-size: 1.05rem; line-height: 1.7; color: var(--prog-text-secondary); max-width: 600px; margin-bottom: 3.5rem; }
  .card-grid { display: grid; gap: 1.5rem; }
  .card-grid--1 { grid-template-columns: 1fr; max-width: 640px; }
  .card-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .prog-card { background: var(--bg-card); -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px); border: 1px solid var(--border-color); border-radius: 4px; padding: 2rem; transition: transform 0.2s ease, border-color 0.2s ease; display: flex; flex-direction: column; }
  @media (hover: hover) { .prog-card:hover { transform: translateY(-3px); border-color: var(--border-color); } }
  .prog-card__title { font-family: var(--prog-font); font-size: 1.15rem; font-weight: 300; color: var(--text-primary); margin-bottom: 0.75rem; letter-spacing: -0.03em; }
  .prog-card__desc { font-family: var(--prog-font); font-size: 0.9rem; line-height: 1.65; color: var(--text-secondary); margin-bottom: 1.25rem; }
  .prog-card__topics { list-style: none; padding: 0; margin: 0 0 auto; flex-grow: 1; }
  .prog-card__topics li { font-family: var(--prog-font); font-size: 0.82rem; line-height: 1.5; color: var(--prog-text-secondary); padding: 0.45rem 0; border-bottom: 1px solid var(--bg-secondary); padding-left: 1rem; position: relative; }
  .prog-card__topics li::before { content: ''; position: absolute; left: 0; top: 50%; width: 4px; height: 4px; border-radius: 50%; background: var(--prog-accent); transform: translateY(-50%); }
  .prog-card__topics li:last-child { border-bottom: none; }
  .prog-card__meta { display: flex; gap: 1.25rem; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--prog-border); flex-wrap: wrap; }
  .prog-card__meta span { font-family: var(--prog-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--prog-text-secondary); }
  .prog-card__fee { font-family: var(--prog-font); font-size: 1rem; font-weight: 600; color: var(--color-accent); margin-top: 0.75rem; margin-bottom: 0; }
  .prog-cta { background: var(--prog-bg); border-top: 1px solid var(--prog-border); padding: 4rem 0; }
  .prog-cta__inner { text-align: center; max-width: 600px; margin: 0 auto; }
  .prog-cta__heading { font-family: var(--prog-font); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 200; color: var(--text-primary); margin-bottom: 1rem; letter-spacing: -0.03em; }
  .prog-cta__sub { font-family: var(--prog-font); font-size: 1.05rem; line-height: 1.7; color: var(--prog-text-secondary); margin-bottom: 2.5rem; }
  .prog-cta__actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .prog-cta__btn { font-family: var(--prog-mono); font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; padding: 0.9rem 2rem; border-radius: 0; transition: all 0.2s ease; cursor: pointer; display: inline-block; }
  .prog-cta__btn--primary { background: var(--prog-accent); color: var(--text-primary); border: 1px solid var(--prog-accent); }
  .prog-cta__btn--primary:hover { background: #d4632e; transform: translateY(-1px); }
  @media (max-width: 768px) { .prog-hero { padding: 6rem 0 3.5rem; } .prog-nav__inner { gap: 1rem; } .card-grid--2 { grid-template-columns: 1fr; } .prog-card { padding: 1.5rem; } }
  @media (max-width: 480px) { .prog-hero__heading { font-size: 1.8rem; } .prog-nav__inner { gap: 0.6rem; } .prog-nav__link { font-size: 0.65rem; } .prog-cta__actions { flex-direction: column; align-items: center; } .prog-cta__btn { width: 100%; text-align: center; } }
</style>
