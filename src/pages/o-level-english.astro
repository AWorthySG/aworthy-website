---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/playbook.css';

const sharpSteps = [
  { letter: 'S', name: 'See' },
  { letter: 'H', name: 'Hit' },
  { letter: 'A', name: 'Apply' },
  { letter: 'R', name: 'Refine' },
  { letter: 'P', name: 'Practise' },
];

const playbookRows = [
  {
    paper: 'Paper 1A',
    section: 'Editing',
    steps: [
      { title: 'Spot the error type', note: 'Grammar, vocabulary or spelling?' },
      { title: 'STAMP CARD', note: '9-category mnemonic sweep' },
      { title: 'Walk each error', note: 'Tick categories in order' },
      { title: 'Re-read for tense', note: 'Catch silent verb shifts' },
      { title: '10-error drills', note: 'Daily editing reps' },
    ],
  },
  {
    paper: 'Paper 1B',
    section: 'Situational Writing',
    steps: [
      { title: 'Decode P-A-R', note: 'Purpose, audience, register' },
      { title: 'RAWCP plan', note: 'Format-matched skeleton' },
      { title: 'Match register', note: 'Word choice + tone alignment' },
      { title: 'Tone audit', note: 'Re-read in the recipient’s voice' },
      { title: 'Format library', note: 'Letters, reports, emails, proposals' },
    ],
  },
  {
    paper: 'Paper 1C',
    section: 'Continuous Writing',
    steps: [
      { title: 'Read the command', note: 'Narrative, expository or argumentative?' },
      { title: 'CAPS planner', note: 'Characters, Arc, Plot, Setting' },
      { title: 'Build the arc', note: 'Tension, climax, resolution' },
      { title: 'Cut weak verbs', note: 'Verb upgrade pass before submit' },
      { title: 'Timed essays', note: 'Weekly 60-minute writes' },
    ],
  },
  {
    paper: 'Paper 2',
    section: 'Comprehension (Texts 1–3)',
    steps: [
      { title: 'Identify Q-type', note: 'Literal, inferential or evaluative' },
      { title: 'Core Move + ACED', note: 'ACED for visual, Core Move for inference' },
      { title: 'P-E-E-L answer', note: 'Point, evidence, explanation, link' },
      { title: 'Mark-allocation check', note: '1 point per mark, no more' },
      { title: 'Past-paper drills', note: 'Cambridge papers, 2019–2024' },
    ],
  },
  {
    paper: 'Paper 2',
    section: 'Summary (80 words)',
    steps: [
      { title: 'List content points', note: 'Number every mark-worthy idea' },
      { title: '80-word target', note: 'Compression rule: 1 word per point' },
      { title: 'Paraphrase chain', note: 'Re-word without dropping marks' },
      { title: 'Cut redundancy', note: 'Strip qualifiers, examples, hedging' },
      { title: 'Daily 80-word drills', note: 'One summary every morning' },
    ],
  },
  {
    paper: 'Paper 4',
    section: 'Oral Communication',
    steps: [
      { title: 'Read the visual cue', note: 'What’s the conversation hook?' },
      { title: '1-2-1 structure', note: 'Opinion, two reasons, restated stance' },
      { title: 'Personalise', note: 'Specific examples, not generalities' },
      { title: 'Tone audit', note: 'Pace, fillers, eye-contact check' },
      { title: 'Mock orals', note: 'Recorded sessions with playback' },
    ],
  },
];
