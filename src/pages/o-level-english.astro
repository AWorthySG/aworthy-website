<script is:inline>
(function(){
  var toc = document.getElementById('sticky-toc-list');
  if (!toc) return;
  var sections = document.querySelectorAll('section[id]');
  sections.forEach(function(s) {
    var heading = s.querySelector('h2, h1');
    if (!heading) return;
    var eyebrow = s.querySelector('.eyebrow');
    var label = eyebrow ? eyebrow.textContent.trim() : heading.textContent.substring(0, 22) + (heading.textContent.length > 22 ? '…' : '');
    var li = document.createElement('li');
    li.className = 'sticky-toc-item';
    var a = document.createElement('a');
    a.className = 'sticky-toc-link';
    a.href = '#' + s.id;
    a.textContent = label;
    li.appendChild(a);
    toc.appendChild(li);
  });

  if (!toc.children.length) { document.getElementById('sticky-toc').style.display = 'none'; return; }

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        toc.querySelectorAll('.sticky-toc-item').forEach(function(li) { li.classList.remove('is-active'); });
        toc.querySelectorAll('.sticky-toc-link').forEach(function(a) { a.classList.remove('is-active'); });
        var link = toc.querySelector('a[href="#' + entry.target.id + '"]');
        if (link) { link.classList.add('is-active'); link.parentElement.classList.add('is-active'); }
      }
    });
  }, { threshold: 0.2, rootMargin: '-20% 0px -60% 0px' });
  sections.forEach(function(s) { observer.observe(s); });
})();
</script>

<script is:inline>
(function(){
  var navLinks = document.querySelectorAll('.prog-nav__link');
  if (!navLinks.length) return;
  var sections = [];
  navLinks.forEach(function(link) {
    var id = link.getAttribute('href');
    if (id && id.charAt(0) === '#') {
      var el = document.querySelector(id);
      if (el) sections.push({ el: el, link: link });
    }
  });
  if (!sections.length) return;
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        navLinks.forEach(function(l) { l.classList.remove('is-active'); });
        sections.forEach(function(s) {
          if (s.el === entry.target) s.link.classList.add('is-active');
        });
      }
    });
  }, { threshold: 0.15, rootMargin: '-20% 0px -60% 0px' });
  sections.forEach(function(s) { obs.observe(s.el); });
})();
</script>

<script is:inline>
function initNotesLightbox() {
  var box = document.getElementById('notes-lightbox');
  var img = document.getElementById('notes-lightbox-img');
  var closeBtn = document.getElementById('notes-lightbox-close');
  var shots = document.querySelectorAll('.notes-shot');
  if (!box || !img || !shots.length) return;

  function open(src, alt) {
    img.src = src;
    img.alt = alt;
    box.classList.add('is-open');
    closeBtn.focus();
  }
  function close() {
    box.classList.remove('is-open');
    img.src = '';
  }

  shots.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var full = btn.getAttribute('data-full');
      var altText = btn.querySelector('img') ? btn.querySelector('img').alt : '';
      open(full, altText);
    });
  });
  closeBtn.addEventListener('click', close);
  box.addEventListener('click', function(e) { if (e.target === box) close(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && box.classList.contains('is-open')) close(); });
}
initNotesLightbox();
document.addEventListener('astro:page-load', initNotesLightbox);
</script>
