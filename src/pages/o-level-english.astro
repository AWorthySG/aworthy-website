  :global([data-theme="dark"]) .prog-hero::before { background: radial-gradient(circle, rgba(90, 155, 240, 0.10) 0%, transparent 70%); }
  .prog-hero .container { position: relative; z-index: 1; }
  .prog-hero__icon { display: block; margin: 0 auto 1rem; }
  .prog-hero__illus { display: block; margin: 0 auto 1rem; width: min(460px, 86%); height: auto; border-radius: 10px; border: 1px solid var(--prog-border); box-shadow: 0 18px 40px -26px rgba(26, 42, 58, 0.4); }
  :global([data-theme="dark"]) .prog-hero__illus { border-color: rgba(245, 239, 227, 0.16); box-shadow: 0 18px 44px -22px rgba(0, 0, 0, 0.6); }
  .prog-hero__heading { font-family: var(--prog-font); font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 200; line-height: 1.15; color: var(--text-primary); margin-bottom: 0.75rem; letter-spacing: -0.03em; }
  .prog-hero__sub { font-family: var(--prog-font); font-size: 1.1rem; line-height: 1.7; color: var(--prog-text-secondary); max-width: 640px; margin: 0 auto; }
  .prog-nav { background: var(--prog-bg); border-bottom: 1px solid var(--prog-border); padding: 0.75rem 0; position: sticky; top: var(--nav-offset); z-index: 90; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; -ms-overflow-style: none; }
  .prog-nav::-webkit-scrollbar { display: none; }
  .prog-nav__inner { display: flex; justify-content: center; gap: 2rem; flex-wrap: nowrap; min-width: max-content; }
  .prog-nav__link { font-family: var(--prog-mono); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--prog-text-secondary); text-decoration: none; padding: 0.4rem 0; min-height: 44px; display: inline-flex; align-items: center; border-bottom: 1px solid transparent; transition: color 0.2s ease, border-color 0.2s ease; touch-action: manipulation; }
  .prog-nav__link:hover { color: var(--prog-text); border-bottom-color: var(--prog-accent); }
  .prog-nav__link.is-active { color: var(--subject-accent-text); border-bottom-color: var(--subject-accent-text); font-weight: 600; }
  .prog-section { background: var(--prog-bg); padding: 1.25rem 0; scroll-margin-top: calc(var(--nav-offset) + 48px); }
  .prog-section + .prog-section { border-top: 1px solid var(--prog-border); }
  .prog-section__heading { font-family: var(--prog-font); font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 200; color: var(--text-primary); margin-bottom: 0.5rem; letter-spacing: -0.03em; }
  .prog-section__sub { font-family: var(--prog-font); font-size: 1.05rem; line-height: 1.7; color: var(--prog-text-secondary); max-width: 600px; margin-bottom: 1rem; }
  .card-grid { display: grid; gap: 1rem; }
  .card-grid--1 { grid-template-columns: 1fr; max-width: 800px; }
  .card-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .prog-card { background: var(--bg-card); -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px); border: 1px solid var(--border-color); border-radius: 4px; padding: 1.25rem; transition: transform 0.2s ease, border-color 0.2s ease; display: flex; flex-direction: column; }
  @media (hover: hover) { .prog-card:hover { transform: translateY(-3px); border-color: var(--border-color); } }
  .prog-card__title { font-family: var(--prog-font); font-size: 1.15rem; font-weight: 300; color: var(--text-primary); margin-bottom: 0.75rem; letter-spacing: -0.03em; }
  .prog-card__desc { font-family: var(--prog-font); font-size: 0.9rem; line-height: 1.65; color: var(--text-secondary); margin-bottom: 0.75rem; }
  .prog-card__topics { list-style: none; padding: 0; margin: 0 0 auto; flex-grow: 1; }
  .prog-card__topics li { font-family: var(--prog-font); font-size: 0.82rem; line-height: 1.5; color: var(--prog-text-secondary); padding: 0.45rem 0; border-bottom: 1px solid var(--bg-secondary); padding-left: 1rem; position: relative; }
  .prog-card__topics li::before { content: ''; position: absolute; left: 0; top: 50%; width: 4px; height: 4px; border-radius: 50%; background: var(--prog-accent); transform: translateY(-50%); }
  .prog-card__topics li:last-child { border-bottom: none; }
  .prog-card__meta { display: flex; gap: 1.25rem; margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--prog-border); flex-wrap: wrap; }
  .prog-card__meta span { font-family: var(--prog-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--prog-text-secondary); }
  .prog-card__fee { font-family: var(--prog-font); font-size: 1rem; font-weight: 600; color: var(--subject-accent-text); margin-top: 0.75rem; margin-bottom: 0; }
  /* ===== LESSON FLOW (editorial spread — claudedesign E.2) ===== */
  .lesson-flow { background: var(--bg-secondary); }
  .prog-section__intro { font-family: var(--prog-font); font-size: 1.05rem; line-height: 1.7; color: var(--prog-text-secondary); max-width: 720px; margin: 0 0 1rem; }
  .prog-section__intro em { font-style: italic; color: var(--subject-accent-text); font-weight: 600; }
  .lesson-timeline { list-style: none; padding: 0; margin: 0; max-width: 1040px; }
  .lesson-step {
    display: grid;
    grid-template-columns: minmax(0, 140px) 1fr;
    gap: 1.25rem;
    padding: 1rem 0;
    border-top: 1px solid var(--prog-border);
  }
  .lesson-step:last-child { border-bottom: 1px solid var(--prog-border); }
  .lesson-step__num {
    font-family: var(--prog-font);
    font-weight: 200;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: var(--subject-accent-text);
    font-feature-settings: "tnum" 1, "lnum" 1;
    font-variant-numeric: tabular-nums lining-nums;
  }
  .lesson-step__body { min-width: 0; }
  .lesson-step__time {
    display: inline-block;
    font-family: var(--prog-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--subject-accent-text);
    margin-bottom: 0.6rem;
  }
  .lesson-step__title {
    font-family: var(--prog-font);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 0 0 0.6rem;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }
  .lesson-step__desc {
    font-family: var(--prog-font);
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    margin: 0;
    text-wrap: pretty;
  }
  .lesson-step__desc em { font-style: italic; color: var(--subject-accent-text); font-weight: 600; }
  .lesson-flow__note { margin-top: 0.75rem; font-size: 0.85rem; color: var(--text-muted); font-style: italic; max-width: 720px; }
  @media (max-width: 720px) {
    .lesson-step { grid-template-columns: 1fr; gap: 0.6rem; padding: 1.25rem 0; }
    .lesson-step__num { font-size: clamp(2.6rem, 14vw, 3.6rem); }
    .lesson-step__desc { font-size: 0.92rem; }
  }

  .prog-inline-cta { text-align: center; padding: 1rem 0 0; }
  .prog-cta { background: var(--prog-bg); border-top: 1px solid var(--prog-border); padding: 1.25rem 0; }
  .prog-cta__inner { text-align: center; max-width: 600px; margin: 0 auto; }
  .prog-cta__heading { font-family: var(--prog-font); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 200; color: var(--text-primary); margin-bottom: 0.75rem; letter-spacing: -0.03em; }
  .prog-cta__sub { font-family: var(--prog-font); font-size: 1.05rem; line-height: 1.7; color: var(--prog-text-secondary); margin-bottom: 1rem; }
  .prog-cta__actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .prog-cta__btn { font-family: var(--prog-mono); font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; padding: 0.9rem 2rem; min-height: 44px; border-radius: 0; transition: all 0.2s ease; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; touch-action: manipulation; }
  .prog-cta__btn--primary { background: var(--subject-accent-text); color: #fff; border: 1px solid var(--subject-accent-text); }
  :global([data-theme="dark"]) .prog-cta__btn--primary { color: #11100E; }
  .prog-cta__btn--primary:hover { filter: brightness(1.12); transform: translateY(-1px); }
  .prog-cta__btn--whatsapp { display: inline-flex; align-items: center; gap: 0.5rem; background: #25D366; color: #11100E; border: none; text-decoration: none; transition: background var(--transition-fast); }
  .prog-cta__btn--whatsapp:hover { background: #4be07f; color: #11100E; }
  @media (max-width: 768px) { .prog-hero { padding: 1rem 0 0.75rem; } .prog-section { padding: 1rem 0; } .prog-section__sub { margin-bottom: 0.75rem; } .prog-nav__inner { gap: 1rem; } .card-grid--2 { grid-template-columns: 1fr; } .prog-card { padding: 1.25rem; } .prog-cta { padding: 1.25rem 0; } .faq-section, .recommended-reading, .subject-testimonials, .related-section { padding: 1rem 0; } }
  @media (max-width: 480px) { .prog-hero { padding: 0.75rem 0 0.5rem; } .prog-hero__heading { font-size: 1.8rem; margin-bottom: 0.5rem; } .prog-hero__sub { font-size: 0.95rem; } .prog-section { padding: 0.75rem 0; } .prog-section__heading { margin-bottom: 0.5rem; } .prog-section__sub { margin-bottom: 0.5rem; } .prog-nav__inner { gap: 0.6rem; } .prog-nav__link { font-size: 0.7rem; padding: 0.5rem 0; min-height: 44px; display: inline-flex; align-items: center; } .prog-cta__actions { flex-direction: column; align-items: center; } .prog-cta__btn { width: 100%; text-align: center; } .prog-card__meta span { font-size: 0.75rem; } .lesson-step__time { font-size: 0.75rem; } .prog-card { padding: 1rem; } .faq-section, .recommended-reading, .subject-testimonials, .related-section { padding: 0.75rem 0; } }

  /* ===== STICKY TOC ===== */
  .sticky-toc {
    position: fixed;
    top: calc(var(--nav-offset) + 1rem);
    right: 1.5rem;
    z-index: 50;
    max-width: 180px;
    display: none;
  }
  @media (min-width: 1280px) {
    .sticky-toc { display: block; }
  }
  .sticky-toc-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--subject-accent-text);
    margin-bottom: 0.5rem;
    padding-left: 1rem;
  }
  .sticky-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid color-mix(in srgb, var(--subject-accent) 25%, transparent);
  }
  .sticky-toc-item {
    padding: 0.35rem 0 0.35rem 1rem;
  }
  .sticky-toc-link {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
    display: block;
  }
  .sticky-toc-link:hover, .sticky-toc-link.is-active {
    color: var(--subject-accent-text);
  }
  .sticky-toc-item.is-active {
    border-left: 2px solid var(--subject-accent);
    margin-left: -2px;
  }
  .related-section { background: var(--bg-secondary); padding: 1.25rem 0; }
  .related-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .related-link {
    display: block;
    text-decoration: none;
    padding: 1.25rem;
    min-height: 44px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  .related-link:hover {
    border-color: var(--subject-accent-text);
    transform: translateY(-3px);
    box-shadow: 0 14px 32px -18px color-mix(in srgb, var(--subject-accent) 40%, transparent);
  }
  .related-link strong {
    display: block;
    font-size: 0.9rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .related-link span {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
  @media (max-width: 1024px) {
    .related-links { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .related-links { grid-template-columns: 1fr; }
  }

  .schedule-table-wrap { overflow-x: auto; margin: 1rem 0; -webkit-overflow-scrolling: touch; scrollbar-width: none; -ms-overflow-style: none; }
  .schedule-table-wrap::-webkit-scrollbar { display: none; }
  .schedule-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .schedule-table th, .schedule-table td { padding: 0.75rem 1.25rem; text-align: left; border-bottom: 1px solid var(--border-color); }
  .schedule-table th { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); font-weight: 500; }
  .schedule-table td { color: var(--text-primary); }
  .schedule-table tbody tr:hover { background: var(--bg-secondary); }
  .slot-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; font-family: var(--font-mono); }
  .slot-badge--limited { background: rgba(59,125,216,0.12); color: var(--subject-accent-text); }
  .slot-badge--open { background: rgba(39,174,96,0.12); color: #14683B; }
  :global([data-theme="dark"]) .slot-badge--open { background: rgba(39,174,96,0.18); color: #2ecc71; }
  .slot-badge--full { background: rgba(231,76,60,0.12); color: #e74c3c; }
  :global([data-theme="dark"]) .slot-badge--full { background: rgba(231,76,60,0.18); color: #f07060; }
  .schedule-note { margin-top: 1rem; font-size: 0.9rem; color: var(--text-secondary); }
  .schedule-note a { color: var(--subject-accent-text); text-decoration: underline; }
  @media (max-width: 640px) {
    .schedule-table th, .schedule-table td { padding: 0.75rem; font-size: 0.85rem; }
  }

  /* ===== FAQ ===== */
  .faq-section {
    padding: 1.25rem 0;
    background: var(--bg-secondary);
    scroll-margin-top: calc(var(--nav-offset) + 48px);
  }
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
  }
  .faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
    transition: border-color var(--transition-fast);
  }
  .faq-item[open] {
    background: linear-gradient(180deg, color-mix(in srgb, var(--subject-accent) 5%, transparent), transparent 80%);
    border-bottom-color: var(--subject-accent-text);
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: var(--border-radius);
  }
  .faq-question {
    font-family: 'Nunito', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 44px;
    touch-action: manipulation;
    transition: color var(--transition-fast);
  }
  .faq-question:hover {
    color: var(--subject-accent-text);
  }
  .faq-question::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--subject-accent-text);
    transition: transform var(--transition-fast);
  }
  .faq-item[open] .faq-question::after {
    content: '\2212';
  }
  .faq-answer {
    padding-top: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .faq-answer p {
    margin: 0;
  }

  /* ===== RECOMMENDED READING ===== */
  .recommended-reading {
    padding: 1.25rem 0;
  }
  .reading-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .reading-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 44px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: transform var(--transition-fast), border-color var(--transition-fast);
  }
  .reading-card:hover {
    transform: translateY(-3px);
    border-color: var(--subject-accent-text);
    box-shadow: 0 14px 32px -18px color-mix(in srgb, var(--subject-accent) 45%, transparent);
  }
  .reading-card:hover .reading-card-arrow {
    transform: translateX(4px);
  }
  .reading-card-arrow {
    transition: transform var(--transition-fast);
  }
  .reading-card h3 {
    color: var(--text-primary);
    font-size: 0.95rem;
    margin: 0;
    font-weight: 600;
  }
  .reading-card-arrow {
    color: var(--subject-accent-text);
    font-size: 1.2rem;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  /* ===== SUBJECT TESTIMONIALS ===== */
  .subject-testimonials {
    padding: 1.25rem 0;
  }
  .subject-testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }
  .subject-quote {
    background: var(--bg-card);
    border-left: 3px solid var(--subject-accent);
    border-radius: var(--border-radius);
    padding: 1.25rem;
    margin: 0;
    position: relative;
    overflow: hidden;
  }
  .subject-quote::before {
    content: '\201C';
    position: absolute;
    top: -1rem;
    right: 0.75rem;
    font-family: var(--font-heading);
    font-size: 4.5rem;
    line-height: 1;
    color: var(--subject-accent-text);
    opacity: 0.08;
    pointer-events: none;
  }
  .subject-quote > * {
    position: relative;
    z-index: 1;
  }
  .subject-quote p {
    color: var(--text-primary);
    font-style: italic;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }
  .subject-quote cite {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-style: normal;
  }

  /* ===== SLOTS BANNER ===== */
  .slots-banner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: rgba(59, 125, 216, 0.08);
    border: 1px solid rgba(59, 125, 216, 0.2);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.25rem;
  }
  .slots-indicator {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .slots-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #e74c3c;
    flex-shrink: 0;
  }
  .slots-dot.pulse {
    animation: slot-pulse 2s ease-in-out infinite;
  }
  @keyframes slot-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(231, 76, 60, 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(231, 76, 60, 0); }
  }
  .slots-text {
    font-size: 0.9rem;
    color: var(--text-primary);
  }
  .slots-text strong {
    color: var(--subject-accent-text);
  }

  /* ===== ORAL COMMUNICATION ===== */
  .oral-quickref {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .oral-peel {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    justify-content: center;
  }
  .oral-peel__label { font-family: var(--prog-mono); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); }
  .oral-peel__chips { display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem; }
  .oral-peel__chip { font-size: 0.85rem; padding: 0.35rem 0.65rem; border-radius: 999px; background: var(--bg-secondary); border: 1px solid var(--border-color); color: var(--text-primary); }
  .oral-peel__chip strong { color: var(--subject-accent-text); }
  .oral-peel__arrow { color: var(--text-muted); font-size: 0.8rem; }

  .oral-types { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .oral-type { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--border-radius); padding: 0.9rem 1rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .oral-type__tag { font-size: 0.8rem; font-weight: 700; color: var(--subject-accent-text); }
  .oral-type__prompt { font-size: 0.82rem; color: var(--text-muted); font-style: italic; }
  .oral-type__desc { font-size: 0.86rem; color: var(--text-secondary); line-height: 1.5; }

  .oral-anatomy { margin-bottom: 2.5rem; }
  .oral-anatomy__head { margin-bottom: 1.25rem; }
  .oral-anatomy__label { display: block; font-family: var(--prog-mono); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--subject-accent-text); margin-bottom: 0.4rem; }
  .oral-anatomy__prompt { font-size: 1rem; color: var(--text-primary); margin: 0; }
  .oral-anatomy__meta { display: inline-block; margin-left: 0.5rem; font-size: 0.78rem; color: var(--text-muted); font-style: normal; }
  .oral-anatomy__note { margin-top: 0.75rem; font-size: 0.85rem; color: var(--text-muted); font-style: italic; }

  .oral-row {
    display: grid;
    grid-template-columns: 130px 1fr 1fr;
    gap: 1rem;
    align-items: start;
    padding: 0.9rem 0;
    border-top: 1px dashed var(--border-color);
  }
  .oral-row:first-of-type { border-top: none; }
