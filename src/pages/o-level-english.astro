// ── Oral Communication (Paper 4) — real excerpts from A-Worthy's
// STAND/PEEL model-answer book (SEAB Spoken Interaction, 2022–2025) ──
const oralQuestionTypes = [
  { tag: 'Position', prompt: '“What is your view?” / “Do you agree?”', desc: 'Take a clear stand, defend it with two points, concede the other side fairly, then reaffirm.' },
  { tag: 'Recommendation', prompt: '“What can be done?” / “What suggestions?”', desc: 'Offer specific, practical actions and explain why each one would work.' },
  { tag: 'Reflective', prompt: '“Why do you say so?” / “What might they feel?”', desc: 'Explore the idea thoughtfully; weigh more than one possibility before settling.' },
  { tag: 'Personal', prompt: '“Tell me about…” / “What do you like…?”', desc: 'Share a genuine experience with vivid, sincere detail; explain why it matters.' },
];

const oralSpheres = [
  { name: 'Self', line: 'Saving electricity, cutting waste, choosing to walk rather than ride — small choices that build responsibility.' },
  { name: 'Family & Peers', line: 'Recycling at home, reminding one another to switch off lights — one habit spreading into a group.' },
  { name: 'School & Community', line: 'Recycling drives, tree-planting, awareness projects — students are not too young for collective action.' },
  { name: 'Singapore', line: 'A direct stake in the Singapore Green Plan 2030 — this generation will live with the results.' },
  { name: 'Global', line: 'A problem no single country can solve alone — the young have the most to gain from acting now.' },
];

const oralAnatomy = [
  { stage: 'STAND', label: 'Commit → signpost → flag balance', text: '“Yes, I strongly believe we should keep our street hawkers in Singapore, and I would defend this through two points, while addressing a common concern.”', why: 'The position is committed in the first breath — a clear “Yes” — and the answer signals its own structure (“two points”) and its fairness (“a common concern”). The examiner now knows exactly what is coming.' },
  { stage: 'P', label: 'Point', text: '“Firstly, hawkers are a treasured part of our culture and identity.”', why: 'A single, clear claim. It is not yet explained; it simply states what this paragraph will argue, so the reasoning has a spine.' },
  { stage: 'E', label: 'Evidence', text: '“Hawker food is something Singaporeans of all backgrounds enjoy and take pride in, so much so that our hawker culture has been recognised by UNESCO.”', why: 'Concrete, not vague: a shared national experience plus a verifiable fact. Specific evidence is far more persuasive than a general assertion.' },
  { stage: 'E', label: 'Explanation', text: '“This matters because hawker culture is woven into who we are as a nation… UNESCO recognition confirms this is not merely local sentiment but something of real cultural significance.”', why: 'This is where the marks are won. The answer explains why the evidence matters, lifting the point from opinion to genuine cultural significance.' },
  { stage: 'L', label: 'Link', text: '“So we should keep hawkers because they are a living part of our national identity.”', why: 'A one-line link returns to the exact terms of the question. It keeps the paragraph disciplined and on task.' },
  { stage: 'COUNTER', label: 'Fair concession', text: '“Some might worry about hygiene or the hardships of the trade, but these can be managed through proper regulation and support, as Singapore already does well, rather than by giving hawkers up.”', why: 'A fair concession shows balanced judgement: the answer names the real objection, then rebuts it. Acknowledging the other side strengthens the case.' },
  { stage: 'LINK', label: 'Final reaffirm', text: '“So overall, I firmly believe we should keep our street hawkers, because they nourish us, preserve our heritage and unite our community.”', why: 'The conclusion gathers the threads and reaffirms the stand with a memorable final image — answering the question fully without repeating earlier wording.' },
];

// ── Paper 4 exam map + Part 2 exchange — from A-Worthy's PEEL Model Answer
// Scheme (video-based format, Syllabus 1184; SEAB band descriptors verified) ──
const oralParts = [
  { part: 'Part 1', name: 'Planned Response', marks: '15 marks · 10 response + 5 delivery', desc: 'One planned speech built on PEEL: a clear stance, two developed reasons, a brief counter-view, and a conclusion — delivered in roughly two minutes after ten minutes of preparation.' },
  { part: 'Part 2', name: 'Spoken Interaction', marks: '15 marks', desc: 'A live discussion with the examiner. One tight PEEL unit per question, with the Link written to keep the conversation open so the discussion can be sustained.' },
];

// The Part 1 planned speech, mapped — stance, two PEEL reasons, counter-view,
// conclusion (each reason's E/E/L rows omitted for length; all quotes verbatim)
const oralPlanned = [
  { stage: 'Stance', text: '“Balance and rhythm are essential for young people because a steady daily structure protects both academic performance and mental health.”' },
  { stage: 'Reason 1 · Point', text: '“My first reason is that a regular rhythm gives the day a dependable structure, and that structure is what allows sustained effort over time.”' },
  { stage: 'Reason 2 · Point', text: '“My second and stronger reason is that balance protects mental well-being, which for young people today is under real pressure.”' },
  { stage: 'The other view', text: '“It is true that too rigid a rhythm can feel mechanical, and life should leave room for spontaneity. But a healthy rhythm is a flexible framework, not a cage.”' },
  { stage: 'Conclusion', text: '“On balance, I believe rhythm and balance are important for young people. They sustain our work, protect our health, and still allow the flexibility that makes life enjoyable.”' },
];

const oralExchanges = [
  {
    q: '“How does the video make you feel about the pace of modern life?”',
    rows: [
      { stage: 'P', label: 'Point', text: '“The video leaves me feeling that modern life is faster than it needs to be, and that we rarely pause.”' },
      { stage: 'E', label: 'Evidence', text: '“The most intense stretch of the film is genuinely uncomfortable to watch — the images pile up so quickly that the eye cannot rest on any single one.”' },
      { stage: 'E', label: 'Explanation', text: '“I think that discomfort is intentional; it makes me reflect on how my own days can blur together when I move from school to tuition to homework without a break. The film suggests that speed itself is not the problem — the problem is never slowing down.”' },
      { stage: 'L', label: 'Link', text: '“So rather than making me anxious, it actually makes me want to build small pauses into my day on purpose.”' },
    ],
  },
  {
    q: '“What different ‘rhythms’ or moods did you notice in the video?”',
    rows: [
      { stage: 'P', label: 'Point', text: '“I noticed a clear three-part movement in the film’s mood — calm, then intensity, then a return to calm.”' },
      { stage: 'E', label: 'Evidence', text: '“The piece opens gently with soft light and slow, unhurried images, builds into fast cutting and crowded, energetic scenes in the middle, and finally settles back into quiet stillness at the end.”' },
      { stage: 'E', label: 'Explanation', text: '“To me that structure mirrors an ordinary day: a peaceful start, a demanding and busy core, and a wind-down in the evening. The filmmaker seems to be showing that intensity is natural, but so is the return to rest.”' },
      { stage: 'L', label: 'Link', text: '“That contrast is really what made the video memorable for me — it turns something as everyday as a daily routine into something that feels meaningful.”' },
    ],
  },
];

const oralSets = ['The Rhythm of Daily Life', 'Being Present: Attendance', 'The Passage of Time', 'Daily Routines and the Passing of Time'];
