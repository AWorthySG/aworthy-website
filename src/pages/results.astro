---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Our Results — A Worthy | Proven Academic Excellence in Singapore">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="r-hero">
    <div class="r-container">
      <span class="eyebrow">Results</span>
      <h1>Proven track record<br />of excellence</h1>
      <p class="r-hero-sub">
        Year after year, our students achieve outstanding O-Level English results through the CASE Method.
      </p>
    </div>
  </section>

  <!-- ===== OVERVIEW STATS ===== -->
  <section class="r-section">
    <div class="r-container">
      <div class="r-stats-row">
        <div class="r-stat" data-animate="reveal-up" data-animate-delay="1">
          <span class="r-stat-num" data-count="90" data-suffix="%">90%</span>
          <span class="r-stat-label">A1-B3 Rate</span>
        </div>
        <div class="r-stat" data-animate="reveal-up" data-animate-delay="2">
          <span class="r-stat-num">6:1</span>
          <span class="r-stat-label">Max Class Size</span>
        </div>
        <div class="r-stat" data-animate="reveal-up" data-animate-delay="3">
          <span class="r-stat-num" data-count="100" data-suffix="+">100+</span>
          <span class="r-stat-label">Students Taught</span>
        </div>
        <div class="r-stat" data-animate="reveal-up" data-animate-delay="4">
          <span class="r-stat-num">3 months</span>
          <span class="r-stat-label">Avg. Improvement Time</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== O-LEVEL ENGLISH 2025 ===== -->
  <section class="r-section" id="olevel">
    <div class="r-container">
      <span class="eyebrow">O-Level English 2025</span>
      <h2 class="r-heading" data-animate="reveal-up">Component breakdown</h2>
      <p class="r-subtitle">Our students consistently outperform national averages across every English Language component.</p>

      <div class="r-cards-3 r-cards-5">
        <div class="r-card" data-animate="reveal-up" data-animate-delay="1">
          <div class="r-card-top">
            <span class="r-card-subject">Comprehension</span>
            <span class="r-card-pct">92%</span>
          </div>
          <div class="r-bar-track">
            <div class="r-bar-fill" style="width: 92%;"></div>
          </div>
          <span class="r-card-note">A1 - B3</span>
        </div>
        <div class="r-card" data-animate="reveal-up" data-animate-delay="2">
          <div class="r-card-top">
            <span class="r-card-subject">Continuous Writing</span>
            <span class="r-card-pct">88%</span>
          </div>
          <div class="r-bar-track">
            <div class="r-bar-fill" style="width: 88%;"></div>
          </div>
          <span class="r-card-note">A1 - B3</span>
        </div>
        <div class="r-card" data-animate="reveal-up" data-animate-delay="3">
          <div class="r-card-top">
            <span class="r-card-subject">Summary</span>
            <span class="r-card-pct">90%</span>
          </div>
          <div class="r-bar-track">
            <div class="r-bar-fill" style="width: 90%;"></div>
          </div>
          <span class="r-card-note">A1 - B3</span>
        </div>
        <div class="r-card" data-animate="reveal-up" data-animate-delay="4">
          <div class="r-card-top">
            <span class="r-card-subject">Oral</span>
            <span class="r-card-pct">85%</span>
          </div>
          <div class="r-bar-track">
            <div class="r-bar-fill" style="width: 85%;"></div>
          </div>
          <span class="r-card-note">A1 - B3</span>
        </div>
        <div class="r-card" data-animate="reveal-up" data-animate-delay="5">
          <div class="r-card-top">
            <span class="r-card-subject">Situational Writing</span>
            <span class="r-card-pct">91%</span>
          </div>
          <div class="r-bar-track">
            <div class="r-bar-fill" style="width: 91%;"></div>
          </div>
          <span class="r-card-note">A1 - B3</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== YEAR-OVER-YEAR ===== -->
  <section class="r-section">
    <div class="r-container">
      <span class="eyebrow">Growth</span>
      <h2 class="r-heading" data-animate="reveal-up">Consistent improvement, year after year</h2>
      <p class="r-subtitle">Our commitment to teaching excellence is reflected in our steadily improving results.</p>

      <div class="r-cards-3">
        <div class="r-card" data-animate="reveal-up">
          <h3 class="r-yoy-title">O-Level English A1-B3 Rate</h3>
          <div class="r-yoy-rows">
            <div class="r-yoy-row">
              <span class="r-yoy-year">2023</span>
              <div class="r-bar-track r-bar-sm">
                <div class="r-bar-fill" style="width: 78%;"></div>
              </div>
              <span class="r-yoy-val">78%</span>
            </div>
            <div class="r-yoy-row">
              <span class="r-yoy-year">2024</span>
              <div class="r-bar-track r-bar-sm">
                <div class="r-bar-fill" style="width: 85%;"></div>
              </div>
              <span class="r-yoy-val">85%</span>
            </div>
            <div class="r-yoy-row">
              <span class="r-yoy-year">2025</span>
              <div class="r-bar-track r-bar-sm">
                <div class="r-bar-fill" style="width: 90%;"></div>
              </div>
              <span class="r-yoy-val">90%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GRADE TRANSFORMATIONS ===== -->
  <section class="r-section">
    <div class="r-container">
      <span class="eyebrow">Before &amp; After</span>
      <h2 class="r-heading" data-animate="reveal-up">Grade transformations</h2>
      <p class="r-subtitle">Real grade improvements from our students in 2024-2025.</p>

      <div class="grade-table" data-animate="reveal-up">
        <div class="grade-row grade-header">
          <span>Student</span>
          <span>Before</span>
          <span></span>
          <span>After</span>
          <span>Duration</span>
        </div>
        <div class="grade-row">
          <span class="grade-name">Sarah T.</span>
          <span class="grade-before">C5</span>
          <span class="grade-arrow">&rarr;</span>
          <span class="grade-after">A2</span>
          <span class="grade-time">3 months</span>
        </div>
        <div class="grade-row">
          <span class="grade-name">Marcus L.</span>
          <span class="grade-before">D7</span>
          <span class="grade-arrow">&rarr;</span>
          <span class="grade-after">B3</span>
          <span class="grade-time">4 months</span>
        </div>
        <div class="grade-row">
          <span class="grade-name">Priya K.</span>
          <span class="grade-before">C6</span>
          <span class="grade-arrow">&rarr;</span>
          <span class="grade-after">A1</span>
          <span class="grade-time">5 months</span>
        </div>
        <div class="grade-row">
          <span class="grade-name">Wei Jie C.</span>
          <span class="grade-before">B4</span>
          <span class="grade-arrow">&rarr;</span>
          <span class="grade-after">A2</span>
          <span class="grade-time">2 months</span>
        </div>
        <div class="grade-row">
          <span class="grade-name">Aisha M.</span>
          <span class="grade-before">C5</span>
          <span class="grade-arrow">&rarr;</span>
          <span class="grade-after">B3</span>
          <span class="grade-time">3 months</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SUCCESS STORIES ===== -->
  <section class="r-section">
    <div class="r-container">
      <span class="eyebrow">Student Stories</span>
      <h2 class="r-heading" data-animate="reveal-up">Real transformations, real students</h2>
      <p class="r-subtitle">See how A Worthy made the difference.</p>

      <img src="/images/illustrations/results-chart.svg" alt="Results improvement chart" class="results-illustration" loading="lazy" />

      <div class="r-cards-3">
        <div class="r-card r-story-card" data-animate="reveal-up" data-animate-delay="1">
          <span class="r-story-badge">O-Level English</span>
          <h3 class="r-story-name">Sarah</h3>
          <p class="r-story-school">Sec 4 — 3 months with A-Worthy</p>
          <div class="r-story-grades">
            <div class="r-grade-block">
              <span class="r-grade-label">Before</span>
              <span class="r-grade-val r-grade-before">D7</span>
            </div>
            <span class="r-grade-arrow">&rarr;</span>
            <div class="r-grade-block">
              <span class="r-grade-label">O-Level Result</span>
              <span class="r-grade-val r-grade-after">A2</span>
            </div>
          </div>
          <p class="r-story-subject">English Language</p>
          <p class="r-story-quote">"The CASE Method completely changed how I approach comprehension questions."</p>
        </div>

        <div class="r-card r-story-card" data-animate="reveal-up" data-animate-delay="2">
          <span class="r-story-badge">O-Level English</span>
          <h3 class="r-story-name">Aiden</h3>
          <p class="r-story-school">Sec 3 — 8 weeks with A-Worthy</p>
          <div class="r-story-grades">
            <div class="r-grade-block">
              <span class="r-grade-label">Before</span>
              <span class="r-grade-val r-grade-before">C5</span>
            </div>
            <span class="r-grade-arrow">&rarr;</span>
            <div class="r-grade-block">
              <span class="r-grade-label">Result</span>
              <span class="r-grade-val r-grade-after">B3</span>
            </div>
          </div>
          <p class="r-story-subject">English Language</p>
          <p class="r-story-quote">"I finally understand how to structure my essays properly."</p>
        </div>

        <div class="r-card r-story-card" data-animate="reveal-up" data-animate-delay="3">
          <span class="r-story-badge">O-Level English</span>
          <h3 class="r-story-name">Priya</h3>
          <p class="r-story-school">Sec 4 — 4 months with A-Worthy</p>
          <div class="r-story-grades">
            <div class="r-grade-block">
              <span class="r-grade-label">Before</span>
              <span class="r-grade-val r-grade-before">B4</span>
            </div>
            <span class="r-grade-arrow">&rarr;</span>
            <div class="r-grade-block">
              <span class="r-grade-label">O-Level Result</span>
              <span class="r-grade-val r-grade-after">A1</span>
            </div>
          </div>
          <p class="r-story-subject">English Language</p>
          <p class="r-story-quote">"The legal reasoning approach made inference questions click."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="r-cta">
    <div class="r-container">
      <span class="eyebrow">Get Started</span>
      <h2 class="r-cta-heading" data-animate="reveal-up">Your child could see results like these</h2>
      <p class="r-cta-sub">Join the students who have transformed their English grades with A-Worthy. Book a free assessment today.</p>
      <div class="r-cta-actions">
        <a href="/contact/" class="r-btn-primary">Book Free Assessment</a>
        <a href="https://wa.me/6591234567" class="r-btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --r-bg: var(--bg-primary);
    --r-bg-card: rgba(255, 255, 255, 0.03);
    --r-border: var(--border-color);
    --r-orange: var(--color-accent);
    --r-white: #ffffff;
    --r-white-70: var(--text-secondary);
    --r-white-50: var(--text-muted);
    --r-white-30: rgba(255, 255, 255, 0.3);
    --r-white-10: rgba(255, 255, 255, 0.06);
    --r-font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --r-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: inline-block;
    font-family: var(--r-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--r-orange);
    margin-bottom: 1.25rem;
  }

  /* ===== CONTAINER ===== */
  .r-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ===== HERO ===== */
  .r-hero {
    background: var(--r-bg);
    padding: calc(var(--header-height) + 3rem) 0 2rem;
    text-align: center;
  }

  .r-hero h1 {
    font-family: var(--r-font);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--r-white);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
  }

  .r-hero-sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--r-white-50);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ===== SECTIONS ===== */
  .r-section {
    background: var(--r-bg);
    padding: 5rem 0;
    border-top: 1px solid var(--r-border);
  }

  .r-heading {
    font-family: var(--r-font);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--r-white);
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }

  .r-subtitle {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--r-white-50);
    max-width: 600px;
    margin: 0 0 3rem;
  }

  /* ===== STATS ROW ===== */
  .r-stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--r-border);
    border: 1px solid var(--r-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .r-stat {
    background: var(--r-bg);
    text-align: center;
    padding: 2.5rem 1rem;
  }

  .r-stat-num {
    display: block;
    font-family: var(--r-font);
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--r-white);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .r-stat-label {
    display: block;
    font-family: var(--r-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--r-white-50);
    margin-top: 0.75rem;
  }

  /* ===== CARDS GRID ===== */
  .r-cards-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .r-cards-5 {
    grid-template-columns: repeat(3, 1fr);
  }

  .r-card {
    background: var(--r-bg-card);
    border: 1px solid var(--r-border);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .r-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }

  .r-card-subject {
    font-family: var(--r-font);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--r-white);
  }

  .r-card-pct {
    font-family: var(--r-font);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--r-orange);
    letter-spacing: -0.02em;
  }

  .r-card-note {
    display: block;
    font-family: var(--r-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--r-white-30);
    margin-top: 0.75rem;
  }

  /* ===== PROGRESS BARS ===== */
  .r-bar-track {
    width: 100%;
    height: 4px;
    background: var(--r-white-10);
    border-radius: 2px;
    overflow: hidden;
  }

  .r-bar-sm {
    height: 3px;
  }

  .r-bar-fill {
    height: 100%;
    background: var(--r-orange);
    border-radius: 2px;
    transition: width 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ===== HIGHLIGHT BANNER ===== */
  .r-highlight {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(232, 113, 58, 0.08);
    border: 1px solid rgba(232, 113, 58, 0.2);
    border-radius: 12px;
    padding: 1.25rem 1.75rem;
    margin-top: 2rem;
  }

  .r-highlight-accent {
    color: var(--r-orange);
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .r-highlight p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--r-white-70);
    margin: 0;
  }

  .r-highlight strong {
    color: var(--r-white);
  }

  /* ===== YEAR-OVER-YEAR ===== */
  .r-yoy-title {
    font-family: var(--r-font);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--r-white);
    margin: 0 0 1.25rem;
  }

  .r-yoy-rows {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .r-yoy-row {
    display: grid;
    grid-template-columns: 40px 1fr 40px;
    align-items: center;
    gap: 0.75rem;
  }

  .r-yoy-year {
    font-family: var(--r-mono);
    font-size: 0.7rem;
    color: var(--r-white-30);
    letter-spacing: 0.05em;
  }

  .r-yoy-val {
    font-family: var(--r-font);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--r-orange);
    text-align: right;
  }

  .results-illustration {
    max-width: 500px;
    margin: 0 auto;
    display: block;
  }

  /* ===== PLACEHOLDER IMAGE ===== */
  .r-placeholder-img {
    background: var(--bg-secondary);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--border-color);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px dashed var(--border-color);
    border-radius: 6px;
    width: 100%;
    margin-bottom: 2.5rem;
  }

  /* ===== STORY CARDS ===== */
  .r-story-card {
    display: flex;
    flex-direction: column;
  }

  .r-story-badge {
    display: inline-block;
    width: fit-content;
    font-family: var(--r-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--r-bg);
    background: var(--r-orange);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .r-story-name {
    font-family: var(--r-font);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--r-white);
    margin: 0 0 0.15rem;
  }

  .r-story-school {
    font-size: 0.8rem;
    color: var(--r-white-30);
    margin: 0 0 1.25rem;
  }

  .r-story-grades {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--r-border);
    border-bottom: 1px solid var(--r-border);
  }

  .r-grade-block {
    text-align: center;
  }

  .r-grade-label {
    display: block;
    font-family: var(--r-mono);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--r-white-30);
    margin-bottom: 0.35rem;
  }

  .r-grade-val {
    display: inline-block;
    font-family: var(--r-font);
    font-size: 1.5rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    line-height: 1.2;
  }

  .r-grade-before {
    background: rgba(239, 68, 68, 0.12);
    color: #f87171;
  }

  .r-grade-after {
    background: rgba(52, 211, 153, 0.12);
    color: #6ee7b7;
  }

  .r-grade-arrow {
    font-size: 1.25rem;
    color: var(--r-white-30);
    font-weight: 300;
  }

  .r-story-subject {
    font-family: var(--r-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--r-orange);
    text-align: center;
    margin: 0 0 1rem;
  }

  .r-story-quote {
    font-size: 0.9rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--r-white-50);
    margin: 0;
    flex-grow: 1;
  }

  /* ===== CTA ===== */
  .r-cta {
    background: var(--r-bg);
    border-top: 1px solid var(--r-border);
    padding: 6rem 0;
    text-align: center;
  }

  .r-cta-heading {
    font-family: var(--r-font);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--r-white);
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }

  .r-cta-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--r-white-50);
    max-width: 550px;
    margin: 0 auto 2.5rem;
  }

  .r-cta-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .r-btn-primary {
    display: inline-block;
    font-family: var(--r-font);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--r-white);
    background: var(--r-orange);
    border: 1px solid var(--r-orange);
    padding: 0.85rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .r-btn-primary:hover {
    opacity: 0.85;
  }

  .r-btn-outline {
    display: inline-block;
    font-family: var(--r-font);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--r-white);
    background: transparent;
    border: 1px solid var(--r-border);
    padding: 0.85rem 2rem;
    border-radius: 8px;
