---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Our Results — A Worthy | Proven Academic Excellence in Singapore">
  <Header slot="header" />

  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <div class="container">
      <span class="hero-badge">Verified Results, Real Impact</span>
      <h1>Our <span class="highlight">Results</span></h1>
      <p class="hero-subtitle">
        Year after year, our students achieve outstanding results across PSLE, GCE O-Level, and A-Level examinations.
        These numbers reflect the dedication of our students, parents, and tutors working together.
      </p>
    </div>
  </section>

  <!-- ===== OVERVIEW STATS ===== -->
  <section class="section overview-stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number">95%</span>
          <span class="stat-label">PSLE A/A*</span>
          <span class="stat-detail">in Mathematics</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">90%</span>
          <span class="stat-label">O-Level A1-A2</span>
          <span class="stat-detail">in Mathematics</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">88%</span>
          <span class="stat-label">Distinction</span>
          <span class="stat-detail">in Science</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">500+</span>
          <span class="stat-label">Students</span>
          <span class="stat-detail">enrolled annually</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">10+</span>
          <span class="stat-label">Years</span>
          <span class="stat-detail">of excellence</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PSLE RESULTS 2025 ===== -->
  <section class="section results-section" id="psle">
    <div class="container">
      <h2 class="section-title">PSLE Results 2025</h2>
      <p class="section-subtitle">Our Primary 6 cohort delivered exceptional results, with many students achieving top Achievement Levels.</p>

      <div class="results-grid">
        <div class="result-card">
          <div class="result-header">
            <h3>Mathematics</h3>
            <span class="result-percent">96%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" style="width: 96%;"></div>
          </div>
          <p class="result-desc">AL1 - AL3</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>Science</h3>
            <span class="result-percent">94%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" style="width: 94%;"></div>
          </div>
          <p class="result-desc">AL1 - AL3</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>English</h3>
            <span class="result-percent">91%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" style="width: 91%;"></div>
          </div>
          <p class="result-desc">AL1 - AL3</p>
        </div>
      </div>

      <div class="highlight-banner">
        <span class="highlight-icon">&#9733;</span>
        <p><strong>15 students</strong> scored a PSLE aggregate of <strong>8 or below</strong> — placing them among the top performers nationwide.</p>
      </div>
    </div>
  </section>

  <!-- ===== GCE O-LEVEL RESULTS 2025 ===== -->
  <section class="section results-section alt-bg" id="olevel">
    <div class="container">
      <h2 class="section-title">GCE O-Level Results 2025</h2>
      <p class="section-subtitle">Our Secondary students consistently outperform national averages across all key subjects.</p>

      <div class="results-grid">
        <div class="result-card">
          <div class="result-header">
            <h3>E Mathematics</h3>
            <span class="result-percent">92%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-secondary" style="width: 92%;"></div>
          </div>
          <p class="result-desc">A1 - A2</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>A Mathematics</h3>
            <span class="result-percent">88%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-secondary" style="width: 88%;"></div>
          </div>
          <p class="result-desc">A1 - A2</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>Pure Chemistry</h3>
            <span class="result-percent">90%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-secondary" style="width: 90%;"></div>
          </div>
          <p class="result-desc">A1 - A2</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>Pure Physics</h3>
            <span class="result-percent">87%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-secondary" style="width: 87%;"></div>
          </div>
          <p class="result-desc">A1 - A2</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>English</h3>
            <span class="result-percent">85%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-secondary" style="width: 85%;"></div>
          </div>
          <p class="result-desc">A1 - B3</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GCE A-LEVEL RESULTS 2025 ===== -->
  <section class="section results-section" id="alevel">
    <div class="container">
      <h2 class="section-title">GCE A-Level Results 2025</h2>
      <p class="section-subtitle">Our JC students demonstrate strong mastery of H1 and H2 subjects at the national examinations.</p>

      <div class="results-grid">
        <div class="result-card">
          <div class="result-header">
            <h3>H2 Mathematics</h3>
            <span class="result-percent">85%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-accent" style="width: 85%;"></div>
          </div>
          <p class="result-desc">A - B</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>H2 Chemistry</h3>
            <span class="result-percent">82%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-accent" style="width: 82%;"></div>
          </div>
          <p class="result-desc">A - B</p>
        </div>

        <div class="result-card">
          <div class="result-header">
            <h3>H1 General Paper</h3>
            <span class="result-percent">78%</span>
          </div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill fill-accent" style="width: 78%;"></div>
          </div>
          <p class="result-desc">A - B</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== YEAR-OVER-YEAR IMPROVEMENT ===== -->
  <section class="section yoy-section alt-bg">
    <div class="container">
      <h2 class="section-title">Consistent Growth, Year After Year</h2>
      <p class="section-subtitle">Our commitment to teaching excellence is reflected in our steadily improving results.</p>

      <div class="yoy-grid">
        <div class="yoy-card">
          <h3>PSLE Maths (AL1-AL3)</h3>
          <div class="yoy-bars">
            <div class="yoy-row">
              <span class="yoy-year">2022</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill" style="width: 88%;"></div>
              </div>
              <span class="yoy-val">88%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2023</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill" style="width: 91%;"></div>
              </div>
              <span class="yoy-val">91%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2024</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill" style="width: 93%;"></div>
              </div>
              <span class="yoy-val">93%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2025</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill" style="width: 96%;"></div>
              </div>
              <span class="yoy-val">96%</span>
            </div>
          </div>
        </div>

        <div class="yoy-card">
          <h3>O-Level E Maths (A1-A2)</h3>
          <div class="yoy-bars">
            <div class="yoy-row">
              <span class="yoy-year">2022</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-secondary" style="width: 84%;"></div>
              </div>
              <span class="yoy-val">84%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2023</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-secondary" style="width: 87%;"></div>
              </div>
              <span class="yoy-val">87%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2024</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-secondary" style="width: 89%;"></div>
              </div>
              <span class="yoy-val">89%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2025</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-secondary" style="width: 92%;"></div>
              </div>
              <span class="yoy-val">92%</span>
            </div>
          </div>
        </div>

        <div class="yoy-card">
          <h3>A-Level H2 Maths (A-B)</h3>
          <div class="yoy-bars">
            <div class="yoy-row">
              <span class="yoy-year">2022</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-accent" style="width: 76%;"></div>
              </div>
              <span class="yoy-val">76%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2023</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-accent" style="width: 79%;"></div>
              </div>
              <span class="yoy-val">79%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2024</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-accent" style="width: 82%;"></div>
              </div>
              <span class="yoy-val">82%</span>
            </div>
            <div class="yoy-row">
              <span class="yoy-year">2025</span>
              <div class="progress-bar-track small">
                <div class="progress-bar-fill fill-accent" style="width: 85%;"></div>
              </div>
              <span class="yoy-val">85%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STUDENT SUCCESS STORIES ===== -->
  <section class="section success-stories">
    <div class="container">
      <h2 class="section-title">Student Success Stories</h2>
      <p class="section-subtitle">Real transformations from real students — see how A Worthy made the difference.</p>

      <img src="/images/general/results-celebration.jpg" alt="Students celebrating their exam results" class="results-img" loading="lazy" />

      <div class="stories-grid">
        <div class="story-card">
          <div class="story-badge">PSLE 2025</div>
          <h3>Chloe Tan</h3>
          <p class="story-school">Nanyang Primary School</p>
          <div class="story-grades">
            <div class="grade-change">
              <div class="grade-before">
                <span class="grade-label">Before (P5 SA2)</span>
                <span class="grade-value poor">AL6</span>
              </div>
              <span class="grade-arrow">&rarr;</span>
              <div class="grade-after">
                <span class="grade-label">PSLE Result</span>
                <span class="grade-value excellent">AL1</span>
              </div>
            </div>
          </div>
          <p class="story-subject">Mathematics</p>
          <p class="story-quote">"I used to dread Maths, but Teacher Sarah broke everything down so clearly. I finally understood problem sums and scored AL1!"</p>
        </div>

        <div class="story-card">
          <div class="story-badge">O-Level 2025</div>
          <h3>Arjun Krishnan</h3>
          <p class="story-school">Bukit Panjang Govt. High School</p>
          <div class="story-grades">
            <div class="grade-change">
              <div class="grade-before">
                <span class="grade-label">Before (Sec 3 EOY)</span>
                <span class="grade-value poor">C5</span>
              </div>
              <span class="grade-arrow">&rarr;</span>
              <div class="grade-after">
                <span class="grade-label">O-Level Result</span>
                <span class="grade-value excellent">A2</span>
              </div>
            </div>
          </div>
          <p class="story-subject">A Mathematics</p>
          <p class="story-quote">"A Worthy's structured revision plan and weekly timed practices helped me build confidence. I never thought I'd get an A2 in A Maths."</p>
        </div>

        <div class="story-card">
          <div class="story-badge">A-Level 2025</div>
          <h3>Wei Ling Ng</h3>
          <p class="story-school">Hwa Chong Institution</p>
          <div class="story-grades">
            <div class="grade-change">
              <div class="grade-before">
                <span class="grade-label">Before (JC1 Promo)</span>
                <span class="grade-value poor">D</span>
              </div>
              <span class="grade-arrow">&rarr;</span>
              <div class="grade-after">
                <span class="grade-label">A-Level Result</span>
                <span class="grade-value excellent">A</span>
              </div>
            </div>
          </div>
          <p class="story-subject">H2 Chemistry</p>
          <p class="story-quote">"The small class setting meant my tutor could address my weak topics directly. Going from a D to an A felt surreal."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA BANNER ===== -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <h2>Your Child Could Be Our Next Success Story</h2>
      <p>Join the hundreds of students who have achieved academic breakthroughs with A Worthy. Book a <strong>free diagnostic assessment</strong> today.</p>
      <div class="cta-actions">
        <a href="/contact/" class="btn btn-accent btn-lg">Book Free Trial</a>
        <a href="https://wa.me/6591234567" class="btn btn-secondary btn-lg" style="border-color: #FFF; color: #FFF;">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .results-img {
    width: 100%;
    max-height: 350px;
    object-fit: cover;
    border-radius: var(--border-radius-lg);
    margin: var(--space-xl) 0;
    box-shadow: 0 4px 15px var(--shadow-color);
  }

  /* ===== PAGE HERO ===== */
  .page-hero {
    padding: var(--space-4xl) 0 var(--space-3xl);
    background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--bg-secondary);
    border: 1px solid var(--color-accent);
    color: var(--color-primary);
    padding: var(--space-xs) var(--space-md);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .page-hero h1 {
    margin-bottom: var(--space-lg);
  }

  .highlight {
    color: var(--color-primary);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.8;
    max-width: 700px;
    margin: 0 auto;
    color: var(--text-secondary);
  }

  /* ===== SECTION HELPERS ===== */
  .section {
    padding: var(--space-4xl) 0;
  }

  .alt-bg {
    background: var(--bg-secondary);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-secondary);
    max-width: 650px;
    margin: 0 auto var(--space-3xl);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* ===== OVERVIEW STATS ===== */
  .overview-stats {
    background: var(--bg-secondary);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-xl);
  }

  .stat-card {
    text-align: center;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-2xl) var(--space-lg);
    box-shadow: 0 2px 12px var(--shadow-color);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px var(--shadow-hover);
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.1;
  }

  .stat-label {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-top: var(--space-xs);
  }

  .stat-detail {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* ===== RESULTS CARDS ===== */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .result-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: 0 2px 12px var(--shadow-color);
  }

  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .result-header h3 {
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .result-percent {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .result-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: var(--space-sm);
    font-weight: 500;
  }

  /* ===== PROGRESS BARS ===== */
  .progress-bar-track {
    width: 100%;
    height: 12px;
    background: var(--border-color);
    border-radius: 6px;
    overflow: hidden;
  }

  .progress-bar-track.small {
    height: 8px;
  }

  .progress-bar-fill {
    height: 100%;
    border-radius: 6px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    transition: width 1s ease-out;
  }

  .progress-bar-fill.fill-secondary {
    background: linear-gradient(90deg, var(--color-secondary) 0%, #4A7C7C 100%);
  }

  .progress-bar-fill.fill-accent {
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-light) 100%);
  }

  /* ===== HIGHLIGHT BANNER ===== */
  .highlight-banner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: #FFFFFF;
    padding: var(--space-xl) var(--space-2xl);
    border-radius: var(--border-radius-lg);
  }

  .highlight-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .highlight-banner p {
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* ===== YEAR-OVER-YEAR ===== */
  .yoy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .yoy-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-2xl);
    box-shadow: 0 2px 12px var(--shadow-color);
  }

  .yoy-card h3 {
    font-size: 1rem;
    margin-bottom: var(--space-lg);
    color: var(--text-primary);
    text-align: center;
  }

  .yoy-bars {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .yoy-row {
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    align-items: center;
    gap: var(--space-sm);
  }

  .yoy-year {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .yoy-val {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    text-align: right;
  }

  /* ===== SUCCESS STORIES ===== */
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .story-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-2xl);
    box-shadow: 0 2px 12px var(--shadow-color);
    position: relative;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .story-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px var(--shadow-hover);
  }

  .story-badge {
    display: inline-block;
    background: var(--color-accent);
    color: #2C1810;
    padding: 3px 12px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .story-card h3 {
    font-size: 1.2rem;
    margin-bottom: 2px;
  }

  .story-school {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
  }

  .story-grades {
    margin-bottom: var(--space-md);
  }

  .grade-change {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
  }

  .grade-before,
  .grade-after {
    text-align: center;
  }

  .grade-label {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }

  .grade-value {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
