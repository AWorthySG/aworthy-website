---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Best GP Tuition Singapore | H1 General Paper Tuition for JC Students | A-Worthy" description="Top-rated GP tuition in Singapore for JC 1-2 students. The CASE Method's legal-analytical framework builds essay argumentation, comprehension, and AQ mastery. Max 6 per class, online via Zoom." ogImage="/images/og-gp.png">
  <Header slot="header" />

  <!-- ===== PAGE HERO ===== -->
  <section class="prog-hero">
    <div class="container">
      <p class="eyebrow">H1 General Paper</p>
      <h1 class="prog-hero__heading">Top-Rated GP Tuition<br />in Singapore for JC Students</h1>
      <p class="prog-hero__sub">Master A-Level General Paper with the CASE Method &mdash; a legal-analytical framework that sharpens essay argumentation, comprehension accuracy, and critical thinking across all 12 GP content themes.</p>
    </div>
  </section>

  <!-- ===== NAV PILLS ===== -->
  <nav class="prog-nav" aria-label="Programme quick links">
    <div class="container prog-nav__inner" data-animate="reveal-up">
      <a href="#jc1" class="prog-nav__link">JC 1</a>
      <a href="#jc2" class="prog-nav__link">JC 2</a>
      <a href="#one-to-one" class="prog-nav__link">One-to-One</a>
      <a href="#syllabus" class="prog-nav__link">Syllabus Coverage</a>
      <a href="#approach" class="prog-nav__link">Our Approach</a>
    </div>
  </nav>

  <!-- ===== JC 1 PROGRAMME ===== -->
  <section class="prog-section" id="jc1">
    <div class="container">
      <p class="eyebrow">JC 1</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">JC 1 General Paper Foundation Programme</h2>
      <p class="prog-section__sub">Build the analytical habits, argument structures, and content knowledge your child needs to excel in GP from JC 1.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Foundation Programme</h3>
          <p class="prog-card__desc">Small group online sessions designed to develop core GP skills from JC 1 &mdash; argumentation fundamentals, comprehension techniques, and content fluency across the 12 GP themes &mdash; using the CASE Method&rsquo;s legal-analytical framework.</p>
          <ul class="prog-card__topics">
            <li>Argument construction &mdash; claims, evidence, reasoning, and rebuttals</li>
            <li>Essay planning &mdash; thesis-driven structure for argumentative and discursive essays</li>
            <li>Comprehension fundamentals &mdash; SAQ techniques and summary skills</li>
            <li>Content building across GP themes (science &amp; tech, politics, media, arts, environment, society)</li>
            <li>Critical reading &mdash; identifying assumptions and evaluating perspectives</li>
            <li>Language precision &mdash; academic register and vocabulary development</li>
          </ul>
          <div class="prog-card__meta">
            <span>90 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 360 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== JC 2 A-LEVEL INTENSIVE ===== -->
  <section class="prog-section" id="jc2">
    <div class="container">
      <p class="eyebrow">JC 2</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">JC 2 A-Level GP Intensive Programme</h2>
      <p class="prog-section__sub">Exam-focused GP preparation with timed essay practice, comprehension drills, and the detailed marker-style feedback that separates A from B grades.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">A-Level Intensive Programme</h3>
          <p class="prog-card__desc">Rigorous, exam-aligned preparation covering every component of the GCE A-Level H1 General Paper (8807) &mdash; with regular timed practice and individualised feedback on essay technique, comprehension accuracy, and argument quality.</p>
          <ul class="prog-card__topics">
            <li>Paper 1 Essay Writing &mdash; argumentative, discursive, and evaluative essays across all 12 content themes</li>
            <li>Paper 2 Comprehension &mdash; SAQ, AQ, summary, and author&rsquo;s craft analysis</li>
            <li>Application Question (AQ) mastery &mdash; evaluating arguments using Singapore context</li>
            <li>Timed essay practice with marker-style feedback</li>
            <li>Current affairs fluency &mdash; structured analysis of global and Singapore-specific issues</li>
            <li>Counter-argument and evaluation &mdash; the skills that separate A from B grades</li>
          </ul>
          <div class="prog-card__meta">
            <span>90 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 400 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ONE-TO-ONE COACHING ===== -->
  <section class="prog-section" id="one-to-one">
    <div class="container">
      <p class="eyebrow">One-to-One</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">One-to-One GP Tuition &amp; Coaching</h2>
      <p class="prog-section__sub">For students requiring targeted support on specific components or intensive exam preparation.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Individual Coaching</h3>
          <p class="prog-card__desc">Fully customised to the student&rsquo;s specific gaps &mdash; whether it&rsquo;s essay argumentation, comprehension technique, AQ strategy, or content knowledge. Individual online sessions via Zoom, scheduled at your convenience.</p>
          <div class="prog-card__meta">
            <span>Per session</span>
            <span>1 student</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 140 / session</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SYLLABUS COVERAGE ===== -->
  <section class="prog-section" id="syllabus">
    <div class="container">
      <p class="eyebrow">8807 Syllabus</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Full H1 General Paper syllabus coverage</h2>
      <p class="prog-section__sub">Every component and content theme in the Singapore-Cambridge GCE A-Level H1 General Paper syllabus (8807), taught with depth and precision.</p>

      <div class="card-grid card-grid--2">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Paper 1 &mdash; Essay</h3>
          <ul class="prog-card__topics">
            <li>Argumentative essays (single-perspective thesis)</li>
            <li>Discursive essays (balanced multi-perspective)</li>
            <li>Evaluative essays (assess extent / effectiveness)</li>
            <li>12 content themes: science &amp; tech, politics, economics, media, arts, environment, society, ethics, education, globalisation, governance, identity</li>
            <li>Singapore-specific and global perspectives</li>
            <li>Real-world examples and case studies</li>
          </ul>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="2">
          <h3 class="prog-card__title">Paper 2 &mdash; Comprehension</h3>
          <ul class="prog-card__topics">
            <li>Short-answer questions (SAQ) &mdash; inference, vocabulary in context, purpose</li>
            <li>Summary &mdash; identifying key points and paraphrasing under word limit</li>
            <li>Application Question (AQ) &mdash; evaluating author&rsquo;s arguments using own knowledge</li>
            <li>Author&rsquo;s craft &mdash; tone, language devices, rhetorical strategies</li>
            <li>Comparing perspectives across passages</li>
            <li>Answering techniques aligned with Cambridge mark schemes</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR APPROACH ===== -->
  <section class="prog-section" id="approach">
    <div class="container">
      <p class="eyebrow">Our Approach</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Why the CASE Method is a natural fit for General Paper</h2>

      <div class="card-grid card-grid--2">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">Legal-Analytical Framework</h3>
          <p class="prog-card__desc">GP and law are built on the same foundation &mdash; constructing watertight arguments, weighing evidence, and dismantling counter-arguments. Your child inherits the same intellectual discipline that law students spend three years developing, condensed into a teachable system that produces GP essays examiners can&rsquo;t ignore.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="2">
          <h3 class="prog-card__title">Content Mastery That Actually Transfers</h3>
          <p class="prog-card__desc">Memorising current affairs isn&rsquo;t enough &mdash; examiners reward students who can apply examples with precision. Your child builds a structured knowledge bank across all 12 GP themes, with every example pre-connected to multiple essay angles. One well-prepared example can earn marks across five different questions.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="3">
          <h3 class="prog-card__title">Essay Architecture That Earns Top Marks</h3>
          <p class="prog-card__desc">The difference between a B and an A in GP is almost never content knowledge &mdash; it&rsquo;s structure. Your child learns to build thesis-driven essays with layered arguments, embedded evaluation, and conclusions that demonstrate the independent thinking examiners actively look for. No more wandering paragraphs that run out of steam.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="4">
          <h3 class="prog-card__title">Comprehension Precision</h3>
          <p class="prog-card__desc">The Application Question alone is worth 10 marks &mdash; yet most students leave marks on the table because they don&rsquo;t know how to evaluate an author&rsquo;s argument systematically. Your child masters SAQ, summary, and AQ with techniques calibrated to the Cambridge mark scheme, so every answer hits the exact criteria examiners are checking.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FREE DIAGNOSTIC ASSESSMENT CTA ===== -->
  <section class="prog-cta">
    <div class="container prog-cta__inner">
      <p class="eyebrow">Get Started</p>
      <h2 class="prog-cta__heading" data-animate="reveal-up">Not sure which programme?</h2>
      <p class="prog-cta__sub">Book a free 20-minute diagnostic assessment. We&rsquo;ll review your child&rsquo;s recent GP paper and identify specific areas for improvement &mdash; no obligation, no sales pitch.</p>
      <div class="prog-cta__actions">
        <a href="/contact/" class="prog-cta__btn prog-cta__btn--primary">Book Assessment</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --prog-bg: var(--bg-primary);
    --prog-bg-card: var(--bg-card);
    --prog-border: var(--border-color);
    --prog-text: var(--text-primary);
    --prog-text-secondary: var(--text-secondary);
    --prog-accent: var(--color-accent);
    --prog-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --prog-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prog-accent);
    margin-bottom: 1rem;
  }

  /* ===== HERO ===== */
  .prog-hero {
    background: var(--prog-bg);
    padding: calc(var(--header-height) + 3rem) 0 3rem;
    text-align: center;
  }

  .prog-hero__heading {
    font-family: var(--prog-font);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 200;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .prog-hero__sub {
    font-family: var(--prog-font);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ===== NAV ===== */
  .prog-nav {
    background: var(--prog-bg);
    border-bottom: 1px solid var(--prog-border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 90;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .prog-nav::-webkit-scrollbar {
    display: none;
  }

  .prog-nav__inner {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: nowrap;
    min-width: max-content;
  }

  .prog-nav__link {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .prog-nav__link:hover {
    color: var(--prog-text);
    border-bottom-color: var(--prog-accent);
  }

  /* ===== SECTIONS ===== */
  .prog-section {
    background: var(--prog-bg);
    padding: 4rem 0;
    scroll-margin-top: 60px;
  }

  .prog-section + .prog-section {
    border-top: 1px solid var(--prog-border);
  }

  .prog-section__heading {
    font-family: var(--prog-font);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 200;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .prog-section__sub {
    font-family: var(--prog-font);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 600px;
    margin-bottom: 3.5rem;
  }

  /* ===== CARD GRID ===== */
  .card-grid {
    display: grid;
    gap: 1.5rem;
  }

  .card-grid--1 {
    grid-template-columns: 1fr;
    max-width: 640px;
  }

  .card-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  /* ===== PROGRAMME CARD ===== */
  .prog-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  @media (hover: hover) {
    .prog-card:hover {
      transform: translateY(-3px);
      border-color: var(--border-color);
    }
  }

  .prog-card__title {
    font-family: var(--prog-font);
    font-size: 1.15rem;
    font-weight: 300;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .prog-card__desc {
    font-family: var(--prog-font);
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .prog-card__topics {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    flex-grow: 1;
  }

  .prog-card__topics li {
    font-family: var(--prog-font);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--prog-text-secondary);
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--bg-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .prog-card__topics li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--prog-accent);
    transform: translateY(-50%);
  }

  .prog-card__topics li:last-child {
    border-bottom: none;
  }

  .prog-card__meta {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--prog-border);
    flex-wrap: wrap;
  }

  .prog-card__meta span {
    font-family: var(--prog-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
  }

  .prog-card__fee {
    font-family: var(--prog-font);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  /* ===== CTA ===== */
  .prog-cta {
    background: var(--prog-bg);
    border-top: 1px solid var(--prog-border);
    padding: 4rem 0;
  }

  .prog-cta__inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .prog-cta__heading {
    font-family: var(--prog-font);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 200;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .prog-cta__sub {
    font-family: var(--prog-font);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    margin-bottom: 2.5rem;
  }

  .prog-cta__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .prog-cta__btn {
    font-family: var(--prog-mono);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.9rem 2rem;
    border-radius: 0;
    transition: all 0.2s ease;
    cursor: pointer;
    display: inline-block;
  }

  .prog-cta__btn--primary {
    background: var(--prog-accent);
    color: var(--text-primary);
    border: 1px solid var(--prog-accent);
  }

  .prog-cta__btn--primary:hover {
    background: #d4632e;
    transform: translateY(-1px);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .card-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .prog-hero {
      padding: 6rem 0 3.5rem;
    }

    .prog-section {
      padding: 4rem 0;
    }

    .prog-nav__inner {
      gap: 1rem;
    }

    .card-grid--2 {
      grid-template-columns: 1fr;
    }

    .prog-card {
      padding: 1.5rem;
    }

    .prog-cta {
      padding: 4rem 0;
    }
  }

  @media (max-width: 480px) {
    .prog-hero__heading {
      font-size: 1.8rem;
    }

    .prog-nav__inner {
      gap: 0.6rem;
    }

    .prog-nav__link {
      font-size: 0.65rem;
    }

    .prog-cta__actions {
      flex-direction: column;
      align-items: center;
    }

    .prog-cta__btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
