---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const testimonials = [
  {
    name: 'Mrs. Linda Tan',
    context: 'Mother of Sec 4 student',
    avatar: 'LT',
    stars: 5,
    quote: 'My son\'s English went from C5 to A2 in three months. The CASE Method gave him a systematic way to approach every comprehension question — no more guessing.',
    featured: true,
  },
  {
    name: 'Ethan Lim',
    context: 'Sec 4 student',
    avatar: 'EL',
    stars: 5,
    quote: 'I used to dread essay writing. The structured approach taught me how to plan and argue properly. Got A1 for O-Levels.',
    featured: false,
  },
  {
    name: 'Mr. Rajesh Kumar',
    context: 'Father of Sec 3 student',
    avatar: 'RK',
    stars: 5,
    quote: 'What impressed me most was how the legal reasoning approach made inference questions click for my daughter. She actually enjoys English now.',
    featured: false,
  },
  {
    name: 'Mrs. Angela Wong',
    context: 'Mother of Sec 4 student',
    avatar: 'AW',
    stars: 5,
    quote: 'After switching to A-Worthy, my daughter\'s English jumped from D7 to B3. The small class size means real attention.',
    featured: true,
  },
  {
    name: 'Mr. Muhammad Faisal',
    context: 'Father of Sec 2 twins',
    avatar: 'MF',
    stars: 5,
    quote: 'Both my boys have improved significantly in their English. The analytical approach builds skills that help across all subjects.',
    featured: false,
  },
  {
    name: 'Ms. Jennifer Lee',
    context: 'Mother of Sec 3 student',
    avatar: 'JL',
    stars: 5,
    quote: 'We switched from a large tuition chain. The difference is night and day — focused, systematic, and my son actually understands why he\'s learning what he\'s learning.',
    featured: false,
  },
  {
    name: 'Ryan Ong',
    context: 'Sec 4 student',
    avatar: 'RO',
    stars: 5,
    quote: 'The CASE Method helped me go from barely passing to B3 in English. Summary was my weakest section and now it\'s my strongest.',
    featured: false,
  },
  {
    name: 'Mrs. Deepa Nair',
    context: 'Mother of Sec 2 student',
    avatar: 'DN',
    stars: 5,
    quote: 'I appreciate the detailed feedback after every mock paper. I can see exactly what my daughter needs to work on.',
    featured: false,
  },
  {
    name: 'Wei Ling',
    context: 'Sec 4 student',
    avatar: 'WL',
    stars: 5,
    quote: 'Got A2 for O-Level English! The comprehension techniques and essay frameworks were exactly what I needed.',
    featured: true,
  },
];
---

<BaseLayout title="Testimonials — A Worthy | What Our Families Say">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="t-hero">
    <div class="t-container t-hero-inner">
      <span class="eyebrow">Reviews</span>
      <h1 class="t-hero-heading">What our families say</h1>
      <p class="t-hero-subtitle">
        Real stories from parents and students who transformed their English grades with A-Worthy.
      </p>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="t-stats-bar">
    <div class="t-container t-stats-inner">
      <div class="t-stat" data-animate="reveal-up" data-animate-delay="1">
        <span class="t-stat-number">50+</span>
        <span class="t-stat-label">Five-Star Reviews</span>
      </div>
      <div class="t-stat-divider"></div>
      <div class="t-stat" data-animate="reveal-up" data-animate-delay="2">
        <span class="t-stat-number">98%</span>
        <span class="t-stat-label">Parent Satisfaction</span>
      </div>
      <div class="t-stat-divider"></div>
      <div class="t-stat" data-animate="reveal-up" data-animate-delay="3">
        <span class="t-stat-number">4.9/5</span>
        <span class="t-stat-label">Google Rating</span>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS GRID ===== -->
  <section class="t-section t-testimonials-section">
    <div class="t-container">
      <div class="t-testimonials-grid">
        {testimonials.map((t, i) => (
          <div class:list={['t-card', { 't-card--featured': t.featured }]} data-animate="reveal-up" data-animate-delay={String((i % 3) + 1)}>
            <div class="t-card-stars" aria-label={`${t.stars} out of 5 stars`}>
              {Array.from({ length: t.stars }).map(() => (
                <span class="t-star">&#9733;</span>
              ))}
            </div>
            <blockquote class="t-card-quote">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <div class="t-card-author">
              <div class="t-placeholder-avatar">{t.avatar}</div>
              <div class="t-card-author-info">
                <strong>{t.name}</strong>
                <span>{t.context}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== GOOGLE REVIEWS ===== -->
  <section class="t-section t-google-section">
    <div class="t-container t-google-inner">
      <div class="t-google-badge" data-animate="scale-in">
        <div class="t-google-logo">
          <span class="t-g t-g-blue">G</span><span class="t-g t-g-red">o</span><span class="t-g t-g-yellow">o</span><span class="t-g t-g-blue">g</span><span class="t-g t-g-green">l</span><span class="t-g t-g-red">e</span>
        </div>
        <div class="t-google-rating">
          <div class="t-google-stars">
            <span class="t-star">&#9733;</span>
            <span class="t-star">&#9733;</span>
            <span class="t-star">&#9733;</span>
            <span class="t-star">&#9733;</span>
            <span class="t-star">&#9733;</span>
          </div>
          <span class="t-google-score">4.9 out of 5</span>
          <span class="t-google-count">Based on 50+ reviews</span>
        </div>
      </div>
      <a href="https://g.page/aworthy/review" class="t-btn t-btn--outline" target="_blank" rel="noopener noreferrer">
        Read Our Google Reviews &rarr;
      </a>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="t-section t-cta">
    <div class="t-container t-cta-inner">
      <span class="eyebrow">Get Started</span>
      <h2 class="t-cta-heading" data-animate="reveal-up">Experience the A Worthy difference</h2>
      <p class="t-cta-subtitle">Join the hundreds of families who trust A Worthy. Book a free trial lesson and see the results for yourself.</p>
      <div class="t-cta-actions">
        <a href="/contact/" class="t-btn t-btn--primary">Book a Free Trial</a>
        <a href="https://wa.me/6591234567" class="t-btn t-btn--outline" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: middle; margin-right: 6px;">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --t-bg: var(--bg-primary);
    --t-bg-card: var(--bg-secondary);
    --t-bg-elevated: #1e2022;
    --t-orange: var(--color-accent);
    --t-white: #ffffff;
    --t-text: rgba(255, 255, 255, 0.85);
    --t-text-muted: var(--text-muted);
    --t-border: var(--border-color);
    --t-radius: 8px;
  }

  /* ===== BASE ===== */
  .t-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .t-section {
    padding: 96px 0;
  }

  .eyebrow {
    display: inline-block;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--t-orange);
    margin-bottom: 20px;
  }

  /* ===== HERO ===== */
  .t-hero {
    background: var(--t-bg);
    padding: 120px 0 80px;
    text-align: center;
  }

  .t-hero-inner {
    max-width: 720px;
  }

  .t-hero-heading {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 700;
    color: var(--t-white);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 24px;
  }

  .t-hero-subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--t-text-muted);
    margin: 0;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== STATS BAR ===== */
  .t-stats-bar {
    background: var(--t-bg-elevated);
    border-top: 1px solid var(--t-border);
    border-bottom: 1px solid var(--t-border);
    padding: 48px 0;
  }

  .t-stats-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 64px;
  }

  .t-stat {
    text-align: center;
  }

  .t-stat-number {
    display: block;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--t-white);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .t-stat-label {
    display: block;
    font-size: 0.85rem;
    color: var(--t-text-muted);
    margin-top: 6px;
    letter-spacing: 0.02em;
  }

  .t-stat-divider {
    width: 1px;
    height: 48px;
    background: var(--t-border);
  }

  /* ===== TESTIMONIALS GRID ===== */
  .t-testimonials-section {
    background: var(--t-bg);
  }

  .t-testimonials-grid {
    columns: 3;
    column-gap: 24px;
  }

  .t-card {
    break-inside: avoid;
    display: inline-block;
    width: 100%;
    background: var(--t-bg-card);
    border: 1px solid var(--t-border);
    border-radius: var(--t-radius);
    padding: 32px;
    margin-bottom: 24px;
    transition: border-color 0.2s ease;
  }

  .t-card:hover {
    border-color: var(--border-color);
  }

  .t-card--featured {
    border-left: 3px solid var(--t-orange);
  }

  .t-card-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 20px;
  }

  .t-star {
    color: var(--t-orange);
    font-size: 1.1rem;
    line-height: 1;
  }

  .t-card-quote {
    font-size: 0.95rem;
    font-style: normal;
    line-height: 1.75;
    color: var(--t-text);
    margin: 0 0 24px;
    padding: 0;
    border: none;
  }

  .t-card-author {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid var(--t-border);
  }

  .t-placeholder-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-primary-light);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .t-card-author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .t-card-author-info strong {
    color: var(--t-white);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .t-card-author-info span {
    font-size: 0.8rem;
    color: var(--t-text-muted);
    line-height: 1.4;
  }

  /* ===== GOOGLE REVIEWS ===== */
  .t-google-section {
    background: var(--t-bg-elevated);
    border-top: 1px solid var(--t-border);
    padding: 64px 0;
  }

  .t-google-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 64px;
    flex-wrap: wrap;
  }

  .t-google-badge {
    text-align: center;
  }

  .t-google-logo {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }

  .t-g { font-family: 'Inter', sans-serif; }
  .t-g-blue { color: #4285F4; }
  .t-g-red { color: #EA4335; }
  .t-g-yellow { color: #FBBC05; }
  .t-g-green { color: #34A853; }

  .t-google-rating {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .t-google-stars {
    display: flex;
    gap: 4px;
  }

  .t-google-stars .t-star {
    font-size: 1.5rem;
  }

  .t-google-score {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--t-white);
  }

  .t-google-count {
    font-size: 0.85rem;
    color: var(--t-text-muted);
  }

  /* ===== BUTTONS ===== */
  .t-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: var(--t-radius);
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .t-btn--primary {
    background: var(--t-orange);
    color: var(--t-white);
  }

  .t-btn--primary:hover {
    background: #d4632f;
    transform: translateY(-1px);
  }

  .t-btn--outline {
    background: transparent;
    color: var(--t-white);
    border: 1px solid var(--t-border);
  }

  .t-btn--outline:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: var(--bg-secondary);
    transform: translateY(-1px);
  }

  /* ===== CTA ===== */
  .t-cta {
    background: var(--t-bg);
    border-top: 1px solid var(--t-border);
    text-align: center;
  }

  .t-cta-inner {
    max-width: 640px;
  }

  .t-cta-heading {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--t-white);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .t-cta-subtitle {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--t-text-muted);
    margin: 0 0 40px;
  }

  .t-cta-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .t-testimonials-grid {
      columns: 2;
    }
  }

  @media (max-width: 768px) {
    .t-hero {
      padding: 96px 0 64px;
    }

    .t-section {
      padding: 72px 0;
    }

    .t-stats-inner {
      flex-direction: column;
      gap: 32px;
    }

    .t-stat-divider {
      width: 60px;
      height: 1px;
    }

    .t-google-inner {
      flex-direction: column;
      gap: 32px;
    }
  }

  @media (max-width: 640px) {
    .t-testimonials-grid {
      columns: 1;
    }

    .t-hero-heading {
      font-size: 2rem;
    }

    .t-card {
      padding: 24px;
    }

    .t-cta-actions {
      flex-direction: column;
      align-items: center;
    }

    .t-btn {
      width: 100%;
      max-width: 300px;
    }
  }

  @media (min-width: 1921px) {
    .t-container {
      max-width: 1400px;
    }

    .t-hero-inner {
      max-width: 900px;
    }

    .t-testimonials-grid {
      max-width: 1400px;
      margin: 0 auto;
    }
  }
</style>
