---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Our Programmes — A Worthy | Primary, Secondary & JC Tuition in Singapore" description="Explore A Worthy's comprehensive tuition programmes for Primary (P3-P6), Secondary (Sec 1-4/5), and JC students in Singapore. Mathematics, Science, English & more.">
  <Header slot="header" />

  <!-- ===== PAGE HERO ===== -->
  <section class="prog-hero">
    <div class="container">
      <p class="eyebrow">Programmes</p>
      <h1 class="prog-hero__heading">Academic programmes<br />designed for results</h1>
      <p class="prog-hero__sub">A comprehensive, MOE-aligned curriculum from Primary 3 to JC2 &mdash; built to develop deep understanding, sharpen exam technique, and help every student achieve their personal best.</p>
    </div>
  </section>

  <!-- ===== NAV PILLS ===== -->
  <nav class="prog-nav" aria-label="Programme quick links">
    <div class="container prog-nav__inner">
      <a href="#primary" class="prog-nav__link">Primary</a>
      <a href="#secondary" class="prog-nav__link">Secondary</a>
      <a href="#jc" class="prog-nav__link">JC</a>
      <a href="#enrichment" class="prog-nav__link">Enrichment</a>
      <a href="#holiday" class="prog-nav__link">Holiday</a>
      <a href="#schedule" class="prog-nav__link">Schedule</a>
    </div>
  </nav>

  <!-- ===== PRIMARY PROGRAMME ===== -->
  <section class="prog-section" id="primary">
    <div class="container">
      <p class="eyebrow">Primary</p>
      <h2 class="prog-section__heading">Primary Programme (P3 &ndash; P6)</h2>
      <p class="prog-section__sub">Build strong foundations and PSLE confidence through hands-on, concept-driven learning.</p>

      <div class="card-grid card-grid--4">
        <div class="prog-card">
          <h3 class="prog-card__title">Mathematics</h3>
          <p class="prog-card__desc">Master problem-solving from the ground up with structured approaches tailored to the PSLE format.</p>
          <ul class="prog-card__topics">
            <li>Model drawing &amp; heuristics</li>
            <li>Problem sums (before/after, assumption, working backwards)</li>
            <li>Whole numbers, fractions &amp; decimals</li>
            <li>Ratios &amp; percentages</li>
            <li>Geometry &amp; mensuration</li>
            <li>Data analysis &amp; interpretation</li>
            <li>PSLE format practice &amp; timed drills</li>
          </ul>
          <div class="prog-card__meta">
            <span>1.5 hrs / week</span>
            <span>Max 8 students</span>
          </div>
          <p class="prog-card__fee">$240 &ndash; $320 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Science</h3>
          <p class="prog-card__desc">Develop scientific reasoning and process skills through inquiry-based learning and structured answering techniques.</p>
          <ul class="prog-card__topics">
            <li>Process skills (comparing, classifying, inferring, predicting)</li>
            <li>Open-ended question techniques (CER method)</li>
            <li>Experimental design &amp; variables</li>
            <li>Diversity of living &amp; non-living things</li>
            <li>Cycles in plants &amp; animals</li>
            <li>Systems (human body, plant, electrical)</li>
            <li>Interactions (forces, ecosystems)</li>
            <li>Energy (forms, conversion, heat)</li>
          </ul>
          <div class="prog-card__meta">
            <span>1.5 hrs / week</span>
            <span>Max 8 students</span>
          </div>
          <p class="prog-card__fee">$240 &ndash; $320 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">English Language</h3>
          <p class="prog-card__desc">Strengthen all four language pillars &mdash; reading, writing, listening, and speaking &mdash; for holistic English mastery.</p>
          <ul class="prog-card__topics">
            <li>Comprehension: literal, inferential &amp; applied questions</li>
            <li>Composition writing using the STAR method</li>
            <li>Grammar cloze &amp; sentence synthesis</li>
            <li>Vocabulary enrichment &amp; contextual usage</li>
            <li>Oral communication &amp; stimulus-based conversation</li>
            <li>Listening comprehension practice</li>
          </ul>
          <div class="prog-card__meta">
            <span>1.5 hrs / week</span>
            <span>Max 8 students</span>
          </div>
          <p class="prog-card__fee">$240 &ndash; $320 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Higher Chinese</h3>
          <p class="prog-card__desc">Available for P5 &ndash; P6 students preparing for PSLE Higher Chinese. Focus on comprehension, composition, and oral examination skills.</p>
          <div class="prog-card__meta">
            <span>1.5 hrs / week</span>
            <span>Max 8 students</span>
          </div>
          <p class="prog-card__fee">$240 &ndash; $320 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECONDARY PROGRAMME ===== -->
  <section class="prog-section" id="secondary">
    <div class="container">
      <p class="eyebrow">Secondary</p>
      <h2 class="prog-section__heading">Secondary Programme (Sec 1 &ndash; 4/5)</h2>
      <p class="prog-section__sub">Structured revision, exam techniques, and consistent practice for O-Level and N-Level success.</p>

      <div class="card-grid card-grid--3">
        <div class="prog-card">
          <h3 class="prog-card__title">E Math &amp; A Math</h3>
          <p class="prog-card__desc">From Elementary to Additional Mathematics, we cover the full O-Level and N-Level syllabus with rigour and clarity.</p>
          <ul class="prog-card__topics">
            <li>Algebra: equations, inequalities, functions</li>
            <li>Geometry: congruence, similarity, properties of circles</li>
            <li>Trigonometry: ratios, identities, graphs, R-formula</li>
            <li>Calculus: differentiation &amp; integration (A Math)</li>
            <li>Statistics &amp; probability</li>
            <li>GCE O-Level &amp; N-Level paper practice</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 8 students</span>
          </div>
          <p class="prog-card__fee">$280 &ndash; $380 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Pure &amp; Combined Sciences</h3>
          <p class="prog-card__desc">Comprehensive coverage of Physics, Chemistry, and Biology for both Pure and Combined Science tracks.</p>
          <ul class="prog-card__topics">
            <li>Physics: mechanics, thermal physics, waves, electricity &amp; magnetism</li>
            <li>Chemistry: atomic structure, chemical bonding, acids/bases, organic chemistry</li>
            <li>Biology: cell biology, nutrition, transport, homeostasis, inheritance</li>
            <li>Practical lab skills &amp; SPA preparation</li>
            <li>Structured &amp; free-response question techniques</li>
            <li>Data-based question strategies</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 8 students</span>
          </div>
          <p class="prog-card__fee">$280 &ndash; $380 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">English Language</h3>
          <p class="prog-card__desc">Develop strong comprehension and writing skills to excel across all components of the GCE O-Level English paper.</p>
          <ul class="prog-card__topics">
            <li>Comprehension: inference, language use, summary writing</li>
            <li>Summary writing techniques &amp; paraphrasing skills</li>
            <li>Situational writing (formal &amp; informal)</li>
            <li>Continuous writing: narrative, argumentative, expository</li>
            <li>Visual text comprehension</li>
            <li>Editing &amp; grammar accuracy</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 8 students</span>
          </div>
          <p class="prog-card__fee">$280 &ndash; $380 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== JC PROGRAMME ===== -->
  <section class="prog-section" id="jc">
    <div class="container">
      <p class="eyebrow">Junior College</p>
      <h2 class="prog-section__heading">JC Programme (JC1 &ndash; JC2)</h2>
      <p class="prog-section__sub">Rigorous content mastery and exam strategy for the GCE A-Level examinations.</p>

      <div class="card-grid card-grid--3">
        <div class="prog-card">
          <h3 class="prog-card__title">H2 Mathematics</h3>
          <p class="prog-card__desc">Deep mastery of both Pure Mathematics and Statistics for H2 Maths, with extensive past-year paper drills.</p>
          <ul class="prog-card__topics">
            <li>Functions &amp; graphs</li>
            <li>Sequences &amp; series (AP, GP, method of differences)</li>
            <li>Vectors in 2D and 3D</li>
            <li>Complex numbers</li>
            <li>Calculus: techniques of differentiation &amp; integration, applications</li>
            <li>Statistics &amp; probability distributions</li>
            <li>Hypothesis testing &amp; regression</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 6 students</span>
          </div>
          <p class="prog-card__fee">$360 &ndash; $450 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">H2 Physics</h3>
          <p class="prog-card__desc">From classical mechanics to modern physics, develop conceptual clarity and problem-solving rigour for the A-Level.</p>
          <ul class="prog-card__topics">
            <li>Mechanics: kinematics, dynamics, energy, momentum</li>
            <li>Waves: superposition, diffraction, interference</li>
            <li>Electricity: circuits, electric &amp; magnetic fields, electromagnetic induction</li>
            <li>Modern physics: quantum theory, nuclear physics</li>
            <li>Practical skills &amp; planning questions</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 6 students</span>
          </div>
          <p class="prog-card__fee">$360 &ndash; $450 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">H2 Chemistry</h3>
          <p class="prog-card__desc">Systematic coverage of physical, inorganic, and organic chemistry with emphasis on application and data analysis.</p>
          <ul class="prog-card__topics">
            <li>Atomic structure &amp; chemical bonding</li>
            <li>Chemical energetics &amp; thermodynamics</li>
            <li>Reaction kinetics &amp; equilibria</li>
            <li>Organic chemistry: mechanisms, synthesis, analysis</li>
            <li>Transition metals &amp; electrochemistry</li>
            <li>Practical &amp; planning question techniques</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 6 students</span>
          </div>
          <p class="prog-card__fee">$360 &ndash; $450 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">H1 General Paper</h3>
          <p class="prog-card__desc">Build critical thinking, argumentation, and comprehension skills for confident GP performance.</p>
          <ul class="prog-card__topics">
            <li>Essay writing: structure, argumentation, evaluation</li>
            <li>Comprehension: summary, application, inference</li>
            <li>Current affairs: Singapore &amp; global issues</li>
            <li>Content mastery across key themes (science &amp; tech, media, environment, politics)</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 6 students</span>
          </div>
          <p class="prog-card__fee">$360 &ndash; $450 / month</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">H2 Economics</h3>
          <p class="prog-card__desc">Master both micro and macro economics with rigorous case study and essay preparation.</p>
          <ul class="prog-card__topics">
            <li>Microeconomics: demand &amp; supply, market failure, government intervention</li>
            <li>Macroeconomics: national income, inflation, unemployment, trade</li>
            <li>Case study skills: data interpretation, analysis, evaluation</li>
            <li>Essay planning &amp; structuring techniques</li>
          </ul>
          <div class="prog-card__meta">
            <span>2 hrs / week</span>
            <span>Max 6 students</span>
          </div>
          <p class="prog-card__fee">$360 &ndash; $450 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ENRICHMENT PROGRAMMES ===== -->
  <section class="prog-section" id="enrichment">
    <div class="container">
      <p class="eyebrow">Enrichment</p>
      <h2 class="prog-section__heading">Enrichment Programmes</h2>
      <p class="prog-section__sub">Go beyond the syllabus with programmes that develop higher-order thinking and competitive edge.</p>

      <div class="card-grid card-grid--3">
        <div class="prog-card">
          <h3 class="prog-card__title">Critical Thinking &amp; Problem Solving</h3>
          <p class="prog-card__desc">Sharpen logical reasoning, analytical skills, and creative problem-solving through structured challenges and real-world scenarios. Suitable for P4 &ndash; Sec 2 students looking to strengthen their thinking toolkit beyond the standard curriculum.</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">ICAS &amp; Math Olympiad Preparation</h3>
          <p class="prog-card__desc">Targeted training for students competing in ICAS and the Singapore Mathematical Olympiad. Covers advanced problem types, number theory, combinatorics, and competition strategies.</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Creative Writing Workshop</h3>
          <p class="prog-card__desc">Guided workshops on storytelling, character development, descriptive writing, and creative composition techniques. Perfect for students who want to elevate their writing from good to outstanding.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOLIDAY INTENSIVES ===== -->
  <section class="prog-section" id="holiday">
    <div class="container">
      <p class="eyebrow">Holiday Intensives</p>
      <h2 class="prog-section__heading">Holiday Programmes</h2>
      <p class="prog-section__sub">Focused crash courses and revision bootcamps during the school holidays to maximise learning when it matters most.</p>

      <div class="card-grid card-grid--3">
        <div class="prog-card">
          <h3 class="prog-card__title">June Intensive Programme</h3>
          <p class="prog-card__desc">Use the mid-year break to close gaps and get ahead. Our June intensives cover key topics from Semester 1 and preview Semester 2 content so students return to school with confidence.</p>
          <ul class="prog-card__topics">
            <li>3-hour daily sessions</li>
            <li>Topic-focused modules</li>
            <li>Available for all levels (P3 &ndash; JC2)</li>
          </ul>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Nov / Dec Intensive Programme</h3>
          <p class="prog-card__desc">Prepare for the year ahead or revise the entire year's syllabus during the long holidays. Ideal for students moving up to a new level (e.g., P6 to Sec 1, Sec 4 to JC1).</p>
          <ul class="prog-card__topics">
            <li>3-hour daily sessions</li>
            <li>Bridging &amp; head-start modules</li>
            <li>Full-year syllabus review option</li>
          </ul>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Exam Revision Bootcamps</h3>
          <p class="prog-card__desc">Intensive revision leading up to PSLE, GCE O-Level, and GCE A-Level exams. Drill past-year papers, refine exam technique, and boost confidence under timed conditions.</p>
          <ul class="prog-card__topics">
            <li>PSLE Bootcamp (Sep &ndash; Oct)</li>
            <li>O-Level Bootcamp (Sep &ndash; Oct)</li>
            <li>A-Level Bootcamp (Oct &ndash; Nov)</li>
            <li>Daily 3-hour intensive sessions</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WEEKLY SCHEDULE ===== -->
  <section class="prog-section" id="schedule">
    <div class="container">
      <p class="eyebrow">Schedule</p>
      <h2 class="prog-section__heading">Weekly Class Schedule</h2>
      <p class="prog-section__sub">Classes run on a regular weekly cycle. Contact us for the latest available slots.</p>

