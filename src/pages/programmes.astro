<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --prog-bg: #2a2c2f;
    --prog-bg-card: rgba(255, 255, 255, 0.03);
    --prog-border: rgba(255, 255, 255, 0.1);
    --prog-text: #ffffff;
    --prog-text-secondary: rgba(255, 255, 255, 0.6);
    --prog-accent: #e8713a;
    --prog-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --prog-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prog-accent);
    margin-bottom: 1rem;
  }

  /* ===== HERO ===== */
  .prog-hero {
    background: var(--prog-bg);
    padding: 8rem 0 5rem;
    text-align: center;
  }

  .prog-hero__heading {
    font-family: var(--prog-font);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--prog-text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .prog-hero__sub {
    font-family: var(--prog-font);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ===== NAV ===== */
  .prog-nav {
    background: var(--prog-bg);
    border-bottom: 1px solid var(--prog-border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 90;
  }

  .prog-nav__inner {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .prog-nav__link {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .prog-nav__link:hover {
    color: var(--prog-text);
    border-bottom-color: var(--prog-accent);
  }

  /* ===== SECTIONS ===== */
  .prog-section {
    background: var(--prog-bg);
    padding: 6rem 0;
    scroll-margin-top: 60px;
  }

  .prog-section + .prog-section {
    border-top: 1px solid var(--prog-border);
  }

  .prog-section__heading {
    font-family: var(--prog-font);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 600;
    color: var(--prog-text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .prog-section__sub {
    font-family: var(--prog-font);
    font-size: 1.05rem;
    line-height: 1.7;
