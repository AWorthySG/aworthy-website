---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="O-Level English Programmes — A Worthy | CASE Method Tuition in Singapore" description="O-Level English tuition built on the CASE Method. Small group online classes for Sec 1-4 students, plus one-to-one coaching. Book a free diagnostic assessment.">
  <Header slot="header" />

  <!-- ===== PAGE HERO ===== -->
  <section class="prog-hero">
    <div class="container">
      <p class="eyebrow">Programmes</p>
      <h1 class="prog-hero__heading">O-Level English programmes<br />built on the CASE Method</h1>
      <p class="prog-hero__sub">Every lesson follows the same four-stage architecture &mdash; Contextualise, Analyse, Structure, Evaluate &mdash; regardless of topic or level.</p>
    </div>
  </section>

  <!-- ===== NAV PILLS ===== -->
  <nav class="prog-nav" aria-label="Programme quick links">
    <div class="container prog-nav__inner">
      <a href="#sec1-2" class="prog-nav__link">Sec 1-2</a>
      <a href="#sec3-4" class="prog-nav__link">Sec 3-4</a>
      <a href="#one-to-one" class="prog-nav__link">One-to-One</a>
      <a href="#lesson-structure" class="prog-nav__link">Lesson Structure</a>
    </div>
  </nav>

  <!-- ===== SEC 1-2 ENGLISH FOUNDATION ===== -->
  <section class="prog-section" id="sec1-2">
    <div class="container">
      <p class="eyebrow">Sec 1 &ndash; 2</p>
      <h2 class="prog-section__heading">Sec 1-2 English Foundation</h2>
      <p class="prog-section__sub">Building analytical habits early for O-Level readiness.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card">
          <h3 class="prog-card__title">Foundation Programme</h3>
          <p class="prog-card__desc">Small group online sessions designed to develop the core English skills that underpin O-Level success &mdash; starting from Secondary 1.</p>
          <ul class="prog-card__topics">
            <li>Close reading and inference techniques</li>
            <li>Essay structure fundamentals (narrative, expository)</li>
            <li>Vocabulary building and contextual usage</li>
            <li>Comprehension answering frameworks</li>
            <li>Grammar and editing accuracy</li>
          </ul>
          <div class="prog-card__meta">
            <span>90 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 280 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SEC 3-4 O-LEVEL INTENSIVE ===== -->
  <section class="prog-section" id="sec3-4">
    <div class="container">
      <p class="eyebrow">Sec 3 &ndash; 4</p>
      <h2 class="prog-section__heading">Sec 3-4 O-Level Intensive</h2>
      <p class="prog-section__sub">Exam-focused preparation with monthly mock grading and detailed feedback.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card">
          <h3 class="prog-card__title">O-Level Intensive Programme</h3>
          <p class="prog-card__desc">Rigorous, exam-aligned preparation covering every component of the GCE O-Level English paper &mdash; with regular mock practice and individualised feedback.</p>
          <ul class="prog-card__topics">
            <li>Paper 1 Situational Writing (format, purpose, audience, register)</li>
            <li>Paper 1 Continuous Writing (narrative, expository, argumentative)</li>
            <li>Paper 2 Comprehension (literal, inferential, evaluative questions)</li>
            <li>Paper 2 Summary (80-word paraphrase technique)</li>
            <li>Oral Communication (video stimulus response)</li>
            <li>Editing (grammar and vocabulary correction)</li>
          </ul>
          <div class="prog-card__meta">
            <span>90 min / week</span>
            <span>Max 6 students</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 320 / month</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ONE-TO-ONE COACHING ===== -->
  <section class="prog-section" id="one-to-one">
    <div class="container">
      <p class="eyebrow">One-to-One</p>
      <h2 class="prog-section__heading">One-to-One Coaching</h2>
      <p class="prog-section__sub">For students requiring tailored support or intensive exam preparation.</p>

      <div class="card-grid card-grid--1">
        <div class="prog-card">
          <h3 class="prog-card__title">Individual Coaching</h3>
          <p class="prog-card__desc">Fully customised to the student's specific gaps. Individual online sessions via Zoom, scheduled at your convenience.</p>
          <div class="prog-card__meta">
            <span>Per session</span>
            <span>1 student</span>
            <span>Online via Zoom</span>
          </div>
          <p class="prog-card__fee">SGD 120 / session</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== THE CASE LESSON STRUCTURE ===== -->
  <section class="prog-section" id="lesson-structure">
    <div class="container">
      <p class="eyebrow">Every Lesson</p>
      <h2 class="prog-section__heading">How a CASE lesson works</h2>

      <div class="card-grid card-grid--2">
        <div class="prog-card">
          <h3 class="prog-card__title">Contextualise (10 min)</h3>
          <p class="prog-card__desc">Tutor presents the task or question type. Students identify context, purpose, and audience. Socratic questioning surfaces what students already know.</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Analyse (20 min)</h3>
          <p class="prog-card__desc">Tutor models analysis using a worked example, thinking aloud through the reasoning process. Students then analyse independently.</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Structure (20 min)</h3>
          <p class="prog-card__desc">Students produce a structured written or spoken response. Outline before drafting. Tutor provides immediate targeted feedback.</p>
        </div>

        <div class="prog-card">
          <h3 class="prog-card__title">Evaluate (10 min)</h3>
          <p class="prog-card__desc">Students self-assess using the CASE checklist. Tutor provides process-level feedback &mdash; not just what was wrong, but why. Students record one specific improvement goal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FREE DIAGNOSTIC ASSESSMENT CTA ===== -->
  <section class="prog-cta">
    <div class="container prog-cta__inner">
      <p class="eyebrow">Get Started</p>
      <h2 class="prog-cta__heading">Not sure which programme?</h2>
      <p class="prog-cta__sub">Book a free 20-minute diagnostic assessment. We'll analyse your child's recent English paper and identify specific areas for improvement &mdash; no obligation, no sales pitch.</p>
      <div class="prog-cta__actions">
        <a href="/contact/" class="prog-cta__btn prog-cta__btn--primary">Book Assessment</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --prog-bg: var(--bg-primary);
    --prog-bg-card: rgba(255, 255, 255, 0.03);
    --prog-border: var(--border-color);
    --prog-text: #ffffff;
    --prog-text-secondary: var(--text-secondary);
    --prog-accent: var(--color-accent);
    --prog-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --prog-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prog-accent);
    margin-bottom: 1rem;
  }

  /* ===== HERO ===== */
  .prog-hero {
    background: var(--prog-bg);
    padding: 8rem 0 5rem;
    text-align: center;
  }

  .prog-hero__heading {
    font-family: var(--prog-font);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--prog-text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .prog-hero__sub {
    font-family: var(--prog-font);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ===== NAV ===== */
  .prog-nav {
    background: var(--prog-bg);
    border-bottom: 1px solid var(--prog-border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 90;
  }

  .prog-nav__inner {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .prog-nav__link {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .prog-nav__link:hover {
    color: var(--prog-text);
    border-bottom-color: var(--prog-accent);
  }

  /* ===== SECTIONS ===== */
  .prog-section {
    background: var(--prog-bg);
    padding: 6rem 0;
    scroll-margin-top: 60px;
  }

  .prog-section + .prog-section {
    border-top: 1px solid var(--prog-border);
  }

  .prog-section__heading {
    font-family: var(--prog-font);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 600;
    color: var(--prog-text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .prog-section__sub {
    font-family: var(--prog-font);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 600px;
    margin-bottom: 3.5rem;
  }

  /* ===== CARD GRID ===== */
  .card-grid {
    display: grid;
    gap: 1.5rem;
  }

  .card-grid--1 {
    grid-template-columns: 1fr;
    max-width: 640px;
  }

  .card-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .card-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .card-grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }

  /* ===== PROGRAMME CARD ===== */
  .prog-card {
    background: var(--prog-bg-card);
    border: 1px solid var(--prog-border);
    border-radius: 12px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .prog-card:hover {
    transform: scale(0.98);
    border-color: var(--border-color);
  }

  .prog-card__title {
    font-family: var(--prog-font);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--prog-text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .prog-card__desc {
    font-family: var(--prog-font);
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--prog-text-secondary);
    margin-bottom: 1.25rem;
  }

  .prog-card__topics {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    flex-grow: 1;
  }

  .prog-card__topics li {
    font-family: var(--prog-font);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--prog-text-secondary);
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--bg-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .prog-card__topics li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--prog-accent);
    transform: translateY(-50%);
  }

  .prog-card__topics li:last-child {
    border-bottom: none;
  }

  .prog-card__meta {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--prog-border);
  }

  .prog-card__meta span {
    font-family: var(--prog-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
  }

  .prog-card__fee {
    font-family: var(--prog-font);
    font-size: 1rem;
    font-weight: 600;
    color: var(--prog-accent);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  /* ===== CTA ===== */
  .prog-cta {
    background: var(--prog-bg);
    border-top: 1px solid var(--prog-border);
    padding: 6rem 0;
  }

  .prog-cta__inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .prog-cta__heading {
    font-family: var(--prog-font);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--prog-text);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .prog-cta__sub {
    font-family: var(--prog-font);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    margin-bottom: 2.5rem;
  }

  .prog-cta__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .prog-cta__btn {
    font-family: var(--prog-mono);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.9rem 2rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    cursor: pointer;
    display: inline-block;
  }

  .prog-cta__btn--primary {
    background: var(--prog-accent);
    color: var(--text-primary);
    border: 1px solid var(--prog-accent);
  }

  .prog-cta__btn--primary:hover {
    background: #d4632e;
    transform: translateY(-1px);
  }

  .prog-cta__btn--outline {
    background: transparent;
    color: var(--prog-text);
    border: 1px solid var(--prog-border);
  }

  .prog-cta__btn--outline:hover {
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-1px);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .card-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }

    .card-grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }

    .card-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .prog-hero {
      padding: 6rem 0 3.5rem;
    }

    .prog-section {
      padding: 4rem 0;
    }

    .prog-nav__inner {
      gap: 1rem;
    }

    .card-grid--4,
    .card-grid--3,
    .card-grid--2 {
      grid-template-columns: 1fr;
    }

    .prog-card {
      padding: 1.5rem;
    }

    .prog-cta {
      padding: 4rem 0;
    }
  }

  @media (max-width: 480px) {
    .prog-hero__heading {
      font-size: 1.8rem;
    }

    .prog-nav__inner {
      gap: 0.6rem;
    }

    .prog-nav__link {
      font-size: 0.65rem;
    }

    .prog-cta__actions {
      flex-direction: column;
      align-items: center;
    }

    .prog-cta__btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
