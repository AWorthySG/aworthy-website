---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Tuition Programmes | English, GP & Econs | A-Worthy" description="A-Worthy's programmes: O-Level English (Sec 1–4), H1 GP & H2 Economics (JC 1–2). Small groups of 6, proven SHARP Method. From SGD 280/month.">
  <Header slot="header" />

  <!-- ===== PAGE HERO ===== -->
  <section class="prog-hero">
    <div class="container">
      <p class="eyebrow">Programmes</p>
      <h1 class="prog-hero__heading">Singapore tuition programmes for O-Level English, GP &amp; H2 Economics</h1>
      <p class="prog-hero__sub">Every A-Worthy programme is built on the proven SHARP Method &mdash; See, Hit, Apply, Refine, Practise. Small groups of 6, online via Zoom, with personalised feedback every session. Choose the programme that fits your child.</p>
    </div>
  </section>

  <!-- ===== PROGRAMME CARDS ===== -->
  <section class="prog-section">
    <div class="container">
      <div class="card-grid card-grid--3">
        <a href="/o-level-english/" class="prog-card prog-card--link" data-animate="reveal-up" data-animate-delay="1">
          <p class="prog-card__eyebrow">Sec 1 &ndash; 4</p>
          <h3 class="prog-card__title">O-Level English</h3>
          <p class="prog-card__desc">Foundation and intensive programmes for Secondary 1&ndash;4 students. Master comprehension, composition, oral, and editing with the SHARP Method.</p>
          <ul class="prog-card__topics">
            <li>Sec 1-2 Foundation &mdash; SGD 280/month</li>
            <li>Sec 3-4 Intensive &mdash; SGD 320/month</li>
            <li>One-to-One &mdash; SGD 120/session</li>
          </ul>
          <div class="prog-card__meta">
            <span class="prog-card__link-text">View O-Level English tuition &rarr;</span>
          </div>
        </a>

        <a href="/h1-general-paper/" class="prog-card prog-card--link" data-animate="reveal-up" data-animate-delay="2">
          <p class="prog-card__eyebrow">JC 1 &ndash; 2</p>
          <h3 class="prog-card__title">H1 General Paper</h3>
          <p class="prog-card__desc">A-Level GP preparation using the SHARP Method&rsquo;s legal-analytical framework. Build argumentation, critical reading, and essay writing across all 12 content themes.</p>
          <ul class="prog-card__topics">
            <li>JC 1 Foundation &mdash; SGD 360/month</li>
            <li>JC 2 Intensive &mdash; SGD 400/month</li>
            <li>One-to-One &mdash; SGD 140/session</li>
          </ul>
          <div class="prog-card__meta">
            <span class="prog-card__link-text">View H1 General Paper tuition &rarr;</span>
          </div>
        </a>

        <a href="/h2-economics/" class="prog-card prog-card--link prog-card--accent" data-animate="reveal-up" data-animate-delay="3">
          <p class="prog-card__eyebrow prog-card__eyebrow--new">New</p>
          <h3 class="prog-card__title">H2 Economics</h3>
          <p class="prog-card__desc">Rigorous A-Level Economics preparation covering the full 9570 syllabus, taught with the SHARP Method. Diagram precision, essay technique, and case study mastery.</p>
          <ul class="prog-card__topics">
            <li>JC 1 Foundation &mdash; SGD 360/month</li>
            <li>JC 2 Intensive &mdash; SGD 400/month</li>
            <li>One-to-One &mdash; SGD 140/session</li>
          </ul>
          <div class="prog-card__meta">
            <span class="prog-card__link-text">View H2 Economics tuition &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== THE SHARP METHOD ===== -->
  <section class="prog-section" id="lesson-structure">
    <div class="container">
      <p class="eyebrow">Every Lesson</p>
      <h2 class="prog-section__heading" data-animate="reveal-up">Inside a SHARP lesson &mdash; the 90 minutes that change how your child thinks</h2>

      <div class="card-grid card-grid--2">
        <div class="prog-card" data-animate="reveal-up" data-animate-delay="1">
          <h3 class="prog-card__title">See (5 min)</h3>
          <p class="prog-card__desc">Your child learns to read questions the way a lawyer reads a brief &mdash; identifying exactly what is being asked, what type of response is required, and where the marks lie. No more losing marks to misread questions.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="2">
          <h3 class="prog-card__title">Hit (15 min)</h3>
          <p class="prog-card__desc">The tutor models expert-level analysis on a live example, then your child selects the right framework &mdash; Core Move or ACED for English, P-E-E-L for GP, DEED for Economics &mdash; and targets the highest-value marks first.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="3">
          <h3 class="prog-card__title">Apply (15 min)</h3>
          <p class="prog-card__desc">Your child writes a full response using the claim-evidence-reasoning framework &mdash; with the tutor providing immediate, targeted feedback. No waiting until next week to find out what went wrong.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="4">
          <h3 class="prog-card__title">Refine (10 min)</h3>
          <p class="prog-card__desc">Your child self-assesses against the SHARP checklist, then receives process-level feedback &mdash; not just what was wrong, but exactly why and how to fix it. Every answer is polished to exam standard.</p>
        </div>

        <div class="prog-card" data-animate="reveal-up" data-animate-delay="5">
          <h3 class="prog-card__title">Practise (15 min)</h3>
          <p class="prog-card__desc">Your child tackles a fresh question independently, applying everything from the lesson. Every session ends with one concrete improvement goal for the week.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY A-WORTHY COMPARISON ===== -->
  <section class="why-section" data-animate="reveal-up">
    <div class="container">
      <span class="eyebrow">Why Us</span>
      <h2 class="section-title">How A-Worthy compares</h2>
      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th class="highlight">A-Worthy</th>
              <th>Typical Tuition</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Class Size</td>
              <td class="highlight">Max 6 students</td>
              <td>15-30 students</td>
            </tr>
            <tr>
              <td>Format</td>
              <td class="highlight">Live online (Zoom)</td>
              <td>Physical centre</td>
            </tr>
            <tr>
              <td>Method</td>
              <td class="highlight">The SHARP Method with paper-matched frameworks</td>
              <td>Ad-hoc worksheets</td>
            </tr>
            <tr>
              <td>Materials</td>
              <td class="highlight">All included</td>
              <td>Extra charges</td>
            </tr>
            <tr>
              <td>Progress Tracking</td>
              <td class="highlight">Monthly reports</td>
              <td>End-of-term only</td>
            </tr>
            <tr>
              <td>Free Resources</td>
              <td class="highlight">16+ downloadable guides</td>
              <td>None</td>
            </tr>
            <tr>
              <td>Trial</td>
              <td class="highlight">Free diagnostic assessment</td>
              <td>Paid trial lesson</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== FREE DIAGNOSTIC ASSESSMENT CTA ===== -->
  <section class="prog-cta">
    <div class="container prog-cta__inner">
      <p class="eyebrow">Get Started</p>
      <h2 class="prog-cta__heading" data-animate="reveal-up">Not sure which programme?</h2>
      <p class="prog-cta__sub">Book a free 20-minute diagnostic assessment. We&rsquo;ll review your child&rsquo;s recent paper and identify specific areas for improvement &mdash; no obligation, no sales pitch.</p>
      <div class="prog-cta__actions">
        <a href="/contact/" class="prog-cta__btn prog-cta__btn--primary">Book Free Assessment</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --prog-bg: var(--bg-primary);
    --prog-bg-card: var(--bg-card);
    --prog-border: var(--border-color);
    --prog-text: var(--text-primary);
    --prog-text-secondary: var(--text-secondary);
    --prog-accent: var(--color-accent);
    --prog-font: var(--font-body);
    --prog-mono: var(--font-mono);
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prog-accent);
    margin-bottom: 1rem;
  }

  /* ===== HERO ===== */
  .prog-hero {
    background: var(--prog-bg);
    padding: 1.75rem 0;
    text-align: center;
  }

  .prog-hero__heading {
    font-family: var(--prog-font);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 200;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .prog-hero__sub {
    font-family: var(--prog-font);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ===== NAV ===== */
  .prog-nav {
    background: var(--prog-bg);
    border-bottom: 1px solid var(--prog-border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 90;
    /* Allow horizontal scroll on small screens */
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    /* Hide scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .prog-nav::-webkit-scrollbar {
    display: none;
  }

  .prog-nav__inner {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: nowrap;
    min-width: max-content;
  }

  .prog-nav__link {
    font-family: var(--prog-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .prog-nav__link:hover {
    color: var(--prog-text);
    border-bottom-color: var(--prog-accent);
  }

  /* ===== SECTIONS ===== */
  .prog-section {
    background: var(--prog-bg);
    padding: 1.75rem 0;
    scroll-margin-top: 60px;
  }

  .prog-section + .prog-section {
    border-top: 1px solid var(--prog-border);
  }

  .prog-section__heading {
    font-family: var(--prog-font);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 200;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .prog-section__sub {
    font-family: var(--prog-font);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    max-width: 600px;
    margin-bottom: 1.5rem;
  }

  /* ===== CARD GRID ===== */
  .card-grid {
    display: grid;
    gap: 1.5rem;
  }

  .card-grid--1 {
    grid-template-columns: 1fr;
    max-width: 640px;
  }

  .card-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .card-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .card-grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }

  /* ===== PROGRAMME CARD ===== */
  .prog-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  @media (hover: hover) {
    .prog-card:hover {
      transform: translateY(-3px);
      border-color: var(--border-color);
    }
  }

  .prog-card__title {
    font-family: var(--prog-font);
    font-size: 1.15rem;
    font-weight: 300;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .prog-card__desc {
    font-family: var(--prog-font);
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .prog-card__topics {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    flex-grow: 1;
  }

  .prog-card__topics li {
    font-family: var(--prog-font);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--prog-text-secondary);
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--bg-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .prog-card__topics li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--prog-accent);
    transform: translateY(-50%);
  }

  .prog-card__topics li:last-child {
    border-bottom: none;
  }

  .prog-card__meta {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--prog-border);
    flex-wrap: wrap;
  }

  .prog-card__meta span {
    font-family: var(--prog-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
  }

  .prog-card__fee {
    font-family: var(--prog-font);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  /* ===== HUB CARD VARIANTS ===== */
  .prog-card--link {
    text-decoration: none;
    cursor: pointer;
  }

  .prog-card--link:hover {
    border-color: var(--color-accent);
  }

  .prog-card--accent {
    border-color: rgba(212,133,58,0.3);
  }

  .prog-card__eyebrow {
    font-family: var(--prog-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--prog-text-secondary);
    margin-bottom: 0.5rem;
  }

  .prog-card__eyebrow--new {
    color: var(--color-accent);
    font-weight: 600;
  }

  .prog-card__link-text {
    color: var(--color-accent);
    font-weight: 500;
  }

  /* ===== CTA ===== */
  .prog-cta {
    background: var(--prog-bg);
    border-top: 1px solid var(--prog-border);
    padding: 1.75rem 0;
  }

  .prog-cta__inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .prog-cta__heading {
    font-family: var(--prog-font);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 200;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .prog-cta__sub {
    font-family: var(--prog-font);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--prog-text-secondary);
    margin-bottom: 1.25rem;
  }

  .prog-cta__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .prog-cta__btn {
    font-family: var(--prog-mono);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.9rem 2rem;
    border-radius: 0;
    transition: all 0.2s ease;
    cursor: pointer;
    display: inline-block;
  }

  .prog-cta__btn--primary {
    background: var(--prog-accent);
    color: var(--text-primary);
    border: 1px solid var(--prog-accent);
  }

  .prog-cta__btn--primary:hover {
    background: var(--color-accent-light);
    transform: translateY(-1px);
  }

  .prog-cta__btn--outline {
    background: transparent;
    color: var(--prog-text);
    border: 1px solid var(--prog-border);
  }

  .prog-cta__btn--outline:hover {
    border-color: rgba(26, 42, 58, 0.2);
    transform: translateY(-1px);
  }

  /* ===== PROGRAMME PLACEHOLDER ===== */
  .prog-placeholder {
    background: var(--bg-secondary);
    border: 1px dashed var(--border-color);
    border-radius: var(--border-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ===== COMPARISON TABLE ===== */
  .why-section {
    padding: var(--space-3xl) 0;
    background: var(--bg-secondary);
  }
  .comparison-table-wrap {
    overflow-x: auto;
    margin-top: 2rem;
  }
  .comparison-table {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .comparison-table th,
  .comparison-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }
  .comparison-table thead th {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 1rem;
  }
  .comparison-table .highlight {
    color: var(--color-primary);
    font-weight: 600;
  }
  .comparison-table tbody td:first-child {
    color: var(--text-secondary);
    font-weight: 500;
  }
  .comparison-table tbody td:last-child {
    color: var(--text-muted);
  }
  @media (max-width: 600px) {
    .comparison-table {
      font-size: 0.85rem;
    }
    .comparison-table th,
    .comparison-table td {
      padding: 0.75rem;
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .card-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }

    .card-grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }

    .card-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .prog-hero {
      padding: 3rem 0 2.25rem;
    }

    .prog-section {
      padding: 1.75rem 0;
    }

    .prog-nav__inner {
      gap: 1rem;
    }

    .card-grid--4,
    .card-grid--3,
    .card-grid--2 {
      grid-template-columns: 1fr;
    }

    .prog-card {
      padding: 1.5rem;
    }

    .prog-cta {
      padding: 1.75rem 0;
    }
  }

  @media (max-width: 480px) {
    .prog-hero__heading {
      font-size: 1.8rem;
    }

    .prog-nav__inner {
      gap: 0.6rem;
    }

    .prog-nav__link {
      font-size: 0.65rem;
    }

    .prog-cta__actions {
      flex-direction: column;
      align-items: center;
    }

    .prog-cta__btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
