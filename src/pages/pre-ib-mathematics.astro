---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/playbook.css';

const sharpSteps = [
  { letter: 'S', name: 'See' },
  { letter: 'H', name: 'Hit' },
  { letter: 'A', name: 'Apply' },
  { letter: 'R', name: 'Refine' },
  { letter: 'P', name: 'Practise' },
];

const playbookRows = [
  {
    paper: 'Year 3',
    section: 'Indices & Surds',
    steps: [
      { title: 'Index or surd form?', note: 'Spot which laws apply' },
      { title: 'State the law first', note: 'Product, quotient, power, root' },
      { title: 'One law per line', note: 'Rationalise surds via the conjugate' },
      { title: 'Watch the sign traps', note: 'Negative & fractional indices' },
      { title: 'Mixed index drills', note: 'Ten simplifications, timed' },
    ],
  },
  {
    paper: 'Year 3',
    section: 'Algebra & Factorisation',
    steps: [
      { title: 'Expand or factorise?', note: 'Read the command word' },
      { title: 'Pick the pattern', note: 'Common factor, grouping, identities' },
      { title: 'Line-by-line working', note: 'Nothing skipped, every step shown' },
      { title: 'Expand to check', note: 'Multiply back to verify' },
      { title: 'Factorisation sets', note: 'All four techniques weekly' },
    ],
  },
  {
    paper: 'Year 3',
    section: 'Pythagoras & Geometry',
    steps: [
      { title: 'Right angle present?', note: 'Identify the triangle first' },
      { title: 'LABEL the figure', note: 'Mark every known length' },
      { title: 'State each reason', note: 'Theorem beside every step' },
      { title: 'Sense-check lengths', note: 'Does the hypotenuse fit?' },
      { title: 'Geometry problem sets', note: 'Mixed application questions' },
    ],
  },
  {
    paper: 'Year 4',
    section: 'Logarithms & Exponentials',
    steps: [
      { title: 'Log or exponential?', note: 'Decide the conversion' },
      { title: 'State the log law', note: 'Product, quotient, power, change of base' },
      { title: 'Convert, then solve', note: 'One law per line of working' },
      { title: 'Check the domain', note: 'Logs need positive arguments' },
      { title: 'Log & exponential drills', note: 'Equations and simplifications' },
    ],
  },
  {
    paper: 'Year 4',
    section: 'Differentiation',
    steps: [
      { title: 'First principles or rules?', note: 'Read what the question demands' },
      { title: 'State the definition/rule', note: 'Limit definition or power rule' },
      { title: 'Cancel h, then limit', note: 'Never substitute h = 0 early' },
      { title: 'Check the gradient', note: 'Sign matches the curve’s shape?' },
      { title: 'First-principles drills', note: 'Set A: full limit working' },
    ],
  },
  {
    paper: 'Year 4',
    section: 'Integration',
    steps: [
      { title: 'Indefinite or definite?', note: 'Are limits given or not?' },
      { title: 'Reverse the power rule', note: 'Add one, divide by the new power' },
      { title: 'Never drop the + C', note: 'Indefinite integrals carry + C' },
      { title: 'Substitute the limits', note: 'Upper minus lower, in order' },
      { title: 'Integration & area drills', note: 'Set D: areas under curves' },
    ],
  },
];
