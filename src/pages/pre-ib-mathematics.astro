  <!-- ===== SYLLABUS COVERAGE ===== -->
  <section class="prog-section" id="syllabus">
    <div class="container">
      <p class="eyebrow">Year 3 &amp; 4 Syllabus</p>
      <h2 class="prog-section__heading">Complete Pre-IB Mathematics (Year 3 &amp; Year 4) Syllabus Coverage</h2>
      <p class="prog-section__sub">Every chapter of the Year 3 &amp; Year 4 course &mdash; from Chapter 1 (Indices) through to Chapter 25 (Introduction to Calculus) &mdash; taught with full, annotated working.</p>

      <div class="card-grid card-grid--2">
        <div class="prog-card">
          <h3 class="prog-card__title">Number, Algebra &amp; Functions</h3>
          <ul class="prog-card__topics">
