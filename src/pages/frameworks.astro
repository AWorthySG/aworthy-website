  .classifier__q:hover { border-color: var(--fw-accent); transform: translateY(-1px); }
  .classifier__q.is-active { border-color: var(--fw-accent); box-shadow: inset 0 0 0 1px var(--fw-accent); }
  .classifier__result { margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--border-color); }
  .classifier__verdict { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
