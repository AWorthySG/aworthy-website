  .caps-part__bar--one { background: var(--fw-accent); color: #fff; border-color: var(--fw-accent); }
  .caps-part__split { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .caps-part__transition { font-size: 0.72rem; font-style: italic; color: var(--text-muted); padding: 0 0.2rem; }
  .caps-tt { width: 100%; border-collapse: collapse; font-size: 0.86rem; }
  .caps-tt th { text-align: left; font-weight: 700; padding: 0.5rem 0.6rem; border-bottom: 2px solid var(--border-color); font-size: 0.8rem; }
  .caps-tt td { padding: 0.5rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); vertical-align: top; }
