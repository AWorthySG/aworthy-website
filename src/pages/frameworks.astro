  .caps-parts { display: flex; flex-direction: column; gap: 0.75rem; }
  .caps-part { display: flex; flex-direction: column; gap: 0.3rem; }
  .caps-part__label { font-size: 0.78rem; font-weight: 700; color: var(--text-muted); }
