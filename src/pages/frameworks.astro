  .qtype-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1rem; }
  .qtype-col__head { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.75rem; }
  .qtype-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .qtype { display: flex; align-items: center; gap: 0.7rem; padding: 0.5rem 0.7rem; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--border-radius); font-size: 0.88rem; }
  .qtype__code { flex-shrink: 0; font-weight: 800; font-size: 0.78rem; padding: 0.15rem 0.45rem; border-radius: 5px; color: #fff; }
  .qtype__code--a { background: #5d6e8c; } .qtype__code--b { background: #8a5a94; }
  .qtype__name { flex: 1; color: var(--text-primary); }
  .qtype__marks { flex-shrink: 0; font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-mono); }

  /* ── CAPS ── */
  .caps-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 2rem; }
  .caps-card { padding: 1.25rem; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--border-radius-lg); }
  .caps-card__head { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.5rem; }
  .caps-card__letter { width: 38px; height: 38px; flex-shrink: 0; display: grid; place-items: center; border-radius: 9px; background: var(--color-accent); color: #fff; font-size: 1.1rem; font-weight: 800; }
  .caps-card__name { font-size: 1.1rem; font-weight: 700; margin: 0; }
  .caps-card__desc { font-size: 0.9rem; line-height: 1.55; color: var(--text-secondary); margin: 0 0 0.9rem; }
  .caps-card__demo { display: flex; flex-direction: column; gap: 0.4rem; }
  .caps-card__before, .caps-card__after { margin: 0; font-size: 0.9rem; line-height: 1.5; padding: 0.55rem 0.7rem; border-radius: var(--border-radius); }
  .caps-card__before { background: var(--bg-secondary); color: var(--text-secondary); }
  .caps-card__after { background: var(--fw-accent-soft); color: var(--text-primary); }
  .caps-card__tag { display: inline-block; font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.07em; text-transform: uppercase; font-weight: 700; margin-right: 0.5rem; color: var(--text-muted); }
