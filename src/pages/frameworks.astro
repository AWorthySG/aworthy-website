  /* ── CTA ── */
  .fw-cta { padding: 3rem 0; background: var(--bg-footer); text-align: center; }
  .fw-cta__title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 400; color: #fff; margin: 0 0 0.6rem; }
  .fw-cta__sub { max-width: 620px; margin: 0 auto 1.75rem; color: rgba(255, 255, 255, 0.75); font-size: 1rem; line-height: 1.6; }
  .fw-cta__actions { display: flex; gap: 0.9rem; justify-content: center; flex-wrap: wrap; }
  .fw-cta .btn-outline { color: #fff; border-color: rgba(255, 255, 255, 0.3); }
  .fw-cta .btn-outline:hover { border-color: #fff; background: rgba(255, 255, 255, 0.08); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .fw-index, .swift-words { grid-template-columns: 1fr 1fr; }
    .method-cards, .caps-extra { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .fw-index, .swift-words, .caps-grid, .classifier__qs, .qtype-grid { grid-template-columns: 1fr; }
    .swift-word { flex-direction: row; align-items: center; gap: 0.6rem; text-align: left; }
    .swift-word__eg { margin-left: auto; text-align: right; }
    .stamp__chip { width: 46px; height: 46px; }
  }
</style>

<script>
  function initFrameworks() {
    // ── STAMP CARD tabs (WAI-ARIA) ──
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.stamp__chip'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('.stamp__panel'));
    function selectStamp(idx: number, focus = true) {
      tabs.forEach((t, i) => {
        const on = i === idx;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.tabIndex = on ? 0 : -1;
        t.classList.toggle('is-active', on);
      });
      panels.forEach((p, i) => {
        const on = i === idx;
        p.classList.toggle('is-active', on);
        p.hidden = !on;
      });
      if (focus) tabs[idx]?.focus();
    }
    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => selectStamp(i, false));
      tab.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); selectStamp((i + 1) % tabs.length); }
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); selectStamp((i - 1 + tabs.length) % tabs.length); }
        else if (e.key === 'Home') { e.preventDefault(); selectStamp(0); }
        else if (e.key === 'End') { e.preventDefault(); selectStamp(tabs.length - 1); }
      });
    });

    // ── SWIFT classifier ──
    const qButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.classifier__q'));
    const result = document.getElementById('classifier-result');
    const badge = document.getElementById('classifier-badge');
    const method = document.getElementById('classifier-method');
    const reason = document.getElementById('classifier-reason');
    qButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        qButtons.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        const cat = btn.dataset.cat;
        const isB = cat === 'B';
        if (badge) { badge.textContent = isB ? 'Category B' : 'Category A'; badge.className = 'classifier__badge ' + (isB ? 'is-b' : 'is-a'); }
        if (method) method.textContent = isB ? 'Infer it — use EIL (Evidence → Implication → Link)' : 'Locate it — use FLIP (Find → Lift → Interpret → Paraphrase)';
        if (reason) reason.textContent = btn.dataset.reason || '';
        if (result) result.hidden = false;
      });
    });
  }

  initFrameworks();
  document.addEventListener('astro:page-load', initFrameworks);
</script>
