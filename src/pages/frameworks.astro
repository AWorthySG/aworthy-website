  .method-card__cat { font-size: 0.78rem; font-weight: 600; color: var(--text-muted); }
  .method-card__name { font-size: 1.5rem; font-weight: 800; letter-spacing: 0.04em; margin: 0.2rem 0 0.6rem; }
  .method-card--a .method-card__name { color: #5d6e8c; } .method-card--b .method-card__name { color: #8a5a94; }
  :global([data-theme="dark"]) .method-card--a .method-card__name { color: #9db3d6; }
  :global([data-theme="dark"]) .method-card--b .method-card__name { color: #c79bd1; }
  .method-card__steps { margin: 0; padding-left: 1.1rem; display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.94rem; line-height: 1.5; color: var(--text-secondary); }
