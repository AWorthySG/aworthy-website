---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
---

<BaseLayout title="Best H2 Economics Tuition in Singapore | A-Level Econs | A-Worthy" description="Top-rated H2 Economics tuition for JC students. Master the 9570 syllabus with diagram precision, essay technique & case study mastery. Max 6 per class. Book a free assessment." ogImage="/images/og-econs.png">
  <Header slot="header" />

  <section class="lp-hero">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">H2 Economics Tuition</span>
      <h1 class="lp-title" data-animate="reveal-up">Master H2 Economics with<br/><strong>analytical precision</strong></h1>
      <p class="lp-subtitle" data-animate="reveal-up">The CASE Method applies legal reasoning to economic analysis &mdash; diagram accuracy, essay structure, and case study evaluation. Small groups of 6 via Zoom.</p>
      <div class="lp-cta-row" data-animate="reveal-up">
        <a href="/contact/" class="btn btn-accent">Book Free Assessment</a>
        <a href="/h2-economics/" class="btn">View Full Programme</a>
      </div>
    </div>
  </section>

  <section class="section lp-proof">
    <div class="container">
      <div class="lp-stats">
        <div class="lp-stat"><span class="lp-stat-num" data-count="85" data-count-suffix="%">0</span><span class="lp-stat-label">score B or above</span></div>
        <div class="lp-stat"><span class="lp-stat-num">6</span><span class="lp-stat-label">max per class</span></div>
        <div class="lp-stat"><span class="lp-stat-num" data-count="4.9">0</span><span class="lp-stat-label">Google rating</span></div>
      </div>

      <div class="lp-testimonial" data-animate="reveal-up">
        <blockquote>&ldquo;The diagram drills and essay frameworks made the difference. Went from D to B in one term.&rdquo;</blockquote>
        <cite>&mdash; Wei Jie C., JC 2 student</cite>
      </div>
    </div>
  </section>

  <section class="section lp-features">
    <div class="container">
      <h2 data-animate="reveal-up">Full 9570 syllabus mastery</h2>
      <div class="lp-features-grid" data-animate="reveal-up">
        <div class="lp-feature">
          <h3>Diagram Precision</h3>
          <p>Every essential diagram mastered &mdash; demand-supply, market failure, AD-AS, exchange rates, Phillips curve. Correctly labelled, exam-ready.</p>
        </div>
        <div class="lp-feature">
          <h3>Essay Technique</h3>
          <p>Structured frameworks for explain, discuss, and evaluate questions. Learn what examiners look for in each mark band.</p>
        </div>
        <div class="lp-feature">
          <h3>Case Study Mastery</h3>
          <p>Extract analysis, data interpretation, and higher-order evaluation. The component where most marks are won or lost.</p>
        </div>
        <div class="lp-feature">
          <h3>Real-World Application</h3>
          <p>Current Singapore and global examples for every topic. Examiners reward students who can connect theory to reality.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section lp-final-cta">
    <div class="container" style="text-align:center;">
      <h2 data-animate="reveal-up">Ready to improve your Economics grade?</h2>
      <p data-animate="reveal-up" style="max-width:540px;margin:0 auto 2rem;color:var(--text-secondary);">Book a free 20-minute diagnostic assessment. We&rsquo;ll identify your specific gaps and recommend the right programme.</p>
      <a href="/contact/" class="btn btn-accent" data-animate="reveal-up">Book Free Assessment</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .lp-hero { padding: 6rem 0 4rem; text-align: center; }
  .lp-title { font-family: var(--font-heading); font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 200; line-height: 1.1; color: var(--text-primary); margin-bottom: 1.25rem; }
  .lp-title strong { color: var(--color-accent); font-weight: 200; }
  .lp-subtitle { font-size: 1.1rem; line-height: 1.7; color: var(--text-secondary); max-width: 600px; margin: 0 auto 2rem; }
  .lp-cta-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .lp-stats { display: flex; justify-content: center; gap: 4rem; margin-bottom: 3rem; }
  .lp-stat { text-align: center; }
  .lp-stat-num { display: block; font-family: var(--font-heading); font-size: 2.5rem; font-weight: 200; color: var(--color-accent); }
  .lp-stat-label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--font-mono); }
  .lp-testimonial { max-width: 600px; margin: 0 auto; text-align: center; }
  .lp-testimonial blockquote { font-family: var(--font-heading); font-size: 1.3rem; font-weight: 300; font-style: italic; color: var(--text-primary); line-height: 1.6; margin-bottom: 0.75rem; }
  .lp-testimonial cite { font-size: 0.85rem; color: var(--text-muted); font-style: normal; }
  .lp-features h2 { font-family: var(--font-heading); font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 400; text-align: center; margin-bottom: 2rem; }
  .lp-features-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 800px; margin: 0 auto; }
  .lp-feature { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.75rem; }
  .lp-feature h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
  .lp-feature p { font-size: 0.9rem; line-height: 1.6; color: var(--text-secondary); }
  .lp-final-cta h2 { font-family: var(--font-heading); font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 300; margin-bottom: 0.75rem; }
  @media (max-width: 640px) { .lp-stats { gap: 2rem; } .lp-features-grid { grid-template-columns: 1fr; } }
</style>
