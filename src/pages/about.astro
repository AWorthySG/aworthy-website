---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="About Us — A Worthy | Singapore Tuition Centre">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-image-wrap">
      <div class="placeholder-img hero-placeholder"></div>
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <span class="eyebrow">About A-Worthy</span>
      <h1>Where legal precision meets English mastery</h1>
    </div>
  </section>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-inner">
      <span class="marquee-item"><span class="marquee-dot"></span> Legal Precision</span>
      <span class="marquee-item"><span class="marquee-dot"></span> English Mastery</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The CASE Method</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Founded by a Law Graduate</span>
      <span class="marquee-item"><span class="marquee-dot"></span> A-Worthy</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Legal Precision</span>
      <span class="marquee-item"><span class="marquee-dot"></span> English Mastery</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The CASE Method</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Founded by a Law Graduate</span>
      <span class="marquee-item"><span class="marquee-dot"></span> A-Worthy</span>
    </div>
  </div>

  <!-- ===== OUR STORY ===== -->
  <section class="section story">
    <div class="container">
      <div class="story-layout">
        <div class="story-text" data-animate="reveal-up">
          <span class="eyebrow">Our Story</span>
          <h2>Born from law, built for English mastery</h2>
          <p>
            A-Worthy was founded by a law graduate who noticed something remarkable: the analytical
            skills developed in law school — close reading, structured argumentation, evidence-based
            reasoning — are exactly what O-Level English examiners reward.
          </p>
          <p>
            A-Worthy is Singapore's first analytical English tuition programme,
            bringing the precision of legal reasoning to help secondary students master every component
            of O-Level English — from comprehension inference to essay argumentation.
          </p>
          <p>
            Our students are Secondary 1 to 4 students across Singapore. We teach exclusively online
            in small groups of six, delivering 90-minute sessions weekly through Zoom. This format
            ensures every student receives focused attention while keeping tuition accessible.
          </p>
        </div>
        <div class="story-image-wrap" data-animate="reveal-right">
          <img src="/images/illustrations/online-learning.svg" alt="Online learning illustration" class="story-illustration" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TEAM ===== -->
  <section class="section team">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Team</span>
      <h2 data-animate="reveal-up">Legal mind, teaching heart</h2>

      <div class="team-grid">
        <div class="team-card" data-animate="reveal-up">
          <div class="team-initials">TF</div>
          <h3>The Founder</h3>
          <span class="team-role">Law Graduate & English Tutor</span>
          <div class="team-credentials">
            <span class="credential">LLB (Hons)</span>
            <span class="credential">CASE Method Creator</span>
          </div>
          <p>
            With a law degree and direct teaching experience, our founder developed the CASE
            Method — a proprietary framework that formalises legal-analytical thinking into a
            teachable pedagogy for O-Level English.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section values">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Values</span>
      <h2 data-animate="reveal-up">The pillars that define who we are</h2>

      <div class="values-grid">
        <div class="value-item" data-animate="reveal-up" data-animate-delay="1">
          <h3>Analytical Precision</h3>
          <p>
            We apply the rigour of legal reasoning to every English skill. No guesswork —
            systematic techniques that examiners reward.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="2">
          <h3>Proven Results</h3>
          <p>
            Specific grade improvements, not vague promises. Our students show measurable
            progress tracked against O-Level marking criteria.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="3">
          <h3>Small Groups</h3>
          <p>
            Maximum six students per class. Every student receives focused attention, immediate
            feedback, and targeted development.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="4">
          <h3>The CASE Method</h3>
          <p>
            Our proprietary framework — Contextualise, Analyse, Structure, Evaluate — applies
            universally across every O-Level English component.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CENTRES ===== -->
  <section class="section centres">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Online Delivery</span>
      <h2 data-animate="reveal-up">100% Online Delivery</h2>

      <div class="centres-grid">
        <div class="centre-card" data-animate="reveal-up">
          <h3>Learn from anywhere in Singapore</h3>
          <p>
            All lessons are conducted via Zoom Pro with cloud recording, screen sharing, and
            breakout rooms. Students join from anywhere in Singapore. No commute, no wasted
            time — just focused learning.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section cta">
    <div class="container cta-inner">
      <span class="eyebrow" data-animate="reveal-up">Get Started</span>
      <h2 data-animate="reveal-up">Book a free diagnostic assessment</h2>
      <p class="cta-desc">
        A 20-minute session analysing your child's recent English paper.
      </p>
      <a href="/contact/" class="cta-button">Get Started</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --about-bg: var(--bg-primary);
    --about-bg-alt: var(--bg-secondary);
    --about-white: #ffffff;
    --about-gray: var(--text-secondary);
    --about-border: var(--border-color);
    --about-accent: var(--color-accent);
    --about-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --about-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: inline-block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--about-accent);
    margin-bottom: 1.25rem;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    width: 100%;
    height: 75vh;
    min-height: 480px;
    max-height: 800px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ===== PLACEHOLDER IMAGES ===== */
  .placeholder-img {
    background: var(--bg-secondary);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--border-color);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px dashed var(--border-color);
  }

  .hero-placeholder {
    position: absolute;
    inset: 0;
    aspect-ratio: auto;
    font-size: 0;
    color: transparent;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(42, 44, 47, 0.95) 0%,
      rgba(42, 44, 47, 0.6) 40%,
      rgba(42, 44, 47, 0.3) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 2rem 5rem;
  }

  .hero-content h1 {
    font-family: var(--about-font);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--about-white);
    max-width: 700px;
    margin: 0;
    letter-spacing: -0.02em;
  }

  /* ===== SECTIONS ===== */
  .section {
    background: var(--about-bg);
    padding: 6rem 0;
  }

  .section:nth-child(even) {
    background: var(--about-bg-alt);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section h2 {
    font-family: var(--about-font);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--about-white);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 3rem;
    max-width: 600px;
  }

  .section p {
    font-family: var(--about-font);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--about-gray);
    margin: 0 0 1.25rem;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  /* ===== OUR STORY ===== */
  .story-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .story-text h2 {
    max-width: 100%;
  }

  .story-image-wrap {
    position: relative;
  }

  .story-image,
  .story-image-wrap .placeholder-img {
    width: 100%;
    height: 100%;
    min-height: 400px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .story-illustration {
    width: 100%;
    height: auto;
  }

  /* ===== TEAM ===== */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .team-card {
    border: 1px solid var(--about-border);
    border-radius: 6px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    background: transparent;
  }

  .team-card:hover {
    transform: scale(0.98);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .team-initials {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--about-accent);
    color: var(--about-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--about-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .team-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--about-white);
    margin: 0 0 0.35rem;
  }

  .team-role {
    display: block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--about-accent);
    margin-bottom: 1rem;
  }

  .team-credentials {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .credential {
    font-family: var(--about-font);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--about-gray);
    border: 1px solid var(--about-border);
    border-radius: 3px;
    padding: 0.2rem 0.6rem;
  }

  .team-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== VALUES ===== */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .value-item {
    border: 1px solid var(--about-border);
    border-radius: 6px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .value-item:hover {
    transform: scale(0.98);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .value-item h3 {
    font-family: var(--about-font);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--about-white);
    margin: 0 0 0.75rem;
  }

  .value-item p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CENTRES ===== */
  .centres-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .centre-card {
    border: 1px solid var(--about-border);
    border-radius: 6px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .centre-card:hover {
    transform: scale(0.98);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .centre-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--about-white);
    margin: 0 0 0.5rem;
  }

  .centre-address {
    font-family: var(--about-mono);
    font-size: 0.72rem !important;
    letter-spacing: 0.04em;
    color: var(--about-accent) !important;
    margin-bottom: 1.25rem !important;
  }

  .centre-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CTA ===== */
  .cta {
    background: var(--about-bg-alt) !important;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta h2 {
    max-width: 100%;
    margin-bottom: 1.25rem;
  }

  .cta-desc {
    text-align: center;
    margin-bottom: 2.5rem !important;
  }

  .cta-button {
    display: inline-block;
    font-family: var(--about-font);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--about-white);
    background: var(--about-accent);
    border: none;
    border-radius: 4px;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    opacity: 0.9;
    transform: scale(0.98);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .story-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .story-image {
      min-height: 300px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 60vh;
      min-height: 380px;
    }

    .hero-content {
      padding: 2.5rem 1.5rem 3.5rem;
    }

    .section {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1.5rem;
    }

    .team-grid,
    .values-grid,
    .centres-grid {
      grid-template-columns: 1fr;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 2rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      height: 50vh;
      min-height: 320px;
    }

    .hero-content {
      padding: 2rem 1.25rem 3rem;
    }

    .section {
      padding: 3rem 0;
    }

    .section h2 {
      margin-bottom: 2rem;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 1.5rem;
    }
  }

  @media (min-width: 1921px) {
    .hero-content {
      max-width: 1400px;
    }

    .container {
      max-width: 1400px;
    }

    .section {
      padding: 8rem 0;
    }
  }
</style>
