---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="About Us — A Worthy | Singapore Tuition Centre">
  <Header slot="header" />

  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <div class="container hero-inner">
      <span class="hero-badge">Est. 2015 | Toa Payoh & Bishan</span>
      <h1>About <span class="highlight">A Worthy</span></h1>
      <p class="hero-subtitle">
        From a humble classroom in Toa Payoh to two thriving centres serving over 500 students,
        we have remained committed to one belief: every child deserves the chance to excel.
      </p>
      <img src="/images/heroes/about-hero.jpg" alt="Students and teachers at A Worthy tuition centre" class="about-hero-img" loading="eager" />
    </div>
  </section>

  <!-- ===== OUR STORY ===== -->
  <section class="section our-story">
    <div class="container">
      <h2 class="section-title">Our Story</h2>
      <p class="section-subtitle">A decade of nurturing young minds in the heart of Singapore.</p>

      <img src="/images/about/team-teaching.jpg" alt="Our tutors engaging students in a lesson" class="story-img" loading="lazy" />

      <div class="story-grid">
        <div class="story-content">
          <p>
            A Worthy was founded in <strong>2015</strong> by <strong>Mr. David Ng</strong>, a passionate
            educator who spent 15 years teaching Mathematics in MOE schools before deciding to create something
            different. As a graduate of the National Institute of Education (NIE) and the National University of
            Singapore (NUS), David saw first-hand how students struggled with rigid, one-size-fits-all classroom
            teaching. He believed there had to be a better way.
          </p>
          <p>
            It all started in a modest rented unit above a coffeeshop on <strong>Toa Payoh Lorong 8</strong>,
            with just <strong>12 students</strong> and a whiteboard. David poured his heart into every lesson,
            crafting materials aligned to the MOE syllabus but delivered with the patience and individual
            attention that school classrooms often cannot provide. Word spread quickly among parents in the
            Toa Payoh community, and within a year, the centre was full.
          </p>
          <p>
            By 2019, A Worthy had expanded to a second centre in <strong>Bishan</strong>, welcoming
            students from across the island. Today, we proudly serve <strong>over 500 students</strong> from
            Primary 3 to JC2, guided by a team of dedicated, MOE-experienced tutors who share David's founding
            mission: to help every child build genuine understanding, confidence, and a love for learning.
          </p>
        </div>
        <div class="story-milestones">
          <div class="milestone">
            <span class="milestone-year">2015</span>
            <p>Founded in Toa Payoh with 12 students</p>
          </div>
          <div class="milestone">
            <span class="milestone-year">2017</span>
            <p>Reached 100 students; expanded to full primary and secondary programmes</p>
          </div>
          <div class="milestone">
            <span class="milestone-year">2019</span>
            <p>Opened second centre in Bishan; launched JC programme</p>
          </div>
          <div class="milestone">
            <span class="milestone-year">2022</span>
            <p>95% of PSLE students achieved A/A*; recognised as a top tuition centre in Toa Payoh</p>
          </div>
          <div class="milestone">
            <span class="milestone-year">2025</span>
            <p>Serving 500+ students across 2 centres with a team of 15 specialist tutors</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MISSION & VISION ===== -->
  <section class="section mission-vision">
    <div class="container">
      <h2 class="section-title">Our Mission & Vision</h2>
      <p class="section-subtitle">Guiding principles that shape everything we do.</p>

      <div class="mv-grid">
        <div class="card mv-card">
          <span class="mv-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></span>
          <h3>Our Mission</h3>
          <p>
            To <strong>empower every student with deep conceptual understanding</strong>, critical thinking
            skills, and the confidence to excel academically. We go beyond drilling and rote memorisation
            — we teach students <em>how</em> to think, not just <em>what</em> to think. Through
            personalised attention, expert instruction, and a nurturing environment, we help each child
            unlock their full potential and develop a lifelong love for learning.
          </p>
        </div>
        <div class="card mv-card">
          <span class="mv-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7S2 12 2 12z"/></svg></span>
          <h3>Our Vision</h3>
          <p>
            To be <strong>Singapore's most trusted education partner</strong> — a centre where parents feel
            assured their children are in excellent hands, and where students feel inspired to push beyond
            their limits. We envision a future where every child, regardless of their starting point, has
            access to world-class tuition that transforms not just their grades, but their relationship with
            learning itself.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MEET OUR TEAM ===== -->
  <section class="section team-section">
    <div class="container">
      <h2 class="section-title">Meet Our Team</h2>
      <p class="section-subtitle">Passionate educators with deep MOE experience and a heart for teaching.</p>

      <div class="team-grid">
        <div class="card team-card">
          <div class="team-avatar">
            <span class="avatar-placeholder">DN</span>
          </div>
          <h3>Mr. David Ng</h3>
          <span class="team-role">Founder & Head Tutor — Mathematics</span>
          <div class="team-credentials">
            <span class="credential">NUS Mathematics</span>
            <span class="credential">NIE PGDE</span>
          </div>
          <p>
            David holds a Bachelor of Science (Honours) in Mathematics from the National University of
            Singapore and a Postgraduate Diploma in Education (PGDE) from the National Institute of Education.
            With <strong>15 years of teaching experience in MOE secondary schools</strong>, he specialised in
            upper secondary and JC Mathematics before founding A Worthy. Known for his ability to
            break down complex topics like differentiation and vectors into intuitive, step-by-step
            explanations, David has helped hundreds of students achieve A1 and A grades at the O-Level and
            A-Level examinations. He personally oversees the curriculum design for all Mathematics programmes.
          </p>
        </div>

        <div class="card team-card">
          <div class="team-avatar">
            <span class="avatar-placeholder">SC</span>
          </div>
          <h3>Ms. Sarah Chen</h3>
          <span class="team-role">Head of Science</span>
          <div class="team-credentials">
            <span class="credential">NTU Chemistry</span>
            <span class="credential">10 Years Teaching</span>
          </div>
          <p>
            Sarah graduated with a Bachelor of Science in Chemistry from Nanyang Technological University
            and brings <strong>10 years of dedicated teaching experience</strong> to A Worthy. She is our resident
            PSLE Science specialist, renowned for her engaging experiment-based teaching approach that makes
            abstract scientific concepts tangible and memorable. Sarah also teaches lower and upper secondary
            Chemistry. Parents frequently praise her detailed post-lesson feedback and her knack for helping
            students overcome their fear of Science. Under her guidance, 92% of our P6 students scored A or
            A* in PSLE Science last year.
          </p>
        </div>

        <div class="card team-card">
          <div class="team-avatar">
            <span class="avatar-placeholder">AK</span>
          </div>
          <h3>Mr. Arun Krishnan</h3>
          <span class="team-role">English & General Paper</span>
          <div class="team-credentials">
            <span class="credential">NUS English Literature</span>
            <span class="credential">MA in Education</span>
          </div>
          <p>
            Arun is a graduate of the National University of Singapore with a Bachelor of Arts (Honours) in
            English Literature and a Master of Arts in Education. He is an <strong>O-Level and A-Level English
            expert</strong> with a particular passion for essay writing, comprehension strategies, and General
            Paper argumentation. Having taught in both government and independent schools, Arun understands
            the nuances of the Cambridge exam format and trains students to write with clarity, critical
            depth, and confidence. His GP students consistently achieve distinction rates above 85%.
          </p>
        </div>

        <div class="card team-card">
          <div class="team-avatar">
            <span class="avatar-placeholder">PS</span>
          </div>
          <h3>Ms. Priya Sharma</h3>
          <span class="team-role">Primary Programme Lead</span>
          <div class="team-credentials">
            <span class="credential">NIE-Trained</span>
            <span class="credential">8 Years MOE Primary</span>
          </div>
          <p>
            Priya is an NIE-trained educator who spent <strong>8 years teaching in MOE primary schools</strong>,
            including stints at Ai Tong School and Tao Nan School, two of Singapore's top primary schools. She
            specialises in Primary Mathematics and Science, with deep expertise in the PSLE exam format and
            marking scheme. Priya is known for her warm, encouraging teaching style that helps younger students
            build confidence while developing strong problem-solving habits. She leads our entire Primary
            Programme, designing worksheets, assessments, and holiday intensive courses for P3 to P6 students.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR VALUES ===== -->
  <section class="section values-section">
    <div class="container">
      <h2 class="section-title">Our Values</h2>
      <p class="section-subtitle">The four pillars that define who we are and how we teach.</p>

      <div class="values-grid">
        <div class="card value-card">
          <span class="value-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M9 18l-3 4"/><path d="M15 18l3 4"/><path d="M12 14v4"/></svg></span>
          <h3>Excellence</h3>
          <p>
            We set the highest standards for ourselves and our students. From meticulously crafted lesson
            materials to rigorous mock examinations, we pursue excellence in every detail. We believe that
            when students are held to high expectations in a supportive environment, they rise to meet them.
          </p>
        </div>
        <div class="card value-card">
          <span class="value-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg></span>
          <h3>Integrity</h3>
          <p>
            We are transparent with parents about their child's progress — the strengths and the areas that
            need work. We never over-promise results, and we never cut corners. Our reputation has been built
            on honest communication and genuine care for every student's development.
          </p>
        </div>
        <div class="card value-card">
          <span class="value-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0010-10v0a10 10 0 0110 10h-3"/><path d="M7 20h10"/></svg></span>
          <h3>Nurture</h3>
          <p>
            Every child learns differently, and every child deserves patience. Our tutors take the time to
            understand each student's unique challenges, learning pace, and goals. We celebrate small wins,
            encourage questions, and create a safe space where mistakes are stepping stones to mastery.
          </p>
        </div>
        <div class="card value-card">
          <span class="value-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M17 21v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6"/><path d="M3 21h18"/><path d="M12 3l9 8H3l9-8z"/></svg></span>
          <h3>Community</h3>
          <p>
            A Worthy is more than a tuition centre — it is a community. We foster strong relationships among
            students, parents, and tutors. From our annual Family Day events to our free PSLE prep workshops
            for the public, we are committed to giving back to the neighbourhoods that have supported us.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR CENTRES ===== -->
  <section class="section centres-section">
    <div class="container">
      <h2 class="section-title">Our Centres</h2>
      <p class="section-subtitle">Purpose-built learning spaces designed for focus and comfort.</p>

      <img src="/images/about/centre-interior.jpg" alt="A Worthy learning centre interior" class="centre-img" loading="lazy" />

      <div class="centres-grid">
        <div class="card centre-card">
          <h3>Toa Payoh Centre (Flagship)</h3>
          <p class="centre-address">Blk 201 Toa Payoh Lorong 8, #01-12, Singapore 310201</p>
          <p>
            Our flagship centre spans <strong>3,200 sq ft</strong> across two interconnected units.
            It features six fully air-conditioned classrooms, each equipped with whiteboards, projectors,
            and ergonomic furniture designed for extended study sessions. The centre includes a dedicated
            <strong>resource library</strong> stocked with past-year papers, assessment books, and reference
            materials that students can use before and after lessons. A comfortable <strong>parent waiting
            area</strong> with complimentary coffee and tea is available for parents who prefer to wait on-site.
            The centre is conveniently located a 3-minute walk from Toa Payoh MRT station.
          </p>
        </div>
        <div class="card centre-card">
          <h3>Bishan Centre</h3>
          <p class="centre-address">Blk 283 Bishan Street 22, #02-08, Singapore 570283</p>
          <p>
            Opened in 2019, our Bishan centre was designed from the ground up to create an optimal
            learning environment. Spanning <strong>2,800 sq ft</strong>, it houses five classrooms, a
            <strong>quiet self-study zone</strong> where students can complete homework or revise
            independently, and a small <strong>discussion room</strong> for group consultations. All
            classrooms feature sound-insulated walls to minimise distractions. The centre is a short walk
            from Bishan MRT station and Junction 8 shopping centre, making it easily accessible for
            families across the central and north-eastern regions of Singapore.
          </p>
        </div>
      </div>

      <div class="facilities-highlights">
        <div class="facility">
          <span class="facility-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07"/></svg></span>
          <span>Fully Air-Conditioned</span>
        </div>
        <div class="facility">
          <span class="facility-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg></span>
          <span>Resource Library</span>
        </div>
        <div class="facility">
          <span class="facility-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M7 21l5-4 5 4"/></svg></span>
          <span>Near MRT Stations</span>
        </div>
        <div class="facility">
          <span class="facility-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/></svg></span>
          <span>Parent Waiting Area</span>
        </div>
        <div class="facility">
          <span class="facility-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg></span>
          <span>Self-Study Zones</span>
        </div>
        <div class="facility">
          <span class="facility-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg></span>
          <span>Sound-Insulated Rooms</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA BANNER ===== -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <h2>Come Visit Us</h2>
      <p>Schedule a free centre tour and meet our tutors in person. See the A Worthy difference for yourself.</p>
      <div class="cta-actions">
        <a href="/contact/" class="btn btn-accent btn-lg">Book a Free Visit</a>
        <a href="https://wa.me/6591234567" class="btn btn-secondary btn-lg" style="border-color: #FFF; color: #FFF;">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== PAGE HERO ===== */
  .page-hero {
    padding: var(--space-4xl) 0;
    background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    text-align: center;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    background: var(--bg-secondary);
    border: 1px solid var(--color-accent);
    color: var(--color-primary);
    padding: var(--space-xs) var(--space-md);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .page-hero h1 {
    margin-bottom: var(--space-lg);
  }

  .highlight {
    color: var(--color-primary);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.8;
    max-width: 650px;
    margin: 0 auto;
  }

  /* ===== OUR STORY ===== */
  .our-story {
    background: var(--bg-primary);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .story-content p {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .story-milestones {
    position: relative;
    padding-left: var(--space-xl);
    border-left: 3px solid var(--color-primary);
  }

  .milestone {
    position: relative;
    margin-bottom: var(--space-xl);
    padding-left: var(--space-md);
  }

  .milestone::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-xl) - 7px);
    top: 6px;
    width: 14px;
    height: 14px;
    background: var(--color-primary);
    border-radius: 50%;
    border: 3px solid var(--bg-primary);
  }

  .milestone-year {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .milestone p {
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  /* ===== MISSION & VISION ===== */
  .mission-vision {
    background: var(--bg-secondary);
  }

  .mv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .mv-card {
    padding: var(--space-2xl);
    text-align: center;
  }

  .mv-icon {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .mv-card h3 {
    font-size: 1.4rem;
    margin-bottom: var(--space-md);
    color: var(--color-primary);
  }

  .mv-card p {
    font-size: 1.02rem;
    line-height: 1.8;
    text-align: left;
  }

  /* ===== TEAM ===== */
  .team-section {
    background: var(--bg-primary);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .team-card {
    padding: var(--space-2xl);
    text-align: center;
  }

  .team-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
  }

  .avatar-placeholder {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: #FFFFFF;
  }

  .team-card h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-xs);
  }

  .team-role {
    display: block;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: var(--space-sm);
  }

  .team-credentials {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .credential {
    background: var(--bg-secondary);
    color: var(--text-secondary);
    padding: 2px 12px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--border-color);
  }

  .team-card p {
    font-size: 0.95rem;
    line-height: 1.75;
    text-align: left;
  }

  /* ===== VALUES ===== */
  .values-section {
    background: var(--bg-secondary);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
  }

  .value-card {
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
  }

  .value-icon {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .value-card h3 {
    font-size: 1.15rem;
    margin-bottom: var(--space-sm);
    color: var(--color-primary);
  }

  .value-card p {
    font-size: 0.95rem;
    text-align: left;
    line-height: 1.75;
  }

  /* ===== CENTRES ===== */
  .centres-section {
    background: var(--bg-primary);
  }

  .centres-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .centre-card {
    padding: var(--space-2xl);
  }

  .centre-card h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-xs);
  }

  .centre-address {
    color: var(--color-primary) !important;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: var(--space-md) !important;
  }

  .centre-card p {
    font-size: 0.98rem;
    line-height: 1.8;
  }

  .facilities-highlights {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-lg);
  }

  .facility {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: var(--space-sm) var(--space-lg);
    border-radius: 50px;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .facility-icon {
    display: flex;
    align-items: center;
  }

  /* ===== CTA BANNER ===== */
  .cta-banner {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: #FFFFFF;
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .cta-banner h2 {
    color: #FFFFFF;
    margin-bottom: var(--space-md);
  }

  .cta-banner p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto var(--space-xl);
  }

  .cta-actions {
