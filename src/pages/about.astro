---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="About Us — A Worthy | Singapore Tuition Centre">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-image-wrap">
      <img src="/images/heroes/about-hero.jpg" alt="Students and teachers at A Worthy tuition centre" class="hero-image" loading="eager" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <span class="eyebrow">About Us</span>
      <h1>Dedicated to academic excellence since 2015</h1>
    </div>
  </section>

  <!-- ===== OUR STORY ===== -->
  <section class="section story">
    <div class="container">
      <div class="story-layout">
        <div class="story-text">
          <span class="eyebrow">Our Story</span>
          <h2>From a single classroom to two thriving centres</h2>
          <p>
            A Worthy was founded in 2015 by Mr. David Ng, a passionate educator who spent 15 years
            teaching Mathematics in MOE schools. A graduate of the National Institute of Education (NIE)
            and the National University of Singapore (NUS), David saw first-hand how students struggled
            with rigid, one-size-fits-all classroom teaching. He believed there had to be a better way.
          </p>
          <p>
            It all started in a modest rented unit above a coffeeshop on Toa Payoh Lorong 8, with just
            12 students and a whiteboard. David poured his heart into every lesson, crafting materials
            aligned to the MOE syllabus but delivered with patience and individual attention that school
            classrooms often cannot provide. Word spread quickly among parents in the Toa Payoh community,
            and within a year, the centre was full.
          </p>
          <p>
            By 2019, A Worthy had expanded to a second centre in Bishan, welcoming students from across
            the island. Today, we proudly serve over 500 students from Primary 3 to JC2, guided by a team
            of dedicated, MOE-experienced tutors who share David's founding mission: to help every child
            build genuine understanding, confidence, and a love for learning.
          </p>
        </div>
        <div class="story-image-wrap">
          <img src="/images/about/team-teaching.jpg" alt="Our tutors engaging students in a lesson" class="story-image" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TEAM ===== -->
  <section class="section team">
    <div class="container">
      <span class="eyebrow">Our Team</span>
      <h2>Passionate educators with deep MOE experience</h2>

      <div class="team-grid">
        <div class="team-card">
          <div class="team-initials">DN</div>
          <h3>David Ng</h3>
          <span class="team-role">Founder & Head Tutor</span>
          <div class="team-credentials">
            <span class="credential">NUS Mathematics</span>
            <span class="credential">NIE PGDE</span>
          </div>
          <p>
            15 years of teaching experience in MOE secondary schools, specialising in upper secondary
            and JC Mathematics. Known for breaking down complex topics into intuitive, step-by-step
            explanations. Personally oversees curriculum design for all Mathematics programmes.
          </p>
        </div>

        <div class="team-card">
          <div class="team-initials">SC</div>
          <h3>Sarah Chen</h3>
          <span class="team-role">Head of Mathematics</span>
          <div class="team-credentials">
            <span class="credential">NTU Chemistry</span>
            <span class="credential">10 Years Teaching</span>
          </div>
          <p>
            PSLE Science specialist renowned for her experiment-based teaching approach. Also teaches
            lower and upper secondary Chemistry. Under her guidance, 92% of P6 students scored A or
            A* in PSLE Science last year.
          </p>
        </div>

        <div class="team-card">
          <div class="team-initials">AK</div>
          <h3>Arun Krishnan</h3>
          <span class="team-role">Head of Science</span>
          <div class="team-credentials">
            <span class="credential">NUS English Literature</span>
            <span class="credential">MA in Education</span>
          </div>
          <p>
            O-Level and A-Level English expert with a passion for essay writing, comprehension
            strategies, and General Paper argumentation. His GP students consistently achieve
            distinction rates above 85%.
          </p>
        </div>

        <div class="team-card">
          <div class="team-initials">PS</div>
          <h3>Priya Sharma</h3>
          <span class="team-role">Head of English</span>
          <div class="team-credentials">
            <span class="credential">NIE-Trained</span>
            <span class="credential">8 Years MOE Primary</span>
          </div>
          <p>
            NIE-trained educator who spent 8 years teaching in MOE primary schools including Ai Tong
            and Tao Nan. Specialises in Primary Mathematics and Science with deep expertise in the
            PSLE exam format. Leads the entire Primary Programme.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section values">
    <div class="container">
      <span class="eyebrow">Our Values</span>
      <h2>The pillars that define who we are</h2>

      <div class="values-grid">
        <div class="value-item">
          <h3>Excellence</h3>
          <p>
            We set the highest standards for ourselves and our students. From meticulously crafted
            lesson materials to rigorous mock examinations, we pursue excellence in every detail.
            When students are held to high expectations in a supportive environment, they rise to
            meet them.
          </p>
        </div>
        <div class="value-item">
          <h3>Integrity</h3>
          <p>
            We are transparent with parents about their child's progress — the strengths and the
            areas that need work. We never over-promise results and we never cut corners. Our
            reputation has been built on honest communication and genuine care for every student.
          </p>
        </div>
        <div class="value-item">
          <h3>Nurture</h3>
          <p>
            Every child learns differently and every child deserves patience. Our tutors take the
            time to understand each student's unique challenges, learning pace, and goals. We
            celebrate small wins, encourage questions, and create a safe space where mistakes are
            stepping stones to mastery.
          </p>
        </div>
        <div class="value-item">
          <h3>Community</h3>
          <p>
            A Worthy is more than a tuition centre — it is a community. We foster strong
            relationships among students, parents, and tutors. From annual Family Day events to
            free PSLE prep workshops, we are committed to giving back to the neighbourhoods that
            have supported us.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CENTRES ===== -->
  <section class="section centres">
    <div class="container">
      <span class="eyebrow">Our Centres</span>
      <h2>Purpose-built spaces for focused learning</h2>

      <div class="centres-grid">
        <div class="centre-card">
          <h3>Toa Payoh — Flagship</h3>
          <p class="centre-address">Blk 201 Toa Payoh Lorong 8, #01-12, Singapore 310201</p>
          <p>
            Our flagship centre spans 3,200 sq ft across two interconnected units featuring six
            fully air-conditioned classrooms, a dedicated resource library, and a comfortable
            parent waiting area. Located 3 minutes from Toa Payoh MRT.
          </p>
        </div>
        <div class="centre-card">
          <h3>Bishan</h3>
          <p class="centre-address">Blk 283 Bishan Street 22, #02-08, Singapore 570283</p>
          <p>
            Opened in 2019, our Bishan centre spans 2,800 sq ft with five classrooms, a quiet
            self-study zone, and a discussion room for group consultations. All classrooms feature
            sound-insulated walls. A short walk from Bishan MRT and Junction 8.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section cta">
    <div class="container cta-inner">
      <span class="eyebrow">Get in Touch</span>
      <h2>Come visit us</h2>
      <p class="cta-desc">
        Schedule a free centre tour and meet our tutors in person.
        See the A Worthy difference for yourself.
      </p>
      <a href="/contact/" class="cta-button">Contact Us</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --about-bg: #2a2c2f;
    --about-bg-alt: #232527;
    --about-white: #ffffff;
    --about-gray: rgba(255, 255, 255, 0.6);
    --about-border: rgba(255, 255, 255, 0.1);
    --about-accent: #e8713a;
    --about-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --about-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: inline-block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--about-accent);
    margin-bottom: 1.25rem;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    width: 100%;
    height: 75vh;
    min-height: 480px;
    max-height: 800px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(42, 44, 47, 0.95) 0%,
      rgba(42, 44, 47, 0.6) 40%,
      rgba(42, 44, 47, 0.3) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 4rem 2rem 5rem;
  }

  .hero-content h1 {
    font-family: var(--about-font);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--about-white);
    max-width: 700px;
    margin: 0;
    letter-spacing: -0.02em;
  }

  /* ===== SECTIONS ===== */
  .section {
    background: var(--about-bg);
    padding: 6rem 0;
  }

  .section:nth-child(even) {
    background: var(--about-bg-alt);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section h2 {
    font-family: var(--about-font);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--about-white);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 3rem;
    max-width: 600px;
  }

  .section p {
    font-family: var(--about-font);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--about-gray);
    margin: 0 0 1.25rem;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  /* ===== OUR STORY ===== */
  .story-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .story-text h2 {
    max-width: 100%;
  }

  .story-image-wrap {
    position: relative;
  }

  .story-image {
    width: 100%;
    height: 100%;
    min-height: 400px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  /* ===== TEAM ===== */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .team-card {
    border: 1px solid var(--about-border);
    border-radius: 6px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    background: transparent;
  }

  .team-card:hover {
    transform: scale(0.98);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .team-initials {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--about-accent);
    color: var(--about-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--about-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .team-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--about-white);
    margin: 0 0 0.35rem;
  }

  .team-role {
    display: block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--about-accent);
    margin-bottom: 1rem;
  }

  .team-credentials {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .credential {
    font-family: var(--about-font);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--about-gray);
    border: 1px solid var(--about-border);
    border-radius: 3px;
    padding: 0.2rem 0.6rem;
  }

  .team-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== VALUES ===== */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .value-item {
    border: 1px solid var(--about-border);
    border-radius: 6px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .value-item:hover {
    transform: scale(0.98);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .value-item h3 {
    font-family: var(--about-font);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--about-white);
    margin: 0 0 0.75rem;
  }

  .value-item p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CENTRES ===== */
  .centres-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .centre-card {
    border: 1px solid var(--about-border);
    border-radius: 6px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .centre-card:hover {
    transform: scale(0.98);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .centre-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--about-white);
    margin: 0 0 0.5rem;
  }

  .centre-address {
    font-family: var(--about-mono);
    font-size: 0.72rem !important;
    letter-spacing: 0.04em;
    color: var(--about-accent) !important;
    margin-bottom: 1.25rem !important;
  }

  .centre-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CTA ===== */
  .cta {
    background: var(--about-bg-alt) !important;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta h2 {
    max-width: 100%;
    margin-bottom: 1.25rem;
  }

  .cta-desc {
    text-align: center;
    margin-bottom: 2.5rem !important;
  }

  .cta-button {
    display: inline-block;
    font-family: var(--about-font);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--about-white);
    background: var(--about-accent);
    border: none;
    border-radius: 4px;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    opacity: 0.9;
    transform: scale(0.98);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .story-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .story-image {
      min-height: 300px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 60vh;
      min-height: 380px;
    }

    .hero-content {
      padding: 2.5rem 1.5rem 3.5rem;
    }

    .section {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1.5rem;
    }

    .team-grid,
    .values-grid,
    .centres-grid {
      grid-template-columns: 1fr;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 2rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      height: 50vh;
      min-height: 320px;
    }

    .hero-content {
      padding: 2rem 1.25rem 3rem;
    }

    .section {
      padding: 3rem 0;
    }

    .section h2 {
      margin-bottom: 2rem;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 1.5rem;
    }
  }

  @media (min-width: 1921px) {
    .hero-content {
      max-width: 1400px;
    }

    .container {
      max-width: 1400px;
    }

    .section {
      padding: 8rem 0;
    }
  }
</style>
