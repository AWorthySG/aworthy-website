---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="About Us — A Worthy | Singapore Tuition Centre" description="Founded by an NUS Law graduate, A-Worthy brings legal reasoning precision to English tuition. Learn about our story, mission, and the CASE Method.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">About A-Worthy</span>
      <h1>Where legal precision meets English mastery</h1>
    </div>
  </section>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-inner">
      <span class="marquee-item"><span class="marquee-dot"></span> Legal Precision</span>
      <span class="marquee-item"><span class="marquee-dot"></span> English Mastery</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The CASE Method</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Founded by a Law Graduate</span>
      <span class="marquee-item"><span class="marquee-dot"></span> A-Worthy</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Legal Precision</span>
      <span class="marquee-item"><span class="marquee-dot"></span> English Mastery</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The CASE Method</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Founded by a Law Graduate</span>
      <span class="marquee-item"><span class="marquee-dot"></span> A-Worthy</span>
    </div>
  </div>

  <!-- ===== OUR STORY ===== -->
  <section class="section story">
    <div class="container">
      <div class="story-layout">
        <div class="story-text" data-animate="reveal-up">
          <span class="eyebrow">Our Story</span>
          <h2>Born from law, built for English mastery</h2>
          <p>
            A-Worthy was founded by a law graduate who noticed something remarkable: the analytical
            skills developed in law school — close reading, structured argumentation, evidence-based
            reasoning — are exactly what O-Level English examiners reward.
          </p>
          <p>
            A-Worthy is Singapore's first analytical English tuition programme,
            bringing the precision of legal reasoning to help secondary students master every component
            of O-Level English — from comprehension inference to essay argumentation.
          </p>
          <p>
            Our students are Secondary 1 to 4 students across Singapore. We teach exclusively online
            in small groups of six, delivering 90-minute sessions weekly through Zoom. This format
            ensures every student receives focused attention while keeping tuition accessible.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TEAM ===== -->
  <section class="section team">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Team</span>
      <h2 data-animate="reveal-up">Legal mind, teaching heart</h2>

      <div class="team-grid">
        <div class="team-card" data-animate="reveal-up">
          <div class="team-photo-wrap">
            <div class="team-photo-placeholder">
              <span class="team-photo-initials">TF</span>
            </div>
          </div>
          <h3>The Founder</h3>
          <span class="team-role">Law Graduate & English Tutor</span>
          <div class="team-credentials">
            <span class="credential">LLB (Hons)</span>
            <span class="credential">CASE Method Creator</span>
          </div>
          <p>
            With a law degree and direct teaching experience, our founder developed the CASE
            Method — a proprietary framework that formalises legal-analytical thinking into a
            teachable pedagogy for O-Level English.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section values">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Values</span>
      <h2 data-animate="reveal-up">The pillars that define who we are</h2>

      <div class="values-grid">
        <div class="value-item" data-animate="reveal-up" data-animate-delay="1">
          <h3>Analytical Precision</h3>
          <p>
            We apply the rigour of legal reasoning to every English skill. No guesswork —
            systematic techniques that examiners reward.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="2">
          <h3>Proven Results</h3>
          <p>
            Specific grade improvements, not vague promises. Our students show measurable
            progress tracked against O-Level marking criteria.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="3">
          <h3>Small Groups</h3>
          <p>
            Maximum six students per class. Every student receives focused attention, immediate
            feedback, and targeted development.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="4">
          <h3>The CASE Method</h3>
          <p>
            Our proprietary framework — Contextualise, Analyse, Structure, Evaluate — applies
            universally across every O-Level English component.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CENTRES ===== -->
  <section class="section centres">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Online Delivery</span>
      <h2 data-animate="reveal-up">100% Online Delivery</h2>

      <div class="centres-grid">
        <div class="centre-card" data-animate="reveal-up">
          <h3>Learn from anywhere in Singapore</h3>
          <p>
            All lessons are conducted via Zoom Pro with cloud recording, screen sharing, and
            breakout rooms. Students join from anywhere in Singapore. No commute, no wasted
            time — just focused learning.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section cta">
    <div class="container cta-inner">
      <span class="eyebrow" data-animate="reveal-up">Get Started</span>
      <h2 data-animate="reveal-up">Book a free diagnostic assessment</h2>
      <p class="cta-desc">
        A 20-minute session analysing your child's recent English paper.
      </p>
      <a href="/contact/" class="cta-button">Get Started</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --about-bg: var(--bg-primary);
    --about-bg-alt: var(--bg-secondary);
    --about-white: #ffffff;
    --about-gray: var(--text-secondary);
    --about-border: var(--border-color);
    --about-accent: var(--color-accent);
    --about-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --about-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: inline-block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--about-accent);
    margin-bottom: 1.25rem;
  }

  /* ===== HERO ===== */
  .hero {
    width: 100%;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    border-bottom: 1px solid var(--border-color);
    padding: calc(var(--header-height) + 3rem) 0 3rem;
    text-align: center;
  }

  .hero-content {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content h1 {
    font-family: var(--about-font);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 200;
    line-height: 1.15;
    color: var(--text-primary);
    max-width: 700px;
    margin: 0 auto;
    letter-spacing: -0.03em;
  }

  /* ===== SECTIONS ===== */
  .section {
    background: var(--about-bg);
    padding: 4rem 0;
  }

  .section:nth-child(even) {
    background: var(--about-bg-alt);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section h2 {
    font-family: var(--about-font);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 200;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0 0 3rem;
    max-width: 600px;
  }

  .section p {
    font-family: var(--about-font);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--about-gray);
    margin: 0 0 1.25rem;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  /* ===== OUR STORY ===== */
  .story-layout {
    max-width: 720px;
  }

  .story-text h2 {
    max-width: 100%;
  }

  /* ===== TEAM ===== */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .team-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .team-card:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  @keyframes team-initials-shimmer {
    0%, 100% { box-shadow: 0 0 0 transparent; }
    50% { box-shadow: 0 0 18px rgba(212, 133, 58, 0.35), 0 0 40px rgba(201, 169, 110, 0.12); }
  }

  .team-photo-wrap {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--color-accent), #2B5A8C, var(--color-accent));
    margin-bottom: 1.5rem;
    animation: team-initials-shimmer 5s ease-in-out infinite;
  }

  .team-photo-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(212, 133, 58, 0.15), rgba(43, 90, 140, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .team-photo-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-photo-initials {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .team-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.35rem;
    letter-spacing: -0.03em;
  }

  .team-role {
    display: block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--about-accent);
    margin-bottom: 1rem;
  }

  .team-credentials {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .credential {
    font-family: var(--about-font);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--about-gray);
    border: 1px solid var(--about-border);
    border-radius: 3px;
    padding: 0.2rem 0.6rem;
  }

  .team-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== VALUES ===== */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .value-item {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .value-item:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  .value-item h3 {
    font-family: var(--about-font);
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
  }

  .value-item p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CENTRES ===== */
  .centres-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .centre-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .centre-card:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  .centre-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
  }

  .centre-address {
    font-family: var(--about-mono);
    font-size: 0.72rem !important;
    letter-spacing: 0.04em;
    color: var(--about-accent) !important;
    margin-bottom: 1.25rem !important;
  }

  .centre-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CTA ===== */
  .cta {
    background: var(--about-bg-alt) !important;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta h2 {
    max-width: 100%;
    margin-bottom: 1.25rem;
  }

  .cta-desc {
    text-align: center;
    margin-bottom: 2.5rem !important;
  }

  .cta-button {
    display: inline-block;
    font-family: var(--about-font);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    background: var(--color-accent);
    border: none;
    border-radius: 0;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    opacity: 0.9;
    transform: translateY(-3px);
  }

  /* ===== RESPONSIVE ===== */

  @media (max-width: 768px) {
    .section {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1.5rem;
    }

    .team-grid,
    .values-grid,
    .centres-grid {
      grid-template-columns: 1fr;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 2rem;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 3rem 0;
    }

    .section h2 {
      margin-bottom: 2rem;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 1.5rem;
    }
  }

  @media (min-width: 1921px) {
    .hero-content {
      max-width: 1400px;
    }

    .container {
      max-width: 1400px;
    }

    .section {
      padding: 8rem 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .team-photo-wrap {
      animation: none;
    }
  }
</style>
