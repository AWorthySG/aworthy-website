---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="About A-Worthy | Analytical Tuition Singapore" description="Founded by an NUS Law graduate, A-Worthy brings legal-analytical precision to O-Level English, GP & H2 Economics tuition. Discover the SHARP Method.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">About A-Worthy</span>
      <h1>Singapore&rsquo;s analytical tuition centre &mdash; where legal precision meets academic results</h1>
    </div>
  </section>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-inner">
      <span class="marquee-item"><span class="marquee-dot"></span> Legal Precision</span>
      <span class="marquee-item"><span class="marquee-dot"></span> O-Level English</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The SHARP Method</span>
      <span class="marquee-item"><span class="marquee-dot"></span> H1 General Paper</span>
      <span class="marquee-item"><span class="marquee-dot"></span> A-Worthy</span>
      <span class="marquee-item"><span class="marquee-dot"></span> H2 Economics</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Founded by a Law Graduate</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Analytical Mastery</span>
      <span class="marquee-item"><span class="marquee-dot"></span> O-Level English</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The SHARP Method</span>
    </div>
  </div>

  <!-- ===== OUR STORY ===== -->
  <section class="section story">
    <div class="container">
      <div class="story-layout">
        <div class="story-text" data-animate="reveal-up">
          <span class="eyebrow">Our Story</span>
          <h2>A letter from our founder</h2>
          <p>Dear parents,</p>
          <p>
            I started A-Worthy because I watched bright students fail exams &mdash; not because they didn&rsquo;t study, but because nobody taught them how to think under pressure.
          </p>
          <p>
            In law school, I learned a precise way to read questions, structure arguments, and check my work before submission. When I started tutoring, I realised these same skills were exactly what English, GP, and Economics examiners reward.
          </p>
          <p>
            That&rsquo;s how SHARP was born &mdash; a five-step method that gives every student a repeatable process: See the question type, Hit the right framework, Apply it to the text, Refine through feedback, and Practise until it&rsquo;s automatic.
          </p>
          <p>
            Today, our students come from schools across Singapore &mdash; Raffles, Hwa Chong, ACS, CHIJ. We teach online in groups of six, because that&rsquo;s the maximum where every student still gets personal feedback every session.
          </p>
          <p>
            If your child knows the content but can&rsquo;t show it under exam conditions, I&rsquo;d love to show you how SHARP changes that.
          </p>
          <p class="founder-sign-off">
            &mdash; Jeremy Lim<br />
            Founder, A-Worthy
          </p>
        </div>
        <aside class="founder-card" data-animate="reveal-up">
          <div class="founder-card__photo" aria-label="Jeremy Lim, Founder of A-Worthy">
            <svg aria-hidden="true" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="founder-gradient" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="rgba(212, 133, 58, 0.15)" />
                  <stop offset="100%" stop-color="rgba(43, 90, 140, 0.12)" />
                </linearGradient>
              </defs>
              <rect width="200" height="200" rx="100" fill="url(#founder-gradient)"/>
              <circle cx="100" cy="80" r="32" fill="rgba(43, 90, 140, 0.2)"/>
              <ellipse cx="100" cy="155" rx="50" ry="38" fill="rgba(43, 90, 140, 0.15)"/>
            </svg>
            <span class="founder-card__initials">JL</span>
          </div>
          <div class="founder-card__body">
            <span class="founder-card__name">Jeremy Lim</span>
            <span class="founder-card__role">Founder &amp; Lead Tutor</span>
            <ul class="founder-card__creds">
              <li>NUS Faculty of Law &mdash; LLB (Hons)</li>
              <li>500+ students taught since 2020</li>
              <li>Creator of the SHARP Method</li>
            </ul>
            <button type="button" class="founder-card__video" aria-label="Watch a 2-minute intro from Jeremy (coming soon)" disabled>
              <svg width="40" height="40" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                <circle cx="32" cy="32" r="30" fill="rgba(212, 133, 58, 0.12)" stroke="var(--color-accent)" stroke-width="1.5"/>
                <polygon points="26,20 26,44 46,32" fill="var(--color-accent)"/>
              </svg>
              <div class="founder-card__video-text">
                <span class="founder-card__video-title">2-minute intro from Jeremy</span>
                <span class="founder-card__video-status">Video coming soon</span>
              </div>
            </button>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ===== WHAT WE TEACH ===== -->
  <section class="section subjects">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">What We Teach</span>
      <h2 data-animate="reveal-up">Three subjects, one proven tuition framework</h2>

      <div class="values-grid">
        <div class="value-item" data-animate="reveal-up" data-animate-delay="1">
          <h3>O-Level English</h3>
          <p>
            For Sec 1&ndash;4 students. Comprehension, composition, oral, and editing &mdash;
            every component taught through the SHARP Method, with paper-matched frameworks at the Hit step. Foundation and intensive programmes available.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="2">
          <h3>H1 General Paper</h3>
          <p>
            For JC 1&ndash;2 students. Essay argumentation, comprehension, and AQ mastery across all
            12 content themes. The SHARP Method&rsquo;s analytical roots make it a natural fit for GP.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="3">
          <h3>H2 Economics</h3>
          <p>
            For JC 1&ndash;2 students. Diagram precision, essay technique, and case study mastery
            covering the full 9570 syllabus. Analytical rigour applied to economic reasoning.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="4">
          <h3>One-to-One Coaching</h3>
          <p>
            Available across all three subjects. Fully customised to the student&rsquo;s specific gaps,
            with flexible scheduling and personalised feedback every session.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TEAM ===== -->
  <section class="section team">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Team</span>
      <h2 data-animate="reveal-up">Legal mind, teaching heart</h2>

      <div class="team-grid">
        <div class="team-card" data-animate="reveal-up">
          <div class="team-photo-wrap">
            <div class="team-photo-placeholder">
              <span class="team-photo-initials">JL</span>
            </div>
          </div>
          <h3>Jeremy Lim</h3>
          <span class="team-role">Law Graduate &amp; Lead Tutor</span>
          <div class="team-credentials">
            <span class="credential">LLB (Hons)</span>
            <span class="credential">SHARP Method Creator</span>
          </div>
          <p>
            With a law degree and years of direct teaching experience, Jeremy asked a simple question: why do law students learn to think so precisely, but secondary and JC students are told to &ldquo;just practise more&rdquo;? The answer became the SHARP Method &mdash; a five-step system (See, Hit, Apply, Refine, Practise) that distils legal-analytical rigour into a repeatable framework any student can master, with paper-matched frameworks deployed at the Hit step to produce the kind of structured thinking that examiners reward with top grades.
          </p>
        </div>
      </div>

      <div class="founder-profile" data-animate="reveal-up">
        <div class="founder-photo-wrap">
          <div class="founder-photo-placeholder" aria-label="Founder photo">
            <svg aria-hidden="true" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" width="200" height="200">
              <rect width="200" height="200" rx="100" fill="rgba(43,90,140,0.08)"/>
              <circle cx="100" cy="75" r="35" fill="rgba(43,90,140,0.15)"/>
              <ellipse cx="100" cy="155" rx="55" ry="40" fill="rgba(43,90,140,0.12)"/>
              <text x="100" y="195" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="rgba(43,90,140,0.4)" letter-spacing="0.1em">PHOTO</text>
            </svg>
          </div>
        </div>
        <div class="founder-info">
          <span class="eyebrow">Meet the Founder</span>
          <h3>Jeremy Lim &mdash; NUS Law Graduate &amp; Educator</h3>
          <p>Jeremy combined legal-analytical training from NUS Law with a passion for education to create the SHARP Method &mdash; a five-step system (See, Hit, Apply, Refine, Practise) that teaches students how to think critically, structure arguments precisely, and write with confidence. Every A-Worthy lesson reflects this unique combination of legal rigour and teaching expertise.</p>
          <div class="founder-credentials">
            <span class="founder-credential"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> NUS Faculty of Law</span>
            <span class="founder-credential"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 500+ Students Taught</span>
            <span class="founder-credential"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> SHARP Method Creator</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section values">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Values</span>
      <h2 data-animate="reveal-up">The pillars that define who we are</h2>

      <div class="values-grid">
        <div class="value-item" data-animate="reveal-up" data-animate-delay="1">
          <h3>Analytical Precision</h3>
          <p>
            Other tuition centres teach content. We teach the thinking process behind the content. The same rigour that trains lawyers to win cases trains your child to win marks &mdash; systematically, across every exam component.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="2">
          <h3>Proven Results</h3>
          <p>
            90% A1&ndash;B3 rate. Students going from D7 to A2 in three months. We don&rsquo;t make vague promises &mdash; we track every student&rsquo;s progress against official marking criteria and show you the numbers.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="3">
          <h3>Small Groups</h3>
          <p>
            Six students maximum. No exceptions. Your child can&rsquo;t be invisible in a class this small &mdash; they get live feedback on their work every session, and the tutor knows their specific strengths and weaknesses by name.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="4">
          <h3>The SHARP Method</h3>
          <p>
            See, Hit, Apply, Refine, Practise &mdash; five steps your child follows for every question, every subject, every exam. Paper-matched frameworks are deployed at the Hit step, giving students precise tools for each paper type. It&rsquo;s not a gimmick; it&rsquo;s a repeatable system that compounds over time, turning analytical thinking into exam results.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ONLINE DELIVERY ===== -->
  <section class="section centres">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Online Delivery</span>
      <h2 data-animate="reveal-up">100% Online Delivery</h2>

      <div class="centres-grid">
        <div class="centre-card" data-animate="reveal-up">
          <h3>Learn from anywhere in Singapore</h3>
          <p>
            All lessons are conducted via Zoom Pro with cloud recording, screen sharing, and
            breakout rooms. Students join from anywhere in Singapore. No commute, no wasted
            time &mdash; just focused learning.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section cta">
    <div class="container cta-inner">
      <span class="eyebrow" data-animate="reveal-up">Get Started</span>
      <h2 data-animate="reveal-up">Book a free diagnostic assessment</h2>
      <p class="cta-desc">
        A 20-minute session analysing your child&rsquo;s recent paper &mdash; English, GP, or Economics.
      </p>
      <a href="/contact/" class="cta-button">Get Started</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --about-bg: var(--bg-primary);
    --about-bg-alt: var(--bg-secondary);
    --about-white: #ffffff;
    --about-gray: var(--text-secondary);
    --about-border: var(--border-color);
    --about-accent: var(--color-accent);
    --about-font: var(--font-body);
    --about-mono: var(--font-mono);
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: inline-block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--about-accent);
    margin-bottom: 1.25rem;
  }

  /* ===== HERO ===== */
  .hero {
    width: 100%;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    border-bottom: 1px solid var(--border-color);
    padding: calc(var(--header-height) + 3rem) 0 3rem;
    text-align: center;
  }

  .hero-content {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content h1 {
    font-family: var(--about-font);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 200;
    line-height: 1.15;
    color: var(--text-primary);
    max-width: 700px;
    margin: 0 auto;
    letter-spacing: -0.03em;
  }

  /* ===== SECTIONS ===== */
  .section {
    background: var(--about-bg);
    padding: 4rem 0;
  }

  .section:nth-child(even) {
    background: var(--about-bg-alt);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section h2 {
    font-family: var(--about-font);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 200;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0 0 3rem;
    max-width: 600px;
  }

  .section p {
    font-family: var(--about-font);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--about-gray);
    margin: 0 0 1.25rem;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  /* ===== OUR STORY ===== */
  .story-text h2 {
    max-width: 100%;
  }

  /* ===== TEAM ===== */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .team-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .team-card:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  @keyframes team-initials-shimmer {
    0%, 100% { box-shadow: 0 0 0 transparent; }
    50% { box-shadow: 0 0 18px rgba(212, 133, 58, 0.35), 0 0 40px rgba(201, 169, 110, 0.12); }
  }

  .team-photo-wrap {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--color-accent), #2B5A8C, var(--color-accent));
    margin-bottom: 1.5rem;
    animation: team-initials-shimmer 5s ease-in-out infinite;
  }

  .team-photo-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(212, 133, 58, 0.15), rgba(43, 90, 140, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .team-photo-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-photo-initials {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .team-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.35rem;
    letter-spacing: -0.03em;
  }

  .team-role {
    display: block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--about-accent);
    margin-bottom: 1rem;
  }

  .team-credentials {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .credential {
    font-family: var(--about-font);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--about-gray);
    border: 1px solid var(--about-border);
    border-radius: 3px;
    padding: 0.2rem 0.6rem;
  }

  .team-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== VALUES ===== */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .value-item {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .value-item:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  .value-item h3 {
    font-family: var(--about-font);
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
  }

  .value-item p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CENTRES ===== */
  .centres-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .centre-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .centre-card:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  .centre-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
  }

  .centre-address {
    font-family: var(--about-mono);
    font-size: 0.72rem !important;
    letter-spacing: 0.04em;
    color: var(--about-accent) !important;
    margin-bottom: 1.25rem !important;
  }

  .centre-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CTA ===== */
  .cta {
    background: var(--about-bg-alt) !important;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta h2 {
    max-width: 100%;
    margin-bottom: 1.25rem;
  }

  .cta-desc {
    text-align: center;
    margin-bottom: 2.5rem !important;
  }

  .cta-button {
    display: inline-block;
    font-family: var(--about-font);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    background: var(--color-accent);
    border: none;
    border-radius: 0;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    opacity: 0.9;
    transform: translateY(-3px);
  }

  /* ===== FOUNDER PROFILE ===== */
  .founder-profile {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-top: 3rem;
    padding: 2.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
  }
  .founder-photo-wrap {
    flex-shrink: 0;
  }
  .founder-photo-placeholder {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border-color);
  }
  .founder-info h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 300;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }
  .founder-info p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }
  .founder-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .founder-credential {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  /* ===== RESPONSIVE ===== */

  @media (max-width: 768px) {
    .section {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1.5rem;
    }

    .team-grid,
    .values-grid,
    .centres-grid {
      grid-template-columns: 1fr;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 2rem;
    }

    .founder-profile {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .founder-photo-wrap {
      display: flex;
      justify-content: center;
    }
    .founder-credentials {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 3rem 0;
    }

