---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="About A-Worthy | Singapore's Analytical Tuition Centre for English, GP & Economics" description="Founded by an NUS Law graduate, A-Worthy is a Singapore tuition centre that brings legal-analytical precision to O-Level English, H1 General Paper & H2 Economics. Discover our story, the CASE Method, and why parents trust us.">
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">About A-Worthy</span>
      <h1>Singapore&rsquo;s analytical tuition centre &mdash; where legal precision meets academic results</h1>
    </div>
  </section>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-inner">
      <span class="marquee-item"><span class="marquee-dot"></span> Legal Precision</span>
      <span class="marquee-item"><span class="marquee-dot"></span> O-Level English</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The CASE Method</span>
      <span class="marquee-item"><span class="marquee-dot"></span> H1 General Paper</span>
      <span class="marquee-item"><span class="marquee-dot"></span> A-Worthy</span>
      <span class="marquee-item"><span class="marquee-dot"></span> H2 Economics</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Founded by a Law Graduate</span>
      <span class="marquee-item"><span class="marquee-dot"></span> Analytical Mastery</span>
      <span class="marquee-item"><span class="marquee-dot"></span> O-Level English</span>
      <span class="marquee-item"><span class="marquee-dot"></span> The CASE Method</span>
    </div>
  </div>

  <!-- ===== OUR STORY ===== -->
  <section class="section story">
    <div class="container">
      <div class="story-layout">
        <div class="story-text" data-animate="reveal-up">
          <span class="eyebrow">Our Story</span>
          <h2>Born from law, built to help Singapore students excel</h2>
          <p>
            A-Worthy was founded by an NUS Law graduate who discovered something remarkable: the analytical skills developed in law school &mdash; close reading, structured argumentation, evidence-based reasoning &mdash; are exactly what O-Level English, GP, and H2 Economics examiners reward.
          </p>
          <p>
            What began as Singapore&rsquo;s first analytical English tuition programme has since grown into a trusted tuition centre for H1 General Paper and H2 Economics. The CASE Method &mdash; our proprietary legal-analytical framework &mdash; is just as powerful for GP essay argumentation and Economics case study analysis as it is for O-Level comprehension and composition.
          </p>
          <p>
            Our students range from Secondary 1 to JC 2, joining from schools across Singapore. We teach exclusively online in small groups of six, delivering focused weekly sessions through Zoom. This format ensures every student receives the individual attention they need &mdash; while keeping tuition fees accessible for families.
          </p>
        </div>
        <div class="video-placeholder" data-animate="reveal-up">
          <div class="video-thumb">
            <svg class="video-play" width="64" height="64" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="32" r="30" stroke="currentColor" stroke-width="2" opacity="0.3"/><polygon points="26,20 26,44 46,32" fill="currentColor" opacity="0.6"/></svg>
            <span class="video-label">Meet our founder &mdash; 2 min intro</span>
          </div>
          <p class="video-caption">Hear from our founder about the CASE Method, legal-analytical teaching, and what makes A-Worthy different.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT WE TEACH ===== -->
  <section class="section subjects">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">What We Teach</span>
      <h2 data-animate="reveal-up">Three subjects, one proven tuition framework</h2>

      <div class="values-grid">
        <div class="value-item" data-animate="reveal-up" data-animate-delay="1">
          <h3>O-Level English</h3>
          <p>
            For Sec 1&ndash;4 students. Comprehension, composition, oral, and editing &mdash;
            every component taught through the CASE Method. Foundation and intensive programmes available.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="2">
          <h3>H1 General Paper</h3>
          <p>
            For JC 1&ndash;2 students. Essay argumentation, comprehension, and AQ mastery across all
            12 content themes. The CASE Method&rsquo;s legal roots make it a natural fit for GP.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="3">
          <h3>H2 Economics</h3>
          <p>
            For JC 1&ndash;2 students. Diagram precision, essay technique, and case study mastery
            covering the full 9570 syllabus. Analytical rigour applied to economic reasoning.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="4">
          <h3>One-to-One Coaching</h3>
          <p>
            Available across all three subjects. Fully customised to the student&rsquo;s specific gaps,
            with flexible scheduling and personalised feedback every session.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TEAM ===== -->
  <section class="section team">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Team</span>
      <h2 data-animate="reveal-up">Legal mind, teaching heart</h2>

      <div class="team-grid">
        <div class="team-card" data-animate="reveal-up">
          <div class="team-photo-wrap">
            <div class="team-photo-placeholder">
              <span class="team-photo-initials">TF</span>
            </div>
          </div>
          <h3>The Founder</h3>
          <span class="team-role">Law Graduate &amp; Lead Tutor</span>
          <div class="team-credentials">
            <span class="credential">LLB (Hons)</span>
            <span class="credential">CASE Method Creator</span>
          </div>
          <p>
            With a law degree and years of direct teaching experience, our founder asked a simple question: why do law students learn to think so precisely, but secondary and JC students are told to &ldquo;just practise more&rdquo;? The answer became the CASE Method &mdash; a proprietary system that distils legal-analytical rigour into a four-step framework any student can master, producing the kind of structured thinking that examiners reward with top grades.
          </p>
        </div>
      </div>

      <div class="founder-profile" data-animate="reveal-up">
        <div class="founder-photo-wrap">
          <div class="founder-photo-placeholder" aria-label="Founder photo">
            <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" width="200" height="200">
              <rect width="200" height="200" rx="100" fill="rgba(43,90,140,0.08)"/>
              <circle cx="100" cy="75" r="35" fill="rgba(43,90,140,0.15)"/>
              <ellipse cx="100" cy="155" rx="55" ry="40" fill="rgba(43,90,140,0.12)"/>
              <text x="100" y="195" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="rgba(43,90,140,0.4)" letter-spacing="0.1em">PHOTO</text>
            </svg>
          </div>
        </div>
        <div class="founder-info">
          <span class="eyebrow">Meet the Founder</span>
          <h3>NUS Law Graduate &amp; Educator</h3>
          <p>Our founder combined legal-analytical training from NUS Law with a passion for education to create the CASE Method &mdash; a systematic approach that teaches students how to think critically, structure arguments precisely, and write with confidence. Every A-Worthy lesson reflects this unique combination of legal rigour and teaching expertise.</p>
          <div class="founder-credentials">
            <span class="founder-credential"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> NUS Faculty of Law</span>
            <span class="founder-credential"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 500+ Students Taught</span>
            <span class="founder-credential"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> CASE Method Creator</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section values">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Our Values</span>
      <h2 data-animate="reveal-up">The pillars that define who we are</h2>

      <div class="values-grid">
        <div class="value-item" data-animate="reveal-up" data-animate-delay="1">
          <h3>Analytical Precision</h3>
          <p>
            Other tuition centres teach content. We teach the thinking process behind the content. The same rigour that trains lawyers to win cases trains your child to win marks &mdash; systematically, across every exam component.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="2">
          <h3>Proven Results</h3>
          <p>
            90% A1&ndash;B3 rate. Students going from D7 to A2 in three months. We don&rsquo;t make vague promises &mdash; we track every student&rsquo;s progress against official marking criteria and show you the numbers.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="3">
          <h3>Small Groups</h3>
          <p>
            Six students maximum. No exceptions. Your child can&rsquo;t be invisible in a class this small &mdash; they get live feedback on their work every session, and the tutor knows their specific strengths and weaknesses by name.
          </p>
        </div>
        <div class="value-item" data-animate="reveal-up" data-animate-delay="4">
          <h3>The CASE Method</h3>
          <p>
            Contextualise, Analyse, Structure, Evaluate &mdash; four steps your child follows for every question, every subject, every exam. It&rsquo;s not a gimmick; it&rsquo;s a repeatable system that compounds over time, turning analytical thinking into exam results.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ONLINE DELIVERY ===== -->
  <section class="section centres">
    <div class="container">
      <span class="eyebrow" data-animate="reveal-up">Online Delivery</span>
      <h2 data-animate="reveal-up">100% Online Delivery</h2>

      <div class="centres-grid">
        <div class="centre-card" data-animate="reveal-up">
          <h3>Learn from anywhere in Singapore</h3>
          <p>
            All lessons are conducted via Zoom Pro with cloud recording, screen sharing, and
            breakout rooms. Students join from anywhere in Singapore. No commute, no wasted
            time &mdash; just focused learning.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section cta">
    <div class="container cta-inner">
      <span class="eyebrow" data-animate="reveal-up">Get Started</span>
      <h2 data-animate="reveal-up">Book a free diagnostic assessment</h2>
      <p class="cta-desc">
        A 20-minute session analysing your child&rsquo;s recent paper &mdash; English, GP, or Economics.
      </p>
      <a href="/contact/" class="cta-button">Get Started</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== DESIGN TOKENS ===== */
  :root {
    --about-bg: var(--bg-primary);
    --about-bg-alt: var(--bg-secondary);
    --about-white: #ffffff;
    --about-gray: var(--text-secondary);
    --about-border: var(--border-color);
    --about-accent: var(--color-accent);
    --about-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --about-mono: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
  }

  /* ===== EYEBROW ===== */
  .eyebrow {
    display: inline-block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--about-accent);
    margin-bottom: 1.25rem;
  }

  /* ===== HERO ===== */
  .hero {
    width: 100%;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    border-bottom: 1px solid var(--border-color);
    padding: calc(var(--header-height) + 3rem) 0 3rem;
    text-align: center;
  }

  .hero-content {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content h1 {
    font-family: var(--about-font);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 200;
    line-height: 1.15;
    color: var(--text-primary);
    max-width: 700px;
    margin: 0 auto;
    letter-spacing: -0.03em;
  }

  /* ===== SECTIONS ===== */
  .section {
    background: var(--about-bg);
    padding: 4rem 0;
  }

  .section:nth-child(even) {
    background: var(--about-bg-alt);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section h2 {
    font-family: var(--about-font);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 200;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0 0 3rem;
    max-width: 600px;
  }

  .section p {
    font-family: var(--about-font);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--about-gray);
    margin: 0 0 1.25rem;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  /* ===== OUR STORY ===== */
  .story-layout {
    max-width: 720px;
  }

  .story-text h2 {
    max-width: 100%;
  }

  /* ===== TEAM ===== */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .team-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .team-card:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  @keyframes team-initials-shimmer {
    0%, 100% { box-shadow: 0 0 0 transparent; }
    50% { box-shadow: 0 0 18px rgba(212, 133, 58, 0.35), 0 0 40px rgba(201, 169, 110, 0.12); }
  }

  .team-photo-wrap {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--color-accent), #2B5A8C, var(--color-accent));
    margin-bottom: 1.5rem;
    animation: team-initials-shimmer 5s ease-in-out infinite;
  }

  .team-photo-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(212, 133, 58, 0.15), rgba(43, 90, 140, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .team-photo-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-photo-initials {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .team-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.35rem;
    letter-spacing: -0.03em;
  }

  .team-role {
    display: block;
    font-family: var(--about-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--about-accent);
    margin-bottom: 1rem;
  }

  .team-credentials {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .credential {
    font-family: var(--about-font);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--about-gray);
    border: 1px solid var(--about-border);
    border-radius: 3px;
    padding: 0.2rem 0.6rem;
  }

  .team-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== VALUES ===== */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .value-item {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .value-item:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  .value-item h3 {
    font-family: var(--about-font);
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
  }

  .value-item p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CENTRES ===== */
  .centres-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .centre-card {
    background: var(--bg-card);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2.5rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .centre-card:hover {
      transform: translateY(-3px);
      border-color: rgba(26, 42, 58, 0.12);
    }
  }

  .centre-card h3 {
    font-family: var(--about-font);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
  }

  .centre-address {
    font-family: var(--about-mono);
    font-size: 0.72rem !important;
    letter-spacing: 0.04em;
    color: var(--about-accent) !important;
    margin-bottom: 1.25rem !important;
  }

  .centre-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  /* ===== CTA ===== */
  .cta {
    background: var(--about-bg-alt) !important;
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta h2 {
    max-width: 100%;
    margin-bottom: 1.25rem;
  }

  .cta-desc {
    text-align: center;
    margin-bottom: 2.5rem !important;
  }

  .cta-button {
    display: inline-block;
    font-family: var(--about-font);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-primary);
    background: var(--color-accent);
    border: none;
    border-radius: 0;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    opacity: 0.9;
    transform: translateY(-3px);
  }

  /* ===== FOUNDER PROFILE ===== */
  .founder-profile {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-top: 3rem;
    padding: 2.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
  }
  .founder-photo-wrap {
    flex-shrink: 0;
  }
  .founder-photo-placeholder {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border-color);
  }
  .founder-info h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 300;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }
  .founder-info p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }
  .founder-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .founder-credential {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  /* ===== RESPONSIVE ===== */

  @media (max-width: 768px) {
    .section {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1.5rem;
    }

    .team-grid,
    .values-grid,
    .centres-grid {
      grid-template-columns: 1fr;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 2rem;
    }

    .founder-profile {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .founder-photo-wrap {
      display: flex;
      justify-content: center;
    }
    .founder-credentials {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 3rem 0;
    }

    .section h2 {
      margin-bottom: 2rem;
    }

    .team-card,
    .value-item,
    .centre-card {
      padding: 1.5rem;
    }
  }

  @media (min-width: 1921px) {
    .hero-content {
      max-width: 1400px;
    }

    .container {
      max-width: 1400px;
    }

    .section {
      padding: 8rem 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .team-photo-wrap {
      animation: none;
    }
  }

  .video-placeholder { margin-top: 2rem; }
  .video-thumb { aspect-ratio: 16/9; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; cursor: pointer; transition: all 0.3s ease; }
  .video-thumb:hover { border-color: var(--color-accent); background: rgba(212,133,58,0.04); }
  .video-play { color: var(--color-accent); }
  .video-label { font-size: 0.85rem; color: var(--text-secondary); font-weight: 500; }
  .video-caption { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.75rem; }
</style>
