---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout title="Page Not Found | A-Worthy Singapore Tuition Centre" description="This page doesn't exist. Return to A-Worthy's homepage for O-Level English, H1 General Paper & H2 Economics tuition in Singapore.">
  <Header slot="header" />

  <section class="error-page">
    <div class="error-bg">404</div>
    <section class="section error-section">
      <div class="container" style="text-align: center; max-width: 600px;">
        <span class="eyebrow">404</span>
        <h1 style="font-family: var(--font-heading); font-size: clamp(4rem, 10vw, 8rem); font-weight: 200; color: var(--color-accent); line-height: 1; margin-bottom: 1rem;">Oops</h1>
        <p style="font-size: 1.15rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 2.5rem;">The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
        <div style="display: flex; flex-direction: column; gap: 0.75rem; align-items: center; margin-bottom: 3rem;">
          <a href="/" class="btn btn-primary" style="min-width: 240px; text-align: center;">Go to Homepage</a>
          <a href="/programmes/" class="btn btn-secondary" style="min-width: 240px; text-align: center;">View Programmes</a>
          <a href="/contact/" class="btn btn-secondary" style="min-width: 240px; text-align: center;">Contact Us</a>
        </div>
        <p style="font-size: 0.85rem; color: var(--text-muted);">Popular pages:</p>
        <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-top: 0.75rem;">
          <a href="/o-level-english/" style="font-size: 0.8rem; color: var(--color-accent); text-decoration: none;">O-Level English</a>
          <span style="color: var(--text-muted);">&middot;</span>
          <a href="/h1-general-paper/" style="font-size: 0.8rem; color: var(--color-accent); text-decoration: none;">H1 General Paper</a>
          <span style="color: var(--text-muted);">&middot;</span>
          <a href="/h2-economics/" style="font-size: 0.8rem; color: var(--color-accent); text-decoration: none;">H2 Economics</a>
          <span style="color: var(--text-muted);">&middot;</span>
          <a href="/resources/" style="font-size: 0.8rem; color: var(--color-accent); text-decoration: none;">Free Resources</a>
          <span style="color: var(--text-muted);">&middot;</span>
          <a href="/results/" style="font-size: 0.8rem; color: var(--color-accent); text-decoration: none;">Results</a>
        </div>
      </div>
    </section>
  </section>

  <Footer />
</BaseLayout>

<style>
  .error-page {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--bg-primary);
    overflow: hidden;
  }

  .error-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Inter', sans-serif;
    font-size: clamp(16rem, 30vw, 28rem);
    font-weight: 800;
    color: var(--bg-secondary);
    line-height: 1;
    letter-spacing: -0.04em;
    user-select: none;
    pointer-events: none;
  }

  .error-content {
    position: relative;
    z-index: 1;
    max-width: 480px;
    padding: 2rem;
  }

  .eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .heading {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 200;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 1rem 0;
  }

  .subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 0 0 2.5rem 0;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .actions .btn {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.75rem 1.75rem;
    border-radius: 0;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    letter-spacing: 0.01em;
  }

  .actions .btn-primary {
    background: var(--color-accent);
    color: var(--text-primary);
    border: 1px solid var(--color-accent);
  }

  .actions .btn-primary:hover {
    background: #d4632f;
    border-color: #d4632f;
  }

  .actions .btn-secondary {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
  }

  .actions .btn-secondary:hover {
    color: var(--text-primary);
    border-color: rgba(26, 42, 58, 0.2);
  }

  /* ===== VISUAL PLACEHOLDER ===== */
  .error-visual-placeholder {
    background: var(--bg-secondary);
    border: 1px dashed var(--border-color);
    border-radius: var(--border-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
