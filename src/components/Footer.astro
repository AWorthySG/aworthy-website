    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} A Worthy Pte Ltd. All rights reserved.</p>
      <p>Registered with the Ministry of Education, Singapore.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #1A2A3A;
    border-top: none;
    padding: 4rem 0 2rem;
    /* Safe area for notched devices */
    padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
    color: rgba(255, 255, 255, 0.65);
    position: relative;
  }

  .footer-gradient {
    position: absolute;
    top: -80px;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(180deg, transparent 0%, #1A2A3A 100%);
    pointer-events: none;
  }
  .footer-gradient::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(212, 133, 58, 0.3) 30%, rgba(212, 133, 58, 0.5) 50%, rgba(212, 133, 58, 0.3) 70%, transparent 100%);
    pointer-events: none;
  }
  :global([data-theme="dark"]) .footer-gradient::before {
    background: linear-gradient(90deg, transparent 0%, rgba(224, 152, 80, 0.2) 30%, rgba(224, 152, 80, 0.35) 50%, rgba(224, 152, 80, 0.2) 70%, transparent 100%);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: var(--space-lg);
  }

  .footer-logo-img {
    height: 24px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.8;
  }

  .footer-socials {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .footer-socials a {
    color: rgba(255, 255, 255, 0.5);
    transition: color var(--transition-fast);
  }

  .footer-socials a:hover {
    color: var(--color-accent);
  }

  .footer-links h4,
  .footer-contact h4 {
    font-family: var(--font-mono);
    color: #ffffff;
    margin-bottom: var(--space-md);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .footer-links ul,
  .footer-contact ul {
    list-style: none;
    padding: 0;
  }

  .footer-links li,
  .footer-contact li {
    margin-bottom: var(--space-sm);
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer-links a,
  .footer-contact a {
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.3s ease;
  }

  .footer-links a:hover,
  .footer-contact a:hover {
    color: #ffffff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 2rem;
    margin-top: 3rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.8rem;
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: var(--space-xs);
    }
  }
</style>
