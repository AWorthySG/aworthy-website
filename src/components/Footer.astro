      </div>

      <!-- Contact -->
      <div class="footer-contact">
        <h4>Contact</h4>
        <ul>
          <li>Online via Zoom — Singapore-wide</li>
          <li><a href="tel:+6561234567">+65 6123 4567</a></li>
          <li><a href="mailto:hello@aworthy.sg">hello@aworthy.sg</a></li>
          <li>Mon-Fri: 2 PM - 9:30 PM<br>Sat-Sun: 9 AM - 6 PM</li>
        </ul>
