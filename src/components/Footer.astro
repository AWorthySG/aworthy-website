        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-links">
        <h4>Education</h4>
        <ul>
          <li><a href="/programmes/#sec1-2">Sec 1-2 Foundation</a></li>
          <li><a href="/programmes/#sec3-4">Sec 3-4 O-Level</a></li>
          <li><a href="/programmes/#one-to-one">One-to-One</a></li>
          <li><a href="/#method">CASE Method</a></li>
          <li><a href="/results/">Results</a></li>
        </ul>
      </div>

      <!-- About -->
      <div class="footer-links">
        <h4>About</h4>
        <ul>
          <li><a href="/about/">Our Story</a></li>
          <li><a href="/about/">Team</a></li>
          <li><a href="/testimonials/">Reviews</a></li>
          <li><a href="/contact/">Contact</a></li>
