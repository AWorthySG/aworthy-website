---
type NavLeaf = { href: string; label: string };
type NavGroup = { label: string; children: NavLeaf[] };
type NavItem = NavLeaf | NavGroup;

const navLinks: NavItem[] = [
  { href: '/about/', label: 'About' },
  { href: '/programmes/', label: 'Programmes' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/results/', label: 'Results' },
  {
    label: 'Library',
    children: [
      { href: '/frameworks/', label: 'Frameworks' },
      { href: '/resources/', label: 'Resources' },
      { href: '/blog/', label: 'Blog' },
    ],
  },
  { href: '/testimonials/', label: 'Reviews' },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href);
const isGroup = (item: NavItem): item is NavGroup => 'children' in item;
const isGroupActive = (group: NavGroup) => group.children.some(c => isActive(c.href));
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="A-Worthy — Home">
      <img src="/images/logo.svg" alt="A-Worthy" class="logo-img" />
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" aria-label="Primary navigation">
      <ul>
        {navLinks.map(link => isGroup(link) ? (
          <li class="has-dropdown">
            <button
              type="button"
              class:list={['nav-trigger', { active: isGroupActive(link) }]}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {link.label}
              <svg class="nav-trigger__caret" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <ul class="nav-dropdown" role="menu">
              {link.children.map(child => (
                <li role="none">
                  <a role="menuitem" href={child.href} class:list={[{ active: isActive(child.href) }]} aria-current={isActive(child.href) ? 'page' : undefined}>
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ) : (
          <li>
            <a href={link.href} class:list={[{ active: isActive(link.href) }]} aria-current={isActive(link.href) ? 'page' : undefined}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <!-- Theme Toggle -->
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle light mode"
        title="Toggle light mode"
      >
        <span class="theme-icon-light"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg></span>
        <span class="theme-icon-dark"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
      </button>

      <!-- CTA -->
      <a href="/contact/" class="btn btn-accent header-cta"><span>Book Free Assessment</span></a>

      <!-- Mobile Hamburger -->
      <button
        class="hamburger"
        id="hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav Overlay -->
  <div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    <ul>
      {navLinks.map(link => isGroup(link) ? (
        <Fragment>
          <li class="mobile-nav-group-label">
            <span>{link.label}</span>
          </li>
          {link.children.map(child => (
            <li class="mobile-nav-child">
              <a href={child.href}>
                {child.label}
              </a>
            </li>
          ))}
        </Fragment>
      ) : (
        <li>
          <a href={link.href}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a href="/contact/" class="btn btn-accent mobile-cta"><span>Book Free Assessment</span></a>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding: 0 max(var(--space-xl), env(safe-area-inset-right, 0px)) 0 max(var(--space-xl), env(safe-area-inset-left, 0px));
    padding-top: env(safe-area-inset-top, 0px);
    height: calc(var(--header-height) + env(safe-area-inset-top, 0px));
    display: flex;
    align-items: center;
    background: transparent;
    transition: background 0.4s ease, border-color 0.4s ease;
    border-bottom: 1px solid transparent;
  }

  .site-header.scrolled {
    background: rgba(253, 251, 247, 0.9);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(26, 42, 58, 0.08);
  }

  :global([data-theme="dark"]) .site-header.scrolled {
    background: rgba(11, 11, 15, 0.9);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    gap: var(--space-md);
  }

  /* Logo — minimal text only */
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 40px;
    width: auto;
    max-width: 100%;
    filter: none;
  }

  /* Desktop Nav */
  .desktop-nav ul {
    display: flex;
    list-style: none;
    gap: 0;
    padding: 0;
  }

  .desktop-nav a {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    text-decoration: none;
    transition: color 0.3s ease;
    white-space: nowrap;
    position: relative;
  }

  .desktop-nav a:hover,
  .desktop-nav a.active {
    color: var(--text-primary);
  }

  .desktop-nav a.active::after {
    content: '';
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.1rem;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-light));
    border-radius: 999px;
  }

  /* Desktop dropdown trigger + panel */
  .desktop-nav .has-dropdown {
    position: relative;
  }
  .desktop-nav .nav-trigger {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.3s ease;
    white-space: nowrap;
    position: relative;
    min-height: 44px;
    font-family: inherit;
  }
  .desktop-nav .nav-trigger:hover,
  .desktop-nav .nav-trigger.active {
    color: var(--text-primary);
  }
  .desktop-nav .nav-trigger.active::after {
    content: '';
    position: absolute;
    left: 1rem;
    right: calc(1rem + 0.6rem);
    bottom: 0.1rem;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-light));
    border-radius: 999px;
  }
  .desktop-nav .nav-trigger__caret {
    transition: transform 0.2s ease;
    opacity: 0.7;
  }
  .desktop-nav .has-dropdown:hover .nav-trigger__caret,
  .desktop-nav .has-dropdown:focus-within .nav-trigger__caret {
    transform: rotate(180deg);
  }
  .desktop-nav .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(0.5rem);
    display: flex;
    flex-direction: column;
    min-width: 180px;
    margin: 0;
    padding: 0.4rem;
    list-style: none;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    box-shadow: 0 12px 30px -8px rgba(26, 42, 58, 0.18), 0 1px 2px rgba(26, 42, 58, 0.05);
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: var(--z-dropdown);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
  }
  .desktop-nav .has-dropdown:hover > .nav-dropdown,
  .desktop-nav .has-dropdown:focus-within > .nav-dropdown {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .desktop-nav .nav-dropdown li {
    list-style: none;
  }
  .desktop-nav .nav-dropdown a {
    display: block;
    padding: 0.55rem 0.85rem;
    border-radius: var(--border-radius);
    color: var(--text-secondary);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .desktop-nav .nav-dropdown a:hover,
  .desktop-nav .nav-dropdown a:focus-visible,
  .desktop-nav .nav-dropdown a.active {
    color: var(--color-accent);
    background: rgba(212, 133, 58, 0.08);
  }
  .desktop-nav .nav-dropdown a.active::after {
    content: none;
  }
  :global([data-theme="dark"]) .desktop-nav .nav-dropdown a:hover,
  :global([data-theme="dark"]) .desktop-nav .nav-dropdown a:focus-visible,
  :global([data-theme="dark"]) .desktop-nav .nav-dropdown a.active {
    background: rgba(224, 152, 80, 0.1);
  }

  /* Header Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .header-cta {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.6rem 1.5rem;
    border: 1px solid rgba(212, 133, 58, 0.4);
    color: var(--color-accent);
    background: transparent;
    border-radius: 0;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .header-cta:hover {
    background: rgba(212, 133, 58, 0.1);
    border-color: var(--color-accent);
  }

  /* Theme Toggle */
  .theme-toggle {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.3s ease;
    padding: 0;
  }

  .theme-toggle:hover {
    color: var(--text-primary);
  }

  :global([data-theme="dark"]) .theme-icon-dark,
  :global([data-theme="light"]) .theme-icon-light { display: none; }

  /* Hamburger — minimal 2-line */
  .hamburger {
    display: none;
    width: 44px;
    height: 44px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--text-primary);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-primary);
    transition: all 0.3s ease;
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(3px, 3px);
  }
  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    transform: rotate(-45deg) translate(3px, -3px);
  }

  /* Mobile Nav */
  .mobile-nav-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: var(--z-dropdown);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .mobile-nav-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav {
    position: fixed;
    top: 0;
    right: -320px;
    width: min(320px, 90vw);
    /* Use dvh for mobile browser chrome awareness, fallback to vh */
    height: 100vh;
    height: 100dvh;
    background: rgba(253, 251, 247, 0.98);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    border-left: 1px solid var(--border-color);
    z-index: calc(var(--z-dropdown) + 1);
    transition: right var(--transition-slow);
    padding: calc(5rem + env(safe-area-inset-top, 0px)) 2rem calc(2rem + env(safe-area-inset-bottom, 0px));
    overflow-y: auto;
    /* Smooth momentum scrolling on iOS */
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }

  .mobile-nav.open {
    right: 0;
  }

  .mobile-nav ul {
    list-style: none;
    padding: 0;
  }

  .mobile-nav a {
    display: block;
    /* Minimum 44px touch target */
    padding: var(--space-md) 0;
    min-height: 44px;
    display: flex;
    align-items: center;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-color);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    touch-action: manipulation;
  }

  .mobile-nav a:active {
    color: var(--color-accent);
  }

  .mobile-nav .mobile-nav-group-label {
    padding: var(--space-md) 0 var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    border-bottom: 1px solid var(--border-color);
  }
  .mobile-nav .mobile-nav-child a {
    padding-left: 1rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .mobile-cta {
    margin-top: var(--space-xl);
    width: 100%;
    text-align: center;
    justify-content: center;
  }

  :global([data-theme="dark"]) .mobile-nav {
    background: rgba(11, 11, 15, 0.98);
  }

  .theme-toggle:focus-visible,
  .hamburger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--border-radius);
  }

  @media (max-width: 1024px) {
    .desktop-nav { display: none; }
    .header-cta { display: none; }
    .hamburger { display: flex; }
  }

  @media (max-width: 480px) {
    .site-header {
      padding-left: max(var(--space-md), env(safe-area-inset-left, 0px));
      padding-right: max(var(--space-md), env(safe-area-inset-right, 0px));
    }
    .header-actions { gap: 0.25rem; }
  }

  /* Wider mobile nav on tablets */
  @media (min-width: 481px) and (max-width: 1024px) {
    .mobile-nav {
      width: min(400px, 80vw);
      right: -400px;
    }
  }

  /* TV / Large screen — larger nav text and logo */
  @media (min-width: 1921px) {
    .logo-img {
      height: 48px;
    }
    .desktop-nav a {
      font-size: 0.8rem;
      padding: 0.75rem 1.25rem;
    }
    .header-cta {
      font-size: 0.8rem;
      padding: 0.75rem 2rem;
    }
  }
</style>

<script>
  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  function updateToggleLabel() {
    var theme = document.documentElement.getAttribute('data-theme');
    var label = theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
    toggle?.setAttribute('aria-label', label);
    toggle?.setAttribute('title', label);
  }
  updateToggleLabel();
  toggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateToggleLabel();
  });

  // Mobile nav
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  const overlay = document.getElementById('mobile-nav-overlay');

  function closeMobileNav() {
    hamburger?.setAttribute('aria-expanded', 'false');
    mobileNav?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMobileNav();
    } else {
      hamburger.setAttribute('aria-expanded', 'true');
      mobileNav?.classList.add('open');
      overlay?.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
  });

  overlay?.addEventListener('click', closeMobileNav);

  // Desktop nav dropdown — sync aria-expanded with hover/focus so screen
  // readers know when the menu is open (CSS handles visibility on its own).
  document.querySelectorAll('.desktop-nav .has-dropdown').forEach(function(group) {
    const trigger = group.querySelector('.nav-trigger');
    if (!trigger) return;
    const setExpanded = (state: boolean) => trigger.setAttribute('aria-expanded', String(state));
    group.addEventListener('mouseenter', () => setExpanded(true));
    group.addEventListener('mouseleave', () => setExpanded(false));
    group.addEventListener('focusin', () => setExpanded(true));
    group.addEventListener('focusout', (e) => {
      // Only collapse when focus leaves the entire group
      if (!group.contains((e as FocusEvent).relatedTarget as Node)) setExpanded(false);
    });
  });

  // Close mobile nav on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && mobileNav?.classList.contains('open')) {
      closeMobileNav();
    }
  });

  // Auto-close mobile nav on link click
  var mobileNavLinks = document.querySelectorAll('#mobile-nav a, .mobile-cta');
  mobileNavLinks.forEach(function(link) {
    link.addEventListener('click', function() {
      if (mobileNav && mobileNav.classList.contains('open')) {
        closeMobileNav();
      }
    });
  });

  // Header scroll effect
  const header = document.getElementById('site-header');
  var scrollTicking = false;
  window.addEventListener('scroll', function() {
    if (!scrollTicking) {
      requestAnimationFrame(function() {
        if (window.scrollY > 10) {
          header?.classList.add('scrolled');
        } else {
          header?.classList.remove('scrolled');
        }
        scrollTicking = false;
      });
      scrollTicking = true;
    }
  });
</script>
