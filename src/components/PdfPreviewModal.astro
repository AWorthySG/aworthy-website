---
/* Full-screen PDF preview modal — opened by resource cards */
---

<!-- PDF Preview Modal Overlay -->
<div class="pdf-modal-overlay" id="pdf-modal" role="dialog" aria-modal="true" aria-label="PDF sample preview" hidden>
  <div class="pdf-modal">
    <!-- Header bar -->
    <div class="pdf-modal-header">
      <div class="pdf-modal-title-group">
        <span class="pdf-modal-badge">Sample Preview</span>
        <h3 class="pdf-modal-title" id="pdf-modal-title"></h3>
      </div>
      <div class="pdf-modal-actions">
        <a class="pdf-modal-btn pdf-modal-btn--download" id="pdf-modal-download" href="#" download aria-label="Download sample PDF">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
        <a class="pdf-modal-btn pdf-modal-btn--full" href="/contact/">
          Get Full Version &rarr;
        </a>
        <button class="pdf-modal-close" id="pdf-modal-close" aria-label="Close preview">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <!-- PDF Viewer -->
    <div class="pdf-modal-body">
      <iframe class="pdf-modal-iframe" id="pdf-modal-iframe" title="PDF preview"></iframe>
      <!-- Fallback for mobile / browsers that don't render PDFs in iframe -->
      <div class="pdf-modal-fallback" id="pdf-modal-fallback" hidden>
        <div class="pdf-modal-fallback-inner">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4;margin-bottom:1rem;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <p class="pdf-fallback-heading">Preview not available in this browser</p>
          <p class="pdf-fallback-sub">Download the sample PDF to view it on your device.</p>
          <a class="pdf-modal-btn pdf-modal-btn--download pdf-fallback-btn" id="pdf-modal-fallback-download" href="#" download>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download Sample PDF
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar: watermark notice -->
    <div class="pdf-modal-footer">
      <p>This is a watermarked sample. Full content notes are provided upon enrolment.</p>
    </div>
  </div>
</div>

<style>
  /* ── Modal overlay ── */
  .pdf-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .pdf-modal-overlay[hidden] { display: none; }
  .pdf-modal-overlay:not([hidden]) { display: flex; }

  .pdf-modal-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Modal container ── */
  .pdf-modal {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 900px;
    height: 90vh;
    max-height: 90vh;
    background: #111118;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
    transform: translateY(20px) scale(0.97);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pdf-modal-overlay.is-open .pdf-modal {
    transform: translateY(0) scale(1);
  }

  /* ── Header ── */
  .pdf-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    flex-shrink: 0;
  }

  .pdf-modal-title-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .pdf-modal-badge {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent, #D4853A);
    background: rgba(212, 133, 58, 0.12);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pdf-modal-title {
    font-family: var(--font-body, 'Space Grotesk', sans-serif);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-primary, #f0f0f2);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pdf-modal-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .pdf-modal-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body, 'Space Grotesk', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pdf-modal-btn--download {
    color: var(--text-primary, #f0f0f2);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .pdf-modal-btn--download:hover {
    background: rgba(255, 255, 255, 0.12);
    color: var(--text-primary, #f0f0f2);
  }

  .pdf-modal-btn--full {
    color: var(--text-primary, #f0f0f2);
    background: var(--color-accent, #D4853A);
  }

  .pdf-modal-btn--full:hover {
    background: #e8a060;
    color: var(--text-primary, #f0f0f2);
  }

  .pdf-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    color: var(--text-muted, rgba(240, 240, 242, 0.4));
    cursor: pointer;
    border-radius: 4px;
    transition: color 0.2s ease, background 0.2s ease;
    margin-left: 0.25rem;
  }

  .pdf-modal-close:hover {
    color: var(--text-primary, #f0f0f2);
    background: rgba(255, 255, 255, 0.06);
  }

  /* ── PDF iframe ── */
  .pdf-modal-body {
    flex: 1;
    position: relative;
    min-height: 0;
    background: #1a1a24;
  }

  .pdf-modal-iframe {
    width: 100%;
    height: 100%;
    border: none;
    background: #fff;
  }

  /* ── Fallback ── */
  .pdf-modal-fallback {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: #111118;
  }
  .pdf-modal-fallback[hidden] { display: none; }
  .pdf-modal-fallback:not([hidden]) { display: flex; }

  .pdf-modal-fallback-inner {
    text-align: center;
    padding: 2rem;
  }

  .pdf-fallback-heading {
    font-family: var(--font-body, 'Space Grotesk', sans-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text-primary, #f0f0f2);
    margin: 0 0 0.5rem;
  }

  .pdf-fallback-sub {
    font-size: 0.9rem;
    color: var(--text-muted, rgba(240, 240, 242, 0.4));
    margin: 0 0 1.5rem;
  }

  .pdf-fallback-btn {
    display: inline-flex;
    padding: 0.75rem 1.5rem;
    font-size: 0.85rem;
  }

  /* ── Footer ── */
  .pdf-modal-footer {
    padding: 0.6rem 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
    flex-shrink: 0;
  }

  .pdf-modal-footer p {
    font-family: var(--font-body, 'Space Grotesk', sans-serif);
    font-size: 0.7rem;
    color: var(--text-muted, rgba(240, 240, 242, 0.4));
    margin: 0;
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pdf-modal-overlay {
      padding: 0;
    }

    .pdf-modal {
      max-width: 100%;
      height: 100vh;
      max-height: 100vh;
      border-radius: 0;
    }

    .pdf-modal-title-group {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .pdf-modal-title {
      font-size: 0.85rem;
    }

    .pdf-modal-btn--full {
      display: none;
    }

    .pdf-modal-actions {
      gap: 0.25rem;
    }
  }

  @media (max-width: 480px) {
    .pdf-modal-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
    }

    .pdf-modal-actions {
      width: 100%;
      justify-content: flex-end;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .pdf-modal-overlay,
    .pdf-modal {
      transition: none;
    }
  }
</style>

<script>
  const modal = document.getElementById('pdf-modal') as HTMLElement;
  const modalTitle = document.getElementById('pdf-modal-title') as HTMLElement;
  const modalIframe = document.getElementById('pdf-modal-iframe') as HTMLIFrameElement;
  const modalDownload = document.getElementById('pdf-modal-download') as HTMLAnchorElement;
  const modalFallbackDownload = document.getElementById('pdf-modal-fallback-download') as HTMLAnchorElement;
  const modalFallback = document.getElementById('pdf-modal-fallback') as HTMLElement;
  const modalClose = document.getElementById('pdf-modal-close') as HTMLElement;

  function openPdfPreview(title: string, pdfUrl: string) {
    modalTitle.textContent = title;
    modalDownload.href = pdfUrl;
    modalFallbackDownload.href = pdfUrl;

    // Detect mobile or known non-PDF-rendering browsers
    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

    if (isMobile) {
      modalIframe.style.display = 'none';
      modalFallback.hidden = false;
    } else {
      modalIframe.style.display = '';
      modalFallback.hidden = true;
      modalIframe.src = pdfUrl;
    }

    modal.hidden = false;
    // Force reflow before adding class for transition
    void modal.offsetHeight;
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closePdfPreview() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    setTimeout(() => {
      modal.hidden = true;
      modalIframe.src = '';
    }, 300);
  }

  // Close handlers
  modalClose.addEventListener('click', closePdfPreview);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closePdfPreview();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closePdfPreview();
  });

  // Listen for preview-pdf custom events from resource cards
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest('[data-preview-pdf]') as HTMLElement | null;
    if (trigger) {
      e.preventDefault();
      const pdfUrl = trigger.getAttribute('data-preview-pdf') || '';
      const title = trigger.getAttribute('data-preview-title') || 'Document';
      openPdfPreview(title, pdfUrl);
    }
  });
</script>
