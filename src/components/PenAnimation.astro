---
/* Hyper-realistic fountain pen writing animation — "You are worth the A" */
---

<div class="pen-animation" aria-label="Animated fountain pen writing: You are worth the A">
  <!-- Vignette overlay -->
  <div class="pen-vignette" aria-hidden="true"></div>

  <svg
    class="pen-svg"
    viewBox="0 0 620 220"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <defs>
      <!-- Wet ink sheen effect -->
      <filter id="wet-ink" x="-5%" y="-5%" width="110%" height="110%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="1.2" result="blur"/>
        <feFlood flood-color="#2a3f6b" flood-opacity="0.35" result="color"/>
        <feComposite in="color" in2="blur" operator="in" result="glow"/>
        <feSpecularLighting in="blur" surfaceScale="2" specularConstant="0.5" specularExponent="25" lighting-color="#ffffff" result="specular">
          <fePointLight x="300" y="-80" z="150"/>
        </feSpecularLighting>
        <feComposite in="specular" in2="SourceAlpha" operator="in" result="specClip"/>
        <feMerge>
          <feMergeNode in="glow"/>
          <feMergeNode in="SourceGraphic"/>
          <feMergeNode in="specClip"/>
        </feMerge>
      </filter>

      <!-- Dry ink look -->
      <filter id="dry-ink" x="-2%" y="-2%" width="104%" height="104%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="0.4" result="blur"/>
        <feFlood flood-color="#1B2A4A" flood-opacity="0.12" result="color"/>
        <feComposite in="color" in2="blur" operator="in" result="shadow"/>
        <feMerge>
          <feMergeNode in="shadow"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>

      <!-- Gold glow for final pulse -->
      <filter id="gold-glow" x="-10%" y="-10%" width="120%" height="120%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="5" result="blur"/>
        <feFlood flood-color="#C9A84C" flood-opacity="0.3" result="color"/>
        <feComposite in="color" in2="blur" operator="in" result="glow"/>
        <feMerge>
          <feMergeNode in="glow"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>

      <!-- Ink gradient (deep indigo wet → navy-black dry) -->
      <linearGradient id="ink-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#1B2A4A"/>
        <stop offset="100%" stop-color="#1B2A4A"/>
      </linearGradient>

      <!-- Pen nib metallic gradient -->
      <linearGradient id="nib-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#E8D5A3"/>
        <stop offset="30%" stop-color="#C9A84C"/>
        <stop offset="50%" stop-color="#F0E0B0"/>
        <stop offset="70%" stop-color="#C9A84C"/>
        <stop offset="100%" stop-color="#8B7340"/>
      </linearGradient>

      <!-- Pen barrel gradient (black resin) -->
      <linearGradient id="barrel-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#0a0a12"/>
        <stop offset="15%" stop-color="#1a1a2e"/>
        <stop offset="40%" stop-color="#2d2d45"/>
        <stop offset="50%" stop-color="#3a3a55"/>
        <stop offset="60%" stop-color="#2d2d45"/>
        <stop offset="85%" stop-color="#1a1a2e"/>
        <stop offset="100%" stop-color="#0a0a12"/>
      </linearGradient>

      <!-- Gold trim gradient -->
      <linearGradient id="gold-trim" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#F0E0B0"/>
        <stop offset="30%" stop-color="#C9A84C"/>
        <stop offset="70%" stop-color="#C9A84C"/>
        <stop offset="100%" stop-color="#8B7340"/>
      </linearGradient>

      <!-- Barrel specular highlight -->
      <linearGradient id="barrel-highlight" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="transparent"/>
        <stop offset="38%" stop-color="transparent"/>
        <stop offset="46%" stop-color="rgba(255,255,255,0.12)"/>
        <stop offset="54%" stop-color="rgba(255,255,255,0.08)"/>
        <stop offset="62%" stop-color="transparent"/>
        <stop offset="100%" stop-color="transparent"/>
      </linearGradient>

      <!-- Pen drop shadow -->
      <filter id="pen-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="2" dy="3" stdDeviation="2.5" flood-color="#000000" flood-opacity="0.3"/>
      </filter>

      <!-- Photorealistic fountain pen -->
      <g id="fountain-pen">
        <g filter="url(#pen-shadow)">
          <!-- Barrel -->
          <rect x="-5" y="-70" width="10" height="52" rx="3" fill="url(#barrel-grad)"/>
          <rect x="-5" y="-70" width="10" height="52" rx="3" fill="url(#barrel-highlight)"/>
          <!-- Cap ring -->
          <rect x="-6" y="-72" width="12" height="4" rx="1.5" fill="url(#gold-trim)"/>
          <!-- Band -->
          <rect x="-6" y="-20" width="12" height="3" rx="1" fill="url(#gold-trim)"/>
          <!-- Clip -->
          <path d="M5 -70 L6 -70 L6 -40 L4.5 -38 L5 -40 L5 -70" fill="url(#gold-trim)"/>
          <circle cx="5.5" cy="-38" r="1.2" fill="#C9A84C"/>
          <!-- Grip -->
          <rect x="-4.5" y="-17" width="9" height="14" rx="2" fill="#12121e"/>
          <line x1="-3" y1="-14" x2="3" y2="-14" stroke="rgba(255,255,255,0.06)" stroke-width="0.3"/>
          <line x1="-3" y1="-11" x2="3" y2="-11" stroke="rgba(255,255,255,0.06)" stroke-width="0.3"/>
          <line x1="-3" y1="-8" x2="3" y2="-8" stroke="rgba(255,255,255,0.06)" stroke-width="0.3"/>
          <!-- Nib collar -->
          <path d="M-4 -3 L-3.5 -3 L-2.5 4 L2.5 4 L3.5 -3 L4 -3 L3 6 L-3 6 Z" fill="url(#gold-trim)"/>
          <!-- Nib feed -->
          <path d="M-2 4 L0 14 L2 4" fill="#1a1a2e"/>
          <line x1="0" y1="4" x2="0" y2="13" stroke="#2a3f6b" stroke-width="0.5" opacity="0.5"/>
          <!-- Nib -->
          <path d="M-3 3 L0 16 L3 3" fill="url(#nib-grad)"/>
          <line x1="0" y1="15" x2="0" y2="5" stroke="#1a1a2e" stroke-width="0.5"/>
          <circle cx="0" cy="6" r="0.8" fill="#1a1a2e"/>
          <!-- Nib highlight -->
          <path d="M-1.5 4 L0 14 L0.2 14 L1 4" fill="rgba(255,255,255,0.15)"/>
          <!-- Iridium tipping -->
          <circle cx="0" cy="15.5" r="0.6" fill="#E8D5A3"/>
        </g>
      </g>
    </defs>

    <!-- Line 1: "You are" — cursive script text with stroke animation -->
    <text
      class="pen-text pen-line-1"
      x="50"
      y="85"
      font-family="'Pinyon Script', 'Great Vibes', 'Dancing Script', 'Segoe Script', cursive"
      font-size="52"
      font-weight="400"
      fill="none"
      stroke="#1B2A4A"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      filter="url(#wet-ink)"
    >You are</text>

    <!-- Line 2: "worth the A" — larger, bolder -->
    <text
      class="pen-text pen-line-2"
      x="100"
      y="170"
      font-family="'Pinyon Script', 'Great Vibes', 'Dancing Script', 'Segoe Script', cursive"
      font-size="72"
      font-weight="400"
      fill="none"
      stroke="#1B2A4A"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      filter="url(#wet-ink)"
    >worth the A</text>

    <!-- Decorative flourish underline -->
    <path
      class="pen-flourish"
      d="M 140 185 Q 260 210 380 185 Q 440 175 490 185"
      fill="none"
      stroke="#C9A84C"
      stroke-width="0.8"
      stroke-linecap="round"
      opacity="0.5"
    />

    <!-- The fountain pen that follows the writing -->
    <use href="#fountain-pen" class="pen-cursor"/>

    <!-- Ink splatter dots -->
    <circle class="ink-dot ink-dot-1" cx="130" cy="70" r="1" fill="#1B2A4A" opacity="0"/>
    <circle class="ink-dot ink-dot-2" cx="330" cy="150" r="0.8" fill="#1B2A4A" opacity="0"/>
    <circle class="ink-dot ink-dot-3" cx="470" cy="162" r="1.2" fill="#1B2A4A" opacity="0"/>
  </svg>
</div>

<style>
  .pen-animation {
    width: 100%;
    max-width: 620px;
    margin: 0 auto;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
  }

  /* Parchment-tinted ambient glow */
  .pen-animation::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 40%, rgba(245,240,230,0.04) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 60%, rgba(212,168,76,0.03) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* Vignette */
  .pen-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, transparent 50%, rgba(245,241,235,0.6) 100%);
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    animation: vignette-in 1.2s ease-out 0.2s forwards;
  }
  @keyframes vignette-in {
    to { opacity: 1; }
  }

  .pen-svg {
    width: 100%;
    height: auto;
    overflow: visible;
    position: relative;
    z-index: 1;
  }

  /* ── Text stroke drawing ── */
  .pen-text {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
  }

  .pen-line-1 {
    animation:
      write-stroke 2s cubic-bezier(0.4, 0, 0.2, 1) 0.5s forwards,
      fill-ink-1 0.8s ease 2.2s forwards,
      ink-dry-1 1s ease 2.5s forwards,
      gold-pulse 1s ease 4.8s forwards;
  }

  .pen-line-2 {
    animation:
      write-stroke 2s cubic-bezier(0.4, 0, 0.2, 1) 2.2s forwards,
      fill-ink-2 0.8s ease 3.8s forwards,
      ink-dry-2 1s ease 4s forwards,
      gold-pulse 1s ease 4.8s forwards;
  }

  @keyframes write-stroke {
    to { stroke-dashoffset: 0; }
  }

  /* Ink fill reveals as text dries */
  @keyframes fill-ink-1 {
    to {
      fill: #1B2A4A;
      fill-opacity: 1;
    }
  }
  @keyframes fill-ink-2 {
    to {
      fill: #1B2A4A;
      fill-opacity: 1;
    }
  }

  /* Wet → dry transition: changes filter and slightly darkens stroke */
  @keyframes ink-dry-1 {
    0% { filter: url(#wet-ink); stroke: #2a3f6b; }
    100% { filter: url(#dry-ink); stroke: #1B2A4A; }
  }
  @keyframes ink-dry-2 {
    0% { filter: url(#wet-ink); stroke: #2a3f6b; }
    100% { filter: url(#dry-ink); stroke: #1B2A4A; }
  }

  /* Single warm-gold pulse after writing completes */
  @keyframes gold-pulse {
    0%   { filter: url(#dry-ink); }
    50%  { filter: url(#gold-glow); }
    100% { filter: url(#dry-ink); }
  }

  /* ── Flourish ── */
  .pen-flourish {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: write-stroke 0.8s ease 4.2s forwards;
  }

  /* ── Fountain pen cursor ── */
  .pen-cursor {
    opacity: 0;
    transform-origin: 0 16px;
    animation:
      pen-enter 0.4s ease-out 0.3s forwards,
      pen-write-1 2s cubic-bezier(0.4, 0, 0.2, 1) 0.5s forwards,
      pen-lift 0.25s ease 2.4s forwards,
      pen-write-2 2s cubic-bezier(0.4, 0, 0.2, 1) 2.2s forwards,
      pen-exit 0.6s ease-in 4.3s forwards;
  }

  /* Pen enters from right */
  @keyframes pen-enter {
    0% {
      opacity: 0;
      transform: translate(100px, 30px) rotate(28deg);
    }
    100% {
      opacity: 1;
      transform: translate(48px, 65px) rotate(28deg);
    }
  }

  /* Pen follows "You are" */
  @keyframes pen-write-1 {
    0%   { transform: translate(48px, 65px) rotate(28deg); }
    15%  { transform: translate(88px, 62px) rotate(25deg); }
    30%  { transform: translate(128px, 66px) rotate(30deg); }
    50%  { transform: translate(175px, 63px) rotate(26deg); }
    70%  { transform: translate(220px, 65px) rotate(28deg); }
    85%  { transform: translate(255px, 62px) rotate(25deg); }
    100% { transform: translate(280px, 64px) rotate(27deg); }
  }

  /* Pen lifts between lines */
  @keyframes pen-lift {
    0%   { transform: translate(280px, 64px) rotate(27deg); }
    100% { transform: translate(98px, 148px) rotate(28deg); }
  }

  /* Pen follows "worth the A" */
  @keyframes pen-write-2 {
    0%   { transform: translate(98px, 148px) rotate(28deg); }
    10%  { transform: translate(148px, 145px) rotate(25deg); }
    25%  { transform: translate(218px, 148px) rotate(30deg); }
    40%  { transform: translate(288px, 145px) rotate(26deg); }
    55%  { transform: translate(348px, 148px) rotate(28deg); }
    70%  { transform: translate(408px, 145px) rotate(25deg); }
    85%  { transform: translate(458px, 148px) rotate(30deg); }
    100% { transform: translate(505px, 146px) rotate(27deg); }
  }

  /* Pen lifts off and fades */
  @keyframes pen-exit {
    0% {
      opacity: 1;
      transform: translate(505px, 146px) rotate(27deg);
    }
    40% {
      opacity: 1;
      transform: translate(505px, 110px) rotate(20deg);
    }
    100% {
      opacity: 0;
      transform: translate(530px, 80px) rotate(15deg);
    }
  }

  /* ── Ink splatter dots ── */
  .ink-dot-1 { animation: dot-splash 0.2s ease 1.3s forwards; }
  .ink-dot-2 { animation: dot-splash 0.2s ease 3.0s forwards; }
  .ink-dot-3 { animation: dot-splash 0.2s ease 3.8s forwards; }

  @keyframes dot-splash {
    0%   { opacity: 0; r: 0; }
    50%  { opacity: 0.5; r: 1.8; }
    100% { opacity: 0.2; r: 1; }
  }

  /* ── Reduced motion: show final result immediately ── */
  @media (prefers-reduced-motion: reduce) {
    .pen-text {
      stroke-dashoffset: 0;
      fill: #1B2A4A;
      filter: url(#dry-ink);
      animation: none;
    }
    .pen-flourish {
      stroke-dashoffset: 0;
      animation: none;
    }
    .pen-cursor { display: none; }
    .ink-dot { opacity: 0.2; animation: none; }
    .pen-vignette { opacity: 1; animation: none; }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pen-animation {
      max-width: 420px;
    }
  }
  @media (max-width: 480px) {
    .pen-animation {
      max-width: 300px;
    }
  }
</style>
