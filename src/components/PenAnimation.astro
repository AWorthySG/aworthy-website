---
/* Hyper-realistic fountain pen calligraphy animation — "You are worth the A"
   Techniques: SVG masking for variable-width calligraphy, ink bleed filter,
   GPU-accelerated transforms, Intersection Observer lazy start,
   ink particles, paper grain, wet-to-dry transition, 6s runtime. */
---

<div class="pen-animation" aria-label="Animated fountain pen writing: You are worth the A">
  <div class="pen-paper" aria-hidden="true"></div>
  <div class="pen-paper-curl" aria-hidden="true"></div>
  <div class="pen-vignette" aria-hidden="true"></div>

  <svg
    class="pen-svg"
    viewBox="0 0 640 260"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <defs>
      <!-- ═══ FILTERS ═══ -->

      <!-- Ink bleed: mimics ink soaking into paper fibers -->
      <filter id="pa-bleed" x="-3%" y="-3%" width="106%" height="106%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="0.4" result="spread"/>
        <feComponentTransfer in="spread" result="crisp">
          <feFuncA type="discrete" tableValues="0 1"/>
        </feComponentTransfer>
        <feMerge>
          <feMergeNode in="crisp"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>

      <!-- Wet ink: specular highlight + indigo halo -->
      <filter id="pa-wet" x="-4%" y="-4%" width="108%" height="108%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="0.8" result="b"/>
        <feFlood flood-color="#2a3f6b" flood-opacity="0.2" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="halo"/>
        <feSpecularLighting in="b" surfaceScale="2" specularConstant="0.45" specularExponent="40" lighting-color="#fff" result="spec">
          <fePointLight x="320" y="-130" z="220"/>
        </feSpecularLighting>
        <feComposite in="spec" in2="SourceAlpha" operator="in" result="sc"/>
        <feMerge><feMergeNode in="halo"/><feMergeNode in="SourceGraphic"/><feMergeNode in="sc"/></feMerge>
      </filter>

      <!-- Dry ink: matte with micro-shadow -->
      <filter id="pa-dry" x="-1%" y="-1%" width="102%" height="102%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="0.2" result="b"/>
        <feFlood flood-color="#14243a" flood-opacity="0.06" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="sh"/>
        <feMerge><feMergeNode in="sh"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>

      <!-- Gold glow pulse -->
      <filter id="pa-gold" x="-8%" y="-8%" width="116%" height="116%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="3.5" result="b"/>
        <feFlood flood-color="#C9A84C" flood-opacity="0.18" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="g"/>
        <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>

      <!-- ═══ GRADIENTS ═══ -->
      <linearGradient id="pa-nib" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#E8D5A3"/><stop offset="25%" stop-color="#C9A84C"/>
        <stop offset="50%" stop-color="#F0E0B0"/><stop offset="75%" stop-color="#C9A84C"/>
        <stop offset="100%" stop-color="#8B7340"/>
      </linearGradient>
      <linearGradient id="pa-brl" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#08080e"/><stop offset="20%" stop-color="#1a1a2e"/>
        <stop offset="45%" stop-color="#2d2d45"/><stop offset="55%" stop-color="#3a3a55"/>
        <stop offset="80%" stop-color="#1a1a2e"/><stop offset="100%" stop-color="#08080e"/>
      </linearGradient>
      <linearGradient id="pa-bsp" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="transparent"/><stop offset="40%" stop-color="transparent"/>
        <stop offset="48%" stop-color="rgba(255,255,255,0.15)"/>
        <stop offset="52%" stop-color="rgba(255,255,255,0.08)"/>
        <stop offset="60%" stop-color="transparent"/><stop offset="100%" stop-color="transparent"/>
      </linearGradient>
      <linearGradient id="pa-gld" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#F0E0B0"/><stop offset="25%" stop-color="#D4B050"/>
        <stop offset="50%" stop-color="#C9A84C"/><stop offset="75%" stop-color="#B8923E"/>
        <stop offset="100%" stop-color="#8B7340"/>
      </linearGradient>
      <filter id="pa-psh" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="1.5" dy="3" stdDeviation="2" flood-color="#000" flood-opacity="0.18"/>
      </filter>

      <!-- ═══ MASKS — progressive calligraphy reveal ═══ -->
      <mask id="m1">
        <path class="mp mp1"
          d="M 55 80 C 80 76, 110 83, 140 78 C 170 73, 200 82, 230 77 C 255 73, 275 80, 300 77"
          fill="none" stroke="white" stroke-width="70" stroke-linecap="round"
          stroke-dasharray="320" stroke-dashoffset="320"/>
      </mask>
      <mask id="m2">
        <path class="mp mp2"
          d="M 80 172 C 115 167, 150 175, 185 169 C 220 163, 255 173, 290 167 C 325 162, 360 172, 395 166 C 425 162, 455 170, 485 165 C 510 162, 535 168, 560 165"
          fill="none" stroke="white" stroke-width="85" stroke-linecap="round"
          stroke-dasharray="620" stroke-dashoffset="620"/>
      </mask>

      <!-- ═══ FOUNTAIN PEN ═══ -->
      <g id="pa-pen">
        <g filter="url(#pa-psh)">
          <rect x="-5" y="-72" width="10" height="54" rx="3.5" fill="url(#pa-brl)"/>
          <rect x="-5" y="-72" width="10" height="54" rx="3.5" fill="url(#pa-bsp)"/>
          <rect x="-6.5" y="-74" width="13" height="4" rx="2" fill="url(#pa-gld)"/>
          <circle cx="0" cy="-74" r="2.5" fill="url(#pa-gld)"/>
          <rect x="-6" y="-20" width="12" height="3.5" rx="1" fill="url(#pa-gld)"/>
          <path d="M5.5 -72 L6.5 -72 L6.5 -40 L5 -37.5 L5.5 -40 Z" fill="url(#pa-gld)"/>
          <ellipse cx="5.8" cy="-37.5" rx="1.5" ry="1.2" fill="#C9A84C"/>
          <rect x="-4.5" y="-16.5" width="9" height="15" rx="2.5" fill="#10101a"/>
          <line x1="-3" y1="-13" x2="3" y2="-13" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <line x1="-3" y1="-10" x2="3" y2="-10" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <line x1="-3" y1="-7" x2="3" y2="-7" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <line x1="-3" y1="-4" x2="3" y2="-4" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <path d="M-4.5 -1.5 L-3 -1.5 L-2 6 L2 6 L3 -1.5 L4.5 -1.5 L3.5 8 L-3.5 8 Z" fill="url(#pa-gld)"/>
          <path d="M-1.8 6 L0 16 L1.8 6" fill="#12121e"/>
          <line x1="0" y1="6" x2="0" y2="15" stroke="#2a3f6b" stroke-width="0.4" opacity="0.4"/>
          <path d="M-3.2 5 L0 18 L3.2 5" fill="url(#pa-nib)"/>
          <line x1="0" y1="17" x2="0" y2="7" stroke="#12121e" stroke-width="0.5"/>
          <circle cx="0" cy="7.5" r="0.9" fill="#12121e"/>
          <path d="M-1.5 6 L-0.2 16 L0.5 16 L1 6" fill="rgba(255,255,255,0.12)"/>
          <ellipse cx="0" cy="17.5" rx="0.7" ry="0.5" fill="#E8D5A3"/>
        </g>
      </g>
    </defs>

    <!-- ═══ CALLIGRAPHY TEXT — filled, revealed by masks ═══ -->
    <g class="tg tg1" mask="url(#m1)" filter="url(#pa-bleed)">
      <text x="60" y="92"
        font-family="'Pinyon Script','Great Vibes','Dancing Script',cursive"
        font-size="54" fill="#1B2A4A">You are</text>
    </g>
    <g class="tg tg2" mask="url(#m2)" filter="url(#pa-bleed)">
      <text x="85" y="185"
        font-family="'Pinyon Script','Great Vibes','Dancing Script',cursive"
        font-size="76" fill="#1B2A4A">worth the A</text>
    </g>

    <!-- Trace strokes — thin outlines that draw + fade -->
    <text class="ts ts1" x="60" y="92"
      font-family="'Pinyon Script','Great Vibes','Dancing Script',cursive"
      font-size="54" fill="none" stroke="#2a3f6b" stroke-width="0.4"
      stroke-linecap="round" opacity="0.35">You are</text>
    <text class="ts ts2" x="85" y="185"
      font-family="'Pinyon Script','Great Vibes','Dancing Script',cursive"
      font-size="76" fill="none" stroke="#2a3f6b" stroke-width="0.5"
      stroke-linecap="round" opacity="0.35">worth the A</text>

    <!-- Ink pool — small blob at pen's starting point -->
    <ellipse class="ink-pool" cx="62" cy="82" rx="0" ry="0" fill="#1B2A4A" opacity="0"/>

    <!-- Ink settle shadow — grows under text as ink "pools" into paper -->
    <text class="ink-shadow ink-sh1" x="60" y="92"
      font-family="'Pinyon Script','Great Vibes','Dancing Script',cursive"
      font-size="54" fill="rgba(26,42,58,0.06)" filter="url(#pa-bleed)">You are</text>
    <text class="ink-shadow ink-sh2" x="85" y="187"
      font-family="'Pinyon Script','Great Vibes','Dancing Script',cursive"
      font-size="76" fill="rgba(26,42,58,0.06)" filter="url(#pa-bleed)">worth the A</text>

    <!-- Primary flourish -->
    <path class="fl fl1"
      d="M 140 200 C 220 225, 360 225, 440 200 C 475 190, 510 197, 545 200"
      fill="none" stroke="#C9A84C" stroke-width="1" stroke-linecap="round" opacity="0"/>

    <!-- Second decorative flourish — elegant swirl -->
    <path class="fl fl2"
      d="M 100 205 C 80 215, 75 230, 95 235 C 115 240, 130 225, 120 215"
      fill="none" stroke="#C9A84C" stroke-width="0.8" stroke-linecap="round" opacity="0"/>

    <!-- End dot — final punctuation -->
    <circle class="end-dot" cx="548" cy="200" r="0" fill="#C9A84C" opacity="0"/>

    <!-- Ink particles -->
    <circle class="pt pt1" cx="105" cy="78" r="0.5" fill="#1B2A4A" opacity="0"/>
    <circle class="pt pt2" cx="165" cy="74" r="0.4" fill="#2a3f6b" opacity="0"/>
    <circle class="pt pt3" cx="240" cy="80" r="0.5" fill="#1B2A4A" opacity="0"/>
    <circle class="pt pt4" cx="170" cy="168" r="0.4" fill="#2a3f6b" opacity="0"/>
    <circle class="pt pt5" cx="260" cy="164" r="0.6" fill="#1B2A4A" opacity="0"/>
    <circle class="pt pt6" cx="360" cy="170" r="0.5" fill="#1B2A4A" opacity="0"/>
    <circle class="pt pt7" cx="450" cy="165" r="0.4" fill="#2a3f6b" opacity="0"/>
    <circle class="pt pt8" cx="530" cy="169" r="0.5" fill="#1B2A4A" opacity="0"/>

    <!-- Ink splatters -->
    <circle class="sp sp1" cx="120" cy="76" r="0.7" fill="#1B2A4A" opacity="0"/>
    <circle class="sp sp2" cx="208" cy="70" r="0.5" fill="#1B2A4A" opacity="0"/>
    <circle class="sp sp3" cx="290" cy="80" r="0.6" fill="#2a3f6b" opacity="0"/>
    <circle class="sp sp4" cx="310" cy="162" r="0.6" fill="#1B2A4A" opacity="0"/>
    <circle class="sp sp5" cx="440" cy="167" r="0.8" fill="#1B2A4A" opacity="0"/>
    <circle class="sp sp6" cx="535" cy="172" r="0.5" fill="#2a3f6b" opacity="0"/>

    <!-- Pen cursor -->
    <use href="#pa-pen" class="pc"/>
  </svg>
</div>

<style>
  /* ═══ CONTAINER — 3D perspective ═══ */
  .pen-animation {
    width: 100%; max-width: 640px; margin: 0 auto;
    position: relative; border-radius: 8px; overflow: hidden;
    contain: layout style paint;
    perspective: 900px;
    transform-style: preserve-3d;
  }

  /* Paper surface — with subtle 3D tilt on hover */
  .pen-paper {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background:
      repeating-conic-gradient(rgba(26,42,58,0.007) 0% 25%, transparent 0% 50%) 0 0 / 3px 3px,
      radial-gradient(ellipse at 30% 35%, rgba(212,168,76,0.03) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 65%, rgba(43,90,140,0.02) 0%, transparent 50%);
  }

  /* Paper curl — folded corner effect bottom-right */
  .pen-paper-curl {
    position: absolute; bottom: 0; right: 0; z-index: 3;
    width: 32px; height: 32px; pointer-events: none;
    background: linear-gradient(135deg, transparent 50%, rgba(230,225,218,0.7) 50%);
    box-shadow: -2px -2px 4px rgba(0,0,0,0.04);
    border-top-left-radius: 4px;
  }

  /* Vignette */
  .pen-vignette {
    position: absolute; inset: 0; pointer-events: none; z-index: 2;
    background: radial-gradient(ellipse at 50% 50%, transparent 55%, rgba(245,241,235,0.4) 100%);
    opacity: 0;
  }
  .pen-animation.is-active .pen-vignette {
    animation: pa-vig 1.5s ease-out forwards;
  }
  @keyframes pa-vig { to { opacity: 1; } }

  .pen-svg {
    width: 100%; height: auto; overflow: visible; position: relative; z-index: 1;
    transform: rotateX(0deg);
    transition: transform 0.6s ease;
  }
  .pen-animation.is-active .pen-svg {
    animation: pa-tilt 1.2s cubic-bezier(0.22,0.61,0.36,1) 0.1s both;
  }
  @keyframes pa-tilt {
    0%   { transform: rotateX(4deg) scale(0.97); }
    100% { transform: rotateX(0deg) scale(1); }
  }

  /* ═══ MASK REVEAL — paused until .is-active ═══ */
  .mp {
    will-change: stroke-dashoffset;
    animation-play-state: paused;
  }
  .mp1 { animation: pa-rev 2.5s cubic-bezier(0.22,0.61,0.36,1) 0.8s both; }
  .mp2 { animation: pa-rev 2.8s cubic-bezier(0.22,0.61,0.36,1) 3.0s both; }
  @keyframes pa-rev { to { stroke-dashoffset: 0; } }

  .pen-animation.is-active .mp { animation-play-state: running; }

  /* ═══ TEXT GROUPS — wet → dry → gold ═══ */
  .tg { will-change: filter; }
  .tg1 { filter: url(#pa-wet); animation: pa-dry 1.5s ease 2.8s both, pa-glow 1.2s ease 6s both; animation-play-state: paused; }
  .tg2 { filter: url(#pa-wet); animation: pa-dry 1.5s ease 5.2s both, pa-glow 1.2s ease 6s both; animation-play-state: paused; }
  @keyframes pa-dry {
    0%   { filter: url(#pa-wet); }
    40%  { filter: url(#pa-wet); }
    100% { filter: url(#pa-dry); }
  }
  @keyframes pa-glow {
    0%   { filter: url(#pa-dry); }
    40%  { filter: url(#pa-gold); }
    100% { filter: url(#pa-dry); }
  }
  .pen-animation.is-active .tg { animation-play-state: running; }

  /* ═══ TRACE STROKES ═══ */
  .ts { stroke-dasharray: 2800; stroke-dashoffset: 2800; will-change: stroke-dashoffset, opacity; animation-play-state: paused; }
  .ts1 { animation: pa-rev 2.5s cubic-bezier(0.22,0.61,0.36,1) 0.8s forwards, pa-fade 0.6s ease 3.0s forwards; }
  .ts2 { animation: pa-rev 2.8s cubic-bezier(0.22,0.61,0.36,1) 3.0s forwards, pa-fade 0.6s ease 5.5s forwards; }
  @keyframes pa-fade { to { opacity: 0; } }
  .pen-animation.is-active .ts { animation-play-state: running; }

  /* ═══ INK POOL — small blob at pen start ═══ */
  .ink-pool { animation: pa-pool 0.6s ease 0.7s both; animation-play-state: paused; }
  @keyframes pa-pool {
    0%   { rx: 0; ry: 0; opacity: 0; }
    30%  { rx: 2.5; ry: 1.8; opacity: 0.35; }
    100% { rx: 1.8; ry: 1.2; opacity: 0.15; }
  }
  .pen-animation.is-active .ink-pool { animation-play-state: running; }

  /* ═══ INK SETTLE SHADOW — grows under text ═══ */
  .ink-shadow { opacity: 0; animation-play-state: paused; }
  .ink-sh1 { animation: pa-shad 1.5s ease 2.5s both; }
  .ink-sh2 { animation: pa-shad 1.5s ease 4.8s both; }
  @keyframes pa-shad {
    0%   { opacity: 0; transform: translateY(1px); }
    100% { opacity: 1; transform: translateY(2px); }
  }
  .pen-animation.is-active .ink-shadow { animation-play-state: running; }

  /* ═══ FLOURISHES ═══ */
  .fl { animation-play-state: paused; }
  .fl1 { stroke-dasharray: 520; stroke-dashoffset: 520; animation: pa-fl 1s cubic-bezier(0.22,0.61,0.36,1) 5.6s both; }
  .fl2 { stroke-dasharray: 200; stroke-dashoffset: 200; animation: pa-fl 0.6s cubic-bezier(0.22,0.61,0.36,1) 6.2s both; }
  @keyframes pa-fl { to { stroke-dashoffset: 0; opacity: 0.4; } }
  .pen-animation.is-active .fl { animation-play-state: running; }

  /* ═══ END DOT — final accent ═══ */
  .end-dot { animation: pa-dot 0.4s ease 6.5s both; animation-play-state: paused; }
  @keyframes pa-dot {
    0%   { r: 0; opacity: 0; }
    50%  { r: 3; opacity: 0.5; }
    100% { r: 2; opacity: 0.3; }
  }
  .pen-animation.is-active .end-dot { animation-play-state: running; }

  /* ═══ INK PARTICLES ═══ */
  .pt { will-change: transform, opacity; animation-play-state: paused; }
  .pt1 { animation: pa-pt 0.9s ease-out 1.3s forwards; --dx:5px; --dy:-11px; }
  .pt2 { animation: pa-pt 0.7s ease-out 1.9s forwards; --dx:-6px; --dy:-9px; }
  .pt3 { animation: pa-pt 0.8s ease-out 2.6s forwards; --dx:7px; --dy:-13px; }
  .pt4 { animation: pa-pt 0.7s ease-out 3.5s forwards; --dx:-5px; --dy:-10px; }
  .pt5 { animation: pa-pt 0.9s ease-out 4.0s forwards; --dx:8px; --dy:-12px; }
  .pt6 { animation: pa-pt 0.7s ease-out 4.5s forwards; --dx:-4px; --dy:-14px; }
  .pt7 { animation: pa-pt 0.8s ease-out 4.9s forwards; --dx:6px; --dy:-9px; }
  .pt8 { animation: pa-pt 0.7s ease-out 5.3s forwards; --dx:-7px; --dy:-11px; }
  @keyframes pa-pt {
    0%   { opacity: 0.5; transform: translate(0,0) scale(1); }
    100% { opacity: 0; transform: translate(var(--dx),var(--dy)) scale(0.15); }
  }
  .pen-animation.is-active .pt { animation-play-state: running; }

  /* ═══ INK SPLATTERS ═══ */
  .sp { animation-play-state: paused; }
  .sp1 { animation: pa-sp 0.3s ease 1.5s forwards; }
  .sp2 { animation: pa-sp 0.25s ease 2.2s forwards; }
  .sp3 { animation: pa-sp 0.25s ease 2.9s forwards; }
  .sp4 { animation: pa-sp 0.3s ease 3.8s forwards; }
  .sp5 { animation: pa-sp 0.25s ease 4.6s forwards; }
  .sp6 { animation: pa-sp 0.25s ease 5.4s forwards; }
  @keyframes pa-sp {
    0%   { opacity: 0; r: 0; }
    35%  { opacity: 0.4; r: 1.4; }
    100% { opacity: 0.1; r: 0.7; }
  }
  .pen-animation.is-active .sp { animation-play-state: running; }

  /* ═══ PEN CURSOR ═══ */
  .pc {
    opacity: 0; transform-origin: 0 18px;
    will-change: transform, opacity;
    animation:
      pa-in 0.6s cubic-bezier(0.34,1.56,0.64,1) 0.4s forwards,
      pa-w1 2.5s cubic-bezier(0.22,0.61,0.36,1) 0.8s forwards,
      pa-lf 0.35s ease-in-out 3.25s forwards,
      pa-w2 2.8s cubic-bezier(0.22,0.61,0.36,1) 3.0s forwards,
      pa-out 0.8s cubic-bezier(0.55,0,1,0.45) 5.9s forwards;
    animation-play-state: paused;
  }
  .pen-animation.is-active .pc { animation-play-state: running; }

  @keyframes pa-in {
    0%   { opacity: 0; transform: translate(640px,40px) rotate(25deg) scale(0.85); }
    55%  { opacity: 1; transform: translate(60px,67px) rotate(30deg) scale(1.02); }
    100% { opacity: 1; transform: translate(56px,70px) rotate(28deg) scale(1); }
  }
  @keyframes pa-w1 {
    0%   { transform: translate(56px,70px) rotate(28deg); }
    7%   { transform: translate(80px,65px) rotate(33deg); }
    16%  { transform: translate(110px,69px) rotate(25deg); }
    26%  { transform: translate(142px,64px) rotate(31deg); }
    37%  { transform: translate(172px,68px) rotate(26deg); }
    48%  { transform: translate(202px,64px) rotate(32deg); }
    60%  { transform: translate(232px,69px) rotate(24deg); }
    72%  { transform: translate(258px,65px) rotate(30deg); }
    85%  { transform: translate(280px,68px) rotate(27deg); }
    100% { transform: translate(298px,66px) rotate(28deg); }
  }
  @keyframes pa-lf {
    0%   { transform: translate(298px,66px) rotate(28deg); }
    25%  { transform: translate(290px,50px) rotate(20deg); }
    100% { transform: translate(82px,162px) rotate(28deg); }
  }
  @keyframes pa-w2 {
    0%   { transform: translate(82px,162px) rotate(28deg); }
    5%   { transform: translate(115px,157px) rotate(34deg); }
    11%  { transform: translate(155px,162px) rotate(25deg); }
    18%  { transform: translate(195px,157px) rotate(32deg); }
    25%  { transform: translate(235px,163px) rotate(26deg); }
    33%  { transform: translate(275px,158px) rotate(33deg); }
    41%  { transform: translate(312px,162px) rotate(24deg); }
    49%  { transform: translate(348px,157px) rotate(31deg); }
    57%  { transform: translate(382px,163px) rotate(27deg); }
    65%  { transform: translate(418px,158px) rotate(34deg); }
    73%  { transform: translate(452px,162px) rotate(25deg); }
    81%  { transform: translate(486px,157px) rotate(30deg); }
    90%  { transform: translate(518px,162px) rotate(27deg); }
    100% { transform: translate(545px,160px) rotate(28deg); }
  }
  @keyframes pa-out {
    0%   { opacity: 1; transform: translate(545px,160px) rotate(28deg); }
    15%  { opacity: 1; transform: translate(548px,145px) rotate(24deg); }
    35%  { opacity: 0.8; transform: translate(552px,125px) rotate(19deg); }
    60%  { opacity: 0.4; transform: translate(558px,100px) rotate(14deg); }
    100% { opacity: 0; transform: translate(565px,70px) rotate(8deg) scale(0.92); }
