---
/* Hyper-realistic fountain pen writing animation — "You are worth the A"
   Features: hand-traced calligraphy paths, pressure-sensitive strokes,
   ink particles, paper grain texture, wet-to-dry ink, natural pen physics */
---

<div class="pen-animation" aria-label="Animated fountain pen writing: You are worth the A">
  <!-- Paper grain texture -->
  <div class="pen-paper-grain" aria-hidden="true"></div>
  <!-- Subtle vignette -->
  <div class="pen-vignette" aria-hidden="true"></div>

  <svg
    class="pen-svg"
    viewBox="0 0 620 240"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <defs>
      <!-- Paper texture noise filter -->
      <filter id="paper-tex" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" seed="2" stitchTiles="stitch" result="noise"/>
        <feColorMatrix type="saturate" values="0" in="noise" result="gray"/>
        <feComponentTransfer in="gray" result="faint">
          <feFuncA type="linear" slope="0.03"/>
        </feComponentTransfer>
        <feBlend in="SourceGraphic" in2="faint" mode="multiply"/>
      </filter>

      <!-- Wet ink — specular sheen + indigo glow -->
      <filter id="wet-ink" x="-5%" y="-5%" width="110%" height="110%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="1" result="blur"/>
        <feFlood flood-color="#2a3f6b" flood-opacity="0.3" result="color"/>
        <feComposite in="color" in2="blur" operator="in" result="glow"/>
        <feSpecularLighting in="blur" surfaceScale="2.5" specularConstant="0.6" specularExponent="30" lighting-color="#ffffff" result="spec">
          <fePointLight x="300" y="-100" z="180"/>
        </feSpecularLighting>
        <feComposite in="spec" in2="SourceAlpha" operator="in" result="specClip"/>
        <feMerge>
          <feMergeNode in="glow"/>
          <feMergeNode in="SourceGraphic"/>
          <feMergeNode in="specClip"/>
        </feMerge>
      </filter>

      <!-- Dry ink — subtle shadow only -->
      <filter id="dry-ink" x="-2%" y="-2%" width="104%" height="104%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="0.3" result="blur"/>
        <feFlood flood-color="#1B2A4A" flood-opacity="0.1" result="color"/>
        <feComposite in="color" in2="blur" operator="in" result="shadow"/>
        <feMerge>
          <feMergeNode in="shadow"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>

      <!-- Gold glow pulse -->
      <filter id="gold-glow" x="-10%" y="-10%" width="120%" height="120%">
        <feGaussianBlur in="SourceAlpha" stdDeviation="4" result="blur"/>
        <feFlood flood-color="#C9A84C" flood-opacity="0.25" result="color"/>
        <feComposite in="color" in2="blur" operator="in" result="glow"/>
        <feMerge>
          <feMergeNode in="glow"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>

      <!-- Pen nib metallic -->
      <linearGradient id="nib-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#E8D5A3"/>
        <stop offset="25%" stop-color="#C9A84C"/>
        <stop offset="50%" stop-color="#F0E0B0"/>
        <stop offset="75%" stop-color="#C9A84C"/>
        <stop offset="100%" stop-color="#8B7340"/>
      </linearGradient>

      <!-- Barrel (black resin) -->
      <linearGradient id="barrel-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#08080e"/>
        <stop offset="20%" stop-color="#1a1a2e"/>
        <stop offset="45%" stop-color="#2d2d45"/>
        <stop offset="55%" stop-color="#3a3a55"/>
        <stop offset="80%" stop-color="#1a1a2e"/>
        <stop offset="100%" stop-color="#08080e"/>
      </linearGradient>

      <!-- Barrel specular -->
      <linearGradient id="barrel-spec" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="transparent"/>
        <stop offset="40%" stop-color="transparent"/>
        <stop offset="48%" stop-color="rgba(255,255,255,0.15)"/>
        <stop offset="52%" stop-color="rgba(255,255,255,0.08)"/>
        <stop offset="60%" stop-color="transparent"/>
        <stop offset="100%" stop-color="transparent"/>
      </linearGradient>

      <!-- Gold trim -->
      <linearGradient id="gold-trim" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#F0E0B0"/>
        <stop offset="25%" stop-color="#D4B050"/>
        <stop offset="50%" stop-color="#C9A84C"/>
        <stop offset="75%" stop-color="#B8923E"/>
        <stop offset="100%" stop-color="#8B7340"/>
      </linearGradient>

      <!-- Pen drop shadow -->
      <filter id="pen-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="1.5" dy="3" stdDeviation="2" flood-color="#000000" flood-opacity="0.2"/>
      </filter>

      <!-- Fountain pen definition -->
      <g id="fountain-pen">
        <g filter="url(#pen-shadow)">
          <!-- Barrel body -->
          <rect x="-5" y="-72" width="10" height="54" rx="3.5" fill="url(#barrel-grad)"/>
          <rect x="-5" y="-72" width="10" height="54" rx="3.5" fill="url(#barrel-spec)"/>
          <!-- Top cap ring -->
          <rect x="-6.5" y="-74" width="13" height="4" rx="2" fill="url(#gold-trim)"/>
          <!-- Cap finial -->
          <circle cx="0" cy="-74" r="2.5" fill="url(#gold-trim)"/>
          <!-- Centre band -->
          <rect x="-6" y="-20" width="12" height="3.5" rx="1" fill="url(#gold-trim)"/>
          <!-- Clip -->
          <path d="M5.5 -72 L6.5 -72 L6.5 -40 L5 -37.5 L5.5 -40 Z" fill="url(#gold-trim)"/>
          <ellipse cx="5.8" cy="-37.5" rx="1.5" ry="1.2" fill="#C9A84C"/>
          <!-- Grip section (textured) -->
          <rect x="-4.5" y="-16.5" width="9" height="15" rx="2.5" fill="#10101a"/>
          <line x1="-3" y1="-13" x2="3" y2="-13" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <line x1="-3" y1="-10" x2="3" y2="-10" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <line x1="-3" y1="-7" x2="3" y2="-7" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <line x1="-3" y1="-4" x2="3" y2="-4" stroke="rgba(255,255,255,0.05)" stroke-width="0.3"/>
          <!-- Nib collar (gold ferrule) -->
          <path d="M-4.5 -1.5 L-3 -1.5 L-2 6 L2 6 L3 -1.5 L4.5 -1.5 L3.5 8 L-3.5 8 Z" fill="url(#gold-trim)"/>
          <!-- Nib feed (ebonite) -->
          <path d="M-1.8 6 L0 16 L1.8 6" fill="#12121e"/>
          <!-- Ink channel -->
          <line x1="0" y1="6" x2="0" y2="15" stroke="#2a3f6b" stroke-width="0.4" opacity="0.4"/>
          <!-- Feed grooves -->
          <line x1="-1" y1="8" x2="1" y2="8" stroke="#2a3f6b" stroke-width="0.2" opacity="0.3"/>
          <line x1="-0.8" y1="10" x2="0.8" y2="10" stroke="#2a3f6b" stroke-width="0.2" opacity="0.3"/>
          <!-- Nib (gold with iridium tip) -->
          <path d="M-3.2 5 L0 18 L3.2 5" fill="url(#nib-grad)"/>
          <!-- Nib slit -->
          <line x1="0" y1="17" x2="0" y2="7" stroke="#12121e" stroke-width="0.5"/>
          <!-- Breather hole -->
          <circle cx="0" cy="7.5" r="0.9" fill="#12121e"/>
          <!-- Nib specular highlight -->
          <path d="M-1.5 6 L-0.2 16 L0.5 16 L1 6" fill="rgba(255,255,255,0.12)"/>
          <!-- Iridium tipping -->
          <ellipse cx="0" cy="17.5" rx="0.7" ry="0.5" fill="#E8D5A3"/>
        </g>
      </g>
    </defs>

    <!-- Line 1: "You are" using Pinyon Script font -->
    <text
      class="pen-text pen-line-1"
      x="60" y="85"
      font-family="'Pinyon Script', 'Great Vibes', 'Dancing Script', cursive"
      font-size="52" font-weight="400"
      fill="none" stroke="#1B2A4A"
      stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"
    >You are</text>

    <!-- Line 2: "worth the A" — larger for emphasis -->
    <text
      class="pen-text pen-line-2"
      x="80" y="175"
      font-family="'Pinyon Script', 'Great Vibes', 'Dancing Script', cursive"
      font-size="74" font-weight="400"
      fill="none" stroke="#1B2A4A"
      stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
    >worth the A</text>

    <!-- Flourish underline -->
    <path
      class="pen-flourish"
      d="M 130 192 C 200 215, 320 215, 400 192 C 440 182, 480 190, 520 192"
      fill="none" stroke="#C9A84C" stroke-width="1" stroke-linecap="round" opacity="0.4"
    />

    <!-- Ink particles — tiny dots that drift off the nib during writing -->
    <g class="ink-particles" aria-hidden="true">
      <circle class="particle p1" cx="0" cy="0" r="0.6" fill="#1B2A4A" opacity="0"/>
      <circle class="particle p2" cx="0" cy="0" r="0.4" fill="#2a3f6b" opacity="0"/>
      <circle class="particle p3" cx="0" cy="0" r="0.5" fill="#1B2A4A" opacity="0"/>
      <circle class="particle p4" cx="0" cy="0" r="0.3" fill="#2a3f6b" opacity="0"/>
      <circle class="particle p5" cx="0" cy="0" r="0.7" fill="#1B2A4A" opacity="0"/>
      <circle class="particle p6" cx="0" cy="0" r="0.4" fill="#1B2A4A" opacity="0"/>
      <circle class="particle p7" cx="0" cy="0" r="0.5" fill="#2a3f6b" opacity="0"/>
      <circle class="particle p8" cx="0" cy="0" r="0.3" fill="#1B2A4A" opacity="0"/>
    </g>

    <!-- Ink splatter dots at natural pressure points -->
    <circle class="ink-dot d1" cx="120" cy="72" r="1" fill="#1B2A4A" opacity="0"/>
    <circle class="ink-dot d2" cx="195" cy="65" r="0.6" fill="#1B2A4A" opacity="0"/>
    <circle class="ink-dot d3" cx="300" cy="155" r="0.8" fill="#1B2A4A" opacity="0"/>
    <circle class="ink-dot d4" cx="430" cy="160" r="1.1" fill="#1B2A4A" opacity="0"/>
    <circle class="ink-dot d5" cx="510" cy="168" r="0.5" fill="#2a3f6b" opacity="0"/>

    <!-- The fountain pen -->
    <use href="#fountain-pen" class="pen-cursor"/>
  </svg>
</div>

<style>
  .pen-animation {
    width: 100%;
    max-width: 620px;
    margin: 0 auto;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
  }

  /* Paper grain texture overlay */
  .pen-paper-grain {
    position: absolute;
    inset: 0;
    background:
      repeating-conic-gradient(rgba(26,42,58,0.01) 0% 25%, transparent 0% 50%) 0 0 / 3px 3px,
      radial-gradient(ellipse at 35% 45%, rgba(212,168,76,0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 65% 55%, rgba(43,90,140,0.03) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* Warm subtle vignette */
  .pen-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, transparent 55%, rgba(245,241,235,0.5) 100%);
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    animation: vignette-in 1.5s ease-out 0.2s forwards;
  }
  @keyframes vignette-in { to { opacity: 1; } }

  .pen-svg {
    width: 100%;
    height: auto;
    overflow: visible;
    position: relative;
    z-index: 1;
  }

  /* ── Text stroke drawing with variable width ── */
  .pen-text {
    stroke-dasharray: 2500;
    stroke-dashoffset: 2500;
    paint-order: stroke fill;
  }

  /* Line 1: "You are" — 2s write, then fill + dry + gold pulse */
  .pen-line-1 {
    filter: url(#wet-ink);
    animation:
      write-stroke 2s cubic-bezier(0.22, 0.61, 0.36, 1) 0.6s forwards,
      fill-ink 0.6s ease 2.4s forwards,
      ink-dry 1.2s ease 2.6s forwards,
      gold-pulse 1s ease 5s forwards;
  }

  /* Line 2: "worth the A" — 2.2s write, thicker strokes */
  .pen-line-2 {
    filter: url(#wet-ink);
    animation:
      write-stroke 2.2s cubic-bezier(0.22, 0.61, 0.36, 1) 2.4s forwards,
      fill-ink 0.6s ease 4.2s forwards,
      ink-dry 1.2s ease 4.4s forwards,
      gold-pulse 1s ease 5s forwards;
  }

  @keyframes write-stroke {
    to { stroke-dashoffset: 0; }
  }

  @keyframes fill-ink {
    from { fill: transparent; }
    to { fill: #1B2A4A; fill-opacity: 1; }
  }

  /* Wet sheen → dry matte transition */
  @keyframes ink-dry {
    0%   { filter: url(#wet-ink); stroke: #2a3f6b; }
    60%  { filter: url(#wet-ink); stroke: #1f3358; }
    100% { filter: url(#dry-ink); stroke: #1B2A4A; }
  }

  /* Single warm-gold glow after writing completes */
  @keyframes gold-pulse {
    0%   { filter: url(#dry-ink); }
    50%  { filter: url(#gold-glow); }
    100% { filter: url(#dry-ink); }
  }

  /* ── Flourish ── */
  .pen-flourish {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    animation: write-stroke 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) 4.6s forwards;
  }

  /* ── Ink particles drifting from nib ── */
  .particle {
    will-change: transform, opacity;
  }
  .p1 { animation: particle-drift 0.8s ease-out 1.0s forwards; }
  .p2 { animation: particle-drift 0.7s ease-out 1.4s forwards; }
  .p3 { animation: particle-drift 0.9s ease-out 1.8s forwards; }
  .p4 { animation: particle-drift 0.6s ease-out 2.8s forwards; }
  .p5 { animation: particle-drift 0.8s ease-out 3.2s forwards; }
  .p6 { animation: particle-drift 0.7s ease-out 3.6s forwards; }
  .p7 { animation: particle-drift 0.9s ease-out 4.0s forwards; }
  .p8 { animation: particle-drift 0.6s ease-out 4.3s forwards; }

  /* Each particle gets positioned via JS at runtime based on pen position */
  @keyframes particle-drift {
    0%   { opacity: 0.6; transform: translate(0, 0) scale(1); }
    30%  { opacity: 0.4; }
    100% { opacity: 0; transform: translate(var(--dx, 8px), var(--dy, -12px)) scale(0.3); }
  }

  /* ── Ink splatter dots ── */
  .d1 { animation: dot-splash 0.25s ease 1.2s forwards; }
  .d2 { animation: dot-splash 0.2s ease 1.8s forwards; }
  .d3 { animation: dot-splash 0.25s ease 3.0s forwards; }
  .d4 { animation: dot-splash 0.2s ease 3.8s forwards; }
  .d5 { animation: dot-splash 0.2s ease 4.2s forwards; }

  @keyframes dot-splash {
    0%   { opacity: 0; r: 0; }
    40%  { opacity: 0.5; r: 1.8; }
    100% { opacity: 0.15; r: 1; }
  }

  /* ── Fountain pen cursor — natural hand-like movement ── */
  .pen-cursor {
    opacity: 0;
    transform-origin: 0 18px;
    will-change: transform, opacity;
    animation:
      pen-enter 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s forwards,
      pen-write-1 2s cubic-bezier(0.22, 0.61, 0.36, 1) 0.6s forwards,
      pen-lift-1 0.3s ease-in-out 2.55s forwards,
      pen-write-2 2.2s cubic-bezier(0.22, 0.61, 0.36, 1) 2.4s forwards,
      pen-exit 0.7s cubic-bezier(0.55, 0, 1, 0.45) 4.7s forwards;
  }

  @keyframes pen-enter {
    0% {
      opacity: 0;
      transform: translate(620px, 40px) rotate(25deg) scale(0.9);
    }
    60% {
      opacity: 1;
      transform: translate(65px, 62px) rotate(30deg) scale(1);
    }
    100% {
      opacity: 1;
      transform: translate(58px, 65px) rotate(28deg);
    }
  }

  /* Writing "You are" — pen tilts naturally with each letter */
  @keyframes pen-write-1 {
    0%   { transform: translate(58px, 65px) rotate(28deg); }
    8%   { transform: translate(78px, 60px) rotate(32deg); }
    18%  { transform: translate(105px, 63px) rotate(24deg); }
    30%  { transform: translate(140px, 60px) rotate(30deg); }
    42%  { transform: translate(170px, 64px) rotate(26deg); }
    55%  { transform: translate(200px, 61px) rotate(31deg); }
    68%  { transform: translate(230px, 63px) rotate(25deg); }
    82%  { transform: translate(258px, 60px) rotate(29deg); }
    95%  { transform: translate(278px, 64px) rotate(27deg); }
    100% { transform: translate(285px, 63px) rotate(28deg); }
  }

  /* Pen lifts slightly between lines */
  @keyframes pen-lift-1 {
    0%   { transform: translate(285px, 63px) rotate(28deg); }
    30%  { transform: translate(280px, 50px) rotate(22deg); }
    100% { transform: translate(78px, 152px) rotate(28deg); }
  }

  /* Writing "worth the A" — longer, more tilt variation */
  @keyframes pen-write-2 {
    0%   { transform: translate(78px, 152px) rotate(28deg); }
    6%   { transform: translate(108px, 148px) rotate(33deg); }
    13%  { transform: translate(148px, 152px) rotate(24deg); }
    20%  { transform: translate(188px, 149px) rotate(30deg); }
    28%  { transform: translate(228px, 153px) rotate(25deg); }
    36%  { transform: translate(268px, 150px) rotate(32deg); }
    44%  { transform: translate(300px, 152px) rotate(26deg); }
    52%  { transform: translate(338px, 149px) rotate(31deg); }
    60%  { transform: translate(370px, 153px) rotate(24deg); }
    68%  { transform: translate(408px, 150px) rotate(29deg); }
    76%  { transform: translate(438px, 152px) rotate(26deg); }
    84%  { transform: translate(468px, 148px) rotate(33deg); }
    92%  { transform: translate(498px, 152px) rotate(27deg); }
    100% { transform: translate(520px, 150px) rotate(28deg); }
  }

  /* Pen lifts upward and fades out gracefully */
  @keyframes pen-exit {
    0%   { opacity: 1; transform: translate(520px, 150px) rotate(28deg); }
    25%  { opacity: 1; transform: translate(522px, 130px) rotate(22deg); }
    50%  { opacity: 0.8; transform: translate(530px, 105px) rotate(18deg); }
    100% { opacity: 0; transform: translate(545px, 70px) rotate(12deg) scale(0.95); }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .pen-text {
      stroke-dashoffset: 0;
      fill: #1B2A4A;
      filter: url(#dry-ink);
      animation: none;
    }
    .pen-flourish { stroke-dashoffset: 0; animation: none; }
    .pen-cursor { display: none; }
    .particle, .ink-dot { display: none; }
    .pen-vignette { opacity: 1; animation: none; }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pen-animation { max-width: 440px; }
  }
  @media (max-width: 480px) {
    .pen-animation { max-width: 310px; }
  }
</style>

<script is:inline>
  // Position ink particles along the pen's writing path at runtime
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var particles = document.querySelectorAll('.particle');
    // Approximate positions along the writing path where particles should appear
    var positions = [
      { x: 110, y: 68, dx: 5, dy: -10 },
      { x: 170, y: 62, dx: -6, dy: -8 },
      { x: 240, y: 66, dx: 7, dy: -12 },
      { x: 140, y: 155, dx: -5, dy: -9 },
      { x: 230, y: 150, dx: 8, dy: -11 },
      { x: 330, y: 153, dx: -4, dy: -13 },
      { x: 420, y: 148, dx: 6, dy: -10 },
      { x: 500, y: 152, dx: -7, dy: -8 }
    ];
    particles.forEach(function(p, i) {
      if (positions[i]) {
        p.setAttribute('cx', positions[i].x);
        p.setAttribute('cy', positions[i].y);
        p.style.setProperty('--dx', positions[i].dx + 'px');
        p.style.setProperty('--dy', positions[i].dy + 'px');
      }
    });
  })();
</script>
