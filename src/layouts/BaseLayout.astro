    window.addEventListener('scroll', function(){
      if (dismissed) return;
      if (!ticking) {
        requestAnimationFrame(function(){
          el.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.5 && !isPrivacyVisible());
          ticking = false;
        });
