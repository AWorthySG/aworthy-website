  <!-- Scroll reveal animation observer -->
  <script is:inline>
    (function() {
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-animate]').forEach(function(el) {
        observer.observe(el);
      });
    })();
  </script>

  <script is:inline>
    (function(){
      var counters = document.querySelectorAll('[data-count]');
      if (!counters.length) return;
      var animated = new Set();
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting || animated.has(entry.target)) return;
          animated.add(entry.target);
          var el = entry.target;
          var target = parseInt(el.getAttribute('data-count'), 10);
          var suffix = el.getAttribute('data-count-suffix') || el.getAttribute('data-suffix') || '';
          var duration = 1500;
          var start = performance.now();
          function tick(now) {
            var progress = Math.min((now - start) / duration, 1);
            var ease = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(target * ease) + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.3 });
      counters.forEach(function(c) { observer.observe(c); });

      // Re-trigger counters on back/forward navigation (bfcache)
      window.addEventListener('pageshow', function(e) {
        if (e.persisted) {
          animated.clear();
          counters.forEach(function(c) { observer.observe(c); });
        }
      });
    })();
  </script>
  <!-- Back to Top -->
  <button class="back-to-top" id="back-to-top" aria-label="Scroll to top">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
  <script is:inline>
    (function(){
      var btn=document.getElementById('back-to-top');
      if(!btn)return;
      var topTicking=false;
      window.addEventListener('scroll',function(){
        if(!topTicking){
          requestAnimationFrame(function(){
            btn.classList.toggle('is-visible',window.scrollY>600);
            topTicking=false;
          });
          topTicking=true;
        }
      });
      btn.addEventListener('click',function(){
        window.scrollTo({top:0,behavior:'smooth'});
      });
    })();
  </script>
  <script is:inline>
  (function(){
    var el = document.getElementById('sticky-cta-global');
    var dismiss = document.getElementById('sticky-cta-global-dismiss');
    if (!el) return;
    // Don't show on homepage (it has its own sticky CTA)
    if (window.location.pathname === '/' || window.location.pathname === '/index.html') return;
    var dismissed = false;
    var ticking = false;
    window.addEventListener('scroll', function(){
      if (dismissed) return;
      if (!ticking) {
        requestAnimationFrame(function(){
          el.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.5);
          ticking = false;
        });
        ticking = true;
      }
    });
    dismiss?.addEventListener('click', function(){
      dismissed = true;
      el.classList.remove('is-visible');
    });
  })();
  </script>

