  <!-- Email Capture Popup -->
  <div class="email-popup-overlay" id="email-popup" hidden>
    <div class="email-popup">
      <button class="email-popup-close" id="email-popup-close" aria-label="Close">&times;</button>
      <span class="eyebrow" style="text-align:center;display:block;">Free Download</span>
      <h3 class="email-popup-title">Get our top-scoring essay framework</h3>
      <p class="email-popup-desc">Download the same CASE Method essay template our A1 students use &mdash; free for your email.</p>
      <form class="email-popup-form" id="email-popup-form">
        <input type="email" placeholder="Your email address" required aria-label="Email address" />
        <button type="submit" class="btn btn-accent" style="width:100%;">Download Free PDF</button>
      </form>
      <p class="email-popup-note">We respect your privacy. Unsubscribe anytime.</p>
    </div>
  </div>

  <script is:inline>
  (function(){
    var popup = document.getElementById('email-popup');
    var closeBtn = document.getElementById('email-popup-close');
    var form = document.getElementById('email-popup-form');
    if (!popup) return;

    // Don't show if already dismissed or on contact page
    if (localStorage.getItem('email-popup-dismissed')) return;
    if (window.location.pathname.indexOf('/contact') > -1) return;

    function showPopup() {
      popup.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function hidePopup() {
      popup.hidden = true;
      document.body.style.overflow = '';
      localStorage.setItem('email-popup-dismissed', '1');
    }

    // Show after 45 seconds
    var timer = setTimeout(showPopup, 45000);

    // Or on exit intent (mouse leaves viewport)
    document.addEventListener('mouseout', function(e) {
      if (e.clientY < 5 && popup.hidden) {
        clearTimeout(timer);
        showPopup();
      }
    }, { once: true });

    closeBtn.addEventListener('click', hidePopup);
    popup.addEventListener('click', function(e) { if (e.target === popup) hidePopup(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !popup.hidden) hidePopup(); });

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = form.querySelector('input').value;
      if (email) {
        form.innerHTML = '<p style="text-align:center;color:var(--color-accent);font-weight:500;">Thanks! Check your inbox for the download link.</p>';
        localStorage.setItem('email-popup-dismissed', '1');
        setTimeout(hidePopup, 3000);
      }
    });
  })();
  </script>

  <script is:inline>
  (function(){
    var bc = document.getElementById('breadcrumb');
    if (!bc) return;
    var path = window.location.pathname.replace(/\/$/, '');
    if (!path || path === '') return; // Don't show on homepage
    bc.style.display = 'block';
    var parts = path.split('/').filter(Boolean);
    var ol = bc.querySelector('ol');
    var href = '';
    parts.forEach(function(part, i) {
      href += '/' + part;
      var li = document.createElement('li');
      var a = document.createElement('a');
      a.href = href + '/';
      a.textContent = part.replace(/-/g, ' ');
      li.appendChild(a);
      ol.appendChild(li);
    });
  })();
  </script>

