  <script is:inline>
  (function(){
    var toggle = document.getElementById('chatbot-toggle');
    var panel = document.getElementById('chatbot-panel');
    var close = document.getElementById('chatbot-close');
    var body = document.getElementById('chatbot-body');
    var opts = document.getElementById('chatbot-options');
    if (!toggle || !panel) return;

    var answers = {
      pricing: 'O-Level English: SGD 280\u2013320/month. H1 GP: SGD 360\u2013400/month. H2 Economics: SGD 360\u2013400/month. 1-to-1: SGD 120\u2013140/session. <a href="/pricing/">View full pricing \u2192</a>',
      schedule: 'Classes run Mon\u2013Fri 2pm\u20139:30pm and Sat\u2013Sun 9am\u20136pm. All sessions are conducted via Zoom. <a href="/contact/">Contact us for available slots \u2192</a>',
      method: 'The CASE Method is our proprietary 4-step system: Contextualise, Analyse, Structure, Evaluate. Adapted from legal reasoning, it teaches students how to think systematically. <a href="/#method">Learn more \u2192</a>',
      enrol: 'Step 1: Book a free diagnostic assessment. Step 2: Get a personalised learning plan. Step 3: Start learning! <a href="/contact/">Book assessment \u2192</a>',
      trial: 'Yes! We offer a free diagnostic assessment for all new students. This helps us understand your child\'s needs before recommending a programme. <a href="/contact/">Book free assessment \u2192</a>',
      online: 'All classes are 100% online via Zoom Pro. This allows us to keep class sizes small (max 6) while serving students across all of Singapore. <a href="/programmes/">View programmes \u2192</a>'
    };

    toggle.addEventListener('click', function() {
      panel.hidden = !panel.hidden;
      if (!panel.hidden) toggle.style.display = 'none';
    });
    close.addEventListener('click', function() {
      panel.hidden = true;
      toggle.style.display = 'flex';
    });

    opts.addEventListener('click', function(e) {
      var btn = e.target.closest('.chatbot-option');
      if (!btn) return;
      var q = btn.getAttribute('data-q');
      var questionText = btn.textContent;
      // Add user message
      var userMsg = document.createElement('div');
      userMsg.className = 'chatbot-msg chatbot-msg--user';
      userMsg.textContent = questionText;
      body.insertBefore(userMsg, opts);
      // Add bot response
      setTimeout(function() {
        var botMsg = document.createElement('div');
        botMsg.className = 'chatbot-msg chatbot-msg--bot';
        botMsg.innerHTML = answers[q] || 'Sorry, I don\'t have an answer for that. Please <a href="/contact/">contact us</a>.';
        body.insertBefore(botMsg, opts);
        body.scrollTop = body.scrollHeight;
      }, 400);
      body.scrollTop = body.scrollHeight;
    });
  })();
  </script>

  <!-- Site Search Script -->
  <script is:inline>
  (function(){
    var overlay = document.getElementById('search-overlay');
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    var closeBtn = document.getElementById('search-close');
    if (!overlay) return;

    var pages = [
      { title: 'Home', url: '/', desc: 'A-Worthy tuition centre — O-Level English, GP & H2 Economics' },
      { title: 'O-Level English', url: '/o-level-english/', desc: 'Comprehensive O-Level English tuition with the CASE Method' },
      { title: 'H1 General Paper', url: '/h1-general-paper/', desc: 'A-Level GP tuition using legal-analytical framework' },
      { title: 'H2 Economics', url: '/h2-economics/', desc: 'Rigorous H2 Economics tuition covering micro and macro' },
      { title: 'Programmes', url: '/programmes/', desc: 'View all tuition programmes from Sec 1 to JC 2' },
      { title: 'Pricing', url: '/pricing/', desc: 'Transparent pricing for all programmes' },
      { title: 'Results', url: '/results/', desc: 'Student results and grade transformations' },
      { title: 'Resources', url: '/resources/', desc: 'Free O-Level English and Economics resources' },
      { title: 'Testimonials', url: '/testimonials/', desc: 'What parents and students say about A-Worthy' },
      { title: 'Success Stories', url: '/success-stories/', desc: 'Student transformation case studies' },
      { title: 'Blog', url: '/blog/', desc: 'Study tips, exam strategies and guides' },
      { title: 'About', url: '/about/', desc: 'About A-Worthy and the CASE Method' },
      { title: 'Contact', url: '/contact/', desc: 'Book a free diagnostic assessment' },
      { title: 'CASE Method', url: '/#method', desc: 'Our proprietary 4-step teaching system' },
      { title: 'FAQ', url: '/#faq', desc: 'Frequently asked questions about tuition' },
    ];

    function open() { overlay.hidden = false; input.value = ''; input.focus(); renderResults(''); }
    function close() { overlay.hidden = true; }

    document.addEventListener('keydown', function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); open(); }
      if (e.key === 'Escape' && !overlay.hidden) close();
    });

    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });

    function renderResults(query) {
      if (!query) {
        results.innerHTML = '<div class="search-hint">Start typing to search pages, programmes, and resources...</div>';
        return;
      }
      var q = query.toLowerCase();
      var matches = pages.filter(function(p) {
        return p.title.toLowerCase().indexOf(q) > -1 || p.desc.toLowerCase().indexOf(q) > -1;
      });
      if (!matches.length) {
        results.innerHTML = '<div class="search-hint">No results found for "' + query + '"</div>';
        return;
      }
      results.innerHTML = matches.map(function(p) {
        return '<a href="' + p.url + '" class="search-result-item"><strong>' + p.title + '</strong><span>' + p.desc + '</span></a>';
      }).join('');
    }

    input.addEventListener('input', function() { renderResults(input.value); });
  })();
  </script>

