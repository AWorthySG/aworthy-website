  <script is:inline>
  (function(){
    // Defer setup until the browser is idle — this widget has a 45s timer
    // before it actually fires, so there's no benefit to running its init
    // during the critical render path.
    function init() {
      var popup = document.getElementById('email-popup');
      var closeBtn = document.getElementById('email-popup-close');
      var form = document.getElementById('email-popup-form');
      if (!popup) return;

      // Don't show if already dismissed or on contact page
      if (localStorage.getItem('email-popup-dismissed')) return;
      if (window.location.pathname.indexOf('/contact') > -1) return;

      function showPopup() {
      popup.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function hidePopup() {
      popup.hidden = true;
      document.body.style.overflow = '';
      localStorage.setItem('email-popup-dismissed', '1');
    }

    // Show after 45 seconds
    var timer = setTimeout(showPopup, 45000);

    // Or on exit intent (mouse leaves viewport)
    document.addEventListener('mouseout', function(e) {
      if (e.clientY < 5 && popup.hidden) {
        clearTimeout(timer);
        showPopup();
      }
    }, { once: true });

    closeBtn.addEventListener('click', hidePopup);
    popup.addEventListener('click', function(e) { if (e.target === popup) hidePopup(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !popup.hidden) hidePopup(); });

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = form.querySelector('input').value;
      if (email) {
        form.innerHTML = '<p style="text-align:center;color:var(--color-accent);font-weight:500;">Thanks! Check your inbox for the download link.</p>';
        localStorage.setItem('email-popup-dismissed', '1');
        setTimeout(hidePopup, 3000);
      }
    });
    }
    if ('requestIdleCallback' in window) requestIdleCallback(init, { timeout: 5000 });
    else setTimeout(init, 2000);
  })();
  </script>

