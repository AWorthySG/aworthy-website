      resources: 'Yes! We have free downloadable resources covering grammar, essay writing, comprehension, vocabulary, and more. No payment required \u2014 just an email address. <a href="/resources/">Browse the resource vault \u2192</a>',
      refund: 'We offer a free diagnostic assessment before you commit to anything. If you\u2019re not satisfied after your first paid month, contact us and we\u2019ll work something out. <a href="/contact/">Get in touch \u2192</a>',
      contact: 'You can reach us via WhatsApp, email, or the contact form on our website. We typically reply within a few hours. <a href="/contact/">Go to contact page \u2192</a>',
      portal: 'We\u2019re building a parent portal where you\u2019ll be able to track your child\u2019s progress, view lesson recordings, and access homework. It\u2019s coming soon! <a href="/parent-portal/">Preview the parent portal \u2192</a>',
      schools: 'Our students come from schools across Singapore \u2014 Raffles Institution, Hwa Chong, ACS, CHIJ, Victoria School, and many neighbourhood schools. The SHARP Method works regardless of starting level. <a href="/success-stories/">Read student stories \u2192</a>'
    };

    toggle.addEventListener('click', function() {
      panel.hidden = !panel.hidden;
      if (!panel.hidden) toggle.style.display = 'none';
    });
    close.addEventListener('click', function() {
      panel.hidden = true;
      toggle.style.display = 'flex';
    });

    opts.addEventListener('click', function(e) {
      var btn = e.target.closest('.chatbot-option');
      if (!btn) return;
      var q = btn.getAttribute('data-q');
      var questionText = btn.textContent;
      // Add user message
      var userMsg = document.createElement('div');
      userMsg.className = 'chatbot-msg chatbot-msg--user';
      userMsg.textContent = questionText;
      body.insertBefore(userMsg, opts);
      // Add bot response
      setTimeout(function() {
        var botMsg = document.createElement('div');
        botMsg.className = 'chatbot-msg chatbot-msg--bot';
        botMsg.innerHTML = answers[q] || 'Sorry, I don\'t have an answer for that. Please <a href="/contact/">contact us</a>.';
        body.insertBefore(botMsg, opts);
        body.scrollTop = body.scrollHeight;
      }, 400);
      body.scrollTop = body.scrollHeight;
    });
    }
    if ('requestIdleCallback' in window) requestIdleCallback(init, { timeout: 5000 });
    else setTimeout(init, 2000);
  })();
  </script>

  <!-- Exam Countdown -->
  <script is:inline>
  (function() {
    // Skip entirely on the homepage — it already has its own urgency cues.
    if (window.location.pathname === '/' || window.location.pathname === '/index.html') return;

    function init() {
      var countdown = document.getElementById('exam-countdown');
      var el = document.getElementById('exam-countdown-text');
      if (!countdown || !el) return;
      var exams = [
        { name: 'O-Level English', date: new Date('2026-10-19') },
        { name: 'A-Level GP', date: new Date('2026-11-09') },
        { name: 'A-Level H2 Economics', date: new Date('2026-11-18') }
      ];
      var now = new Date();
      var next = exams
        .map(function(e) { return { name: e.name, days: Math.ceil((e.date - now) / 86400000) }; })
        .filter(function(e) { return e.days > 0; })
        .sort(function(a, b) { return a.days - b.days; })[0];
      if (next) {
        el.textContent = next.days + ' days to ' + next.name + ' — every lesson counts';
        countdown.hidden = false;
        countdown.setAttribute('aria-hidden', 'false');
      }
    }
    if ('requestIdleCallback' in window) requestIdleCallback(init, { timeout: 3000 });
    else setTimeout(init, 1000);
  })();
  </script>

  <!-- Mobile Subject Selector -->
  <script is:inline>
  (function() {
    var sel = document.getElementById('subject-selector');
    if (!sel) return;
    // Only show on homepage
    if (window.location.pathname !== '/' && window.location.pathname !== '/index.html') {
      sel.style.display = 'none';
      return;
    }
    var shown = false;
    window.addEventListener('scroll', function() {
      if (window.scrollY > 600 && !shown) {
        sel.classList.add('visible');
        shown = true;
      } else if (window.scrollY <= 600 && shown) {
        sel.classList.remove('visible');
        shown = false;
      }
    }, { passive: true });
  })();
  </script>

  <!-- Service Worker Registration -->
  <script is:inline>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(function(){});
  }
  </script>
</body>
</html>
